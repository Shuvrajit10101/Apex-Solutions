<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Apex.Desktop.ViewModels"
        xmlns:conv="using:Apex.Desktop.Converters"
        xmlns:ledger="using:Apex.Ledger.Domain"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="Apex.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="1100" Height="700"
        MinWidth="820" MinHeight="560"
        Background="{StaticResource Cream}"
        FontFamily="Consolas, Cascadia Mono, Menlo, monospace"
        Title="Apex Solutions">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:ScreenEqualsConverter x:Key="ScreenEquals"/>
        <conv:SelectedToBrushConverter x:Key="SelBrush"/>
        <conv:SelectedActiveToBrushConverter x:Key="SelActiveBrush"/>
        <conv:SelectedToForegroundConverter x:Key="SelFore"/>
        <conv:BoolToWeightConverter x:Key="BoolWeight"/>
        <conv:DrCrLabelConverter x:Key="DrCrLabel"/>
        <conv:BalancedToBrushConverter x:Key="BalancedBrush"/>
        <conv:UpperConverter x:Key="Upper"/>
        <conv:SubIndentConverter x:Key="SubIndent"/>
        <conv:IndentToThicknessConverter x:Key="Indent"/>
        <conv:ColumnWidthConverter x:Key="ColWidth"/>
        <conv:ColumnHeaderBrushConverter x:Key="ColHeaderBrush"/>
        <conv:BillRefTypeLabelConverter x:Key="BillRefLabel"/>
        <conv:BudgetTypeLabelConverter x:Key="BudgetTypeLabel"/>
        <conv:BankTxTypeLabelConverter x:Key="BankTxTypeLabel"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Menu item row -->
        <Style Selector="Border.menuRow">
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
        <!-- Button-bar button -->
        <Style Selector="Button.barBtn">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.barBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Amber}"/>
        </Style>
        <!-- Report grid header cell -->
        <Style Selector="TextBlock.colHdr">
            <Setter Property="Foreground" Value="{StaticResource AppWhite}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ============ TOP BAR (navy) ============ -->
        <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="34">
                <TextBlock Grid.Column="0" Text="Apex Solutions"
                           Foreground="White" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ScreenTitle}"
                           Foreground="#CFE0FF" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="P: Print   E: Export   M: E-Mail   O: Import"
                           Foreground="#9FB8E0" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ============ MENU ROW (navy dark) ============ -->
        <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Height="24">
            <TextBlock Text="Gateway of Apex Solutions   —   K: Company   Y: Data   Z: Exchange   G: Go To   O: Import   E: Export   M: Share"
                       Foreground="#8FA9D6" FontSize="11" VerticalAlignment="Center" Margin="12,0"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ============ BODY: work area + right button bar ============ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,168">

            <!-- CENTRAL CREAM WORK AREA -->
            <Border Grid.Column="0" Background="{StaticResource Cream}" Margin="6">
                <Panel>

                    <!-- SCREEN: Company Select / Gateway / (menu-based screens) -->
                    <Grid IsVisible="{Binding IsMenuScreen}" RowDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Row="0" Text="{Binding ScreenTitle}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BrandNavy}"
                                   HorizontalAlignment="Center" Margin="0,18,0,10"/>

                        <!-- The keyboard-navigable menu (centred vertical list) -->
                        <Border Grid.Row="1"
                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                Background="White"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,10" MinWidth="420" Padding="0,8">
                            <ItemsControl ItemsSource="{Binding Menu}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MenuItemViewModel">
                                        <Panel>
                                            <!-- Section header: dim, uppercase, non-selectable -->
                                            <Border Classes="menuRow" IsVisible="{Binding IsHeader}"
                                                    Margin="0,7,0,1">
                                                <TextBlock Text="{Binding Label, Converter={StaticResource Upper}}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#9098A8"
                                                           LetterSpacing="1.5"/>
                                            </Border>
                                            <!-- Selectable item -->
                                            <Border Classes="menuRow" IsVisible="{Binding IsSelectable}"
                                                    Background="{Binding IsSelected, Converter={StaticResource SelBrush}}">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      Margin="{Binding IsSubItem, Converter={StaticResource SubIndent}}">
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                               FontSize="14"
                                                               Foreground="{Binding IsSelected, Converter={StaticResource SelFore}}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Hint}"
                                                               FontSize="11" Foreground="#6A6A6A"
                                                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Create-company inline form -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding CurrentScreen, Converter={StaticResource ScreenEquals}, ConverterParameter=CreateCompany}"
                                Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,10" Width="460" Padding="18">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Name" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <TextBox x:Name="CompanyNameBox" Text="{Binding NewCompanyName, Mode=TwoWay}"
                                         PlaceholderText="e.g. Acme Traders" FontSize="14"/>
                                <TextBlock Text="Financial year begins 1-Apr; base currency ₹ INR (Phase 1 defaults)."
                                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                <Button Content="Create (Ctrl+A)" HorizontalAlignment="Right"
                                        Click="OnCreateCompanyClick"
                                        Background="{StaticResource BrandNavy}" Foreground="White" Padding="14,6"/>
                            </StackPanel>
                        </Border>

                        <!-- Message / hint line -->
                        <TextBlock Grid.Row="2" Text="{Binding Message}"
                                   IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="{StaticResource AlertRed}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,6,0,14" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- ============ CASCADING (MILLER-COLUMNS) GATEWAY ============ -->
                    <!-- A horizontal row of columns: each drill-in adds a column to the right; earlier
                         columns stay visible. Menu columns are narrow; a page column is wide. The whole
                         row scrolls sideways if it overflows; each column has its own up/down scroll so
                         text is never clipped or overwritten across columns. -->
                    <ScrollViewer x:Name="CascadeScroller"
                                  IsVisible="{Binding IsGatewayCascade}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                      <ItemsControl x:Name="CascadeColumns" ItemsSource="{Binding Columns}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:GatewayColumn">
                            <!-- One column: header band + body. Menu columns = 300 wide; page columns = 560. -->
                            <Border Margin="0,0,6,0"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Background="White"
                                    Width="{Binding IsMenu, Converter={StaticResource ColWidth}}">
                              <Grid RowDefinitions="Auto,*">

                                <!-- Column header -->
                                <Border Grid.Row="0"
                                        Background="{Binding IsActive, Converter={StaticResource ColHeaderBrush}}"
                                        Padding="10,6">
                                  <TextBlock Text="{Binding Title}"
                                             Foreground="White" FontWeight="SemiBold" FontSize="13"
                                             TextTrimming="CharacterEllipsis"/>
                                </Border>

                                <!-- BODY (a) menu column: keyboard-navigable list -->
                                <ScrollViewer Grid.Row="1" IsVisible="{Binding IsMenu}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0,6">
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:MenuItemViewModel">
                                        <Panel>
                                          <!-- Section header: dim, uppercase, non-selectable -->
                                          <Border Classes="menuRow" IsVisible="{Binding IsHeader}" Margin="0,7,0,1">
                                            <TextBlock Text="{Binding Label, Converter={StaticResource Upper}}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#9098A8" LetterSpacing="1.5"/>
                                          </Border>
                                          <!-- Selectable item: bright amber in the active column, dim slate when
                                               selected in an earlier column, transparent otherwise. -->
                                          <Border Classes="menuRow" IsVisible="{Binding IsSelectable}">
                                            <Border.Background>
                                              <MultiBinding Converter="{x:Static conv:SelectedActiveToBrushConverter.Instance}">
                                                <Binding Path="IsSelected"/>
                                                <Binding Path="IsActiveColumn"/>
                                              </MultiBinding>
                                            </Border.Background>
                                            <Grid ColumnDefinitions="*,Auto"
                                                  Margin="{Binding IsSubItem, Converter={StaticResource SubIndent}}">
                                              <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                         FontSize="14" TextTrimming="CharacterEllipsis"
                                                         Foreground="{Binding IsSelected, Converter={StaticResource SelFore}}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Hint}"
                                                         FontSize="11" Foreground="#6A6A6A"
                                                         VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            </Grid>
                                          </Border>
                                        </Panel>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>

                                <!-- BODY (b) page column: exactly one of the four page kinds -->
                                <Panel Grid.Row="1" IsVisible="{Binding IsPage}">

                    <!-- PAGE: Report viewer -->
                    <ContentControl IsVisible="{Binding Report, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Report}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ReportsViewModel">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                        <TextBlock Grid.Row="0" Text="{Binding Title}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                   HorizontalAlignment="Center" Margin="0,12,0,2"/>
                        <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                   FontSize="12" Foreground="#555555"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- Scenario picker (TB / P&L / Balance Sheet): view the figures under a scenario. -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,10"
                              IsVisible="{Binding SupportsScenario}">
                          <TextBlock Grid.Column="0" Text="Scenario" FontWeight="SemiBold"
                                     VerticalAlignment="Center" Margin="0,0,10,0"
                                     Foreground="{StaticResource BrandNavy}"/>
                          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                    ItemsSource="{Binding Scenarios}"
                                    SelectedItem="{Binding SelectedScenario, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:ScenarioOption">
                                <TextBlock Text="{Binding Display}"/>
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </Grid>

                        <!-- Column header band (navy) -->
                        <Border Grid.Row="3" Background="{StaticResource BrandNavy}">
                            <Grid ColumnDefinitions="*,150,150">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <!-- Two-column (Dr/Cr) mode -->
                                <TextBlock Grid.Column="1" Text="Debit" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding IsTwoColumn}"/>
                                <TextBlock Grid.Column="2" Text="Credit" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding IsTwoColumn}"/>
                                <!-- Single-amount mode -->
                                <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding !IsTwoColumn}"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="4" Background="White">
                            <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ReportRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Background="Transparent">
                                            <Grid ColumnDefinitions="*,150,150" Height="24">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center" Margin="8,0">
                                                    <TextBlock Text="{Binding Particulars}"
                                                               FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                               FontSize="12.5"/>
                                                    <TextBlock Text="{Binding Secondary}"
                                                               FontSize="10.5" Foreground="#8A8A8A"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- Two-column (Dr/Cr) mode: Debit + Credit both visible -->
                                                <TextBlock Grid.Column="1" Text="{Binding Debit}"
                                                           TextAlignment="Right" Margin="0,0,10,0"
                                                           IsVisible="{Binding IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Credit}"
                                                           TextAlignment="Right" Margin="0,0,10,0"
                                                           IsVisible="{Binding IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                                <!-- Single-amount mode: Amount occupies column 2 alone -->
                                                <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                           TextAlignment="Right" Margin="0,0,10,0"
                                                           IsVisible="{Binding !IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Voucher entry (Contra/Payment/Receipt/Journal/Sales/Purchase) -->
                    <ContentControl IsVisible="{Binding Voucher, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Voucher}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:VoucherEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="4">

                            <!-- Header: type + auto number + optional/post-dated toggles + applicable-upto + date -->
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}" Padding="10,6">
                              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                            VerticalAlignment="Center">
                                  <TextBlock Text="{Binding TypeName}"
                                             Foreground="White" FontWeight="Bold" FontSize="15"
                                             VerticalAlignment="Center"/>
                                  <!-- Provisional-kind badge (Memorandum / Reversing Journal): off-books entry. -->
                                  <Border IsVisible="{Binding IsProvisionalType}"
                                          Background="#3E5C8A" CornerRadius="3" Padding="6,1"
                                          VerticalAlignment="Center">
                                    <TextBlock Text="Provisional — off books" Foreground="#EAF1FF" FontSize="10"/>
                                  </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Foreground="#CFE0FF" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,18,0">
                                  <Run Text="No. "/><Run Text="{Binding VoucherNumber}"/>
                                </TextBlock>
                                <!-- Optional (Ctrl+L): hidden for a provisional type (already off-books). -->
                                <CheckBox Grid.Column="2" Content="Optional (Ctrl+L)"
                                          IsChecked="{Binding IsOptional, Mode=TwoWay}"
                                          IsVisible="{Binding !IsProvisionalType}"
                                          Foreground="#CFE0FF" FontSize="11"
                                          VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <CheckBox Grid.Column="3" Content="Post-Dated (Ctrl+T)"
                                          IsChecked="{Binding IsPostDated, Mode=TwoWay}"
                                          IsVisible="{Binding !IsProvisionalType}"
                                          Foreground="#CFE0FF" FontSize="11"
                                          VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <!-- Applicable Upto (Reversing Journal only). -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6"
                                            IsVisible="{Binding IsReversing}"
                                            VerticalAlignment="Center" Margin="0,0,16,0">
                                  <TextBlock Text="Applicable Upto" Foreground="#CFE0FF" FontSize="11"
                                             VerticalAlignment="Center"/>
                                  <TextBox Width="130" Text="{Binding ApplicableUptoText, Mode=TwoWay}"
                                           FontSize="12" VerticalAlignment="Center"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </StackPanel>
                                <TextBox Grid.Column="5" Width="140"
                                         Text="{Binding DateText, Mode=TwoWay}"
                                         FontSize="12" VerticalAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Column header band -->
                            <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Margin="0,6,0,0">
                              <Grid ColumnDefinitions="*,90,160,40">
                                <TextBlock Grid.Column="0" Text="Particulars (Ledger)" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Dr/Cr" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="2" Text="" />

                            <!-- Particulars grid: Dr/Cr lines -->
                            <ScrollViewer Grid.Row="3" Background="White" VerticalScrollBarVisibility="Auto">
                              <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:VoucherLineViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Padding="6,4">
                                      <StackPanel Spacing="0">
                                        <Grid ColumnDefinitions="*,90,160,40">
                                          <ComboBox Grid.Column="0" MinWidth="200"
                                                    HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding Ledgers}"
                                                    SelectedItem="{Binding SelectedLedger, Mode=TwoWay}"
                                                    PlaceholderText="Select ledger…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Ledger">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Margin="6,0" Width="80"
                                                    ItemsSource="{Binding Sides}"
                                                    SelectedItem="{Binding Side, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource DrCrLabel}}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Width="150"
                                                   Text="{Binding AmountText, Mode=TwoWay}"
                                                   TextAlignment="Right"
                                                   PlaceholderText="0.00"/>
                                        </Grid>

                                        <!-- Bill-wise Details sub-panel (only for a bill-by-bill ledger) -->
                                        <Border IsVisible="{Binding IsBillWise}"
                                                Background="#F4F7FB"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Bill-wise Details"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <!-- Allocation column header -->
                                            <Grid ColumnDefinitions="130,*,120,120">
                                              <TextBlock Grid.Column="0" Text="Type of Ref" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Name" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Due Date" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="3" Text="Amount" FontSize="10.5"
                                                         Foreground="#6A6A6A" TextAlignment="Right"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding BillAllocations}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:BillAllocationRowViewModel">
                                                  <Grid ColumnDefinitions="130,*,120,120" Margin="0,1">
                                                    <ComboBox Grid.Column="0" Width="124"
                                                              ItemsSource="{Binding RefTypes}"
                                                              SelectedItem="{Binding RefType, Mode=TwoWay}"
                                                              FontSize="11">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                          <TextBlock Text="{Binding Converter={StaticResource BillRefLabel}}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="1" Margin="4,0,0,0"
                                                             Text="{Binding Name, Mode=TwoWay}"
                                                             FontSize="11" PlaceholderText="Bill ref…"/>
                                                    <TextBox Grid.Column="2" Width="114" Margin="4,0,0,0"
                                                             Text="{Binding DueDateText, Mode=TwoWay}"
                                                             FontSize="11" PlaceholderText="dd-MMM-yyyy"/>
                                                    <TextBox Grid.Column="3" Width="114"
                                                             Text="{Binding AmountText, Mode=TwoWay}"
                                                             FontSize="11" TextAlignment="Right"
                                                             PlaceholderText="0.00"/>
                                                  </Grid>
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="Auto,*">
                                              <Button Grid.Column="0" Content="+ Add bill"
                                                      FontSize="10.5" Padding="8,2"
                                                      Background="{StaticResource Panel}"
                                                      Click="OnAddBillAllocationClick"
                                                      CommandParameter="{Binding}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding BillSummary}"
                                                         FontSize="10.5" Foreground="#555555"
                                                         VerticalAlignment="Center" TextAlignment="Right"
                                                         Margin="8,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>

                                        <!-- Cost Allocation sub-panel (only for a cost-applicable ledger
                                             when the company has cost centres) -->
                                        <Border IsVisible="{Binding IsCostApplicable}"
                                                Background="#F3FBF4"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Cost Allocation"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <!-- Allocation column header -->
                                            <Grid ColumnDefinitions="*,*,120">
                                              <TextBlock Grid.Column="0" Text="Category" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Cost Centre" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Amount" FontSize="10.5"
                                                         Foreground="#6A6A6A" TextAlignment="Right"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding CostAllocations}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CostAllocationRowViewModel">
                                                  <Grid ColumnDefinitions="*,*,120" Margin="0,1">
                                                    <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding Categories}"
                                                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                                              FontSize="11" PlaceholderText="Category…">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="ledger:CostCategory">
                                                          <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <ComboBox Grid.Column="1" Margin="4,0,0,0"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding Centres}"
                                                              SelectedItem="{Binding SelectedCentre, Mode=TwoWay}"
                                                              FontSize="11" PlaceholderText="Centre…">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="ledger:CostCentre">
                                                          <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="2" Width="114"
                                                             Text="{Binding AmountText, Mode=TwoWay}"
                                                             FontSize="11" TextAlignment="Right"
                                                             PlaceholderText="0.00"/>
                                                  </Grid>
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="Auto,*">
                                              <Button Grid.Column="0" Content="+ Add centre"
                                                      FontSize="10.5" Padding="8,2"
                                                      Background="{StaticResource Panel}"
                                                      Click="OnAddCostAllocationClick"
                                                      CommandParameter="{Binding}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding CostSummary}"
                                                         FontSize="10.5" Foreground="#555555"
                                                         VerticalAlignment="Center" TextAlignment="Right"
                                                         Margin="8,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>

                                        <!-- Bank Allocation sub-panel (only for a bank-account ledger) -->
                                        <Border IsVisible="{Binding IsBankLine}"
                                                Background="#EEF4FB"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Bank Allocation"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <Grid ColumnDefinitions="150,*,140">
                                              <TextBlock Grid.Column="0" Text="Transaction Type" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Instrument No." FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Instrument Date" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="150,*,140">
                                              <ComboBox Grid.Column="0" Width="144"
                                                        ItemsSource="{Binding BankTransactionTypes}"
                                                        SelectedItem="{Binding BankTransactionType, Mode=TwoWay}"
                                                        FontSize="11">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource BankTxTypeLabel}}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="1" Margin="4,0,0,0"
                                                       Text="{Binding InstrumentNumber, Mode=TwoWay}"
                                                       FontSize="11" PlaceholderText="Cheque / UTR / ref…"/>
                                              <TextBox Grid.Column="2" Width="134" Margin="4,0,0,0"
                                                       Text="{Binding InstrumentDateText, Mode=TwoWay}"
                                                       FontSize="11" PlaceholderText="dd-MMM-yyyy"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>

                                        <!-- Forex Details sub-panel (only for a foreign-currency ledger) -->
                                        <Border IsVisible="{Binding IsForexLine}"
                                                Background="#FBF1E9"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                              <TextBlock Text="Forex Details"
                                                         FontWeight="SemiBold" FontSize="11"
                                                         Foreground="{StaticResource BrandNavy}"/>
                                              <TextBlock Text="{Binding ForexCurrencyCode}"
                                                         FontSize="10.5" Foreground="#6A6A6A"
                                                         VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Grid ColumnDefinitions="150,150,*">
                                              <TextBlock Grid.Column="0" Text="Amount in Forex" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Rate of Exchange" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Amount in ₹ (forex × rate)" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0" TextAlignment="Right"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="150,150,*">
                                              <Grid Grid.Column="0" ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{Binding ForexSymbol}"
                                                           FontSize="11" Foreground="#6A6A6A"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding ForexAmountText, Mode=TwoWay}"
                                                         FontSize="11" TextAlignment="Right"
                                                         PlaceholderText="0.00"/>
                                              </Grid>
                                              <TextBox Grid.Column="1" Width="140" Margin="4,0,0,0"
                                                       Text="{Binding ForexRateText, Mode=TwoWay}"
                                                       FontSize="11" TextAlignment="Right"
                                                       PlaceholderText="e.g. 83.25"/>
                                              <TextBlock Grid.Column="2" Text="{Binding ForexBaseText}"
                                                         FontSize="12" FontWeight="SemiBold"
                                                         Foreground="{StaticResource BrandNavy}"
                                                         TextAlignment="Right" VerticalAlignment="Center"
                                                         Margin="4,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Add-line -->
                            <Button Grid.Row="4" Content="+ Add line" HorizontalAlignment="Left"
                                    Margin="0,6" Padding="10,4"
                                    Background="{StaticResource Panel}"
                                    Click="OnAddVoucherLineClick"/>

                            <!-- Live balance indicator -->
                            <Border Grid.Row="5" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <TextBlock Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center">
                                  <Run Text="Difference: "/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding DifferenceText}"
                                           VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="{Binding !IsBalanced, Converter={StaticResource BoolWeight}}"
                                           Foreground="{Binding IsBalanced, Converter={StaticResource BalancedBrush}}"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0" FontSize="12">
                                  <Run Text="Dr "/><Run Text="{Binding TotalDebitText}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="12,0" FontSize="12">
                                  <Run Text="Cr "/><Run Text="{Binding TotalCreditText}"/>
                                </TextBlock>
                              </Grid>
                            </Border>

                            <!-- Narration + accept row + message -->
                            <StackPanel Grid.Row="6" Spacing="6" Margin="0,4,0,0">
                              <TextBox Text="{Binding Narration, Mode=TwoWay}"
                                       PlaceholderText="Narration…" AcceptsReturn="False"/>
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Content="Cancel (Esc)" Margin="0,0,8,0" Padding="12,6"
                                        Click="OnCancelVoucherClick"/>
                                <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                        IsEnabled="{Binding CanAccept}"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnAcceptVoucherClick"/>
                              </Grid>
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Ledger master (create + list) -->
                    <ContentControl IsVisible="{Binding Ledger, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Ledger}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:LedgerMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Ledger Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. State Bank of India"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Groups}"
                                            SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                            PlaceholderText="Select group…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Group">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <!-- Currency of ledger (base ₹/INR, or a created foreign currency) -->
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Currency" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding CurrencyChoices}"
                                            SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:CurrencyChoice">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <!-- Bill-wise options (shown for party groups: Sundry Debtors/Creditors) -->
                                <StackPanel Spacing="8" IsVisible="{Binding IsPartyGroup}">
                                  <CheckBox Content="Maintain balances bill-by-bill"
                                            IsChecked="{Binding MaintainBillByBill, Mode=TwoWay}"
                                            FontSize="13"/>
                                  <Grid ColumnDefinitions="180,120"
                                        IsVisible="{Binding MaintainBillByBill}">
                                    <TextBlock Grid.Column="0" Text="Default credit period (days)"
                                               VerticalAlignment="Center" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DefaultCreditPeriodText, Mode=TwoWay}"
                                             PlaceholderText="e.g. 30" TextAlignment="Right"/>
                                  </Grid>
                                </StackPanel>

                                <!-- Interest Calculation parameters (catalog §7) -->
                                <Border Background="#FBF7EE"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="12,10">
                                  <StackPanel Spacing="8">
                                    <CheckBox Content="Activate Interest Calculation"
                                              IsChecked="{Binding EnableInterest, Mode=TwoWay}"
                                              FontSize="13" FontWeight="SemiBold"
                                              Foreground="{StaticResource BrandNavy}"/>
                                    <StackPanel Spacing="8" IsVisible="{Binding EnableInterest}">
                                      <Grid ColumnDefinitions="110,*">
                                        <TextBlock Grid.Column="0" Text="Rate %"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                                 Text="{Binding InterestRateText, Mode=TwoWay}"
                                                 PlaceholderText="e.g. 18" TextAlignment="Right"/>
                                      </Grid>
                                      <Grid ColumnDefinitions="110,*">
                                        <TextBlock Grid.Column="0" Text="Per"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding PerChoices}"
                                                  SelectedItem="{Binding SelectedPer, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid ColumnDefinitions="110,*">
                                        <TextBlock Grid.Column="0" Text="On"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding OnBalanceChoices}"
                                                  SelectedItem="{Binding SelectedOnBalance, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid ColumnDefinitions="110,*">
                                        <TextBlock Grid.Column="0" Text="Applicability"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ApplicabilityChoices}"
                                                  SelectedItem="{Binding SelectedApplicability, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid ColumnDefinitions="110,*">
                                        <TextBlock Grid.Column="0" Text="Style"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding StyleChoices}"
                                                  SelectedItem="{Binding SelectedStyle, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateLedgerClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing ledgers header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,150,110,70,120">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Opening" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Currency" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Interest" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:LedgerListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,150,110,70,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Opening}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Currency}"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Interest}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Chart of Accounts (read-only group/ledger tree) -->
                    <ContentControl IsVisible="{Binding Chart, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Chart}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ChartOfAccountsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,160">
                                <TextBlock Grid.Column="0" Text="Group / Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Nature / Opening" Classes="colHdr"
                                           TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ChartRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="{Binding Indent, Converter={StaticResource Indent}}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12.5"
                                                   FontWeight="{Binding IsGroup, Converter={StaticResource BoolWeight}}"
                                                   Foreground="{Binding IsGroup, Converter={StaticResource SelFore}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Outstandings (Receivables / Payables) with Ctrl+B bill settlement -->
                    <ContentControl IsVisible="{Binding Outstanding, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Outstanding}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:OutstandingsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,110,90,90,120,90">
                                <TextBlock Grid.Column="0" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Ref" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Due Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Pending" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Ageing" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:OutstandingRowViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Border.Background>
                                        <MultiBinding Converter="{x:Static conv:OutstandingRowBrushConverter.Instance}">
                                          <Binding Path="IsSelected"/>
                                          <Binding Path="IsHighlighted"/>
                                        </MultiBinding>
                                      </Border.Background>
                                      <Grid ColumnDefinitions="*,110,90,90,120,90" Height="24">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center" Margin="8,0">
                                          <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                     Foreground="#2E7D32"
                                                     IsVisible="{Binding IsSelected}"/>
                                          <TextBlock Text="{Binding Party}" FontSize="12.5"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Reference}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#333333"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Date}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DueDate}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Pending}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Ageing}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Total + settle bar -->
                            <Border Grid.Row="4" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2">
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Space: select bill    Ctrl+B: settle selected"
                                           FontSize="11" Foreground="#6A6A6A" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                                           FontWeight="SemiBold">
                                  <Run Text="Total Pending: "/><Run Text="{Binding TotalText}"/>
                                </TextBlock>
                                <Button Grid.Column="2" Content="Settle (Ctrl+B)" Padding="12,5"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnSettleBillsClick"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="5" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,4,0,0" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Cost Category master (create + list) -->
                    <ContentControl IsVisible="{Binding CostCategory, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CostCategory}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CostCategoryMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Cost Category Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Departments"/>
                                </Grid>
                                <CheckBox Content="Allocate Revenue Items"
                                          IsChecked="{Binding AllocateRevenueItems, Mode=TwoWay}" FontSize="13"/>
                                <CheckBox Content="Allocate Non-Revenue Items"
                                          IsChecked="{Binding AllocateNonRevenueItems, Mode=TwoWay}" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateCostCategoryClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing categories header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,220,120">
                                <TextBlock Grid.Column="0" Text="Cost Category" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Allocates" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Kind" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CostCategoryListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,220,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Allocates}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Cost Centre master (create + list) -->
                    <ContentControl IsVisible="{Binding CostCentre, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CostCentre}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CostCentreMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Cost Centre Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Sales Team A"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Category" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Categories}"
                                            SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                            PlaceholderText="Select category…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:CostCategory">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentCentreOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateCostCentreClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing centres header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,180,160">
                                <TextBlock Grid.Column="0" Text="Cost Centre" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Category" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Under" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CostCentreListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,180,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Category}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Under}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Cost report (Category Summary / Cost Centre Break-up) -->
                    <ContentControl IsVisible="{Binding CostReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CostReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CostReportsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,160">
                                <TextBlock Grid.Column="0" Text="{Binding ParticularsHeader}" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Particulars}"
                                                   Margin="{Binding Indent, Converter={StaticResource Indent}}"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                   Foreground="{Binding IsHeader, Converter={StaticResource SelFore}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Amount}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Budget master (create budget + lines + list) -->
                    <ContentControl IsVisible="{Binding BudgetMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BudgetMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BudgetMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Budget Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form: name + period + line builder -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Q1 Budget"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*,60,*">
                                  <TextBlock Grid.Column="0" Text="From" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding PeriodFromText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                  <TextBlock Grid.Column="2" Text="To" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextAlignment="Center"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding PeriodToText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>

                                <!-- Line builder: Target + Type + Amount + Add -->
                                <Border Background="#F4F7FB"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="10,8">
                                  <StackPanel Spacing="8">
                                    <TextBlock Text="Add Budget Line" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="*,190,120,Auto">
                                      <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding Targets}"
                                                SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                                                PlaceholderText="Group or ledger…">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:BudgetTargetOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <ComboBox Grid.Column="1" Margin="6,0" Width="184"
                                                ItemsSource="{Binding Types}"
                                                SelectedItem="{Binding SelectedType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource BudgetTypeLabel}}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBox Grid.Column="2" Width="114"
                                               Text="{Binding LineAmountText, Mode=TwoWay}"
                                               TextAlignment="Right" PlaceholderText="0.00"/>
                                      <Button Grid.Column="3" Content="+ Add line" Margin="6,0,0,0"
                                              Padding="10,4" Background="{StaticResource Panel}"
                                              Click="OnAddBudgetLineClick"/>
                                    </Grid>

                                    <!-- Pending lines header -->
                                    <Border Background="{StaticResource BrandNavyDark}">
                                      <Grid ColumnDefinitions="*,180,120">
                                        <TextBlock Grid.Column="0" Text="Target" Classes="colHdr"/>
                                        <TextBlock Grid.Column="1" Text="Type" Classes="colHdr"/>
                                        <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                      </Grid>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding PendingLines}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PendingBudgetLineRow">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                  Background="White">
                                            <Grid ColumnDefinitions="*,180,120" Height="22">
                                              <TextBlock Grid.Column="0" Text="{Binding Target}"
                                                         Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Type}"
                                                         VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                              <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                         TextAlignment="Right" Margin="0,0,10,0"
                                                         VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateBudgetClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing budgets header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,240,120">
                                <TextBlock Grid.Column="0" Text="Budget" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Period" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Lines" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BudgetListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,240,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Period}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Lines}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Scenario master (create scenario + toggle voucher types + list) -->
                    <ContentControl IsVisible="{Binding ScenarioMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ScenarioMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ScenarioMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Scenario Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form: name + include-actuals + voucher-type toggles -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="120,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Provisional"/>
                                </Grid>
                                <CheckBox Content="Include Actuals (base the scenario on the real books)"
                                          IsChecked="{Binding IncludeActuals, Mode=TwoWay}"
                                          FontSize="12" Foreground="{StaticResource Ink}"/>

                                <!-- Voucher-type include toggles -->
                                <Border Background="#F4F7FB"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="10,8">
                                  <StackPanel Spacing="6">
                                    <TextBlock Text="Include these voucher types" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Text="Tick a type to surface its Optional / Reversing / Memorandum vouchers under this scenario."
                                               FontSize="10.5" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding Types}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioTypeRow">
                                          <Grid ColumnDefinitions="24,*,160" Height="24">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Include, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       VerticalAlignment="Center" FontSize="12.5"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                       TextAlignment="Right" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                          </Grid>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateScenarioClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing scenarios header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,90,*">
                                <TextBlock Grid.Column="0" Text="Scenario" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Actuals" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Includes" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ScenarioListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,90,*" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Actuals}"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Includes}"
                                                   Margin="4,0,10,0" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Currency master (create currency + rates of exchange + lists) -->
                    <ContentControl IsVisible="{Binding CurrencyMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CurrencyMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CurrencyMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Currency &amp; Rates of Exchange"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create-currency form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                              <StackPanel Spacing="10">
                                <TextBlock Text="New Currency" FontWeight="SemiBold" FontSize="12.5"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <Grid ColumnDefinitions="110,*,120,*,120,90">
                                  <TextBlock Grid.Column="0" Text="Symbol" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Symbol, Mode=TwoWay}"
                                           PlaceholderText="$"/>
                                  <TextBlock Grid.Column="2" Text="Formal Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FormalName, Mode=TwoWay}"
                                           PlaceholderText="USD"/>
                                  <TextBlock Grid.Column="4" Text="Decimals" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="5" Text="{Binding DecimalPlacesText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="2"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding CurrencyMessage}"
                                             IsVisible="{Binding CurrencyMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create Currency (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateCurrencyClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Rate-of-exchange form -->
                            <Border Grid.Row="2" Background="#FBF7EE"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                              <StackPanel Spacing="10">
                                <TextBlock Text="Rate of Exchange" FontWeight="SemiBold" FontSize="12.5"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock IsVisible="{Binding !HasForeignCurrencies}"
                                           Text="Create a foreign currency above first, then set its dated rates here."
                                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                <StackPanel Spacing="10" IsVisible="{Binding HasForeignCurrencies}">
                                  <Grid ColumnDefinitions="110,*,90,150">
                                    <TextBlock Grid.Column="0" Text="Currency" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ForeignCurrencies}"
                                              SelectedItem="{Binding RateCurrency, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:Currency">
                                          <TextBlock Text="{Binding FormalName}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding RateDateText, Mode=TwoWay}"
                                             PlaceholderText="dd-MMM-yyyy"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="110,*,110,*,110,*">
                                    <TextBlock Grid.Column="0" Text="Standard ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding StandardRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="e.g. 83.25"/>
                                    <TextBlock Grid.Column="2" Text="Selling ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding SellingRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="optional"/>
                                    <TextBlock Grid.Column="4" Text="Buying ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="5" Text="{Binding BuyingRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="optional"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding RateMessage}"
                                               IsVisible="{Binding RateMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{StaticResource AlertRed}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Add Rate" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnCreateExchangeRateClick"/>
                                  </Grid>
                                </StackPanel>
                              </StackPanel>
                            </Border>

                            <!-- Currencies list header -->
                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="120,*,90,90">
                                <TextBlock Grid.Column="0" Text="Symbol" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Formal Name" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Decimals" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Kind" Classes="colHdr" TextAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Currencies + Rates lists side by side -->
                            <Grid Grid.Row="4" ColumnDefinitions="*,*" Margin="0,0,0,0">
                              <ScrollViewer Grid.Column="0" Background="White">
                                <ItemsControl ItemsSource="{Binding Currencies}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CurrencyListRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,*,90,90" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                     Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding FormalName}"
                                                     VerticalAlignment="Center" FontSize="12.5"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Decimals}"
                                                     TextAlignment="Center"
                                                     VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Kind}"
                                                     TextAlignment="Center"
                                                     VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>

                              <Border Grid.Column="1" BorderBrush="{StaticResource GridLine}" BorderThickness="1,0,0,0">
                                <Grid RowDefinitions="Auto,*">
                                  <Border Grid.Row="0" Background="{StaticResource BrandNavyDark}">
                                    <Grid ColumnDefinitions="*,110,90,80,80">
                                      <TextBlock Grid.Column="0" Text="Rates — Currency" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Date" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Std ₹" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="3" Text="Sell ₹" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="4" Text="Buy ₹" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ScrollViewer Grid.Row="1" Background="White">
                                    <ItemsControl ItemsSource="{Binding Rates}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ExchangeRateListRow">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,110,90,80,80" Height="24">
                                              <TextBlock Grid.Column="0" Text="{Binding Currency}"
                                                         Margin="8,0" VerticalAlignment="Center" FontSize="12"
                                                         TextTrimming="CharacterEllipsis"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Date}"
                                                         VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                              <TextBlock Grid.Column="2" Text="{Binding Standard}"
                                                         TextAlignment="Right" Margin="0,0,6,0"
                                                         VerticalAlignment="Center" FontSize="11.5"/>
                                              <TextBlock Grid.Column="3" Text="{Binding Selling}"
                                                         TextAlignment="Right" Margin="0,0,6,0"
                                                         VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="4" Text="{Binding Buying}"
                                                         TextAlignment="Right" Margin="0,0,6,0"
                                                         VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </ScrollViewer>
                                </Grid>
                              </Border>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Forex Gain/Loss (unrealized revaluation) report -->
                    <ContentControl IsVisible="{Binding ForexReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ForexReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ForexReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- As-of date + recompute + book adjustment -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,Auto,Auto,*" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Revalue as at" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <TextBox Grid.Column="1" Text="{Binding AsOfText, Mode=TwoWay}"
                                       PlaceholderText="dd-MMM-yyyy"/>
                              <Button Grid.Column="2" Content="Recompute" Margin="8,0,0,0" Padding="12,5"
                                      Background="{StaticResource Panel}"
                                      Click="OnRecomputeForexClick"/>
                              <Button Grid.Column="3" Content="Book Adjustment (Journal)" Margin="8,0,0,0" Padding="12,5"
                                      IsEnabled="{Binding CanBook}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnBookForexAdjustmentClick"/>
                            </Grid>

                            <!-- Net summary headline -->
                            <Border Grid.Row="3" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="8,0,8,8">
                              <TextBlock Text="{Binding NetSummary}" FontWeight="SemiBold"
                                         Foreground="{Binding IsNetGain, Converter={StaticResource BalancedBrush}}"/>
                            </Border>

                            <!-- Column header -->
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}" Margin="8,0">
                              <Grid ColumnDefinitions="*,90,130,110,80,130,60">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Currency" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Forex Bal." Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Booked ₹" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Revalued ₹" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="G/L" Classes="colHdr" TextAlignment="Center"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="5" Background="White" Margin="8,0">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ForexReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Background="{Binding IsTotal, Converter={StaticResource SelBrush}}">
                                      <Grid ColumnDefinitions="*,90,130,110,80,130,60" Height="26">
                                        <TextBlock Grid.Column="0" Text="{Binding Ledger}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Currency}"
                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ForexBalance}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding BookedBase}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Rate}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="5" Text="{Binding RevaluedBase}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Direction}"
                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="6" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="8,6" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Budget Variance report (Budget / Actual / Variance) -->
                    <ContentControl IsVisible="{Binding BudgetVariance, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BudgetVariance}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BudgetVarianceViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Budget picker -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,10">
                              <TextBlock Grid.Column="0" Text="Budget" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Budgets}"
                                        SelectedItem="{Binding SelectedBudget, Mode=TwoWay}"
                                        PlaceholderText="No budgets defined…">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="ledger:Budget">
                                    <TextBlock Text="{Binding Name}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,130,130,140,90">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Budget" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Actual" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Variance" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="%" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="4" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BudgetVarianceRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,130,130,140,90" Height="24">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center" Margin="8,0">
                                          <TextBlock Text="{Binding Target}"
                                                     FontSize="12.5"
                                                     FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                          <TextBlock Text="{Binding Type}"
                                                     FontSize="10.5" Foreground="#8A8A8A"
                                                     VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Budget}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Actual}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Variance}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}">
                                          <TextBlock.Foreground>
                                            <MultiBinding Converter="{x:Static conv:VarianceToBrushConverter.Instance}">
                                              <Binding Path="IsOver"/>
                                              <Binding Path="IsUnder"/>
                                            </MultiBinding>
                                          </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Grid.Column="4" Text="{Binding VariancePercent}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11">
                                          <TextBlock.Foreground>
                                            <MultiBinding Converter="{x:Static conv:VarianceToBrushConverter.Instance}">
                                              <Binding Path="IsOver"/>
                                              <Binding Path="IsUnder"/>
                                            </MultiBinding>
                                          </TextBlock.Foreground>
                                        </TextBlock>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Bank Reconciliation (pick bank → editable Bank Date → book-vs-bank) -->
                    <ContentControl IsVisible="{Binding BankReconciliation, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BankReconciliation}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BankReconciliationViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Bank ledger picker -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Bank Ledger" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding BankLedgers}"
                                        SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                        PlaceholderText="No bank ledgers defined…">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="ledger:Ledger">
                                    <TextBlock Text="{Binding Name}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Book-vs-Bank balance summary -->
                            <Border Grid.Row="3" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="8,0,8,8">
                              <Grid ColumnDefinitions="*,*,Auto">
                                <StackPanel Grid.Column="0">
                                  <TextBlock Text="Balance as per Company Books" FontSize="11" Foreground="#6A6A6A"/>
                                  <TextBlock Text="{Binding BalanceAsPerBooksText}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                  <TextBlock Text="Balance as per Bank" FontSize="11" Foreground="#6A6A6A"/>
                                  <TextBlock Text="{Binding BalanceAsPerBankText}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                  <TextBlock Text="Not reflected in bank" FontSize="11" Foreground="#6A6A6A"
                                             TextAlignment="Right"/>
                                  <TextBlock Text="{Binding AmountNotReflectedText}" FontSize="13" FontWeight="SemiBold"
                                             TextAlignment="Right"/>
                                </StackPanel>
                              </Grid>
                            </Border>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="90,60,*,90,110,130">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="V.No" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Instrument / Type" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Dr/Cr" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Bank Date" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="5" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BankReconRowViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="90,60,*,90,110,130" Height="28">
                                        <TextBlock Grid.Column="0" Text="{Binding Date}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding VoucherNo}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center">
                                          <TextBlock Text="{Binding Instrument}" FontSize="12"/>
                                          <TextBlock Text="{Binding Kind}" FontSize="10.5" Foreground="#8A8A8A"
                                                     VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{Binding Direction}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox Grid.Column="5" Text="{Binding BankDateText, Mode=TwoWay}"
                                                 Margin="4,2,6,2" FontSize="11" Height="22"
                                                 VerticalContentAlignment="Center"
                                                 PlaceholderText="dd-MMM-yyyy"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Reconcile bar -->
                            <Border Grid.Row="6" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,4">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Type a Bank Date on each cleared transaction, then Reconcile (Ctrl+A)."
                                           FontSize="11" Foreground="#6A6A6A" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Reconcile (Ctrl+A)" Padding="12,5"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnReconcileBankClick"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="7" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,2,0,2" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Import Bank Statement (CSV → auto-match → matched/unmatched) -->
                    <ContentControl IsVisible="{Binding BankStatementImport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BankStatementImport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BankStatementImportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Bank ledger picker -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Bank Ledger" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding BankLedgers}"
                                        SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                        PlaceholderText="No bank ledgers defined…">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="ledger:Ledger">
                                    <TextBlock Text="{Binding Name}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- CSV path + Import -->
                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Statement CSV" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <TextBox Grid.Column="1" Text="{Binding StatementPath, Mode=TwoWay}"
                                       PlaceholderText="path to bank-statement.csv (date, description, amount, instrument)"/>
                              <Button Grid.Column="2" Content="Import (Ctrl+A)" Margin="8,0,0,0" Padding="12,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnImportBankStatementClick"/>
                            </Grid>

                            <!-- Summary -->
                            <TextBlock Grid.Row="4" Text="{Binding SummaryText}"
                                       IsVisible="{Binding SummaryText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                       Margin="8,0,8,6"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="5" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="150,90,*,120,110,100">
                                <TextBlock Grid.Column="0" Text="Status" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Description" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Instrument" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Amount" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Bank Date" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="6" Background="White">
                              <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:StatementResultRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Background="{Binding Kind, Converter={x:Static conv:StatementRowBrushConverter.Instance}}">
                                      <Grid ColumnDefinitions="150,90,*,120,110,100" Height="26">
                                        <TextBlock Grid.Column="0" Text="{Binding StatusLabel}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Date}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Description}"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Instrument}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#333333"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}"
                                                   VerticalAlignment="Center" FontSize="11"/>
                                        <TextBlock Grid.Column="5" Text="{Binding BankDate}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="7" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,4,0,2" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Interest Calculation report (per interest-enabled ledger: principal / rate / days / interest) -->
                    <ContentControl IsVisible="{Binding InterestReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding InterestReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:InterestReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,110,150,80,80,150">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Ref" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Principal" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Days" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Interest" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:InterestReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,110,150,80,80,150" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Ledger}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Reference}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Principal}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Rate}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Days}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Interest}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                                </Panel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                </Panel>
            </Border>

            <!-- RIGHT BUTTON BAR -->
            <Border Grid.Column="1" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ButtonBar}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ButtonBarItem">
                                <Button Classes="barBtn" Command="{Binding Invoke}" IsEnabled="{Binding Enabled}">
                                    <Grid ColumnDefinitions="34,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                   Foreground="{StaticResource AlertRed}" FontWeight="Bold"
                                                   FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Caption}"
                                                   Foreground="{StaticResource Ink}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ============ STATUS BAR (navy) ============ -->
        <Border Grid.Row="3" Background="{StaticResource BrandNavy}" Height="26">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="12,0" FontSize="11" Foreground="#CFE0FF"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="Company: "/><Run Text="{Binding StatusCompany}"/>
                </TextBlock>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0" FontSize="11" Foreground="#CFE0FF">
                    <Run Text="Current Date: "/><Run Text="{Binding StatusDate}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
