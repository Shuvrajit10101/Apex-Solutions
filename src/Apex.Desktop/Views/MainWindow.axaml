<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Apex.Desktop.ViewModels"
        xmlns:conv="using:Apex.Desktop.Converters"
        xmlns:views="using:Apex.Desktop.Views"
        xmlns:ledger="using:Apex.Ledger.Domain"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="Apex.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="1440" Height="900"
        MinWidth="1120" MinHeight="560"
        Background="{StaticResource Cream}"
        FontFamily="Consolas, Cascadia Mono, Menlo, monospace"
        Title="Apex Solutions">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:ScreenEqualsConverter x:Key="ScreenEquals"/>
        <conv:SelectedToBrushConverter x:Key="SelBrush"/>
        <conv:SelectedActiveToBrushConverter x:Key="SelActiveBrush"/>
        <conv:SelectedToForegroundConverter x:Key="SelFore"/>
        <conv:BoolToWeightConverter x:Key="BoolWeight"/>
        <conv:BoolToTextAlignmentConverter x:Key="NumAlign"/>
        <conv:DrCrLabelConverter x:Key="DrCrLabel"/>
        <conv:BalancedToBrushConverter x:Key="BalancedBrush"/>
        <conv:UpperConverter x:Key="Upper"/>
        <conv:SubIndentConverter x:Key="SubIndent"/>
        <conv:IndentToThicknessConverter x:Key="Indent"/>
        <conv:ColumnHeaderBrushConverter x:Key="ColHeaderBrush"/>
        <conv:BillRefTypeLabelConverter x:Key="BillRefLabel"/>
        <conv:BudgetTypeLabelConverter x:Key="BudgetTypeLabel"/>
        <conv:BankTxTypeLabelConverter x:Key="BankTxTypeLabel"/>
        <conv:GstStatementTypeLabelConverter x:Key="GstStatementTypeLabel"/>
        <conv:ExpiryRowToBrushConverter x:Key="ExpiryRowBrush"/>
        <conv:ExpiryWarningToBrushConverter x:Key="ExpiryWarningBrush"/>
        <conv:CollectionEmptyConverter x:Key="CollectionEmpty"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Menu item row -->
        <Style Selector="Border.menuRow">
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
        <!-- Button-bar button -->
        <Style Selector="Button.barBtn">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.barBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Amber}"/>
        </Style>
        <!-- Report grid header cell -->
        <Style Selector="TextBlock.colHdr">
            <Setter Property="Foreground" Value="{StaticResource AppWhite}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <!-- Report grid NUMERIC VALUE cell (C10). Right-aligned with an 8px right inset that MATCHES
             the colHdr Padding.Right (8,4) above, so a value's right edge lands EXACTLY under its column
             header's right edge. Value cells previously carried an ad-hoc 10px right margin, leaving a
             2px drift between the header figure and the value beneath it. Tagging a money/amount value
             cell Classes="numCell" (instead of the local TextAlignment="Right" Margin="0,0,10,0") pins
             it flush with its header. The header style is deliberately UNTOUCHED (it drives ~277 headers
             app-wide); only the value cells migrate. -->
        <Style Selector="TextBlock.numCell">
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <!-- Editable-grid dropdown: left-align the selection box so the item name is never
             clipped on the left (the default Fluent ComboBox anchors the selection oddly when
             the content is wide). Applies only to comboboxes tagged Classes="gridCombo". -->
        <Style Selector="ComboBox.gridCombo /template/ ContentControl#ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <!-- Stat-strip cell (label stacked over value) inside a 4-up "*,*,*,*" summary Grid.
             A vertical StackPanel stretches each TextBlock to the FULL cell width, so a value
             tagged TextAlignment="Right" drifts to its cell's RIGHT edge while its own label
             stays at the cell's LEFT edge. The value then sits visually adjacent to the NEXT
             cell's label and the reader attaches the figure to the WRONG head — a financial
             misread (on RunSetOff the IGST liability 5,400.00 read as "RCM (cash-only)", which
             is really 0.00). The gap GROWS as the pane widens, so alignment must be intrinsic.
             Tagging the cell Classes="statCell" pins BOTH label and value to the same edge, so
             the pair reads as one unit at any width.
             NOTE: this is deliberately NOT applied to every strip cell. Only MONEY/amount cells
             are tagged. Cells holding TEXT (Cmp08 "Trader" / "1% on turnover base") or plain
             counts stay left/left — they already match, and right-aligning them would be a NEW
             defect. The rule is that label and value MATCH, not that everything goes right. -->
        <!-- G10: GST Actions bars (Generate e-Invoice / Generate e-Way Bill / Post ITC Reversal). Their input
             TextBoxes top-aligned their text while the row's ComboBoxes centre theirs, so a mixed combo+textbox
             row sat at two baselines. Centre the TextBox content so every field on a row shares one baseline.
             Scoped to bars tagged Classes="gstActionBar" so no other TextBox app-wide is affected. -->
        <Style Selector="Border.gstActionBar TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="StackPanel.statCell > TextBlock">
            <Setter Property="TextAlignment" Value="Right"/>
            <!-- GUTTER (load-bearing — do not drop). The strips have NO gutter of their own: a
                 right-aligned cell's text ends EXACTLY on its cell boundary, and the next cell's
                 left-aligned text starts EXACTLY on that same boundary, so the two COLLIDE with no
                 separating space. Form 24Q renders "money | count | money": without this inset the
                 amount 12,45,678.50 butted the neighbouring count 6 and read as "12,45,678.506" —
                 the count looked like a trailing DIGIT of the figure (a financial misread, the very
                 class of bug C3 fixed). The inset applies to the label AND the value equally, so
                 they stay flush with each other and C3 cannot return. Verified by render. -->
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ============ TOP BAR (navy) ============ -->
        <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="34">
                <TextBlock Grid.Column="0" Text="Apex Solutions"
                           Foreground="White" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ScreenTitle}"
                           Foreground="#CFE0FF" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="P: Print   E: Export   M: E-Mail   O: Import"
                           Foreground="#9FB8E0" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ============ MENU ROW (navy dark) ============ -->
        <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Height="24">
            <TextBlock Text="Gateway of Apex Solutions   —   F3: Company   Y: Data   O: Import"
                       Foreground="#8FA9D6" FontSize="11" VerticalAlignment="Center" Margin="12,0"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ============ BODY: work area + right button bar ============ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,168">

            <!-- CENTRAL CREAM WORK AREA -->
            <Border Grid.Column="0" Background="{StaticResource Cream}" Margin="6">
                <Panel>

                    <!-- SCREEN: Company Select / Gateway / (menu-based screens) -->
                    <Grid IsVisible="{Binding IsMenuScreen}" RowDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Row="0" Text="{Binding ScreenTitle}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BrandNavy}"
                                   HorizontalAlignment="Center" Margin="0,18,0,10"/>

                        <!-- The keyboard-navigable menu (centred vertical list) -->
                        <Border Grid.Row="1"
                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                Background="White"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,10" MinWidth="420" Padding="0,8">
                            <ItemsControl ItemsSource="{Binding Menu}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MenuItemViewModel">
                                        <Panel>
                                            <!-- Section header: dim, uppercase, non-selectable -->
                                            <Border Classes="menuRow" IsVisible="{Binding IsHeader}"
                                                    Margin="0,7,0,1">
                                                <TextBlock Text="{Binding Label, Converter={StaticResource Upper}}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#9098A8"
                                                           LetterSpacing="1.5"/>
                                            </Border>
                                            <!-- Selectable item -->
                                            <Border Classes="menuRow" IsVisible="{Binding IsSelectable}"
                                                    Background="{Binding IsSelected, Converter={StaticResource SelBrush}}">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      Margin="{Binding IsSubItem, Converter={StaticResource SubIndent}}">
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                               FontSize="14"
                                                               Foreground="{Binding IsSelected, Converter={StaticResource SelFore}}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Hint}"
                                                               FontSize="11" Foreground="#6A6A6A"
                                                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Create-company inline form -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding CurrentScreen, Converter={StaticResource ScreenEquals}, ConverterParameter=CreateCompany}"
                                Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,10" Width="460" Padding="18">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Name" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <TextBox x:Name="CompanyNameBox" Text="{Binding NewCompanyName, Mode=TwoWay}"
                                         PlaceholderText="e.g. Acme Traders" FontSize="14"/>
                                <TextBlock Text="Financial year begins 1-Apr; base currency ₹ INR."
                                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                <Button Content="Create (Ctrl+A)" HorizontalAlignment="Right"
                                        Click="OnCreateCompanyClick"
                                        Background="{StaticResource BrandNavy}" Foreground="White" Padding="14,6"/>
                            </StackPanel>
                        </Border>

                        <!-- Message / hint line -->
                        <TextBlock Grid.Row="2" Text="{Binding Message}"
                                   IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="{StaticResource AlertRed}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,6,0,14" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- ============ CASCADING (MILLER-COLUMNS) GATEWAY ============ -->
                    <!-- A horizontal row of columns: each drill-in adds a column to the right; earlier
                         columns stay visible. Menu columns are narrow; a page column is wide. The whole
                         row scrolls sideways if it overflows; each column has its own up/down scroll so
                         text is never clipped or overwritten across columns. -->
                    <ScrollViewer x:Name="CascadeScroller"
                                  IsVisible="{Binding IsGatewayCascade}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                      <ItemsControl x:Name="CascadeColumns" ItemsSource="{Binding Columns}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:GatewayColumn">
                            <!-- One column: header band + body. C4 viewport-aware, position-aware sizing:
                                 a MENU column content-sizes within [260,380]; the TERMINAL (rightmost) PAGE
                                 column fills the leftover viewport (viewport − ownX − 6, floored at 640) so
                                 the h-ScrollViewer scrolls rather than squeezing the report — no dead cream;
                                 a NON-terminal page column (a report with a drill column to its right) keeps
                                 the bounded 640 floor so both fit side-by-side. Width is a MultiBinding (NOT
                                 a fixed attribute) fed IsMenu + viewport + own-X + IsLast. -->
                            <Border Margin="0,0,6,0"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Background="White"
                                    MinWidth="{Binding IsMenu, Converter={x:Static conv:ColumnMinWidthConverter.Instance}}"
                                    MaxWidth="{Binding IsMenu, Converter={x:Static conv:ColumnMaxWidthConverter.Instance}}">
                              <Border.Width>
                                <MultiBinding Converter="{x:Static conv:CascadeColumnWidthConverter.Instance}">
                                  <Binding Path="IsMenu"/>
                                  <Binding Path="$parent[ScrollViewer].Bounds.Width"/>
                                  <Binding Path="$parent[ContentPresenter].Bounds.X"/>
                                  <Binding Path="IsLast"/>
                                </MultiBinding>
                              </Border.Width>
                              <Grid RowDefinitions="Auto,*">

                                <!-- Column header -->
                                <Border Grid.Row="0"
                                        Background="{Binding IsActive, Converter={StaticResource ColHeaderBrush}}"
                                        Padding="10,6">
                                  <TextBlock Text="{Binding Title}"
                                             Foreground="White" FontWeight="SemiBold" FontSize="13"
                                             TextTrimming="CharacterEllipsis"/>
                                </Border>

                                <!-- BODY (a) menu column: keyboard-navigable list -->
                                <ScrollViewer Grid.Row="1" IsVisible="{Binding IsMenu}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0,6">
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:MenuItemViewModel">
                                        <Panel>
                                          <!-- Section header: dim, uppercase, non-selectable -->
                                          <Border Classes="menuRow" IsVisible="{Binding IsHeader}" Margin="0,7,0,1">
                                            <TextBlock Text="{Binding Label, Converter={StaticResource Upper}}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#9098A8" LetterSpacing="1.5"/>
                                          </Border>
                                          <!-- Selectable item: bright amber in the active column, dim slate when
                                               selected in an earlier column, transparent otherwise. -->
                                          <Border Classes="menuRow" IsVisible="{Binding IsSelectable}">
                                            <Border.Background>
                                              <MultiBinding Converter="{x:Static conv:SelectedActiveToBrushConverter.Instance}">
                                                <Binding Path="IsSelected"/>
                                                <Binding Path="IsActiveColumn"/>
                                              </MultiBinding>
                                            </Border.Background>
                                            <Grid ColumnDefinitions="*,Auto"
                                                  Margin="{Binding IsSubItem, Converter={StaticResource SubIndent}}">
                                              <!-- C11: this shared cascade menu row reaches EVERY menu column on all
                                                   screens (party/ledger pickers included). The full label stays VISIBLE
                                                   by default (C4 widened the panes) and TextTrimming degrades honestly if
                                                   a name still overflows; ToolTip.Tip surfaces the full label — including
                                                   the parenthetical disambiguator (state / GSTIN / branch) — on hover, a
                                                   bonus for mouse users of this keyboard-first list. -->
                                              <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                         FontSize="14" TextTrimming="CharacterEllipsis"
                                                         ToolTip.Tip="{Binding Label}"
                                                         Foreground="{Binding IsSelected, Converter={StaticResource SelFore}}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Hint}"
                                                         FontSize="11" Foreground="#6A6A6A"
                                                         VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            </Grid>
                                          </Border>
                                        </Panel>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>

                                <!-- BODY (b) page column: exactly one of the four page kinds -->
                                <Panel Grid.Row="1" IsVisible="{Binding IsPage}">

                    <!-- PAGE: Report viewer -->
                    <ContentControl IsVisible="{Binding Report, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Report}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ReportsViewModel">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                        <TextBlock Grid.Row="0" Text="{Binding Title}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                   HorizontalAlignment="Center" Margin="0,12,0,2"/>
                        <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                   FontSize="12" Foreground="#555555"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- Scenario picker (TB / P&L / Balance Sheet): view the figures under a scenario. -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,10"
                              IsVisible="{Binding SupportsScenario}">
                          <TextBlock Grid.Column="0" Text="Scenario" FontWeight="SemiBold"
                                     VerticalAlignment="Center" Margin="0,0,10,0"
                                     Foreground="{StaticResource BrandNavy}"/>
                          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                    ItemsSource="{Binding Scenarios}"
                                    SelectedItem="{Binding SelectedScenario, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:ScenarioOption">
                                <TextBlock Text="{Binding Display}"/>
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </Grid>

                        <!-- Payroll wage-month + employee picker (Phase 8 slice 8): every payroll report is scoped to
                             one wage month; the Payslip is additionally scoped to a single employee. -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" Margin="8,0,8,10"
                              IsVisible="{Binding ShowPayrollMonthPicker}">
                          <TextBlock Grid.Column="0" Text="Wage Month" FontWeight="SemiBold"
                                     VerticalAlignment="Center" Margin="0,0,10,0"
                                     Foreground="{StaticResource BrandNavy}"/>
                          <ComboBox Grid.Column="1" Width="150" MaxDropDownHeight="360"
                                    ItemsSource="{Binding PayrollMonths}"
                                    SelectedItem="{Binding SelectedPayrollMonth, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:PayrollMonthOption">
                                <TextBlock Text="{Binding Label}"/>
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBlock Grid.Column="2" Text="Employee" FontWeight="SemiBold"
                                     VerticalAlignment="Center" Margin="18,0,10,0"
                                     Foreground="{StaticResource BrandNavy}"
                                     IsVisible="{Binding ShowPayrollEmployeePicker}"/>
                          <ComboBox Grid.Column="3" HorizontalAlignment="Stretch" MaxDropDownHeight="360"
                                    ItemsSource="{Binding PayrollEmployees}"
                                    SelectedItem="{Binding SelectedPayrollEmployee, Mode=TwoWay}"
                                    IsVisible="{Binding ShowPayrollEmployeePicker}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:PayrollEmployeeOption">
                                <TextBlock Text="{Binding Display}"/>
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </Grid>

                        <!-- ============ ACCOUNTING reports (TB / BS / P&L / Day Book): Particulars | Dr | Cr | Amount ============ -->
                        <Grid Grid.Row="3" Grid.RowSpan="2" RowDefinitions="Auto,*" IsVisible="{Binding ShowSingleAccountingGrid}">
                        <!-- Column header band (navy) -->
                        <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                            <Grid ColumnDefinitions="*,150,150">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <!-- Two-column (Dr/Cr) mode -->
                                <TextBlock Grid.Column="1" Text="Debit" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding IsTwoColumn}"/>
                                <TextBlock Grid.Column="2" Text="Credit" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding IsTwoColumn}"/>
                                <!-- Single-amount mode -->
                                <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding !IsTwoColumn}"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" Background="White">
                            <!-- RQ-7 drill: a ListBox (not a plain ItemsControl) so a row can be highlighted and
                                 Enter/double-click drills a drillable ledger row (TB/BS/P&L → that ledger's
                                 vouchers) or a Day Book voucher row (→ the voucher's detail). Non-drillable rows
                                 (headers/totals/synthetic) are a safe no-op. -->
                            <ListBox ItemsSource="{Binding Rows}" Background="White" Tag="drill"
                                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                     DoubleTapped="OnAccountingReportDrill" KeyDown="OnAccountingReportKeyDown">
                                <!-- C10: zero the ListBoxItem chrome so a row's grid spans the FULL width
                                     (matching the header band, which has no such inset) and each row's height
                                     is driven by the template's own Height=24. Without this the default Fluent
                                     ListBoxItem padding inset the row grid, so value right edges sat left of the
                                     header right edges and rows were taller than the header band. Copied verbatim
                                     from the working Stock Summary ListBox. -->
                                <ListBox.Styles>
                                  <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                  </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ReportRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Background="Transparent">
                                            <Grid ColumnDefinitions="*,150,150" Height="24">
                                                <!-- C1 (financial misread): Particulars + the grey Secondary tag used to
                                                     sit in a horizontal StackPanel, which measures its children at
                                                     INFINITE width — so TextTrimming could never engage and a long
                                                     ledger name painted straight over the amount column, e.g.
                                                     "HDFC Bank Limited - Current A/c ... Bank Accou32,500.00", where the
                                                     overprinted "n" turns Rs 22,500 into a readable Rs 32,500.
                                                     Trimming the pair as ONE run of text gives LEFTMOST PRIORITY, which
                                                     is right for BOTH profiles this shared template serves:
                                                       - TB / BS / P&L: Particulars = unbounded ledger name, Secondary =
                                                         short group tag  -> keep the name, drop the tag.
                                                       - Day Book: Particulars = short "date + voucher no", Secondary =
                                                         unbounded narration -> keep the identity, drop the narration.
                                                     Do NOT "simplify" this to an inner Grid "*,Auto": that was tried and
                                                     rendered — the Auto column takes its FULL desired width and starves
                                                     the identity column to zero, silently ERASING the Day Book dates. -->
                                                <TextBlock Grid.Column="0" FontSize="12.5"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" Margin="8,0">
                                                    <Run Text="{Binding Particulars}"
                                                         FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{Binding Secondary}"
                                                         FontSize="10.5" Foreground="#8A8A8A"/>
                                                </TextBlock>
                                                <!-- Two-column (Dr/Cr) mode: Debit + Credit both visible -->
                                                <TextBlock Grid.Column="1" Text="{Binding Debit}"
                                                           Classes="numCell"
                                                           IsVisible="{Binding IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Credit}"
                                                           Classes="numCell"
                                                           IsVisible="{Binding IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                                <!-- Single-amount mode: Amount occupies column 2 alone -->
                                                <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                           Classes="numCell"
                                                           IsVisible="{Binding !IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                        </Grid>

                        <!-- ============ INVENTORY reports (slice 3.4b): wide per-report grids ============ -->
                        <Grid x:Name="InventoryReportPane" Grid.Row="3" Grid.RowSpan="2" RowDefinitions="Auto,*"
                              IsVisible="{Binding ShowSingleInventoryGrid}">

                          <!-- == Stock Summary: Item | Inward | Outward | Closing Qty | Rate | Value (drill: dbl-click / Enter) == -->
                          <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsStockSummary}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,90,90,100,90,110">
                                <TextBlock Grid.Column="0" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Inward" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Outward" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Closing Qty" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ListBox Grid.Row="1" Background="White" x:Name="StockSummaryList" Tag="drill"
                                     ItemsSource="{Binding Rows}"
                                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                     DoubleTapped="OnStockSummaryDrill" KeyDown="OnStockSummaryKeyDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                              <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                  <Setter Property="Padding" Value="0"/>
                                  <Setter Property="MinHeight" Value="0"/>
                                </Style>
                              </ListBox.Styles>
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ReportRow">
                                  <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="*,90,90,100,90,110" Height="24">
                                      <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                 VerticalAlignment="Center" FontSize="12.5"
                                                 TextTrimming="CharacterEllipsis"
                                                 FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Col2}" TextAlignment="Right"
                                                 Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                 Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                 Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                 FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                 Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                 Foreground="#555555"/>
                                      <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                 Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                 FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                          </Grid>

                          <!-- == Godown Summary: Godown | Item | Qty | Value == -->
                          <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsGodownSummary}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,*,140,160">
                                <TextBlock Grid.Column="0" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Quantity" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,*,140,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>

                          <!-- == Stock Item Movement: Date | Voucher | In | Out | Balance | Value == -->
                          <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsStockMovement}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="120,*,80,80,90,95">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Voucher Type" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Inward" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Outward" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Balance" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="120,*,80,80,90,95" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>

                          <!-- == Reorder Status: Item | Closing | Reorder Level | Pending POs | SOs Due | Shortfall | Order to be Placed == -->
                          <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsReorderStatus}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,92,110,100,92,92,140">
                                <TextBlock Grid.Column="0" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Closing" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Reorder Level" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Pending POs" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="SOs Due" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Shortfall" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Order to be Placed" Classes="colHdr"
                                           TextAlignment="Right" Margin="0,0,10,0"/>
                              </Grid>
                            </Border>
                            <!-- ListBox (not a plain ItemsControl) so a row can be highlighted: Ctrl+F9 raises a
                                 pre-filled Purchase Order from the selected row (RQ-53) and Enter/double-click
                                 drills into that item's Stock Item Movement, mirroring the Stock-Summary grid. -->
                            <ListBox Grid.Row="1" Background="White" Tag="drill"
                                     ItemsSource="{Binding Rows}"
                                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                     DoubleTapped="OnStockSummaryDrill" KeyDown="OnStockSummaryKeyDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                              <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                  <Setter Property="Padding" Value="0"/>
                                  <Setter Property="MinHeight" Value="0"/>
                                </Style>
                              </ListBox.Styles>
                              <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,92,110,100,92,92,140" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource AlertRed}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="SemiBold"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                          </Grid>

                          <!-- == Physical Stock Register: Date | Item | Godown | Book | Counted | Variance == -->
                          <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsPhysicalStockRegister}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="110,*,*,110,110,110">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Book" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Counted" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Variance" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="110,*,*,110,110,110" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource AlertRed}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>

                          <!-- == Order Register: Date | Voucher | Party | Item | Godown | Ordered | Pending | Rate ==
                               Wide grid pinned to a MinWidth so the two "*" (Party / Item) columns never starve to
                               zero in a narrow pane (C6); it fills the pane when wider and horizontally scrolls when
                               narrower, so the Grand-Total / empty-state text is never laid out into zero px. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsOrderRegister}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #InventoryReportPane.Bounds.Width}" MinWidth="980">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="100,150,*,*,120,100,100,110" MinWidth="980">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Voucher" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Ordered" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Pending" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="100,150,*,*,120,100,100,110" MinWidth="980" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Col8}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Allocation registers (Receipt Note / Delivery Note / Rejection / Material In/Out):
                               Date | No. | Party | Item | Godown | Qty | Rate | Value | Batch ==
                               MinWidth-pinned so the single "*" (Item) column keeps >=150px in a narrow pane (C6):
                               the Grand-Total label parked in that column, and the empty-state, are never rendered
                               into zero px. Fills the pane when wide; horizontally scrolls when narrow. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsAllocationRegister}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #InventoryReportPane.Bounds.Width}" MinWidth="900">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="95,60,150,*,120,90,100,120" MinWidth="900">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="No." Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="95,60,150,*,120,90,100,120" MinWidth="900" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" TextAlignment="Right"
                                                   Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   Foreground="#555555"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Col8}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Job Work Order Book (Phase 6 slice 8; RQ-51): order header rows + tracked component rows.
                               Date | Order No. | Party | Item | Track | Ordered | Fulfilled | Pending ==
                               MinWidth-pinned so the "*" (Item) column keeps >=150px in a narrow pane (C6): the order
                               header line + empty-state parked in that column are never rendered into zero px. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsJobWorkOrderBook}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #InventoryReportPane.Bounds.Width}" MinWidth="920">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="95,120,150,*,110,95,95,95" MinWidth="920">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Order No." Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Track" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Ordered" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Fulfilled" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="Pending" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="95,120,150,*,110,95,95,95" MinWidth="920" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Col8}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Batch-wise (Phase 6 Cluster 1; RQ-8): Item | Batch | Mfg | Expiry | Godown | Inward | Outward | Closing | Value ==
                               Wide grid; horizontal scroll so no column clips. Header + rows share the SAME
                               explicit widths so they scroll together and line up. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsBatchwise}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #InventoryReportPane.Bounds.Width}" MinWidth="1080">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,120,110,110,140,100,100,100,120" MinWidth="1080">
                                <TextBlock Grid.Column="0" Text="Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Batch" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Mfg" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Expiry" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Inward" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Outward" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="Closing" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="8" Text="Value ₹" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,120,110,110,140,100,100,100,120" MinWidth="1080" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Col8}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="8" Text="{Binding Secondary}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Batch Age Analysis (Phase 6 Cluster 1; RQ-8): Item | Batch | Mfg | Expiry | Days | Godown | Qty | Value ==
                               Past-expiry rows flagged distinctly (red foreground via ExpiryRowBrush). -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsBatchAgeAnalysis}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #InventoryReportPane.Bounds.Width}" MinWidth="1030">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,120,110,110,130,140,110,120" MinWidth="1030">
                                <TextBlock Grid.Column="0" Text="Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Batch" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Mfg" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Expiry" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Days" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="6" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="Value ₹" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,120,110,110,130,140,110,120" MinWidth="1030" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                   Foreground="{Binding IsExpired, Converter={StaticResource ExpiryRowBrush}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding IsExpired, Converter={StaticResource ExpiryRowBrush}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   Foreground="{Binding IsExpired, Converter={StaticResource ExpiryRowBrush}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   Foreground="{Binding IsExpired, Converter={StaticResource ExpiryRowBrush}}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Secondary}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Price List (Phase 6 slice 5; RQ-31): Level | Item | Applicable From | From | To | Rate | Disc % | Net Rate ==
                               Level + item repeat only at the top of each group so the nesting reads. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsPriceList}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #InventoryReportPane.Bounds.Width}" MinWidth="1080">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="170,*,130,90,90,120,90,120" MinWidth="1080">
                                <TextBlock Grid.Column="0" Text="Price Level" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Applicable From" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="From" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="To" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Rate ₹" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Disc %" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="Net Rate ₹" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="170,*,130,90,90,120,90,120" MinWidth="1080" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Secondary}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                        </Grid>

                        <!-- ============ GST reports (slice 4d): Tax Analysis / GSTR-1 / GSTR-3B ============ -->
                        <Grid x:Name="GstReportPane" Grid.Row="3" Grid.RowSpan="2"
                              IsVisible="{Binding IsGstReport}">

                          <!-- == Tax Analysis: Rate / Head | CGST | SGST | IGST | Taxable | Tax ==
                               Wide statutory grid — horizontal scroll so no column collapses/clips;
                               first "Rate / Head" column FIXED (never collapses); header + rows share
                               the SAME explicit width so they scroll together and line up. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsTaxAnalysis}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #GstReportPane.Bounds.Width}" MinWidth="830"
                                Height="{Binding #GstReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,120,120,120,150,150" MinWidth="830">
                                <TextBlock Grid.Column="0" Text="Rate / Head" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="CGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="SGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="IGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Taxable" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Tax" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,120,120,120,150,150" MinWidth="830" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == GSTR-1: Party/HSN | GSTIN/Desc | Invoice/UQC | POS/Qty | Taxable | CGST | SGST | IGST ==
                               G2: the grid is FLUID — Width binds to the page pane and MinWidth (950) is now BELOW the
                               1440-default pane (~998px), so at 1440 the grid equals the pane and ALL eight columns —
                               including the rightmost IGST — fit within it (previously MinWidth 1030 forced the grid
                               wider than the pane, scrolling IGST off behind the shortcut bar). The four numeric tax
                               columns (Taxable/CGST/SGST/IGST) are NOT squeezed; the small saving comes from Invoice/UQC.
                               A horizontal scrollbar only appears if the pane is narrower than the 950 floor. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsGstr1}">
                          <Grid RowDefinitions="Auto,*" Width="{Binding #GstReportPane.Bounds.Width}" MinWidth="950"
                                Height="{Binding #GstReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,150,150,90,130,110,110,110" MinWidth="950">
                                <TextBlock Grid.Column="0" Text="Party / HSN" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="GSTIN / Description" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Invoice / UQC" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="POS / Qty" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Taxable" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="CGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="SGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="7" Text="IGST" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,150,150,90,130,110,110,110" MinWidth="950" Height="24">
                                        <!-- G2: a section-header row (B2B / B2C / Rate-wise / HS-SAC) shows its label
                                             SPANNING the full width so it is never clipped into the narrow Party/HSN
                                             column; the columnar Col1 is used only for data rows (party name / HSN). -->
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding !IsHeader}"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="0" Grid.ColumnSpan="8" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding IsHeader}"
                                                   VerticalAlignment="Center" FontSize="11.5" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="7" Text="{Binding Col8}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == GSTR-3B: Particulars | Taxable value | CGST | SGST | IGST ==
                               Wide "Particulars" (MinWidth) so labels like "3.1 Details of outward
                               supplies…" / "Net payable / (credit carried forward)" show in full;
                               numeric columns trimmed. The grid stretches to fill the pane but has a
                               floor width — a horizontal scrollbar appears only if the pane is narrower
                               than that floor, so labels are never clipped. Header + rows share the same
                               widths and scroll together. -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsGstr3b}">
                          <Grid RowDefinitions="Auto,*" MinWidth="700"
                                Width="{Binding #GstReportPane.Bounds.Width}"
                                Height="{Binding #GstReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,100,95,95,95" MinWidth="700">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Taxable Value" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="CGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="SGST" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="IGST" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,100,95,95,95" MinWidth="700" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                        </Grid>

                        <!-- ============ STATUTORY TDS/TCS reports (Phase 7 slice 8): outstandings / not-withheld /
                             interest / nature summary / ledgers-without-PAN ============
                             Wide statutory grids: each family is horizontally scrollable (fixed total width) so no
                             column collapses/clips; header + rows share the SAME explicit column widths so they scroll
                             together and line up. The TDS and TCS members of a pair share a grid; the header labels
                             that differ come from the VM (StatCodeHeader / StatWithheldHeader / …). Amounts are whole
                             rupees. De-branded. -->
                        <Grid x:Name="StatutoryReportPane" Grid.Row="3" Grid.RowSpan="2"
                              IsVisible="{Binding IsStatutoryReport}">

                          <!-- == Outstandings (R1/R5): Section/Code | Nature | Deducted/Collected | Deposited | Outstanding | Overdue == -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsStatutoryOutstanding}">
                          <Grid RowDefinitions="Auto,*" MinWidth="600" Width="{Binding #StatutoryReportPane.Bounds.Width}"
                                Height="{Binding #StatutoryReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="96,*,98,98,104,84">
                                <TextBlock Grid.Column="0" Text="{Binding StatCodeHeader}" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Nature" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="{Binding StatWithheldHeader}" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Deposited" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Outstanding" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Overdue Days" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="96,*,98,98,104,84" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding !IsHeader}"
                                                   VerticalAlignment="Center" FontSize="12.5" TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="0" Grid.ColumnSpan="6" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding IsHeader}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Not Deducted / Not Collected (R2/R6): Date | Party | Section/Nature | Assessable | Cumulative | Threshold | Shortfall == -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsStatutoryNotWithheld}">
                          <Grid RowDefinitions="Auto,*" MinWidth="624" Width="{Binding #StatutoryReportPane.Bounds.Width}"
                                Height="{Binding #StatutoryReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="96,*,100,84,92,84,86">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Sec./Nature" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Assessable" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Cumul. (FY)" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Threshold" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="Shortfall" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="96,*,100,84,92,84,86" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding !IsHeader}"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="0" Grid.ColumnSpan="7" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding IsHeader}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Interest (R3/R7): Party | Section/Code | TDS/TCS | Deduction/Collection Date | Deposit Date |
                               Due Date | Months | Interest — with the late-deduction-limb footnote below == -->
                          <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsStatutoryInterest}">
                            <ScrollViewer Grid.Row="0" x:Name="StatInterestBody"
                                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                              <Grid RowDefinitions="Auto,*" MinWidth="610" Width="{Binding #StatInterestBody.Bounds.Width}"
                                    Height="{Binding #StatInterestBody.Bounds.Height}">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,72,64,80,86,82,46,108">
                                    <TextBlock Grid.Column="0" Text="Party" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StatCodeHeader}" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="{Binding StatTaxHeader}" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding StatEventDateHeader}" Classes="colHdr"/>
                                    <TextBlock Grid.Column="4" Text="Deposit Date" Classes="colHdr"/>
                                    <TextBlock Grid.Column="5" Text="Due Date" Classes="colHdr"/>
                                    <TextBlock Grid.Column="6" Text="Months" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="7" Text="{Binding StatInterestHeader}" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" Background="White">
                                  <ItemsControl ItemsSource="{Binding Rows}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ReportRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="*,72,64,80,86,82,46,108" Height="24">
                                            <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                       IsVisible="{Binding !IsHeader}"
                                                       VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                                       FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                                       FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                       FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Col5}" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Grid.Column="5" Text="{Binding Col6}" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Grid.Column="7" Text="{Binding Col8}" TextAlignment="Right"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                       FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                            <TextBlock Grid.Column="0" Grid.ColumnSpan="8" Text="{Binding Col1}" Margin="8,0"
                                                       IsVisible="{Binding IsHeader}" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>
                              </Grid>
                            </ScrollViewer>
                            <Border Grid.Row="1" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}"
                                    BorderThickness="0,1,0,0" Padding="10,6"
                                    IsVisible="{Binding HasStatutoryFootnote}">
                              <TextBlock Text="{Binding StatutoryFootnote}" TextWrapping="Wrap"
                                         FontSize="11" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>

                          <!-- == Nature summary (R4/R8): Section/Code | Nature | Assessable | Deducted/Collected | Deposited | Outstanding | Below-thr == -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsStatutoryNatureSummary}">
                          <Grid RowDefinitions="Auto,*" MinWidth="670" Width="{Binding #StatutoryReportPane.Bounds.Width}"
                                Height="{Binding #StatutoryReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="96,*,90,88,88,92,120">
                                <TextBlock Grid.Column="0" Text="{Binding StatCodeHeader}" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Nature" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Assessable" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="{Binding StatWithheldHeader}" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Deposited" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Outstanding" Classes="colHdr" TextAlignment="Right"/>
                                <!-- G7: full "Below Threshold" (was clipped to "Below Thr." in a 66px column hard against
                                     the pane border). The column is widened so the header shows in full. -->
                                <TextBlock Grid.Column="6" Text="Below Threshold" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="96,*,90,88,88,92,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding !IsHeader}"
                                                   VerticalAlignment="Center" FontSize="12.5" TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Col6}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Col7}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="0" Grid.ColumnSpan="7" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding IsHeader}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                          <!-- == Ledgers without PAN (R9): Party | Type | PAN? | Sections/Codes | Tax at no-PAN rate == -->
                          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                        IsVisible="{Binding IsLedgersWithoutPan}">
                          <Grid RowDefinitions="Auto,*" MinWidth="589" Width="{Binding #StatutoryReportPane.Bounds.Width}"
                                Height="{Binding #StatutoryReportPane.Bounds.Height}">
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,135,76,130,98">
                                <TextBlock Grid.Column="0" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Deductee/Collectee" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="PAN?" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Sections / Codes" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Tax @ No-PAN" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,135,76,130,98" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding !IsHeader}"
                                                   VerticalAlignment="Center" FontSize="12.5" TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Col2}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Col3}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Col4}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Col5}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="0" Grid.ColumnSpan="5" Text="{Binding Col1}" Margin="8,0"
                                                   IsVisible="{Binding IsHeader}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                          </ScrollViewer>

                        </Grid>

                        <!-- ============ COMPARATIVE / columnar report (RQ-4): Particulars + N value columns ============
                             Shown when one or more comparison columns are added (Alt+C / Alt+N). The label column is
                             fixed; the value columns scroll HORIZONTALLY (reusing the GST-report h-scroll pattern) so
                             many periods/scenarios never overflow the pane. Header row, per-column totals row and each
                             data row are laid out as a fixed-width label cell + a horizontal ItemsControl of equal-width
                             value cells, so columns line up across rows. A blank cell = the key is absent in that column. -->
                        <Grid Grid.Row="3" Grid.RowSpan="2" x:Name="ComparativePane"
                              RowDefinitions="Auto,Auto,*" IsVisible="{Binding IsComparative}">

                          <!-- Column-header band: fixed "Particulars" label + one navy header cell per column -->
                          <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                          Offset="{Binding #ComparativeBodyScroller.Offset, Mode=OneWay}">
                              <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Particulars" Classes="colHdr" Width="220"/>
                                <ItemsControl ItemsSource="{Binding ComparativeColumns}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ComparativeColumnVM">
                                      <StackPanel Width="150" Margin="0,0,0,0">
                                        <TextBlock Text="{Binding Label}" Classes="colHdr"
                                                   TextAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding TotalText}" Foreground="#CBD5E8"
                                                   FontSize="10" TextAlignment="Right"
                                                   Margin="0,1,8,0" TextTrimming="CharacterEllipsis"/>
                                      </StackPanel>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                          </Border>

                          <!-- Data rows: label + horizontally-scrolling value cells (scroll drives the header offset) -->
                          <ScrollViewer Grid.Row="2" x:Name="ComparativeBodyScroller" Background="White"
                                        HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ComparativeRows}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ComparativeRowVM">
                                  <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Height="24">
                                      <StackPanel Orientation="Horizontal" Spacing="6" Width="220"
                                                  VerticalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="{Binding Label}" FontSize="12.5"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding GroupName}" FontSize="10.5"
                                                   Foreground="#8A8A8A" VerticalAlignment="Center"/>
                                      </StackPanel>
                                      <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel>
                                          <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                          </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="x:String">
                                            <TextBlock Text="{Binding}" Width="150" FontSize="12.5"
                                                       TextAlignment="Right" Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </Grid>

                        <!-- ============ PAYROLL matrix reports (Phase 8 slice 8): Pay Sheet / Payroll Register /
                             Attendance Register / Payment Advice ============
                             Every wide payroll grid is rendered through the SAME dynamic matrix (columns + rows carry
                             their own per-column widths + numeric/text alignment), scrolling HORIZONTALLY so a wide
                             sheet (Payroll Register = 10 columns; a many-head Pay Sheet) never clips. The header band
                             scrolls in lock-step with the body (its offset mirrors the body scroller). De-branded. -->
                        <Grid Grid.Row="3" Grid.RowSpan="2" x:Name="PayrollMatrixPane"
                              RowDefinitions="Auto,*" IsVisible="{Binding IsPayrollMatrix}">
                          <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                          Offset="{Binding #PayrollBodyScroller.Offset, Mode=OneWay}">
                              <ItemsControl ItemsSource="{Binding PayrollColumns}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PayrollMatrixColumnVm">
                                    <TextBlock Text="{Binding Header}" Classes="colHdr" Width="{Binding Width}"
                                               TextAlignment="{Binding IsNumeric, Converter={StaticResource NumAlign}}"
                                               TextTrimming="CharacterEllipsis"/>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Border>
                          <ScrollViewer Grid.Row="1" x:Name="PayrollBodyScroller" Background="White"
                                        HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                              <ItemsControl ItemsSource="{Binding PayrollRows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PayrollMatrixRowVm">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            TextElement.FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}">
                                      <ItemsControl ItemsSource="{Binding Cells}" Height="24">
                                        <ItemsControl.ItemsPanel>
                                          <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayrollMatrixCellVm">
                                            <!-- Padding (NOT Margin) so each cell's total width EQUALS its column
                                                 Width and stays aligned with the header band in the horizontal
                                                 StackPanel; Margin would add outside Width and shift columns right. -->
                                            <TextBlock Text="{Binding Text}" Width="{Binding Width}"
                                                       VerticalAlignment="Center" FontSize="12.5" Padding="8,0,8,0"
                                                       TextAlignment="{Binding IsNumeric, Converter={StaticResource NumAlign}}"
                                                       TextTrimming="CharacterEllipsis"/>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                              <TextBlock Text="{Binding PayrollEmptyNote}" IsVisible="{Binding IsPayrollEmpty}"
                                         Margin="12" FontSize="12.5" Foreground="#777"/>
                            </StackPanel>
                          </ScrollViewer>
                        </Grid>

                        <!-- ============ PAYSLIP (Phase 8 slice 8): single-employee detail ============
                             The employee identity, side-by-side Earnings / Deductions tables footing to gross / total
                             deductions, the net pay + amount-in-words, the informational employer contributions and the
                             attendance + YTD summary. P / Ctrl+P prints the dedicated de-branded PayslipPdf. -->
                        <Grid Grid.Row="3" Grid.RowSpan="2" IsVisible="{Binding IsPayslipReport}">
                          <ScrollViewer Background="White">
                            <StackPanel Margin="14,8" Spacing="6" IsVisible="{Binding !IsPayslipEmpty}">
                              <TextBlock Text="{Binding PayslipEmployee}" FontSize="15" FontWeight="Bold"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <TextBlock Text="{Binding PayslipPeriodText}" FontSize="12" Foreground="#555555"/>
                              <TextBlock Text="{Binding PayslipMeta}" FontSize="11.5" Foreground="#555555" TextWrapping="Wrap"/>
                              <TextBlock Text="{Binding PayslipMeta2}" FontSize="11.5" Foreground="#555555" TextWrapping="Wrap"/>

                              <Grid ColumnDefinitions="*,16,*" Margin="0,6,0,0">
                                <!-- Earnings -->
                                <StackPanel Grid.Column="0">
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="*,120">
                                      <TextBlock Text="Earnings" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding PayslipEarnings}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PayslipLineVm">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="*,120" Height="23">
                                            <TextBlock Text="{Binding Name}" Margin="8,0" VerticalAlignment="Center"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount}" TextAlignment="Right"
                                                       Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0">
                                    <Grid ColumnDefinitions="*,120" Height="24">
                                      <TextBlock Text="Gross Earnings" Margin="8,0" VerticalAlignment="Center"
                                                 FontWeight="Bold" FontSize="12"/>
                                      <TextBlock Grid.Column="1" Text="{Binding PayslipGross}" TextAlignment="Right"
                                                 Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                  </Border>
                                </StackPanel>
                                <!-- Deductions -->
                                <StackPanel Grid.Column="2">
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="*,120">
                                      <TextBlock Text="Deductions" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding PayslipDeductions}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PayslipLineVm">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="*,120" Height="23">
                                            <TextBlock Text="{Binding Name}" Margin="8,0" VerticalAlignment="Center"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount}" TextAlignment="Right"
                                                       Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0">
                                    <Grid ColumnDefinitions="*,120" Height="24">
                                      <TextBlock Text="Total Deductions" Margin="8,0" VerticalAlignment="Center"
                                                 FontWeight="Bold" FontSize="12"/>
                                      <TextBlock Grid.Column="1" Text="{Binding PayslipTotalDeductions}" TextAlignment="Right"
                                                 Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                  </Border>
                                </StackPanel>
                              </Grid>

                              <Border Background="#EEF2F8" Padding="10,7" Margin="0,8,0,0">
                                <Grid ColumnDefinitions="*,150">
                                  <TextBlock Text="Net Pay" FontSize="14" FontWeight="Bold"
                                             Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"/>
                                  <TextBlock Grid.Column="1" Text="{Binding PayslipNet}" FontSize="14" FontWeight="Bold"
                                             TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                              </Border>
                              <TextBlock Text="{Binding PayslipNetWords}" FontSize="11.5" FontStyle="Italic"
                                         Foreground="#555555" TextWrapping="Wrap"/>

                              <StackPanel IsVisible="{Binding HasPayslipEmployerContributions}" Margin="0,8,0,0">
                                <TextBlock Text="Employer Contributions (not part of net pay)" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                                <ItemsControl ItemsSource="{Binding PayslipEmployerContributions}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PayslipLineVm">
                                      <Grid ColumnDefinitions="*,150" Height="22">
                                        <TextBlock Text="{Binding Name}" Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Amount}" TextAlignment="Right"
                                                   Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>

                              <TextBlock Text="{Binding PayslipAttendance}" FontSize="11.5" Foreground="#555555" Margin="0,8,0,0"/>
                              <TextBlock Text="{Binding PayslipYtd}" FontSize="11.5" Foreground="#555555"/>
                            </StackPanel>
                          </ScrollViewer>
                          <TextBlock Text="{Binding Subtitle}" IsVisible="{Binding IsPayslipEmpty}"
                                     Margin="14" FontSize="12.5" Foreground="#777777" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- The ONE reusable empty-state (UI-defect C7): overlays the whole report body and shows
                             when the report projected no rows. Declared last so it paints over the (empty) grid +
                             its column-header band, spanning ALL columns instead of being routed into one starved
                             cell — the mistake the register reports used to make. -->
                        <views:EmptyState Grid.Row="3" Grid.RowSpan="2"
                                          IsVisible="{Binding IsEmpty}"
                                          Message="{Binding EmptyMessage}"/>

                        </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: RQ-7 Ledger Vouchers drill (a drilled TB/BS/P&L ledger's LedgerBook) -->
                    <ContentControl IsVisible="{Binding LedgerVouchers, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding LedgerVouchers}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:LedgerVouchersViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,130,130,140">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Debit" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Credit" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Balance" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="3" Background="White">
                              <!-- Enter/double-click a posting row drills one level deeper into the voucher detail. -->
                              <ListBox ItemsSource="{Binding Rows}" Background="White" Tag="drill"
                                       SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                       DoubleTapped="OnAccountingReportDrill" KeyDown="OnAccountingReportKeyDown">
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Background="Transparent">
                                      <Grid ColumnDefinitions="*,130,130,140" Height="34">
                                        <!-- Same ROOT CAUSE as the accounting-grid row template above (a horizontal
                                             StackPanel measures at INFINITE width, so TextTrimming can never engage and
                                             the text paints over the amount), but this template needs a DIFFERENT
                                             remedy, because it serves the mirror-image profile:
                                               Particulars = "date + voucher type + no."  (the row IDENTITY)
                                               Secondary   = the COUNTER-LEDGER            (unbounded — and it is real
                                                             accounting information, the contra account, not a tag).
                                             BOTH must stay readable, and NEITHER may be spent to save the other:
                                               - one trimmed run (leftmost priority, as used above) ellipsises the
                                                 counter-ledger away entirely;
                                               - an inner "Auto,*" split fails too. MEASURED, not assumed: this cell is
                                                 only 198px wide (the 130+130+140 amount columns take 400px of the
                                                 638px pane), while the identity alone needs 186px and even a TYPICAL
                                                 row needs 165+8+81 = 254px. The Auto side then starves its sibling to
                                                 4px — the render showed the counter-ledger simply GONE. "Bounded" is
                                                 relative: 186px is not bounded inside 198px.
                                             198px cannot hold both side-by-side at any split, so stack them instead:
                                             each line gets the FULL cell width. The identity fits outright and the
                                             counter-ledger trims from ~75% of its length — both readable. Row height
                                             24 -> 34 pays for the second line. -->
                                        <Grid Grid.Column="0" RowDefinitions="Auto,Auto"
                                              VerticalAlignment="Center" Margin="8,0">
                                          <TextBlock Grid.Row="0" Text="{Binding Particulars}" FontSize="12.5"
                                                     FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Row="1" Text="{Binding Secondary}" FontSize="10.5"
                                                     Foreground="#8A8A8A" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <TextBlock Grid.Column="1" Text="{Binding Debit}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Credit}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Amount}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: RQ-7 Voucher Detail drill (read-only leaf) -->
                    <ContentControl IsVisible="{Binding VoucherDetail, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding VoucherDetail}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:VoucherDetailViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10" Spacing="3">
                              <TextBlock Text="{Binding Subtitle}"
                                         FontSize="12" Foreground="#555555" HorizontalAlignment="Center"/>
                              <!-- Document label: "Bill of Supply" for a composition sale, "Tax Invoice" for a
                                   Regular Sales item-invoice (Phase 9 slice 3; RQ-10). Empty for a plain voucher. -->
                              <Border IsVisible="{Binding DocumentLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                      Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      CornerRadius="3" Padding="10,2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DocumentLabel}" FontSize="11.5" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                              </Border>
                              <TextBlock Text="{Binding BillOfSupplyDeclaration}"
                                         IsVisible="{Binding BillOfSupplyDeclaration, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         FontSize="11" FontStyle="Italic" Foreground="#777777"
                                         HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="440"/>
                            </StackPanel>
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,150,150">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Debit" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Credit" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Background="Transparent">
                                      <Grid ColumnDefinitions="*,150,150" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Particulars}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Debit}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Credit}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Voucher entry (Contra/Payment/Receipt/Journal/Sales/Purchase) -->
                    <ContentControl IsVisible="{Binding Voucher, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Voucher}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:VoucherEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="4">

                            <!-- Header: type + auto number + date on the top line; optional/post-dated/item
                                 toggles on their own line below so nothing overprints in a narrow pane. -->
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}" Padding="10,6">
                              <Grid RowDefinitions="Auto,Auto">
                                <!-- Top line: type + No. (left) and the date (right). -->
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto">
                                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                              VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TypeName}"
                                               Foreground="White" FontWeight="Bold" FontSize="15"
                                               VerticalAlignment="Center"/>
                                    <!-- Provisional-kind badge (Memorandum / Reversing Journal): off-books entry. -->
                                    <Border IsVisible="{Binding IsProvisionalType}"
                                            Background="#3E5C8A" CornerRadius="3" Padding="6,1"
                                            VerticalAlignment="Center">
                                      <TextBlock Text="Provisional — off books" Foreground="#EAF1FF" FontSize="10"/>
                                    </Border>
                                  </StackPanel>
                                  <TextBlock Grid.Column="1" Foreground="#CFE0FF" FontSize="12"
                                             VerticalAlignment="Center" Margin="16,0,0,0">
                                    <Run Text="No. "/><Run Text="{Binding VoucherNumber}"/>
                                  </TextBlock>
                                  <TextBox Grid.Column="3" Width="140"
                                           Text="{Binding DateText, Mode=TwoWay}"
                                           FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Toggle line: evenly spaced (Spacing=16) so captions never overprint. -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="0,6,0,0">
                                  <!-- Item-Invoice toggle (Ctrl+I) — only on a Purchase/Sales voucher. -->
                                  <CheckBox IsVisible="{Binding CanBeItemInvoice}"
                                            Content="Item Invoice (Ctrl+I)"
                                            IsChecked="{Binding IsItemInvoice, Mode=TwoWay}"
                                            Foreground="#CFE0FF" FontSize="11"
                                            VerticalAlignment="Center"/>
                                  <!-- Optional (Ctrl+L): hidden for a provisional type (already off-books). -->
                                  <CheckBox Content="Optional (Ctrl+L)"
                                            IsChecked="{Binding IsOptional, Mode=TwoWay}"
                                            IsVisible="{Binding !IsProvisionalType}"
                                            Foreground="#CFE0FF" FontSize="11"
                                            VerticalAlignment="Center"/>
                                  <CheckBox Content="Post-Dated (Ctrl+T)"
                                            IsChecked="{Binding IsPostDated, Mode=TwoWay}"
                                            IsVisible="{Binding !IsProvisionalType}"
                                            Foreground="#CFE0FF" FontSize="11"
                                            VerticalAlignment="Center"/>
                                  <!-- Applicable Upto (Reversing Journal only). -->
                                  <StackPanel Orientation="Horizontal" Spacing="6"
                                              IsVisible="{Binding IsReversing}"
                                              VerticalAlignment="Center">
                                    <TextBlock Text="Applicable Upto" Foreground="#CFE0FF" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBox Width="130" Text="{Binding ApplicableUptoText, Mode=TwoWay}"
                                             FontSize="12" VerticalAlignment="Center"
                                             PlaceholderText="dd-MMM-yyyy"/>
                                  </StackPanel>
                                </StackPanel>
                              </Grid>
                            </Border>

                            <!-- Column header band -->
                            <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Margin="0,6,0,0"
                                    IsVisible="{Binding !IsItemInvoice}">
                              <Grid ColumnDefinitions="*,90,160,40">
                                <TextBlock Grid.Column="0" Text="Particulars (Ledger)" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Dr/Cr" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="2" Text="" />

                            <!-- Particulars grid: Dr/Cr lines.
                                 MinHeight is load-bearing: this ScrollViewer sits in the template's ONLY '*' row while
                                 the GST panels stack in the trailing Auto row below, so two panels showing at once
                                 (e.g. TDS + RCM on a Purchase) starved the '*' row to a ~15px sliver and voucher entry
                                 became unusable. The floor keeps ~3 rows of grid visible no matter how many panels are
                                 on screen; the panels get their own bounded scroll region instead of taking it. -->
                            <ScrollViewer Grid.Row="3" Background="White" VerticalScrollBarVisibility="Auto"
                                          MinHeight="140"
                                          IsVisible="{Binding !IsItemInvoice}">
                              <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:VoucherLineViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Padding="6,4">
                                      <StackPanel Spacing="0">
                                        <Grid ColumnDefinitions="*,90,160,40">
                                          <ComboBox Grid.Column="0" MinWidth="200"
                                                    HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding Ledgers}"
                                                    SelectedItem="{Binding SelectedLedger, Mode=TwoWay}"
                                                    PlaceholderText="Select ledger…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Ledger">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Margin="6,0" Width="80"
                                                    ItemsSource="{Binding Sides}"
                                                    SelectedItem="{Binding Side, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource DrCrLabel}}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Width="150"
                                                   Text="{Binding AmountText, Mode=TwoWay}"
                                                   TextAlignment="Right"
                                                   PlaceholderText="0.00"/>
                                        </Grid>

                                        <!-- Bill-wise Details sub-panel (only for a bill-by-bill ledger) -->
                                        <Border IsVisible="{Binding IsBillWise}"
                                                Background="#F4F7FB"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Bill-wise Details"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <!-- Allocation column header -->
                                            <Grid ColumnDefinitions="130,*,120,120">
                                              <TextBlock Grid.Column="0" Text="Type of Ref" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Name" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Due Date" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="3" Text="Amount" FontSize="10.5"
                                                         Foreground="#6A6A6A" TextAlignment="Right"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding BillAllocations}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:BillAllocationRowViewModel">
                                                  <Grid ColumnDefinitions="130,*,120,120" Margin="0,1">
                                                    <ComboBox Grid.Column="0" Width="124"
                                                              ItemsSource="{Binding RefTypes}"
                                                              SelectedItem="{Binding RefType, Mode=TwoWay}"
                                                              FontSize="11">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                          <TextBlock Text="{Binding Converter={StaticResource BillRefLabel}}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="1" Margin="4,0,0,0"
                                                             Text="{Binding Name, Mode=TwoWay}"
                                                             FontSize="11" PlaceholderText="Bill ref…"/>
                                                    <TextBox Grid.Column="2" Width="114" Margin="4,0,0,0"
                                                             Text="{Binding DueDateText, Mode=TwoWay}"
                                                             FontSize="11" PlaceholderText="dd-MMM-yyyy"/>
                                                    <TextBox Grid.Column="3" Width="114"
                                                             Text="{Binding AmountText, Mode=TwoWay}"
                                                             FontSize="11" TextAlignment="Right"
                                                             PlaceholderText="0.00"/>
                                                  </Grid>
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="Auto,*">
                                              <Button Grid.Column="0" Content="+ Add bill"
                                                      FontSize="10.5" Padding="8,2"
                                                      Background="{StaticResource Panel}"
                                                      Click="OnAddBillAllocationClick"
                                                      CommandParameter="{Binding}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding BillSummary}"
                                                         FontSize="10.5" Foreground="#555555"
                                                         VerticalAlignment="Center" TextAlignment="Right"
                                                         Margin="8,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>

                                        <!-- Cost Allocation sub-panel (only for a cost-applicable ledger
                                             when the company has cost centres) -->
                                        <Border IsVisible="{Binding IsCostApplicable}"
                                                Background="#F3FBF4"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Cost Allocation"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <!-- Allocation column header -->
                                            <Grid ColumnDefinitions="*,*,120">
                                              <TextBlock Grid.Column="0" Text="Category" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Cost Centre" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Amount" FontSize="10.5"
                                                         Foreground="#6A6A6A" TextAlignment="Right"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding CostAllocations}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CostAllocationRowViewModel">
                                                  <Grid ColumnDefinitions="*,*,120" Margin="0,1">
                                                    <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding Categories}"
                                                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                                              FontSize="11" PlaceholderText="Category…">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="ledger:CostCategory">
                                                          <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <ComboBox Grid.Column="1" Margin="4,0,0,0"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding Centres}"
                                                              SelectedItem="{Binding SelectedCentre, Mode=TwoWay}"
                                                              FontSize="11" PlaceholderText="Centre…">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="ledger:CostCentre">
                                                          <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="2" Width="114"
                                                             Text="{Binding AmountText, Mode=TwoWay}"
                                                             FontSize="11" TextAlignment="Right"
                                                             PlaceholderText="0.00"/>
                                                  </Grid>
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="Auto,*">
                                              <Button Grid.Column="0" Content="+ Add centre"
                                                      FontSize="10.5" Padding="8,2"
                                                      Background="{StaticResource Panel}"
                                                      Click="OnAddCostAllocationClick"
                                                      CommandParameter="{Binding}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding CostSummary}"
                                                         FontSize="10.5" Foreground="#555555"
                                                         VerticalAlignment="Center" TextAlignment="Right"
                                                         Margin="8,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>

                                        <!-- Bank Allocation sub-panel (only for a bank-account ledger) -->
                                        <Border IsVisible="{Binding IsBankLine}"
                                                Background="#EEF4FB"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Bank Allocation"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <Grid ColumnDefinitions="150,*,140">
                                              <TextBlock Grid.Column="0" Text="Transaction Type" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Instrument No." FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Instrument Date" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="150,*,140">
                                              <ComboBox Grid.Column="0" Width="144"
                                                        ItemsSource="{Binding BankTransactionTypes}"
                                                        SelectedItem="{Binding BankTransactionType, Mode=TwoWay}"
                                                        FontSize="11">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource BankTxTypeLabel}}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="1" Margin="4,0,0,0"
                                                       Text="{Binding InstrumentNumber, Mode=TwoWay}"
                                                       FontSize="11" PlaceholderText="Cheque / UTR / ref…"/>
                                              <TextBox Grid.Column="2" Width="134" Margin="4,0,0,0"
                                                       Text="{Binding InstrumentDateText, Mode=TwoWay}"
                                                       FontSize="11" PlaceholderText="dd-MMM-yyyy"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>

                                        <!-- Forex Details sub-panel (only for a foreign-currency ledger) -->
                                        <Border IsVisible="{Binding IsForexLine}"
                                                Background="#FBF1E9"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                              <TextBlock Text="Forex Details"
                                                         FontWeight="SemiBold" FontSize="11"
                                                         Foreground="{StaticResource BrandNavy}"/>
                                              <TextBlock Text="{Binding ForexCurrencyCode}"
                                                         FontSize="10.5" Foreground="#6A6A6A"
                                                         VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Grid ColumnDefinitions="150,150,*">
                                              <TextBlock Grid.Column="0" Text="Amount in Forex" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Rate of Exchange" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Amount in ₹ (forex × rate)" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0" TextAlignment="Right"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="150,150,*">
                                              <Grid Grid.Column="0" ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{Binding ForexSymbol}"
                                                           FontSize="11" Foreground="#6A6A6A"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding ForexAmountText, Mode=TwoWay}"
                                                         FontSize="11" TextAlignment="Right"
                                                         PlaceholderText="0.00"/>
                                              </Grid>
                                              <TextBox Grid.Column="1" Width="140" Margin="4,0,0,0"
                                                       Text="{Binding ForexRateText, Mode=TwoWay}"
                                                       FontSize="11" TextAlignment="Right"
                                                       PlaceholderText="e.g. 83.25"/>
                                              <TextBlock Grid.Column="2" Text="{Binding ForexBaseText}"
                                                         FontSize="12" FontWeight="SemiBold"
                                                         Foreground="{StaticResource BrandNavy}"
                                                         TextAlignment="Right" VerticalAlignment="Center"
                                                         Margin="4,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Add-line -->
                            <Button Grid.Row="4" Content="+ Add line" HorizontalAlignment="Left"
                                    Margin="0,6" Padding="10,4"
                                    Background="{StaticResource Panel}"
                                    IsVisible="{Binding !IsItemInvoice}"
                                    Click="OnAddVoucherLineClick"/>

                            <!-- Live balance indicator -->
                            <Border Grid.Row="5" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2"
                                    IsVisible="{Binding !IsItemInvoice}">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto,40">
                                <TextBlock Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center">
                                  <Run Text="Difference: "/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding DifferenceText}"
                                           VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="{Binding !IsBalanced, Converter={StaticResource BoolWeight}}"
                                           Foreground="{Binding IsBalanced, Converter={StaticResource BalancedBrush}}"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0" FontSize="12">
                                  <Run Text="Dr "/><Run Text="{Binding TotalDebitText}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="12,0" FontSize="12">
                                  <Run Text="Cr "/><Run Text="{Binding TotalCreditText}"/>
                                </TextBlock>
                              </Grid>
                            </Border>

                            <!-- ITEM-INVOICE MODE (Ctrl+I) — party + inventory lines; the accounting legs are
                                 auto-derived so the pairing invariant always holds (no hand-balancing). -->
                            <Grid Grid.Row="1" Grid.RowSpan="5" IsVisible="{Binding IsItemInvoice}"
                                  RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,6,0,0">

                              <!-- Party (supplier/customer) + value ledger band -->
                              <Border Grid.Row="0" Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                      Padding="10,6">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding PartyCaption}" FontWeight="SemiBold"
                                             Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Parties}"
                                            SelectedItem="{Binding SelectedParty, Mode=TwoWay}"
                                            PlaceholderText="Select party…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PartyOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="{Binding StockLedgerCaption}" FontWeight="SemiBold"
                                             Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"
                                             Margin="16,0,8,0"/>
                                  <ComboBox Grid.Column="3" Width="220"
                                            ItemsSource="{Binding StockLedgers}"
                                            SelectedItem="{Binding SelectedStockLedger, Mode=TwoWay}"
                                            PlaceholderText="Value ledger…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Ledger">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <!-- Price Level header (slice 5; RQ-30) — Sales item-invoice + F11 flag on only
                                       (ShowPriceLevelSelector). Auto-fills each line's Rate/Discount from the resolver;
                                       an operator override sticks. A trailing gated column ⇒ byte-identical when off. -->
                                  <TextBlock Grid.Column="4" Text="Price Level" FontWeight="SemiBold"
                                             Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"
                                             Margin="16,0,8,0" IsVisible="{Binding ShowPriceLevelSelector}"/>
                                  <ComboBox Grid.Column="5" Width="180"
                                            IsVisible="{Binding ShowPriceLevelSelector}"
                                            ItemsSource="{Binding PriceLevelOptions}"
                                            SelectedItem="{Binding SelectedPriceLevel, Mode=TwoWay}"
                                            PlaceholderText="Price level…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PriceLevelSelectorOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                              </Border>

                              <!-- Item-lines column header band. Stock Item stays the flexible star; the
                                   page pane is now wide (C4/C5 fluid), so Godown (184) fits a real godown
                                   name like "Main Location" past the chevron (D-2) and the Batch/Lot header
                                   (92) shows in
                                   full (D-1). Numeric Qty (84) / Rate (72) columns are left untouched. -->
                              <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Margin="0,6,0,0">
                                <Grid ColumnDefinitions="*,184,84,Auto,72,92,36,Auto,Auto,Auto">
                                  <TextBlock Grid.Column="0" Text="Stock Item" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Godown" Classes="colHdr"/>
                                  <!-- Quantity header relabels to "Qty (Actual)" when the Actual/Billed split is on. -->
                                  <TextBlock Grid.Column="2" Text="{Binding QuantityHeader}" Classes="colHdr" TextAlignment="Right"/>
                                  <!-- Billed-quantity column — shown only when the company "Use separate Actual &amp; Billed
                                       Qty" flag is on (Sales/Purchase item-invoice only). Value + GST derive from Billed. -->
                                  <TextBlock Grid.Column="3" Text="Qty (Billed)" Classes="colHdr" TextAlignment="Right"
                                             Width="78" Margin="6,0,0,0"
                                             IsVisible="{Binding ShowActualBilledColumns}"/>
                                  <TextBlock Grid.Column="4" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="5" Text="Batch/Lot" Classes="colHdr"/>
                                  <TextBlock Grid.Column="6" Text="" Classes="colHdr"/>
                                  <!-- Landed (effective) rate/value columns — shown only when additional costs are tracked. -->
                                  <TextBlock Grid.Column="7" Text="Landed Rate" Classes="colHdr" TextAlignment="Right"
                                             Width="90" IsVisible="{Binding ShowAdditionalCosts}"/>
                                  <TextBlock Grid.Column="8" Text="Landed Value" Classes="colHdr" TextAlignment="Right"
                                             Width="96" IsVisible="{Binding ShowAdditionalCosts}"/>
                                  <!-- Price-Level Discount % column (slice 5; RQ-30) — Sales + F11 flag only. A trailing
                                       gated column ⇒ byte-identical when off (ER-13). -->
                                  <TextBlock Grid.Column="9" Text="Disc %" Classes="colHdr" TextAlignment="Right"
                                             Width="60" IsVisible="{Binding ShowPriceLevelSelector}"/>
                                </Grid>
                              </Border>

                              <!-- Item lines grid (reuses the stock-voucher inventory-line UX) -->
                              <ScrollViewer Grid.Row="2" Background="White" VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="0">
                                  <ItemsControl ItemsSource="{Binding InventoryLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:InventoryVoucherLineViewModel">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Padding="6,4">
                                          <Grid ColumnDefinitions="*,184,84,Auto,72,92,36,Auto,Auto,Auto">
                                            <ComboBox Grid.Column="0" Classes="gridCombo"
                                                      MinWidth="0" HorizontalAlignment="Stretch"
                                                      HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                      ItemsSource="{Binding StockItems}"
                                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                      PlaceholderText="Select item…">
                                              <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="ledger:StockItem">
                                                  <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                              </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Column="1" Classes="gridCombo"
                                                      HorizontalAlignment="Stretch" Margin="6,0"
                                                      HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                      ItemsSource="{Binding Godowns}"
                                                      SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                                      PlaceholderText="Godown…">
                                              <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="ledger:Godown">
                                                  <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                              </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <!-- Actual (stock) quantity. -->
                                            <TextBox Grid.Column="2" Width="78"
                                                     Text="{Binding QuantityText, Mode=TwoWay}"
                                                     TextAlignment="Right" PlaceholderText="0"/>
                                            <!-- Billed (accounts/GST) quantity — shown only when the company A/B flag is
                                                 on (ShowActualBilled). Blank ⇒ Billed defaults to Actual (RQ-22/25). -->
                                            <TextBox Grid.Column="3" Width="78" Margin="6,0,0,0"
                                                     Text="{Binding BilledQuantityText, Mode=TwoWay}"
                                                     TextAlignment="Right" PlaceholderText="= Actual"
                                                     IsVisible="{Binding ShowActualBilled}"/>
                                            <TextBox Grid.Column="4" Width="64" Margin="6,0"
                                                     Text="{Binding RateText, Mode=TwoWay}"
                                                     TextAlignment="Right" PlaceholderText="0.00"/>
                                            <TextBox Grid.Column="5" Width="84" HorizontalAlignment="Left"
                                                     Text="{Binding BatchLabel, Mode=TwoWay}"
                                                     PlaceholderText="—"/>
                                            <!-- Read-only landed (effective) rate + value from the apportionment engine
                                                 (ER-4). Auto columns collapse to 0 when ShowLanded is off. -->
                                            <TextBlock Grid.Column="7" Width="90" Margin="6,0,0,0"
                                                       Text="{Binding LandedRateText}" TextAlignment="Right"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandNavy}"
                                                       IsVisible="{Binding ShowLanded}"/>
                                            <TextBlock Grid.Column="8" Width="96" Margin="6,0,0,0"
                                                       Text="{Binding LandedValueText}" TextAlignment="Right"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandNavy}"
                                                       IsVisible="{Binding ShowLanded}"/>
                                            <!-- Price-Level Discount % (slice 5; RQ-30) — auto-filled from the resolver,
                                                 operator-overridable; only shown on a Sales price-level line (ShowDiscount). -->
                                            <TextBox Grid.Column="9" Width="56" Margin="6,0,0,0"
                                                     Text="{Binding DiscountText, Mode=TwoWay}"
                                                     TextAlignment="Right" PlaceholderText="0"
                                                     IsVisible="{Binding ShowDiscount}"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>

                                  <Button Content="+ Add item" HorizontalAlignment="Left"
                                          Margin="0,6" Padding="10,4"
                                          Background="{StaticResource Panel}"
                                          Click="OnAddItemInvoiceLineClick"/>

                                  <!-- Voucher-type editor affordance (Book pp.133–141): "Track Additional Costs for
                                       Purchases" — a Purchase voucher-type flag; on ⇒ the additional-cost area shows. -->
                                  <CheckBox Content="Track Additional Costs for Purchases"
                                            IsChecked="{Binding TrackAdditionalCosts, Mode=TwoWay}"
                                            IsVisible="{Binding CanTrackAdditionalCosts}"
                                            FontSize="12.5" FontWeight="SemiBold" Margin="0,2,0,0"
                                            Foreground="{StaticResource BrandNavy}"/>

                                  <!-- Company feature (Book pp.145–147): "Use separate Actual & Billed Quantity columns
                                       in invoices" — Sales/Purchase item-invoice only. On ⇒ a Billed-qty column shows;
                                       stock moves on Actual, accounts/GST on Billed. -->
                                  <CheckBox Content="Use separate Actual &amp; Billed Quantity columns in invoices"
                                            IsChecked="{Binding UseSeparateActualBilledQuantity, Mode=TwoWay}"
                                            IsVisible="{Binding CanUseSeparateActualBilled}"
                                            FontSize="12.5" FontWeight="SemiBold" Margin="0,2,0,0"
                                            Foreground="{StaticResource BrandNavy}"/>

                                  <!-- Voucher-type flag (Book pp.142–143): "Allow zero-valued transactions" — on ⇒ a
                                       ₹0 free-goods line is accepted (moves stock, posts ₹0). Sales/Purchase only. -->
                                  <CheckBox Content="Allow zero-valued transactions"
                                            IsChecked="{Binding AllowZeroValued, Mode=TwoWay}"
                                            IsVisible="{Binding CanAllowZeroValued}"
                                            FontSize="12.5" FontWeight="SemiBold" Margin="0,2,0,0"
                                            Foreground="{StaticResource BrandNavy}"/>

                                  <!-- Additional-cost entry area (shown only when tracking is on). Each row picks an
                                       additional-cost ledger (a Direct-Expenses ledger with a Method of Appropriation)
                                       + an amount; the amount posts its own Dr (P&L) AND loads the item landed rate. -->
                                  <Border IsVisible="{Binding ShowAdditionalCosts}"
                                          Background="#FBF7EE" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10,8" Margin="0,4,0,0">
                                    <StackPanel Spacing="6">
                                      <TextBlock Text="Additional Cost of Purchase" FontWeight="Bold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ItemsControl ItemsSource="{Binding AdditionalCosts}">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="vm:AdditionalCostRowViewModel">
                                            <Grid ColumnDefinitions="*,120" Margin="0,0,0,4">
                                              <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                                        ItemsSource="{Binding AdditionalCostLedgers}"
                                                        SelectedItem="{Binding SelectedLedger, Mode=TwoWay}"
                                                        PlaceholderText="Additional-cost ledger…">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate x:DataType="ledger:Ledger">
                                                    <TextBlock Text="{Binding Name}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="1"
                                                       Text="{Binding AmountText, Mode=TwoWay}"
                                                       TextAlignment="Right" PlaceholderText="0.00"/>
                                            </Grid>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                      <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Button Grid.Column="0" Content="+ Add cost" Padding="10,4"
                                                Background="{StaticResource Panel}"
                                                Click="OnAddAdditionalCostClick"/>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold"
                                                   FontSize="12.5" Foreground="{StaticResource BrandNavy}">
                                          <Run Text="Additional ₹ "/><Run Text="{Binding AdditionalCostTotalText}"/>
                                        </TextBlock>
                                      </Grid>
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </ScrollViewer>

                              <!-- Items total + derived Dr/Cr summary. The derived string wraps (no ellipsis)
                                   so it can never clip; the authoritative GST numbers live in the band below. -->
                              <Border Grid.Row="3" Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="10,6" Margin="0,2">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                  <TextBlock Grid.Column="0" Text="Derived:" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <TextBlock Grid.Column="1" Text="{Binding DerivedSummary}"
                                             VerticalAlignment="Center" TextWrapping="Wrap"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold"
                                             FontSize="13" Foreground="{StaticResource BrandNavy}" Margin="8,0,0,0">
                                    <Run Text="Items Total ₹ "/><Run Text="{Binding ItemsTotalText}"/>
                                  </TextBlock>
                                </Grid>
                              </Border>

                              <!-- GST summary band (shown only when GST is on — IsGstInvoice). Carries the
                                   authoritative tax breakdown (CGST/SGST/IGST) + the party total so nothing
                                   is lost to ellipsis in the Derived line at any report/voucher-pane width. -->
                              <Border Grid.Row="4" IsVisible="{Binding IsGstInvoice}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                      Padding="10,6" Margin="0,2,0,0">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="GST Summary" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <Grid ColumnDefinitions="*,Auto,24,*,Auto">
                                    <!-- Left column: Taxable + CGST -->
                                    <TextBlock Grid.Column="0" Text="Taxable Value ₹" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ItemsTotalText}" TextAlignment="Right"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="3" Text="CGST ₹" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding GstCgstText}" TextAlignment="Right"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="*,Auto,24,*,Auto">
                                    <!-- Right pair: SGST + IGST -->
                                    <TextBlock Grid.Column="0" Text="SGST ₹" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GstSgstText}" TextAlignment="Right"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="3" Text="IGST ₹" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding GstIgstText}" TextAlignment="Right"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </Grid>
                                  <!-- Compensation Cess (Phase 9 slice 1) — ring-fenced beside the GST heads; reads
                                       0.00 for a company that bears no cess (byte-identical when advanced-GST off). -->
                                  <Grid ColumnDefinitions="*,Auto,24,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Compensation Cess ₹" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GstCessText}" TextAlignment="Right"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </Grid>
                                  <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                          Padding="0,4,0,0" Margin="0,2,0,0">
                                    <Grid ColumnDefinitions="*,Auto">
                                      <TextBlock Grid.Column="0" Text="Party Total (Taxable + Tax + Cess) ₹"
                                                 FontWeight="Bold" VerticalAlignment="Center"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBlock Grid.Column="1" Text="{Binding PartyTotalText}" TextAlignment="Right"
                                                 FontWeight="Bold" FontSize="14" VerticalAlignment="Center"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                    </Grid>
                                  </Border>
                                </StackPanel>
                              </Border>
                            </Grid>

                            <!-- Narration + accept row + message -->
                            <StackPanel Grid.Row="6" Spacing="6" Margin="0,4,0,0">

                              <!-- The GST/TDS advisory panels live in their own bounded, scrollable region. Several can
                                   be on screen at once (TDS + RCM on a Purchase; §34 + advance on a note), and stacking
                                   them straight into this Auto row let them grow without limit and squeeze the lines
                                   grid in the '*' row above down to nothing. Capped here and scrolled internally, they
                                   can never crowd out voucher entry — and the narration + Accept row below stay put. -->
                              <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                <StackPanel Spacing="6">

                              <!-- TDS withholding panel (Phase 7 slice 2) — shown only when a deductee party +
                                   expense line are on a TDS-enabled Payment/Journal/Purchase (ShowTdsPanel). The
                                   figures come from the SAME engine the posting uses (ER-4); off ⇒ byte-identical. -->
                              <Border IsVisible="{Binding ShowTdsPanel}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="10,8" Margin="0,0,0,2">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,220,*,Auto">
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="TDS — Nature of Payment"
                                             FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                  <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding TdsNatureOptions}"
                                            SelectedItem="{Binding SelectedTdsNature, Mode=TwoWay}"
                                            PlaceholderText="Select TDS section…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:NatureOfPayment">
                                        <TextBlock>
                                          <Run Text="{Binding SectionCode}"/><Run Text=" — "/><Run Text="{Binding Name}"/>
                                        </TextBlock>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" Spacing="18"
                                              VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5">
                                      <Run Text="Rate "/><Run Text="{Binding TdsRateText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5">
                                      <Run Text="TDS ₹ "/><Run Text="{Binding TdsAmountText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5">
                                      <Run Text="Net payable ₹ "/><Run Text="{Binding TdsNetPayableText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                  </StackPanel>
                                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                             Text="{Binding TdsSummary}" Margin="0,6,0,0"
                                             FontSize="11.5" Foreground="{StaticResource BrandNavy}"
                                             TextWrapping="Wrap"/>
                                </Grid>
                              </Border>

                              <!-- RCM inward-supply panel (Phase 9 slice 2; RQ-3/RQ-7/RQ-8/RQ-11) — shown only when a
                                   reverse-charge-flagged expense leg + a supplier leg are on a GST company's plain-grid
                                   Purchase/Journal (ShowRcmPanel). Applicability + the rate come from the SAME engine the
                                   posting uses (ER-4). The RCM liability is CASH-ONLY (§49(4)) — the summary says so.
                                   Off ⇒ the panel is hidden and the voucher posts byte-identically (ER-13). -->
                              <Border IsVisible="{Binding ShowRcmPanel}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                      Padding="10,8" Margin="0,0,0,2">
                                <!-- Layout note: the voucher pane is ~630px, so every row here must WRAP rather than
                                     commit to a fixed horizontal run. An Orientation="Horizontal" StackPanel measures its
                                     children at infinite width, so it silently clips whatever overflows — which is how the
                                     resolved figures and the Rule-47A toggle first went missing off the right edge. -->
                                <StackPanel Spacing="6">
                                  <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="Reverse charge — supply kind"
                                               FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding RcmSupplyKinds}"
                                              SelectedItem="{Binding SelectedRcmSupplyKind, Mode=TwoWay}"
                                              PlaceholderText="Select the inward-supply kind…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RcmSupplyKindOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>

                                  <!-- The recipient qualifiers Resolve needs: §9(4) fires ONLY for a promoter recipient
                                       (so the blanket §9(4) stays off by default), and body-corporate drives the GTA /
                                       security / motor-vehicle recipient qualifier — plus the Rule-47A / Rule-52 document
                                       toggles. A WrapPanel so a narrow pane wraps them instead of clipping them away. -->
                                  <WrapPanel>
                                    <CheckBox IsChecked="{Binding RcmRecipientIsPromoter, Mode=TwoWay}"
                                              Content="We are a promoter (§9(4))" FontSize="12" Margin="0,0,18,4"/>
                                    <CheckBox IsChecked="{Binding RcmRecipientIsBodyCorporate, Mode=TwoWay}"
                                              Content="We are a body corporate" FontSize="12" Margin="0,0,18,4"/>
                                    <CheckBox IsChecked="{Binding GenerateRcmSelfInvoice, Mode=TwoWay}"
                                              Content="Generate self-invoice (Rule 47A)" FontSize="12" Margin="0,0,18,4"/>
                                    <CheckBox IsChecked="{Binding GenerateRcmPaymentVoucher, Mode=TwoWay}"
                                              Content="Generate payment voucher (Rule 52)" FontSize="12" Margin="0,0,18,4"/>
                                  </WrapPanel>

                                  <WrapPanel>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,2"
                                               Text="{Binding RcmAppliesText}" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,2"
                                               Text="{Binding RcmPosText}"/>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,2">
                                      <Run Text="Rate "/><Run Text="{Binding RcmRateText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,2">
                                      <Run Text="RCM tax ₹ "/><Run Text="{Binding RcmTaxText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <!-- Compensation Cess gets its OWN figure: it is ring-fenced to its own head (ER-2)
                                         and folded into the RCM-tax headline above, so showing only the headline would
                                         leave the operator unable to see what the cess contributed. -->
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,2"
                                               IsVisible="{Binding ShowRcmCess}">
                                      <Run Text="of which Cess ₹ "/><Run Text="{Binding RcmCessText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                  </WrapPanel>

                                  <TextBlock Text="{Binding RcmCategoryText}" FontSize="11.5" TextWrapping="Wrap"/>

                                  <TextBlock Text="{Binding RcmSummary}"
                                             FontSize="11.5" Foreground="{StaticResource BrandNavy}"
                                             TextWrapping="Wrap"/>
                                </StackPanel>
                              </Border>

                              <!-- §34 credit/debit-note panel (Phase 9 slice 2b; RQ-24; ER-12) — shown on a Credit/Debit
                                   Note on a GST company. The §34 details are OPT-IN: off ⇒ no link record is created and
                                   the note posts exactly as before (ER-13). On ⇒ the original-invoice reference is
                                   mandatory (a §34 note is never free-floating) and the §34(2) 30-Nov cut-off applies.
                                   The cut-off itself comes from the engine (ER-4). -->
                              <Border IsVisible="{Binding CanBeSection34Note}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                      Padding="10,8" Margin="0,0,0,2">
                                <StackPanel Spacing="6">
                                  <CheckBox IsChecked="{Binding IsSection34Note, Mode=TwoWay}"
                                            Content="This is a §34 GST credit/debit note (link the original invoice)"
                                            FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                  <StackPanel IsVisible="{Binding ShowSection34Details}" Spacing="6">
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                                      <TextBlock Grid.Column="0" Text="Original invoice"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12.5"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding CdnOriginalInvoices}"
                                                SelectedItem="{Binding SelectedCdnOriginalInvoice, Mode=TwoWay}"
                                                PlaceholderText="Select the original invoice this note adjusts…">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:CdnOriginalInvoiceOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>

                                    <!-- Consolidated / unregistered reference (ER-12's second limb): no voucher link, so
                                         the original invoice number + date are typed. The DATE drives the §34(2) FY basis. -->
                                    <Grid IsVisible="{Binding ShowCdnConsolidatedFields}"
                                          ColumnDefinitions="Auto,*,Auto,160">
                                      <TextBlock Grid.Column="0" Text="Original invoice no."
                                                 VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12.5"/>
                                      <TextBox Grid.Column="1" Text="{Binding CdnOriginalInvoiceNumber, Mode=TwoWay}"
                                               PlaceholderText="e.g. INV-1042"/>
                                      <TextBlock Grid.Column="2" Text="Original date"
                                                 VerticalAlignment="Center" Margin="12,0,8,0" FontSize="12.5"/>
                                      <TextBox Grid.Column="3" Text="{Binding CdnOriginalInvoiceDateText, Mode=TwoWay}"
                                               PlaceholderText="dd-MMM-yyyy"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                      <TextBlock Grid.Column="0" Text="§34 reason"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12.5"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding CdnReasonCodes}"
                                                SelectedItem="{Binding SelectedCdnReasonCode, Mode=TwoWay}"
                                                PlaceholderText="Select the §34 reason…"/>
                                    </Grid>

                                    <!-- These two get their OWN wrapping row. Sharing a fixed horizontal row with the
                                         reason picker pushed the Override clean off the right edge — rendered, reachable
                                         to a binding probe (clipping is not invisibility), and yet invisible to the
                                         operator the §34(2) refusal tells to tick it. -->
                                    <WrapPanel>
                                      <CheckBox FontSize="12" Margin="0,0,18,4"
                                                IsChecked="{Binding CdnIs9BTarget, Mode=TwoWay}"
                                                Content="Registered party (GSTR-1 Table 9B)"/>
                                      <CheckBox FontSize="12" Margin="0,0,18,4"
                                                IsVisible="{Binding ShowCdnOverride}"
                                                IsChecked="{Binding CdnOverrideTimeLimit, Mode=TwoWay}"
                                                Content="Override §34(2) time limit"/>
                                    </WrapPanel>

                                    <TextBlock Text="{Binding CdnSummary}" FontSize="11.5"
                                               Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                  </StackPanel>
                                </StackPanel>
                              </Border>

                              <!-- GST advance-receipt panel (Phase 9 slice 2b; RQ-25; Rule 50) — shown on a Receipt on a
                                   GST company. Opt-in: off ⇒ no advance record, no tax pair, no suspense ledger, and an
                                   ordinary receipt posts exactly as before (ER-13). A SERVICE advance is taxed on receipt
                                   (§13 → GSTR-1 11A); a GOODS advance is de-taxed (Notn 66/2017). -->
                              <Border IsVisible="{Binding CanBeAdvanceReceipt}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                      Padding="10,8" Margin="0,0,0,2">
                                <StackPanel Spacing="6">
                                  <CheckBox IsChecked="{Binding IsAdvanceReceipt, Mode=TwoWay}"
                                            Content="This receipt is an advance against a future supply (GST — Rule 50)"
                                            FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                  <StackPanel IsVisible="{Binding ShowAdvanceReceiptDetails}" Spacing="6">
                                    <Grid ColumnDefinitions="Auto,*,Auto,80,Auto,70">
                                      <TextBlock Grid.Column="0" Text="Advance (ex-tax) ₹"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12.5"/>
                                      <TextBox Grid.Column="1" Text="{Binding AdvanceAmountText, Mode=TwoWay}"
                                               PlaceholderText="10000.00"/>
                                      <TextBlock Grid.Column="2" Text="Rate %"
                                                 VerticalAlignment="Center" Margin="12,0,8,0" FontSize="12.5"/>
                                      <TextBox Grid.Column="3" Text="{Binding AdvanceRateText, Mode=TwoWay}"
                                               PlaceholderText="18"/>
                                      <TextBlock Grid.Column="4" Text="POS state"
                                                 VerticalAlignment="Center" Margin="12,0,8,0" FontSize="12.5"/>
                                      <TextBox Grid.Column="5"
                                               Text="{Binding AdvancePlaceOfSupplyStateCode, Mode=TwoWay}"
                                               PlaceholderText="27"/>
                                    </Grid>

                                    <!-- The computed figures get their own wrapping row: sharing the input row clipped
                                         them off the right edge, hiding the very numbers this panel exists to show. -->
                                    <WrapPanel>
                                      <CheckBox IsChecked="{Binding AdvanceIsService, Mode=TwoWay}"
                                                Content="Service advance (a goods advance is de-taxed)"
                                                FontSize="12" Margin="0,0,18,4"/>
                                      <CheckBox IsChecked="{Binding AdvanceInterState, Mode=TwoWay}"
                                                Content="Inter-State (IGST)" FontSize="12" Margin="0,0,18,4"/>
                                      <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,4">
                                        <Run Text="Advance tax ₹ "/><Run Text="{Binding AdvanceTaxText}" FontWeight="SemiBold"/>
                                      </TextBlock>
                                      <TextBlock VerticalAlignment="Center" FontSize="12.5" Margin="0,0,18,4">
                                        <Run Text="Gross ₹ "/><Run Text="{Binding AdvanceGrossText}" FontWeight="SemiBold"/>
                                      </TextBlock>
                                    </WrapPanel>

                                    <TextBlock Text="{Binding AdvanceSummary}" FontSize="11.5"
                                               Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                  </StackPanel>
                                </StackPanel>
                              </Border>

                              <!-- GST advance adjust/refund panel (Phase 9 slice 2b; RQ-25 → GSTR-1 11B; Rule 51) —
                                   shown on a Journal (adjust against the tax invoice) or a Payment (refund) when an
                                   OUTSTANDING advance exists. An already-adjusted/refunded advance is never offered.
                                   A company that never books an advance never sees this panel (ER-13). -->
                              <Border IsVisible="{Binding ShowAdvanceActionPanel}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                      Padding="10,8" Margin="0,0,0,2">
                                <StackPanel Spacing="6">
                                  <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="GST advance"
                                               FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding OutstandingAdvances}"
                                              SelectedItem="{Binding SelectedOutstandingAdvance, Mode=TwoWay}"
                                              PlaceholderText="Select the outstanding advance…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AdvanceReceiptOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>

                                  <Grid IsVisible="{Binding ShowAdvanceInvoicePicker}" ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="Against invoice"
                                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12.5"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding AdvanceInvoices}"
                                              SelectedItem="{Binding SelectedAdvanceInvoice, Mode=TwoWay}"
                                              PlaceholderText="Select the tax invoice the advance is adjusted against…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AdvanceInvoiceOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>

                                  <TextBlock Text="{Binding AdvanceActionSummary}" FontSize="11.5"
                                             Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                </StackPanel>
                              </Border>

                              <!-- TCS collection band (Phase 7 slice 5) — shown only on a TCS-enabled Sales item
                                   invoice to a collectee party carrying a §206C-applicable stock item / sales ledger
                                   (ShowTcs). TCS is ADDITIVE (collected on top → the party total already includes it);
                                   the figures come from the SAME engine the posting uses (ER-4). Off ⇒ byte-identical. -->
                              <Border IsVisible="{Binding ShowTcs}"
                                      Background="{StaticResource Cream}"
                                      BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                      Padding="10,8" Margin="0,0,0,2">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="TCS — Nature of Goods (§206C)"
                                             FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                  <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="18"
                                              VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5">
                                      <Run Text="Collection code "/><Run Text="{Binding TcsCollectionCodeText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5">
                                      <Run Text="Rate "/><Run Text="{Binding TcsRateText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock VerticalAlignment="Center" FontSize="12.5">
                                      <Run Text="TCS ₹ "/><Run Text="{Binding TcsAmountText}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                  </StackPanel>
                                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                             Text="{Binding TcsSummary}" Margin="0,6,0,0"
                                             FontSize="11.5" Foreground="{StaticResource BrandNavy}"
                                             TextWrapping="Wrap"/>
                                </Grid>
                              </Border>

                                </StackPanel>
                              </ScrollViewer>

                              <TextBox Text="{Binding Narration, Mode=TwoWay}"
                                       PlaceholderText="Narration…" AcceptsReturn="False"/>
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Content="Cancel (Esc)" Margin="0,0,8,0" Padding="12,6"
                                        Click="OnCancelVoucherClick"/>
                                <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                        IsEnabled="{Binding CanAccept}"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnAcceptVoucherClick"/>
                              </Grid>
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Inventory / order voucher entry (PO/SO, GRN, Delivery, Rejection In/Out,
                         Stock Journal, Physical Stock) — posts the separate InventoryVoucher aggregate. -->
                    <ContentControl IsVisible="{Binding InventoryVoucher, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding InventoryVoucher}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:InventoryVoucherEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="4">

                            <!-- Header: type + auto number + post-dated toggle + date -->
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}" Padding="10,6">
                              <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding TypeName}"
                                           Foreground="White" FontWeight="Bold" FontSize="15"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Foreground="#CFE0FF" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,18,0">
                                  <Run Text="No. "/><Run Text="{Binding VoucherNumber}"/>
                                </TextBlock>
                                <CheckBox Grid.Column="2" Content="Post-Dated (Ctrl+T)"
                                          IsChecked="{Binding IsPostDated, Mode=TwoWay}"
                                          Foreground="#CFE0FF" FontSize="11"
                                          VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBox Grid.Column="3" Width="140"
                                         Text="{Binding DateText, Mode=TwoWay}"
                                         FontSize="12" VerticalAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Party (supplier/customer) picker + direction hint band -->
                            <Border Grid.Row="1" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                    Padding="10,6" Margin="0,4,0,0">
                              <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Party (PO/SO only) -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding IsOrder}" VerticalAlignment="Center">
                                  <TextBlock Text="Party" FontWeight="SemiBold"
                                             Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"/>
                                  <!-- C11: the pane fix does not reach this hardcoded picker (it sits in a
                                       horizontal StackPanel). Let it grow with the party name — floored so it
                                       never collapses, capped so it never crowds the direction hint — instead
                                       of a fixed 240px that ellipsized a party's state/GSTIN disambiguator. -->
                                  <ComboBox MinWidth="240" MaxWidth="420" ItemsSource="{Binding Parties}"
                                            SelectedItem="{Binding SelectedParty, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PartyOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </StackPanel>
                                <!-- Direction hint (movement notes) -->
                                <TextBlock Grid.Column="2" Text="{Binding DirectionHint}"
                                           IsVisible="{Binding DirectionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Primary lines column header band -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavyDark}" Margin="0,6,0,0">
                              <Grid ColumnDefinitions="*,152,84,88,86,36">
                                <TextBlock Grid.Column="0" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="{Binding QuantityHeader}" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Rate" Classes="colHdr" TextAlignment="Right"
                                           IsVisible="{Binding LinesShowRate}"/>
                                <TextBlock Grid.Column="4" Text="Batch/Lot" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <!-- "Source (consumed)" sub-caption for a Stock Journal -->
                            <TextBlock Grid.Row="3" Text="Source — consumed (outward)"
                                       IsVisible="{Binding IsStockJournal}"
                                       FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                       Margin="6,4,0,0"/>

                            <!-- Primary lines grid -->
                            <ScrollViewer Grid.Row="4" Background="White" VerticalScrollBarVisibility="Auto">
                              <StackPanel Spacing="0">
                                <ItemsControl ItemsSource="{Binding Lines}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InventoryVoucherLineViewModel">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                              Padding="6,4">
                                        <Grid ColumnDefinitions="*,152,84,88,86,36">
                                          <ComboBox Grid.Column="0" Classes="gridCombo"
                                                    MinWidth="0" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding StockItems}"
                                                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                    PlaceholderText="Select item…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:StockItem">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Classes="gridCombo" Width="146" Margin="6,0"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding Godowns}"
                                                    SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                                    PlaceholderText="Godown…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Godown">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Width="78"
                                                   Text="{Binding QuantityText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0"/>
                                          <TextBox Grid.Column="3" Width="80" Margin="6,0"
                                                   Text="{Binding RateText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0.00"
                                                   IsVisible="{Binding ShowsRate}"/>
                                          <TextBox Grid.Column="4" Width="84"
                                                   Text="{Binding BatchLabel, Mode=TwoWay}"
                                                   PlaceholderText="—"
                                                   IsVisible="{Binding ShowsBatch}"/>
                                          <!-- Batch-allocation sub-screen affordance (RQ-3): shown ONLY where the
                                               sub-screen applies — company flag on, item Maintains-in-Batches,
                                               godown + a positive qty (RQ-52 UI-leak fix). Opens the per-batch
                                               allocation column; Alt+B is the keyboard equivalent (NFR-2). -->
                                          <Button Grid.Column="5" Width="30" Padding="0" Content="⧉"
                                                  ToolTip.Tip="Allocate batches (Alt+B)"
                                                  IsVisible="{Binding WantsBatchAllocation}"
                                                  Click="OnOpenBatchAllocationClick"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="+ Add line" HorizontalAlignment="Left"
                                        Margin="0,6" Padding="10,4"
                                        Background="{StaticResource Panel}"
                                        Click="OnAddInventoryLineClick"/>

                                <!-- Stock Journal destination (produced/inward) list -->
                                <StackPanel Spacing="0" IsVisible="{Binding IsStockJournal}">
                                  <TextBlock Text="Destination — produced (inward)"
                                             FontSize="11" FontWeight="SemiBold"
                                             Foreground="{StaticResource BrandNavy}" Margin="6,6,0,2"/>
                                  <ItemsControl ItemsSource="{Binding DestinationLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:InventoryVoucherLineViewModel">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Padding="6,4">
                                          <Grid ColumnDefinitions="*,152,84,88,86,36,Auto,Auto">
                                            <ComboBox Grid.Column="0" Classes="gridCombo"
                                                      MinWidth="0" HorizontalAlignment="Stretch"
                                                      HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                      ItemsSource="{Binding StockItems}"
                                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                      PlaceholderText="Select item…">
                                              <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="ledger:StockItem">
                                                  <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                              </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Column="1" Classes="gridCombo" Width="146" Margin="6,0"
                                                      HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                      ItemsSource="{Binding Godowns}"
                                                      SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                                      PlaceholderText="Godown…">
                                              <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="ledger:Godown">
                                                  <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                              </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBox Grid.Column="2" Width="78"
                                                     Text="{Binding QuantityText, Mode=TwoWay}"
                                                     TextAlignment="Right" PlaceholderText="0"/>
                                            <TextBox Grid.Column="3" Width="80" Margin="6,0"
                                                     Text="{Binding RateText, Mode=TwoWay}"
                                                     TextAlignment="Right" PlaceholderText="0.00"
                                                     IsVisible="{Binding ShowsRate}"/>
                                            <TextBox Grid.Column="4" Width="84"
                                                     Text="{Binding BatchLabel, Mode=TwoWay}"
                                                     PlaceholderText="—"
                                                     IsVisible="{Binding ShowsBatch}"/>
                                            <!-- Read-only landed (effective) inward rate + value from the transfer
                                                 apportionment engine (ER-4/RQ-20). Collapse when ShowLanded is off. -->
                                            <TextBlock Grid.Column="6" Width="90" Margin="6,0,0,0"
                                                       Text="{Binding LandedRateText}" TextAlignment="Right"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandNavy}"
                                                       IsVisible="{Binding ShowLanded}"/>
                                            <TextBlock Grid.Column="7" Width="96" Margin="6,0,0,0"
                                                       Text="{Binding LandedValueText}" TextAlignment="Right"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandNavy}"
                                                       IsVisible="{Binding ShowLanded}"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Button Content="+ Add destination line" HorizontalAlignment="Left"
                                          Margin="0,6" Padding="10,4"
                                          Background="{StaticResource Panel}"
                                          Click="OnAddInventoryDestinationLineClick"/>

                                  <!-- Additional cost of a transfer (RQ-20): each row picks an additional-cost ledger
                                       + amount, apportioned onto the destination landed rate by the ledger's method. -->
                                  <Border IsVisible="{Binding ShowAdditionalCosts}"
                                          Background="#FBF7EE" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10,8" Margin="0,4,0,0">
                                    <StackPanel Spacing="6">
                                      <TextBlock Text="Additional Cost of Transfer" FontWeight="Bold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ItemsControl ItemsSource="{Binding AdditionalCosts}">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="vm:AdditionalCostRowViewModel">
                                            <Grid ColumnDefinitions="*,120" Margin="0,0,0,4">
                                              <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                                        ItemsSource="{Binding AdditionalCostLedgers}"
                                                        SelectedItem="{Binding SelectedLedger, Mode=TwoWay}"
                                                        PlaceholderText="Additional-cost ledger…">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate x:DataType="ledger:Ledger">
                                                    <TextBlock Text="{Binding Name}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="1"
                                                       Text="{Binding AmountText, Mode=TwoWay}"
                                                       TextAlignment="Right" PlaceholderText="0.00"/>
                                            </Grid>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                      <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Button Grid.Column="0" Content="+ Add cost" Padding="10,4"
                                                Background="{StaticResource Panel}"
                                                Click="OnAddTransferAdditionalCostClick"/>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold"
                                                   FontSize="12.5" Foreground="{StaticResource BrandNavy}">
                                          <Run Text="Additional ₹ "/><Run Text="{Binding AdditionalCostTotalText}"/>
                                        </TextBlock>
                                      </Grid>
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </StackPanel>
                            </ScrollViewer>

                            <!-- Stock-Journal balance indicator -->
                            <Border Grid.Row="5" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2"
                                    IsVisible="{Binding IsStockJournal}">
                              <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Balance:" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding BalanceText}"
                                           VerticalAlignment="Center" Margin="6,0"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="{Binding !IsBalanced, Converter={StaticResource BoolWeight}}"
                                           Foreground="{Binding IsBalanced, Converter={StaticResource BalancedBrush}}"/>
                              </Grid>
                            </Border>

                            <!-- Narration -->
                            <TextBox Grid.Row="6" Text="{Binding Narration, Mode=TwoWay}"
                                     PlaceholderText="Narration…" AcceptsReturn="False" Margin="0,4,0,0"/>

                            <!-- Accept row + message -->
                            <Grid Grid.Row="7" ColumnDefinitions="*,Auto,Auto" Margin="0,6,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource AlertRed}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                              <Button Grid.Column="1" Content="Cancel (Esc)" Margin="0,0,8,0" Padding="12,6"
                                      Click="OnCancelInventoryVoucherClick"/>
                              <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                      IsEnabled="{Binding CanAccept}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnAcceptInventoryVoucherClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Job Work In/Out Order entry (Phase 6 slice 8; RQ-47) -->
                    <ContentControl IsVisible="{Binding JobWorkOrderEntry, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding JobWorkOrderEntry}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:JobWorkOrderEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="4">

                            <!-- Header: type + auto number + date -->
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}" Padding="10,6">
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding TypeName}"
                                           Foreground="White" FontWeight="Bold" FontSize="15"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Foreground="#CFE0FF" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,18,0">
                                  <Run Text="No. "/><Run Text="{Binding VoucherNumber}"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Width="140"
                                         Text="{Binding DateText, Mode=TwoWay}"
                                         FontSize="12" VerticalAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Direction hint + party / order details -->
                            <Border Grid.Row="1" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                    Padding="10,6" Margin="0,4,0,0">
                              <StackPanel Spacing="6">
                                <TextBlock Text="{Binding DirectionHint}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="Auto,220,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Party" FontWeight="SemiBold" Margin="0,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Parties}"
                                            SelectedItem="{Binding SelectedParty, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PartyOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Order No." FontWeight="SemiBold" Margin="14,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding OrderNo, Mode=TwoWay}"
                                           PlaceholderText="e.g. DKP/789"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Duration" FontWeight="SemiBold" Margin="0,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding DurationOfProcess, Mode=TwoWay}"
                                           PlaceholderText="e.g. 30 days"/>
                                  <TextBlock Grid.Column="2" Text="Nature" FontWeight="SemiBold" Margin="14,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding NatureOfProcessing, Mode=TwoWay}"
                                           PlaceholderText="nature of processing"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Finished good + Tracking / Fill Components -->
                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                    Padding="10,6" Margin="0,2,0,0">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*,Auto,90,Auto,120">
                                  <TextBlock Grid.Column="0" Text="Finished Good" FontWeight="SemiBold" Margin="0,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding StockItems}"
                                            SelectedItem="{Binding FinishedGood, Mode=TwoWay}"
                                            PlaceholderText="Select item…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:StockItem">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Qty" FontWeight="SemiBold" Margin="12,0,6,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FinishedGoodQtyText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="0"/>
                                  <TextBlock Grid.Column="4" Text="Rate" FontWeight="SemiBold" Margin="12,0,6,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="5" Text="{Binding FinishedGoodRateText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="0.00"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,220,Auto,140,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Location" FontWeight="SemiBold" Margin="0,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Godowns}"
                                            SelectedItem="{Binding FinishedGoodGodown, Mode=TwoWay}"
                                            PlaceholderText="Godown…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Godown">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Due" FontWeight="SemiBold" Margin="12,0,6,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FinishedGoodDueText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                  <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                    <CheckBox Content="Tracking Components"
                                              IsChecked="{Binding TrackingComponents, Mode=TwoWay}"
                                              FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Fill using" FontWeight="SemiBold" Margin="8,0,4,0"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Width="220" ItemsSource="{Binding FillOptions}"
                                              SelectedItem="{Binding SelectedFill, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:JobWorkFillOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </StackPanel>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Component column header band -->
                            <Border Grid.Row="3" Background="{StaticResource BrandNavyDark}" Margin="0,6,0,0"
                                    IsVisible="{Binding TrackingComponents}">
                              <Grid ColumnDefinitions="*,150,150,90,90,110">
                                <TextBlock Grid.Column="0" Text="Component" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Track" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Due" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <!-- Component lines grid -->
                            <ScrollViewer Grid.Row="4" Background="White" VerticalScrollBarVisibility="Auto"
                                          IsVisible="{Binding TrackingComponents}">
                              <StackPanel Spacing="0">
                                <ItemsControl ItemsSource="{Binding Lines}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:JobWorkComponentLineViewModel">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                              Padding="6,4">
                                        <Grid ColumnDefinitions="*,150,150,90,90,110">
                                          <ComboBox Grid.Column="0" Classes="gridCombo"
                                                    MinWidth="0" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding StockItems}"
                                                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                    PlaceholderText="Select item…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:StockItem">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Classes="gridCombo" Width="144" Margin="6,0"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding TrackOptions}"
                                                    SelectedItem="{Binding SelectedTrack, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="vm:JobWorkTrackOption">
                                                <TextBlock Text="{Binding Display}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="2" Classes="gridCombo" Width="144"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding Godowns}"
                                                    SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                                    PlaceholderText="Godown…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Godown">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="3" Width="84" Margin="6,0"
                                                   Text="{Binding QuantityText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0"/>
                                          <TextBox Grid.Column="4" Width="84"
                                                   Text="{Binding RateText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0.00"/>
                                          <TextBox Grid.Column="5" Width="104" Margin="6,0,0,0"
                                                   Text="{Binding DueText, Mode=TwoWay}"
                                                   PlaceholderText="dd-MMM-yyyy"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add component" HorizontalAlignment="Left"
                                        Margin="0,6" Padding="10,4"
                                        Background="{StaticResource Panel}"
                                        Click="OnAddJobWorkLineClick"/>
                              </StackPanel>
                            </ScrollViewer>

                            <!-- Narration -->
                            <TextBox Grid.Row="5" Text="{Binding Narration, Mode=TwoWay}"
                                     PlaceholderText="Narration…" AcceptsReturn="False" Margin="0,4,0,0"/>

                            <!-- Accept row + message -->
                            <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto" Margin="0,6,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource AlertRed}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                              <Button Grid.Column="1" Content="Cancel (Esc)" Margin="0,0,8,0" Padding="12,6"
                                      Click="OnCancelJobWorkOrderClick"/>
                              <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                      IsEnabled="{Binding CanAccept}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnAcceptJobWorkOrderClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Material In/Out movement entry (Phase 6 slice 8; RQ-48) -->
                    <ContentControl IsVisible="{Binding MaterialMovementEntry, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding MaterialMovementEntry}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:MaterialMovementEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="4">

                            <!-- Header: type + auto number + date -->
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}" Padding="10,6">
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding TypeName}"
                                           Foreground="White" FontWeight="Bold" FontSize="15"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Foreground="#CFE0FF" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,18,0">
                                  <Run Text="No. "/><Run Text="{Binding VoucherNumber}"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Width="140"
                                         Text="{Binding DateText, Mode=TwoWay}"
                                         FontSize="12" VerticalAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Direction hint + party / order / godowns -->
                            <Border Grid.Row="1" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                    Padding="10,6" Margin="0,4,0,0">
                              <StackPanel Spacing="6">
                                <TextBlock Text="{Binding DirectionHint}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="Auto,220,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Party" FontWeight="SemiBold" Margin="0,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Parties}"
                                            SelectedItem="{Binding SelectedParty, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PartyOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Order No." FontWeight="SemiBold" Margin="14,0,8,0"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Orders}"
                                            SelectedItem="{Binding SelectedOrder, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:JobWorkOrderOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,240,Auto,240">
                                  <TextBlock Grid.Column="0" Text="{Binding SourceGodownLabel}" FontWeight="SemiBold"
                                             Margin="0,0,8,0" VerticalAlignment="Center"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Godowns}"
                                            SelectedItem="{Binding SourceGodown, Mode=TwoWay}"
                                            PlaceholderText="Godown…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Godown">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="{Binding DestinationGodownLabel}" FontWeight="SemiBold"
                                             Margin="14,0,8,0" VerticalAlignment="Center"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Godowns}"
                                            SelectedItem="{Binding DestinationGodown, Mode=TwoWay}"
                                            PlaceholderText="Godown…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Godown">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Source (outward) + Destination (inward) grids -->
                            <ScrollViewer Grid.Row="2" Background="White" VerticalScrollBarVisibility="Auto">
                              <StackPanel Spacing="0">
                                <TextBlock Text="Source — outward (consumed / dispatched)"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" Margin="6,6,0,2"/>
                                <ItemsControl ItemsSource="{Binding SourceLines}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InventoryVoucherLineViewModel">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                              Padding="6,4">
                                        <Grid ColumnDefinitions="*,152,84,88">
                                          <ComboBox Grid.Column="0" Classes="gridCombo"
                                                    MinWidth="0" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding StockItems}"
                                                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                    PlaceholderText="Select item…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:StockItem">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Classes="gridCombo" Width="146" Margin="6,0"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding Godowns}"
                                                    SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                                    PlaceholderText="Godown…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Godown">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Width="78"
                                                   Text="{Binding QuantityText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0"/>
                                          <TextBox Grid.Column="3" Width="80" Margin="6,0"
                                                   Text="{Binding RateText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0.00"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add source line" HorizontalAlignment="Left"
                                        Margin="0,6" Padding="10,4"
                                        Background="{StaticResource Panel}"
                                        Click="OnAddMaterialSourceLineClick"/>

                                <TextBlock Text="Destination — inward (received / produced)"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" Margin="6,6,0,2"/>
                                <ItemsControl ItemsSource="{Binding DestinationLines}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InventoryVoucherLineViewModel">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                              Padding="6,4">
                                        <Grid ColumnDefinitions="*,152,84,88">
                                          <ComboBox Grid.Column="0" Classes="gridCombo"
                                                    MinWidth="0" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding StockItems}"
                                                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                    PlaceholderText="Select item…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:StockItem">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Classes="gridCombo" Width="146" Margin="6,0"
                                                    HorizontalContentAlignment="Left" Padding="8,3,6,3"
                                                    ItemsSource="{Binding Godowns}"
                                                    SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                                    PlaceholderText="Godown…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Godown">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Width="78"
                                                   Text="{Binding QuantityText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0"/>
                                          <TextBox Grid.Column="3" Width="80" Margin="6,0"
                                                   Text="{Binding RateText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="0.00"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add destination line" HorizontalAlignment="Left"
                                        Margin="0,6" Padding="10,4"
                                        Background="{StaticResource Panel}"
                                        Click="OnAddMaterialDestinationLineClick"/>
                              </StackPanel>
                            </ScrollViewer>

                            <!-- Narration -->
                            <TextBox Grid.Row="3" Text="{Binding Narration, Mode=TwoWay}"
                                     PlaceholderText="Narration…" AcceptsReturn="False" Margin="0,4,0,0"/>

                            <!-- Accept row + message -->
                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,6,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource AlertRed}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                              <Button Grid.Column="1" Content="Cancel (Esc)" Margin="0,0,8,0" Padding="12,6"
                                      Click="OnCancelMaterialClick"/>
                              <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                      IsEnabled="{Binding CanAccept}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnAcceptMaterialClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Ledger master (create + list) -->
                    <ContentControl IsVisible="{Binding Ledger, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Ledger}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:LedgerMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Ledger Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10" Grid.IsSharedSizeScope="True">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LedTopL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. State Bank of India"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LedTopL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Groups}"
                                            SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                            PlaceholderText="Select group…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Group">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <!-- Currency of ledger (base ₹/INR, or a created foreign currency) -->
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LedTopL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Currency" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding CurrencyChoices}"
                                            SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:CurrencyChoice">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <!-- Default Price Level (Book pp.34–35; slice 5 RQ-30): shown ONLY when the company's
                                     "Enable multiple Price Levels" F11 flag is on AND the group is a party (Sundry
                                     Debtors). A Sales voucher for this party defaults its Price-Level header to this. -->
                                <Grid IsVisible="{Binding ShowDefaultPriceLevel}">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LedTopL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Default Price Level" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding PriceLevelChoices}"
                                            SelectedItem="{Binding SelectedPriceLevel, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PriceLevelChoice">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <!-- Method of Appropriation in Purchase invoice (Book pp.133–141): shown ONLY when
                                     the ledger-screen F12 configuration is on AND the group is under Direct
                                     Expenses. A non-None pick marks this an additional-cost ledger (RQ-16..RQ-20). -->
                                <Border Background="#FBF7EE"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="12,10" IsVisible="{Binding ShowAppropriation}">
                                  <StackPanel Spacing="8">
                                    <TextBlock Text="Additional Cost of Purchase (F12)" FontWeight="SemiBold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="Auto,*">
                                      <TextBlock Grid.Column="0" Text="Method of Appropriation" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" FontSize="12.5"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding MethodChoices}"
                                                SelectedItem="{Binding SelectedMethod, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:MethodOfAppropriationChoice">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Bill-wise options (shown for party groups: Sundry Debtors/Creditors) -->
                                <StackPanel Spacing="8" IsVisible="{Binding IsPartyGroup}">
                                  <CheckBox Content="Maintain balances bill-by-bill"
                                            IsChecked="{Binding MaintainBillByBill, Mode=TwoWay}"
                                            FontSize="13"/>
                                  <!-- Auto, not a fixed 180: the label needs 192.4px and was sliced to "…(day" at the
                                       TextBox border. It is the only label row in this block, so it needs no shared
                                       size group — there is no sibling row for its input edge to line up with. -->
                                  <Grid ColumnDefinitions="Auto,120"
                                        IsVisible="{Binding MaintainBillByBill}">
                                    <TextBlock Grid.Column="0" Text="Default credit period (days)"
                                               VerticalAlignment="Center" FontSize="12.5"
                                               Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DefaultCreditPeriodText, Mode=TwoWay}"
                                             PlaceholderText="e.g. 30" TextAlignment="Right"/>
                                  </Grid>
                                </StackPanel>

                                <!-- Party GST details (shown for a party group while GST is enabled; catalog §12) -->
                                <Border Background="#FBF7EE"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="12,10" IsVisible="{Binding ShowPartyGst}">
                                  <StackPanel Spacing="8">
                                    <TextBlock Text="GST Details (party)" FontWeight="SemiBold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LedGstL"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="GSTIN/UIN" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" FontSize="12.5"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding PartyGstin, Mode=TwoWay}"
                                               PlaceholderText="15-char GSTIN (blank ⇒ B2C)"/>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LedGstL"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="Registration" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" FontSize="12.5"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding PartyRegistrationTypes}"
                                                SelectedItem="{Binding PartyRegistrationType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:GstRegistrationTypeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LedGstL"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="State/UT" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" FontSize="12.5"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding PartyStates}"
                                                SelectedItem="{Binding PartyState, Mode=TwoWay}"
                                                PlaceholderText="place of supply…">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:IndianStateOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- TDS / TCS details (Phase 7 slice 1; catalog §13): shown when TDS/TCS is enabled.
                                     "Is TDS/TCS Applicable" + default nature apply to expense/sales ledgers; the
                                     deductee/collectee type + PAN + "deduct in same voucher" apply to a party ledger. -->
                                <Border Background="#FBF7EE"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="12,10" IsVisible="{Binding ShowTdsTcs}">
                                  <StackPanel Spacing="8">
                                    <TextBlock Text="TDS / TCS Details" FontWeight="SemiBold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>

                                    <!-- TDS applicability + default Nature of Payment -->
                                    <StackPanel Spacing="8" IsVisible="{Binding TdsEnabled}">
                                      <CheckBox Content="Is TDS Applicable (withhold on payments to this ledger)"
                                                IsChecked="{Binding TdsApplicable, Mode=TwoWay}" FontSize="12.5"/>
                                      <Grid IsVisible="{Binding TdsApplicable}">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedTdsL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nature of Payment" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding TdsNatureChoices}"
                                                  SelectedItem="{Binding SelectedTdsNature, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:NatureOfPaymentChoice">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>

                                    <!-- TCS applicability + default Nature of Goods -->
                                    <StackPanel Spacing="8" IsVisible="{Binding TcsEnabled}">
                                      <CheckBox Content="Is TCS Applicable (collect on sales through this ledger)"
                                                IsChecked="{Binding TcsApplicable, Mode=TwoWay}" FontSize="12.5"/>
                                      <Grid IsVisible="{Binding TcsApplicable}">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedTdsL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nature of Goods" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding TcsNatureChoices}"
                                                  SelectedItem="{Binding SelectedTcsNature, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:NatureOfGoodsChoice">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>

                                    <!-- Party deductee/collectee details (party group only) -->
                                    <StackPanel Spacing="8" IsVisible="{Binding ShowPartyTdsTcs}">
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedTdsL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Party PAN" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="1" Text="{Binding PartyPan, Mode=TwoWay}"
                                                 FontFamily="Consolas,Menlo,monospace"
                                                 PlaceholderText="10-char PAN (blank ⇒ no-PAN higher rate)"/>
                                      </Grid>
                                      <Grid IsVisible="{Binding TdsEnabled}">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedTdsL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Deductee Type" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding DeducteeTypeChoices}"
                                                  SelectedItem="{Binding SelectedDeducteeType, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DeducteeTypeChoice">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid IsVisible="{Binding TcsEnabled}">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedTdsL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Collectee Type" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding CollecteeTypeChoices}"
                                                  SelectedItem="{Binding SelectedCollecteeType, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:CollecteeTypeChoice">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <CheckBox Content="Deduct TDS in the same voucher"
                                                IsChecked="{Binding DeductTdsInSameVoucher, Mode=TwoWay}"
                                                FontSize="12.5" IsVisible="{Binding TdsEnabled}"/>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>

                                <!-- Interest Calculation parameters (catalog §7) -->
                                <Border Background="#FBF7EE"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="12,10">
                                  <StackPanel Spacing="8">
                                    <CheckBox Content="Activate Interest Calculation"
                                              IsChecked="{Binding EnableInterest, Mode=TwoWay}"
                                              FontSize="13" FontWeight="SemiBold"
                                              Foreground="{StaticResource BrandNavy}"/>
                                    <StackPanel Spacing="8" IsVisible="{Binding EnableInterest}">
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedIntL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Rate %" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                                 Text="{Binding InterestRateText, Mode=TwoWay}"
                                                 PlaceholderText="e.g. 18" TextAlignment="Right"/>
                                      </Grid>
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedIntL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Per" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding PerChoices}"
                                                  SelectedItem="{Binding SelectedPer, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedIntL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="On" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding OnBalanceChoices}"
                                                  SelectedItem="{Binding SelectedOnBalance, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedIntL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Applicability" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ApplicabilityChoices}"
                                                  SelectedItem="{Binding SelectedApplicability, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" SharedSizeGroup="LedIntL"/>
                                          <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Style" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding StyleChoices}"
                                                  SelectedItem="{Binding SelectedStyle, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateLedgerClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing ledgers header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,150,110,70,120">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Opening" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Currency" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Interest" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:LedgerListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,150,110,70,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Opening}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Currency}"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Interest}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Chart of Accounts (read-only group/ledger tree) -->
                    <ContentControl IsVisible="{Binding Chart, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Chart}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ChartOfAccountsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,160">
                                <TextBlock Grid.Column="0" Text="Group / Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Nature / Opening" Classes="colHdr"
                                           TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ChartRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="{Binding Indent, Converter={StaticResource Indent}}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12.5"
                                                   FontWeight="{Binding IsGroup, Converter={StaticResource BoolWeight}}"
                                                   Foreground="{Binding IsGroup, Converter={StaticResource SelFore}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Outstandings (Receivables / Payables) with Ctrl+B bill settlement -->
                    <ContentControl IsVisible="{Binding Outstanding, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Outstanding}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:OutstandingsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,110,90,90,120,90">
                                <TextBlock Grid.Column="0" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Ref" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Due Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Pending" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Ageing" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:OutstandingRowViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Border.Background>
                                        <MultiBinding Converter="{x:Static conv:OutstandingRowBrushConverter.Instance}">
                                          <Binding Path="IsSelected"/>
                                          <Binding Path="IsHighlighted"/>
                                        </MultiBinding>
                                      </Border.Background>
                                      <Grid ColumnDefinitions="*,110,90,90,120,90" Height="24">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center" Margin="8,0">
                                          <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                     Foreground="#2E7D32"
                                                     IsVisible="{Binding IsSelected}"/>
                                          <TextBlock Text="{Binding Party}" FontSize="12.5"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Reference}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#333333"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Date}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DueDate}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Pending}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Ageing}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Total + settle bar -->
                            <Border Grid.Row="4" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2">
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Space: select bill    Ctrl+B: settle selected"
                                           FontSize="11" Foreground="#6A6A6A" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                                           FontWeight="SemiBold">
                                  <Run Text="Total Pending: "/><Run Text="{Binding TotalText}"/>
                                </TextBlock>
                                <Button Grid.Column="2" Content="Settle (Ctrl+B)" Padding="12,5"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnSettleBillsClick"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="5" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,4,0,0" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Cost Category master (create + list) -->
                    <ContentControl IsVisible="{Binding CostCategory, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CostCategory}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CostCategoryMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Cost Category Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Departments"/>
                                </Grid>
                                <CheckBox Content="Allocate Revenue Items"
                                          IsChecked="{Binding AllocateRevenueItems, Mode=TwoWay}" FontSize="13"/>
                                <CheckBox Content="Allocate Non-Revenue Items"
                                          IsChecked="{Binding AllocateNonRevenueItems, Mode=TwoWay}" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateCostCategoryClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing categories header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,220,120">
                                <TextBlock Grid.Column="0" Text="Cost Category" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Allocates" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Kind" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CostCategoryListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,220,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Allocates}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Cost Centre master (create + list) -->
                    <ContentControl IsVisible="{Binding CostCentre, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CostCentre}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CostCentreMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Cost Centre Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10" Grid.IsSharedSizeScope="True">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CcL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Sales Team A"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CcL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Category" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Categories}"
                                            SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                            PlaceholderText="Select category…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:CostCategory">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CcL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentCentreOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateCostCentreClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing centres header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,180,160">
                                <TextBlock Grid.Column="0" Text="Cost Centre" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Category" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Under" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CostCentreListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,180,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Category}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Under}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Cost report (Category Summary / Cost Centre Break-up) -->
                    <ContentControl IsVisible="{Binding CostReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CostReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CostReportsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,160">
                                <TextBlock Grid.Column="0" Text="{Binding ParticularsHeader}" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Particulars}"
                                                   Margin="{Binding Indent, Converter={StaticResource Indent}}"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                   Foreground="{Binding IsHeader, Converter={StaticResource SelFore}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Amount}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Budget master (create budget + lines + list) -->
                    <ContentControl IsVisible="{Binding BudgetMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BudgetMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BudgetMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Budget Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form: name + period + line builder -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Q1 Budget"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*,60,*">
                                  <TextBlock Grid.Column="0" Text="From" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding PeriodFromText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                  <TextBlock Grid.Column="2" Text="To" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextAlignment="Center"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding PeriodToText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>

                                <!-- Line builder: Target + Type + Amount + Add -->
                                <Border Background="#F4F7FB"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="10,8">
                                  <StackPanel Spacing="8">
                                    <TextBlock Text="Add Budget Line" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="*,190,120,Auto">
                                      <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding Targets}"
                                                SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                                                PlaceholderText="Group or ledger…">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:BudgetTargetOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <ComboBox Grid.Column="1" Margin="6,0" Width="184"
                                                ItemsSource="{Binding Types}"
                                                SelectedItem="{Binding SelectedType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource BudgetTypeLabel}}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBox Grid.Column="2" Width="114"
                                               Text="{Binding LineAmountText, Mode=TwoWay}"
                                               TextAlignment="Right" PlaceholderText="0.00"/>
                                      <Button Grid.Column="3" Content="+ Add line" Margin="6,0,0,0"
                                              Padding="10,4" Background="{StaticResource Panel}"
                                              Click="OnAddBudgetLineClick"/>
                                    </Grid>

                                    <!-- Pending lines header -->
                                    <Border Background="{StaticResource BrandNavyDark}">
                                      <Grid ColumnDefinitions="*,180,120">
                                        <TextBlock Grid.Column="0" Text="Target" Classes="colHdr"/>
                                        <TextBlock Grid.Column="1" Text="Type" Classes="colHdr"/>
                                        <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                      </Grid>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding PendingLines}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PendingBudgetLineRow">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                  Background="White">
                                            <Grid ColumnDefinitions="*,180,120" Height="22">
                                              <TextBlock Grid.Column="0" Text="{Binding Target}"
                                                         Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Type}"
                                                         VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                              <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                         TextAlignment="Right" Margin="0,0,10,0"
                                                         VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateBudgetClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing budgets header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,240,120">
                                <TextBlock Grid.Column="0" Text="Budget" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Period" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Lines" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BudgetListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,240,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Period}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Lines}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No budgets created yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Scenario master (create scenario + toggle voucher types + list) -->
                    <ContentControl IsVisible="{Binding ScenarioMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ScenarioMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ScenarioMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Scenario Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form: name + include-actuals + voucher-type toggles -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Provisional"/>
                                </Grid>
                                <CheckBox Content="Include Actuals (base the scenario on the real books)"
                                          IsChecked="{Binding IncludeActuals, Mode=TwoWay}"
                                          FontSize="12" Foreground="{StaticResource Ink}"/>

                                <!-- Voucher-type include toggles -->
                                <Border Background="#F4F7FB"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="10,8">
                                  <StackPanel Spacing="6">
                                    <TextBlock Text="Include these voucher types" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Text="Tick a type to surface its Optional / Reversing / Memorandum vouchers under this scenario."
                                               FontSize="10.5" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding Types}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioTypeRow">
                                          <Grid ColumnDefinitions="24,*,160" Height="24">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Include, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       VerticalAlignment="Center" FontSize="12.5"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                       TextAlignment="Right" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                          </Grid>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateScenarioClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing scenarios header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,90,*">
                                <TextBlock Grid.Column="0" Text="Scenario" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Actuals" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Includes" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ScenarioListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,90,*" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Actuals}"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Includes}"
                                                   Margin="4,0,10,0" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No scenarios created yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Currency master (create currency + rates of exchange + lists) -->
                    <ContentControl IsVisible="{Binding CurrencyMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding CurrencyMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CurrencyMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Currency &amp; Rates of Exchange"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create-currency form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                              <StackPanel Spacing="10">
                                <TextBlock Text="New Currency" FontWeight="SemiBold" FontSize="12.5"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <Grid ColumnDefinitions="110,*,120,*,120,90">
                                  <TextBlock Grid.Column="0" Text="Symbol" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Symbol, Mode=TwoWay}"
                                           PlaceholderText="$"/>
                                  <TextBlock Grid.Column="2" Text="Formal Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FormalName, Mode=TwoWay}"
                                           PlaceholderText="USD"/>
                                  <TextBlock Grid.Column="4" Text="Decimals" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="5" Text="{Binding DecimalPlacesText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="2"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding CurrencyMessage}"
                                             IsVisible="{Binding CurrencyMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create Currency (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateCurrencyClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Rate-of-exchange form -->
                            <Border Grid.Row="2" Background="#FBF7EE"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                              <StackPanel Spacing="10">
                                <TextBlock Text="Rate of Exchange" FontWeight="SemiBold" FontSize="12.5"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock IsVisible="{Binding !HasForeignCurrencies}"
                                           Text="Create a foreign currency above first, then set its dated rates here."
                                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                <StackPanel Spacing="10" IsVisible="{Binding HasForeignCurrencies}">
                                  <Grid ColumnDefinitions="110,*,90,150">
                                    <TextBlock Grid.Column="0" Text="Currency" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ForeignCurrencies}"
                                              SelectedItem="{Binding RateCurrency, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:Currency">
                                          <TextBlock Text="{Binding FormalName}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding RateDateText, Mode=TwoWay}"
                                             PlaceholderText="dd-MMM-yyyy"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="110,*,110,*,110,*">
                                    <TextBlock Grid.Column="0" Text="Standard ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding StandardRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="e.g. 83.25"/>
                                    <TextBlock Grid.Column="2" Text="Selling ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding SellingRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="optional"/>
                                    <TextBlock Grid.Column="4" Text="Buying ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="5" Text="{Binding BuyingRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="optional"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding RateMessage}"
                                               IsVisible="{Binding RateMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{StaticResource AlertRed}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Add Rate" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnCreateExchangeRateClick"/>
                                  </Grid>
                                </StackPanel>
                              </StackPanel>
                            </Border>

                            <!-- Currencies + Rates lists side by side. Each table now owns its OWN header band
                                 at Row 0 of an Auto,* grid, so the two headers share one baseline (D-4) and each
                                 header's columns sit over its own data (D-3). The Currencies header used to be a
                                 full-width Row-3 band whose Decimals/Kind floated over the adjacent Rate table. -->
                            <Grid Grid.Row="3" ColumnDefinitions="*,*" Margin="0,0,0,0">
                              <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavyDark}">
                                  <Grid ColumnDefinitions="120,*,90,90">
                                    <TextBlock Grid.Column="0" Text="Symbol" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Formal Name" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Decimals" Classes="colHdr" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="Kind" Classes="colHdr" TextAlignment="Center"/>
                                  </Grid>
                                </Border>
                              <ScrollViewer Grid.Row="1" Background="White">
                                <ItemsControl ItemsSource="{Binding Currencies}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CurrencyListRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,*,90,90" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                     Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding FormalName}"
                                                     VerticalAlignment="Center" FontSize="12.5"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Decimals}"
                                                     TextAlignment="Center"
                                                     VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Kind}"
                                                     TextAlignment="Center"
                                                     VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                              </Grid>

                              <Border Grid.Column="1" BorderBrush="{StaticResource GridLine}" BorderThickness="1,0,0,0">
                                <Grid RowDefinitions="Auto,*">
                                  <Border Grid.Row="0" Background="{StaticResource BrandNavyDark}">
                                    <Grid ColumnDefinitions="*,110,90,80,80">
                                      <TextBlock Grid.Column="0" Text="Rates — Currency" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Date" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Std ₹" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="3" Text="Sell ₹" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="4" Text="Buy ₹" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ScrollViewer Grid.Row="1" Background="White">
                                    <ItemsControl ItemsSource="{Binding Rates}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ExchangeRateListRow">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,110,90,80,80" Height="24">
                                              <TextBlock Grid.Column="0" Text="{Binding Currency}"
                                                         Margin="8,0" VerticalAlignment="Center" FontSize="12"
                                                         TextTrimming="CharacterEllipsis"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Date}"
                                                         VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                              <TextBlock Grid.Column="2" Text="{Binding Standard}"
                                                         TextAlignment="Right" Margin="0,0,6,0"
                                                         VerticalAlignment="Center" FontSize="11.5"/>
                                              <TextBlock Grid.Column="3" Text="{Binding Selling}"
                                                         TextAlignment="Right" Margin="0,0,6,0"
                                                         VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="4" Text="{Binding Buying}"
                                                         TextAlignment="Right" Margin="0,0,6,0"
                                                         VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </ScrollViewer>
                                </Grid>
                              </Border>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Stock Group master (create + list) -->
                    <ContentControl IsVisible="{Binding StockGroupMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding StockGroupMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:StockGroupMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Stock Group Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*,70,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Finished Goods"/>
                                  <TextBlock Grid.Column="2" Text="Alias" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding Alias, Mode=TwoWay}"
                                           PlaceholderText="optional"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentStockGroupOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <CheckBox Content="Should quantities be added?"
                                          IsChecked="{Binding AddQuantities, Mode=TwoWay}" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateStockGroupClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing groups header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,200,120">
                                <TextBlock Grid.Column="0" Text="Stock Group" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Quantities" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:StockGroupListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,200,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Quantities}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Stock Category master (create + list) -->
                    <ContentControl IsVisible="{Binding StockCategoryMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding StockCategoryMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:StockCategoryMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Stock Category Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*,70,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Brand A"/>
                                  <TextBlock Grid.Column="2" Text="Alias" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding Alias, Mode=TwoWay}"
                                           PlaceholderText="optional"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentStockCategoryOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateStockCategoryClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing categories header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,220">
                                <TextBlock Grid.Column="0" Text="Stock Category" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:StockCategoryListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,220" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Unit of Measure master (Simple/Compound toggle; create + list) -->
                    <ContentControl IsVisible="{Binding UnitMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding UnitMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:UnitMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Unit of Measure Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <!-- Simple / Compound toggle -->
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                  <RadioButton Content="Simple" GroupName="UnitType"
                                               IsChecked="{Binding !IsCompound, Mode=OneWay}"
                                               Click="OnUnitSimpleClick" FontSize="13"/>
                                  <RadioButton Content="Compound" GroupName="UnitType"
                                               IsChecked="{Binding IsCompound, Mode=OneWay}"
                                               Click="OnUnitCompoundClick" FontSize="13"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="90,*,110,*">
                                  <TextBlock Grid.Column="0" Text="Symbol" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Symbol, Mode=TwoWay}"
                                           PlaceholderText="e.g. Nos / Dozen"/>
                                  <TextBlock Grid.Column="2" Text="Formal Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FormalName, Mode=TwoWay}"
                                           PlaceholderText="e.g. Numbers"/>
                                </Grid>

                                <!-- Simple-only fields -->
                                <Grid ColumnDefinitions="90,*,140,110" IsVisible="{Binding ShowSimpleForm}">
                                  <TextBlock Grid.Column="0" Text="UQC" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding UnitQuantityCode, Mode=TwoWay}"
                                           PlaceholderText="optional (e.g. NOS)"/>
                                  <TextBlock Grid.Column="2" Text="Decimals (0–4)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding DecimalPlacesText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="0"/>
                                </Grid>

                                <!-- Compound-only fields -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsCompound}">
                                  <TextBlock IsVisible="{Binding !CanBuildCompound}"
                                             Text="A compound unit needs two existing simple units — create at least two simple units first."
                                             FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                  <Grid ColumnDefinitions="90,*,110,90,90,*" IsVisible="{Binding CanBuildCompound}">
                                    <TextBlock Grid.Column="0" Text="First unit" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding SimpleUnits}"
                                              SelectedItem="{Binding FirstUnit, Mode=TwoWay}"
                                              PlaceholderText="base unit…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:Unit">
                                          <TextBlock Text="{Binding Symbol}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="× Factor" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding ConversionFactorText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="12"/>
                                    <TextBlock Grid.Column="4" Text="Tail unit" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="5" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding SimpleUnits}"
                                              SelectedItem="{Binding TailUnit, Mode=TwoWay}"
                                              PlaceholderText="tail unit…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:Unit">
                                          <TextBlock Text="{Binding Symbol}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateUnitClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing units header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="120,*,90,*">
                                <TextBlock Grid.Column="0" Text="Symbol" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Formal Name" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Kind" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Detail" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:UnitListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="120,*,90,*" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FormalName}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Detail}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Godown master (create + list) -->
                    <ContentControl IsVisible="{Binding GodownMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding GodownMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GodownMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Godown / Location Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*,70,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Warehouse 2"/>
                                  <TextBlock Grid.Column="2" Text="Alias" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding Alias, Mode=TwoWay}"
                                           PlaceholderText="optional"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentGodownOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <CheckBox Content="Third-party (our stock with others)"
                                          IsChecked="{Binding ThirdParty, Mode=TwoWay}" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateGodownClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing godowns header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,200,140">
                                <TextBlock Grid.Column="0" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Kind" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GodownListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,200,140" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Stock Item master (create + list) -->
                    <ContentControl IsVisible="{Binding StockItemMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding StockItemMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:StockItemMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Stock Item Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Create form -->
                            <ScrollViewer Grid.Row="1" MaxHeight="360" Margin="0,0,0,10">
                              <Border Background="White"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="16">
                                <StackPanel Spacing="10">
                                  <Grid ColumnDefinitions="90,*,70,*">
                                    <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                             PlaceholderText="e.g. Widget-X"/>
                                    <TextBlock Grid.Column="2" Text="Alias" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding Alias, Mode=TwoWay}"
                                             PlaceholderText="optional"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="90,*,90,*">
                                    <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Groups}"
                                              SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                              PlaceholderText="stock group…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:StockGroup">
                                          <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Category" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding CategoryOptions}"
                                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                              PlaceholderText="(none)">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:OptionalStockCategoryOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="90,*,90,*">
                                    <TextBlock Grid.Column="0" Text="Base unit" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Units}"
                                              SelectedItem="{Binding SelectedUnit, Mode=TwoWay}"
                                              PlaceholderText="unit…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:Unit">
                                          <TextBlock Text="{Binding Symbol}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Valuation" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ValuationMethods}"
                                              SelectedItem="{Binding SelectedValuation, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ValuationMethodOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <!-- Reorder / Min-order-qty are label-less and rely on their placeholder hint;
                                       the Min-order field was 110px and clipped "Min order qty" → "Min order q"
                                       (D-5). Widened to 140 (the "*" HSN field yields the room) so the full hint
                                       shows. -->
                                  <Grid ColumnDefinitions="90,*,90,120,140">
                                    <TextBlock Grid.Column="0" Text="HSN/SAC" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding HsnSacCode, Mode=TwoWay}"
                                             PlaceholderText="optional"/>
                                    <CheckBox Grid.Column="2" Content="Taxable" Margin="10,0,0,0"
                                              IsChecked="{Binding IsTaxable, Mode=TwoWay}" FontSize="12"
                                              VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="3" Text="{Binding ReorderLevelText, Mode=TwoWay}"
                                             TextAlignment="Right" Margin="6,0,0,0"
                                             PlaceholderText="Reorder lvl"/>
                                    <TextBox Grid.Column="4" Text="{Binding MinimumOrderQtyText, Mode=TwoWay}"
                                             TextAlignment="Right" Margin="6,0,0,0"
                                             PlaceholderText="Min order qty"/>
                                  </Grid>

                                  <!-- GST details (shown when GST is enabled; catalog §12) -->
                                  <Border Background="#FBF7EE"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10" IsVisible="{Binding GstEnabled}">
                                    <StackPanel Spacing="8">
                                      <TextBlock Text="GST Details" FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <Grid ColumnDefinitions="90,*,90,*">
                                        <TextBlock Grid.Column="0" Text="Taxability" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding Taxabilities}"
                                                  SelectedItem="{Binding Taxability, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:GstTaxabilityOption">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Grid.Column="2" Text="GST rate" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding GstRates}"
                                                  SelectedItem="{Binding GstRate, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:GstRateOption">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>

                                      <!-- GST 2.0 valuation basis + Retail Sale Price (Phase 9 slice 1). RSP drives the
                                           tobacco/pan-masala carve-out valuation + RSP-factor cess. -->
                                      <Grid ColumnDefinitions="Auto,*,120,140">
                                        <CheckBox Grid.Column="0" Content="Value on RSP" FontSize="12"
                                                  IsChecked="{Binding ValuationIsRsp, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Retail Sale Price ₹" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   TextAlignment="Right" Margin="0,0,6,0"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="3" Text="{Binding RetailSalePriceText, Mode=TwoWay}"
                                                 TextAlignment="Right" PlaceholderText="per unit"/>
                                      </Grid>

                                      <!-- Compensation-Cess override (Phase 9 slice 1). Off ⇒ the item inherits the
                                           dated cess master for its HSN; on ⇒ its own valuation mode + figures. -->
                                      <CheckBox Content="Declare a Compensation-Cess override on this item" FontSize="12"
                                                IsChecked="{Binding CessApplicable, Mode=TwoWay}"/>
                                      <StackPanel Spacing="8" Margin="20,0,0,0"
                                                  IsVisible="{Binding CessApplicable}">
                                        <Grid ColumnDefinitions="90,*">
                                          <TextBlock Grid.Column="0" Text="Cess basis" FontWeight="SemiBold" FontSize="12"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding CessValuationModes}"
                                                    SelectedItem="{Binding CessMode, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="vm:CessValuationModeOption">
                                                <TextBlock Text="{Binding Display}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                        </Grid>
                                        <Grid ColumnDefinitions="90,110,90,110,90,110">
                                          <TextBlock Grid.Column="0" Text="Rate %" FontSize="12"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <TextBox Grid.Column="1" Text="{Binding CessRatePercentText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="ad-val %"/>
                                          <TextBlock Grid.Column="2" Text="₹/unit" FontSize="12" Margin="8,0,0,0"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <TextBox Grid.Column="3" Text="{Binding CessPerUnitText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="specific"/>
                                          <TextBlock Grid.Column="4" Text="RSP ×" FontSize="12" Margin="8,0,0,0"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <TextBox Grid.Column="5" Text="{Binding CessRspFactorText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="factor"/>
                                        </Grid>
                                      </StackPanel>
                                    </StackPanel>
                                  </Border>

                                  <!-- TCS Nature of Goods (Phase 7 slice 1; §206C) — shown only when TCS is enabled.
                                       A sale of this item auto-collects TCS under this nature. -->
                                  <Border Background="#FBF7EE"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10" IsVisible="{Binding TcsEnabled}">
                                    <StackPanel Spacing="8">
                                      <TextBlock Text="TCS Details" FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="Nature of Goods" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding TcsNatureChoices}"
                                                  SelectedItem="{Binding SelectedTcsNature, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:NatureOfGoodsChoice">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>
                                  </Border>

                                  <!-- Batch switches (Phase 6 Cluster 1; RQ-2) — shown only when the company
                                       flag "Maintain Batch-wise details" is on (RQ-52). The three switches are
                                       independent (Use-Expiry may be on without Track-Mfg). -->
                                  <Border Background="#EEF4FB"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10" IsVisible="{Binding ShowBatchSwitches}">
                                    <StackPanel Spacing="6">
                                      <TextBlock Text="Batch Details" FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <CheckBox Content="Maintain in Batches"
                                                IsChecked="{Binding MaintainInBatches, Mode=TwoWay}" FontSize="12.5"/>
                                      <CheckBox Content="Track date of Manufacturing"
                                                IsChecked="{Binding TrackManufacturingDate, Mode=TwoWay}" FontSize="12.5"/>
                                      <CheckBox Content="Use Expiry dates"
                                                IsChecked="{Binding UseExpiryDates, Mode=TwoWay}" FontSize="12.5"/>
                                    </StackPanel>
                                  </Border>

                                  <!-- BOM switch (Phase 6 Cluster 2; RQ-10) — shown only when the F12 config
                                       "Set Components (BOM)" is on. Declares the item a manufactured finished good;
                                       its recipes are defined on the Bill of Materials master. -->
                                  <Border Background="#EEF4FB"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10" IsVisible="{Binding ShowBomSwitch}">
                                    <StackPanel Spacing="6">
                                      <TextBlock Text="Manufacturing" FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <CheckBox Content="Set Components (BOM)"
                                                IsChecked="{Binding SetComponents, Mode=TwoWay}" FontSize="12.5"/>
                                    </StackPanel>
                                  </Border>

                                  <!-- Opening balance (optional) -->
                                  <Border Background="#FBF7EE"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10">
                                    <StackPanel Spacing="8">
                                      <TextBlock Text="Opening Balance (optional)" FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <Grid ColumnDefinitions="90,*,80,120,70,120">
                                        <TextBlock Grid.Column="0" Text="Godown" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding Godowns}"
                                                  SelectedItem="{Binding OpeningGodown, Mode=TwoWay}"
                                                  PlaceholderText="Main Location">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="ledger:Godown">
                                              <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Grid.Column="2" Text="Qty" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="3" Text="{Binding OpeningQuantityText, Mode=TwoWay}"
                                                 TextAlignment="Right" PlaceholderText="0"/>
                                        <TextBlock Grid.Column="4" Text="Rate ₹" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="5" Text="{Binding OpeningRateText, Mode=TwoWay}"
                                                 TextAlignment="Right" PlaceholderText="0.00"/>
                                      </Grid>
                                      <Grid ColumnDefinitions="90,*">
                                        <TextBlock Grid.Column="0" Text="Batch/Lot" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="1" Text="{Binding OpeningBatchLabel, Mode=TwoWay}"
                                                 PlaceholderText="optional label"/>
                                      </Grid>
                                    </StackPanel>
                                  </Border>

                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Message}"
                                               IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{StaticResource AlertRed}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnCreateStockItemClick"/>
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </ScrollViewer>

                            <!-- Existing items header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,150,70,150,120">
                                <TextBlock Grid.Column="0" Text="Stock Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Unit" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Valuation" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Opening ₹" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:StockItemListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,150,70,150,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Unit}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Valuation}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding OpeningValue}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Batch / Lot master (create + list) — Phase 6 Cluster 1 (RQ-1/RQ-4/RQ-54) -->
                    <ContentControl IsVisible="{Binding BatchMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BatchMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BatchMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Batch / Lot Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Create form -->
                            <ScrollViewer Grid.Row="1" MaxHeight="330" Margin="0,0,0,10">
                              <Border Background="White"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="16">
                                <StackPanel Spacing="10">
                                  <Grid ColumnDefinitions="110,*,90,*">
                                    <TextBlock Grid.Column="0" Text="Batch / Lot" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding BatchNumber, Mode=TwoWay}"
                                             PlaceholderText="e.g. LOT-2401"/>
                                    <TextBlock Grid.Column="2" Text="Item" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Items}"
                                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                              PlaceholderText="batch-tracked item…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:StockItem">
                                          <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="110,*,90,*">
                                    <TextBlock Grid.Column="0" Text="Godown" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding GodownOptions}"
                                              SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                              PlaceholderText="(unspecified)">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:OptionalGodownOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Mfg date" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding ManufacturingDateText, Mode=TwoWay}"
                                             PlaceholderText="dd-MMM-yyyy (optional)"/>
                                  </Grid>

                                  <!-- Expiry: an absolute date OR a period (RQ-4) -->
                                  <Border Background="#FBF7EE"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10">
                                    <StackPanel Spacing="8">
                                      <TextBlock Text="Expiry — enter a date OR a period (resolved from mfg date)"
                                                 FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <Grid ColumnDefinitions="110,*,70,90,120">
                                        <TextBlock Grid.Column="0" Text="Expiry date" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="1" Text="{Binding ExpiryDateText, Mode=TwoWay}"
                                                 PlaceholderText="dd-MMM-yyyy"/>
                                        <TextBlock Grid.Column="2" Text="or" FontStyle="Italic"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#6A6A6A"/>
                                        <TextBox Grid.Column="3" Text="{Binding ExpiryPeriodCountText, Mode=TwoWay}"
                                                 TextAlignment="Right" PlaceholderText="count"/>
                                        <ComboBox Grid.Column="4" HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                                  ItemsSource="{Binding ExpiryUnits}"
                                                  SelectedItem="{Binding ExpiryPeriodUnit, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ExpiryPeriodUnitOption">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>
                                  </Border>

                                  <!-- Opening inward cost layer (optional; RQ-6/DP-8) -->
                                  <Grid ColumnDefinitions="110,*,90,*">
                                    <TextBlock Grid.Column="0" Text="Opening qty" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding OpeningQuantityText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="0 (optional)"/>
                                    <TextBlock Grid.Column="2" Text="Rate ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding OpeningRateText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="0.00"/>
                                  </Grid>

                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Message}"
                                               IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{StaticResource AlertRed}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnCreateBatchClick"/>
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </ScrollViewer>

                            <!-- Existing batches header — column widths MUST match the row template below so the
                                 labels sit over their data (Opening ₹ widened so the amounts don't clip). -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="118,*,96,92,124,96">
                                <TextBlock Grid.Column="0" Text="Batch / Lot" Classes="colHdr" Margin="8,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="Item" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Godown" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Mfg Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Expiry" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Opening ₹" Classes="colHdr"
                                           TextAlignment="Right" Margin="0,0,10,0"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BatchListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="118,*,96,92,124,96" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding BatchNumber}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Item}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Godown}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding MfgDate}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Expiry}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" Text="{Binding OpeningValue}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Batch-allocation sub-screen (voucher entry) — Phase 6 Cluster 1 (RQ-3/RQ-7) -->
                    <ContentControl IsVisible="{Binding BatchAllocation, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BatchAllocation}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BatchAllocationViewModel">
                          <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="Batch Allocation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,6"/>

                            <!-- Context header: item + godown + qty to allocate -->
                            <Border Grid.Row="1" Background="#EEF4FB"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="12,8" Margin="0,0,0,8">
                              <StackPanel Orientation="Horizontal" Spacing="18">
                                <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GodownName}" Foreground="#555555" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LineQuantityText}" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandNavy}" VerticalAlignment="Center"/>
                              </StackPanel>
                            </Border>

                            <!-- Header + rows share ONE fixed width inside a horizontal scroller (as the batch
                                 REPORTS do) so the Rate column can never be clipped by the page pane; the six
                                 columns (156,88,92,92,66,66 = 560) fit the ~626px pane, and the h-scroll is a
                                 safety net if the pane is ever narrower. Header and rows use IDENTICAL widths. -->
                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" Background="White">
                              <Grid RowDefinitions="Auto,*" Width="560" HorizontalAlignment="Left">
                                <!-- Column header: Batch | New No. | Mfg | Expiry | Qty | Rate -->
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="156,88,92,92,66,66">
                                    <TextBlock Grid.Column="0" Text="Batch / Lot" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="New No." Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Mfg Dt." Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Expiry" Classes="colHdr"/>
                                    <TextBlock Grid.Column="4" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>

                                <!-- Repeatable batch lines -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled" Background="White">
                                  <ItemsControl ItemsSource="{Binding Lines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:BatchAllocationLineViewModel">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Padding="0,2">
                                          <StackPanel>
                                            <Grid ColumnDefinitions="156,88,92,92,66,66">
                                              <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" Margin="4,0"
                                                        ItemsSource="{Binding BatchOptions}"
                                                        SelectedItem="{Binding SelectedBatch, Mode=TwoWay}"
                                                        PlaceholderText="pick / New…">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate x:DataType="vm:BatchPickOption">
                                                    <TextBlock Text="{Binding Display}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="1" Text="{Binding NewBatchNumber, Mode=TwoWay}"
                                                       Margin="2,0" PlaceholderText="new no."/>
                                              <TextBox Grid.Column="2" Text="{Binding ManufacturingDateText, Mode=TwoWay}"
                                                       Margin="2,0" FontSize="11"/>
                                              <TextBox Grid.Column="3" Text="{Binding ExpiryText, Mode=TwoWay}"
                                                       Margin="2,0" FontSize="11"/>
                                              <TextBox Grid.Column="4" Text="{Binding QuantityText, Mode=TwoWay}"
                                                       Margin="2,0" TextAlignment="Right"/>
                                              <TextBox Grid.Column="5" Text="{Binding RateText, Mode=TwoWay}"
                                                       Margin="2,0" TextAlignment="Right"/>
                                            </Grid>
                                            <!-- Non-blocking expiry warning (RQ-7): red when expired, amber near-expiry -->
                                            <TextBlock Text="{Binding Warning}" Margin="8,1,0,2" FontSize="11"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding Warning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       Foreground="{Binding IsExpired, Converter={StaticResource ExpiryWarningBrush}}"/>
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>
                              </Grid>
                            </ScrollViewer>

                            <!-- Balance line + Accept -->
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                              <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding RemainingText}" FontSize="12"
                                           FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                              <Button Grid.Column="1" Content="Accept (Ctrl+A)" Padding="14,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnAcceptBatchAllocationClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Bill of Materials master (create + list) — Phase 6 Cluster 2 (RQ-9/RQ-10/RQ-54) -->
                    <ContentControl IsVisible="{Binding BomMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BomMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BomMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Bill of Materials Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Create form -->
                            <ScrollViewer Grid.Row="1" MaxHeight="370" Margin="0,0,0,10">
                              <Border Background="White"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="16">
                                <StackPanel Spacing="10">
                                  <Grid ColumnDefinitions="120,*,120,90">
                                    <TextBlock Grid.Column="0" Text="BOM name" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                             PlaceholderText="e.g. Standard"/>
                                    <TextBlock Grid.Column="2" Text="Unit of Mfg" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding UnitOfManufactureText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="1"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="Finished good" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding FinishedGoods}"
                                              SelectedItem="{Binding SelectedFinishedGood, Mode=TwoWay}"
                                              PlaceholderText="finished-good item…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:StockItem">
                                          <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>

                                  <!-- Component / output line grid -->
                                  <Border Background="#FBF7EE"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="10,8">
                                    <StackPanel Spacing="6">
                                      <TextBlock Text="Components &amp; outputs (per unit-of-manufacture block)"
                                                 FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                    VerticalScrollBarVisibility="Disabled">
                                        <Grid RowDefinitions="Auto,*" Width="596" HorizontalAlignment="Left">
                                          <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                            <Grid ColumnDefinitions="176,110,110,70,60,70">
                                              <TextBlock Grid.Column="0" Text="Item" Classes="colHdr"/>
                                              <TextBlock Grid.Column="1" Text="Godown" Classes="colHdr"/>
                                              <TextBlock Grid.Column="2" Text="Type" Classes="colHdr"/>
                                              <TextBlock Grid.Column="3" Text="Qty/blk" Classes="colHdr" TextAlignment="Right"/>
                                              <TextBlock Grid.Column="4" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                              <TextBlock Grid.Column="5" Text="%" Classes="colHdr" TextAlignment="Right"/>
                                            </Grid>
                                          </Border>
                                          <ItemsControl Grid.Row="1" ItemsSource="{Binding Lines}">
                                            <ItemsControl.ItemTemplate>
                                              <DataTemplate x:DataType="vm:BomLineRowViewModel">
                                                <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                        Padding="0,2">
                                                  <Grid ColumnDefinitions="176,110,110,70,60,70">
                                                    <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" Margin="2,0"
                                                              ItemsSource="{Binding ItemOptions}"
                                                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                              PlaceholderText="item…">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="ledger:StockItem">
                                                          <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" Margin="2,0"
                                                              ItemsSource="{Binding GodownOptions}"
                                                              SelectedItem="{Binding SelectedGodown, Mode=TwoWay}">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:OptionalGodownOption">
                                                          <TextBlock Text="{Binding Display}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <!-- Type picker only when the F12 "Define type of component"
                                                         config is on (RQ-10); otherwise every line is a Component. -->
                                                    <ComboBox Grid.Column="2" HorizontalAlignment="Stretch" Margin="2,0"
                                                              IsVisible="{Binding ShowTypePicker}"
                                                              ItemsSource="{Binding TypeOptions}"
                                                              SelectedItem="{Binding SelectedType, Mode=TwoWay}">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:BomLineTypeOption">
                                                          <TextBlock Text="{Binding Display}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Grid.Column="2" Text="Component" FontSize="11"
                                                               IsVisible="{Binding !ShowTypePicker}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                                               Foreground="#6A6A6A"/>
                                                    <TextBox Grid.Column="3" Text="{Binding QuantityText, Mode=TwoWay}"
                                                             Margin="2,0" TextAlignment="Right"/>
                                                    <TextBox Grid.Column="4" Text="{Binding CarveOutRateText, Mode=TwoWay}"
                                                             Margin="2,0" TextAlignment="Right" FontSize="11"
                                                             IsVisible="{Binding IsCarveOut}"/>
                                                    <TextBox Grid.Column="5" Text="{Binding CarveOutPercentText, Mode=TwoWay}"
                                                             Margin="2,0" TextAlignment="Right" FontSize="11"
                                                             IsVisible="{Binding IsCarveOut}"/>
                                                  </Grid>
                                                </Border>
                                              </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                          </ItemsControl>
                                        </Grid>
                                      </ScrollViewer>
                                      <Button Content="+ Add line" Padding="10,3" HorizontalAlignment="Left"
                                              FontSize="11" Click="OnAddBomLineClick"/>
                                    </StackPanel>
                                  </Border>

                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Message}"
                                               IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{StaticResource AlertRed}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnCreateBomClick"/>
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </ScrollViewer>

                            <!-- Existing BOMs header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="140,150,70,*,*">
                                <TextBlock Grid.Column="0" Text="BOM" Classes="colHdr" Margin="8,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="Finished Good" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Unit" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Components" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Carve-outs" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BomListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="140,150,70,*,*" Height="26">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FinishedGood}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding UnitOfManufacture}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Components}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding CarveOuts}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No bills of materials created yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Manufacturing Journal voucher entry — Phase 6 Cluster 2 (RQ-11/12/13/15) -->
                    <ContentControl IsVisible="{Binding ManufacturingJournalEntry, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ManufacturingJournalEntry}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ManufacturingJournalEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Header form: finished good + BOM + qty + date + godowns -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="14" Margin="0,0,0,8">
                              <StackPanel Spacing="9">
                                <Grid ColumnDefinitions="110,*,90,110">
                                  <TextBlock Grid.Column="0" Text="Finished good" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding FinishedGoods}"
                                            SelectedItem="{Binding SelectedFinishedGood, Mode=TwoWay}"
                                            PlaceholderText="finished-good item…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:StockItem">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Qty" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding QuantityText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="1"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*,90,110">
                                  <TextBlock Grid.Column="0" Text="BOM" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Boms}"
                                            SelectedItem="{Binding SelectedBom, Mode=TwoWay}"
                                            PlaceholderText="BOM…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:BomOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding DateText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*,110,*">
                                  <TextBlock Grid.Column="0" Text="Consume from" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Godowns}"
                                            SelectedItem="{Binding ConsumptionGodown, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Godown">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Produce into" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Godowns}"
                                            SelectedItem="{Binding ProductionGodown, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Godown">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Scrollable body: consumption + additional cost + carve-outs -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                              <StackPanel Spacing="8">
                                <!-- Auto-scaled component consumption (read-only, RQ-12) — from the engine preview -->
                                <TextBlock Text="Component consumption (auto-scaled — from the engine)"
                                           FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,110,110,110,120">
                                    <TextBlock Grid.Column="0" Text="Component" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Batch" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Consumption}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ManufacturingConsumptionRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                              Background="White">
                                        <Grid ColumnDefinitions="*,110,110,110,120" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Item}" Margin="8,0"
                                                     VerticalAlignment="Center" FontSize="12"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Batch}"
                                                     VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Quantity}" TextAlignment="Right"
                                                     Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Rate}" TextAlignment="Right"
                                                     Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11.5"
                                                     Foreground="#555555"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Value}" TextAlignment="Right"
                                                     Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Additional cost lines (labour/overhead/freight → adds to FG value, RQ-13) -->
                                <TextBlock Text="Additional costs (labour / overhead / freight)"
                                           FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <ItemsControl ItemsSource="{Binding AdditionalCosts}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ManufacturingAdditionalCostRowViewModel">
                                      <Grid ColumnDefinitions="*,140" Margin="0,1">
                                        <TextBox Grid.Column="0" Text="{Binding Name, Mode=TwoWay}" Margin="0,0,4,0"
                                                 PlaceholderText="cost name (e.g. Labour)"/>
                                        <TextBox Grid.Column="1" Text="{Binding AmountText, Mode=TwoWay}"
                                                 TextAlignment="Right" PlaceholderText="₹ amount"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add cost" Padding="10,3" HorizontalAlignment="Left"
                                        FontSize="11" Click="OnAddManufacturingCostClick"/>

                                <!-- Carve-outs (by-product / co-product / scrap, read-only, RQ-13/DP-3) -->
                                <StackPanel Spacing="4" IsVisible="{Binding CarveOuts.Count}">
                                  <TextBlock Text="Carve-outs (by-product / co-product / scrap — from the engine)"
                                             FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="*,120,120,120">
                                      <TextBlock Grid.Column="0" Text="Output" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Kind" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="3" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding CarveOuts}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ManufacturingCarveOutRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Background="White">
                                          <Grid ColumnDefinitions="*,120,120,120" Height="24">
                                            <TextBlock Grid.Column="0" Text="{Binding Item}" Margin="8,0"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Kind}"
                                                       VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Quantity}" TextAlignment="Right"
                                                       Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Value}" TextAlignment="Right"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>

                                <!-- Finished-good valuation breakdown (RQ-13): components + add'l − carve-outs -->
                                <Border Background="#EEF4FB" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="14,10" Margin="0,4,0,0">
                                  <StackPanel Spacing="5">
                                    <TextBlock Text="Finished-Good Valuation"
                                               FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="*,130">
                                      <TextBlock Grid.Column="0" Text="Component cost" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding ComponentCostText}"
                                                 TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,130">
                                      <TextBlock Grid.Column="0" Text="+ Additional cost" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding AdditionalCostText}"
                                                 TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,130">
                                      <TextBlock Grid.Column="0" Text="− Carve-outs (by/co/scrap)" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding CarveOutText}"
                                                 TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Border BorderBrush="{StaticResource BrandNavy}" BorderThickness="0,1,0,0"
                                            Padding="0,4,0,0">
                                      <Grid ColumnDefinitions="*,150">
                                        <TextBlock Grid.Column="0" Text="= Finished-good value"
                                                   FontWeight="Bold" FontSize="13" Foreground="{StaticResource BrandNavy}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FinishedGoodValueText}"
                                                   TextAlignment="Right" FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                      </Grid>
                                    </Border>
                                    <Grid ColumnDefinitions="*,150">
                                      <TextBlock Grid.Column="0" Text="Unit rate" FontSize="12" Foreground="#555555"/>
                                      <TextBlock Grid.Column="1" Text="{Binding FinishedGoodUnitRateText}"
                                                 TextAlignment="Right" FontSize="12" Foreground="#555555"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>
                              </StackPanel>
                            </ScrollViewer>

                            <!-- Message + Accept / Cancel -->
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource AlertRed}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                              <Button Grid.Column="1" Content="Cancel (Alt+X)" Padding="12,6" Margin="0,0,8,0"
                                      Click="OnCancelManufacturingJournalClick"/>
                              <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnAcceptManufacturingJournalClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: POS Billing voucher entry — Phase 6 slice 7 (RQ-38..RQ-44) -->
                    <ContentControl IsVisible="{Binding PosBilling, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding PosBilling}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PosBillingViewModel">
                          <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Header: party (walk-in) / Sales ledger / godown / date + payment mode -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="14" Margin="0,0,0,8">
                              <StackPanel Spacing="9">
                                <Grid ColumnDefinitions="110,*,90,150">
                                  <TextBlock Grid.Column="0" Text="Customer" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Parties}"
                                            SelectedItem="{Binding SelectedParty, Mode=TwoWay}"
                                            PlaceholderText="(cash) walk-in…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:PartyOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding DateText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*,90,150">
                                  <TextBlock Grid.Column="0" Text="Sales ledger" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding SalesLedgers}"
                                            SelectedItem="{Binding SelectedSalesLedger, Mode=TwoWay}"
                                            PlaceholderText="Sales A/c…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Ledger">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Godown" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Godowns}"
                                            SelectedItem="{Binding SelectedGodown, Mode=TwoWay}"
                                            PlaceholderText="Godown…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Godown">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                             Text="{Binding PaymentModeText, StringFormat='Payment mode: {0}'}"/>
                                  <Button Grid.Column="1" Content="Payment Mode (Alt+I)" Padding="10,5"
                                          Click="OnTogglePosPaymentModeClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                              <StackPanel Spacing="10">
                                <!-- Item lines: Item / Qty / Rate -->
                                <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,90,120">
                                      <TextBlock Grid.Column="0" Text="Item" FontWeight="Bold"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBlock Grid.Column="1" Text="Qty" FontWeight="Bold" TextAlignment="Right"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBlock Grid.Column="2" Text="Rate" FontWeight="Bold" TextAlignment="Right"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InventoryVoucherLineViewModel">
                                          <Grid ColumnDefinitions="*,90,120" Margin="0,2">
                                            <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding StockItems}"
                                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                      PlaceholderText="stock item…">
                                              <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="ledger:StockItem">
                                                  <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                              </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBox Grid.Column="1" Text="{Binding QuantityText, Mode=TwoWay}"
                                                     TextAlignment="Right" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="2" Text="{Binding RateText, Mode=TwoWay}"
                                                     TextAlignment="Right" Margin="4,0,0,0"/>
                                          </Grid>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="+ Add item" Padding="10,4" HorizontalAlignment="Left"
                                            Click="OnAddPosItemLineClick"/>
                                  </StackPanel>
                                </Border>

                                <!-- Live totals -->
                                <Border Background="#EEF4FB" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="14,10">
                                  <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,150">
                                      <TextBlock Grid.Column="0" Text="Items total" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding ItemsTotalText}" TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,150">
                                      <TextBlock Grid.Column="0" Text="CGST" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding GstCgstText}" TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,150">
                                      <TextBlock Grid.Column="0" Text="SGST" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding GstSgstText}" TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,150">
                                      <TextBlock Grid.Column="0" Text="IGST" FontSize="12.5"/>
                                      <TextBlock Grid.Column="1" Text="{Binding GstIgstText}" TextAlignment="Right" FontSize="12.5"/>
                                    </Grid>
                                    <Border BorderBrush="{StaticResource BrandNavy}" BorderThickness="0,1,0,0" Padding="0,4,0,0">
                                      <Grid ColumnDefinitions="*,150">
                                        <TextBlock Grid.Column="0" Text="Bill total" FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding BillTotalText}" TextAlignment="Right"
                                                   FontWeight="Bold" FontSize="13" Foreground="{StaticResource BrandNavy}"/>
                                      </Grid>
                                    </Border>
                                  </StackPanel>
                                </Border>

                                <!-- SINGLE tender: one Cash tender for the whole bill -->
                                <Border IsVisible="{Binding !IsMultiTender}" Background="White"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="14,10">
                                  <StackPanel Spacing="7" DataContext="{Binding CashRow}" x:DataType="vm:PosTenderRowViewModel">
                                    <TextBlock Text="Payment — Single (Cash)" FontWeight="Bold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="120,*">
                                      <TextBlock Grid.Column="0" Text="Cash ledger" VerticalAlignment="Center"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding LedgerChoices}"
                                                SelectedItem="{Binding SelectedLedger, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="ledger:Ledger">
                                            <TextBlock Text="{Binding Name}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <Grid ColumnDefinitions="120,140,120,140">
                                      <TextBlock Grid.Column="0" Text="Cash tendered" VerticalAlignment="Center"/>
                                      <TextBox Grid.Column="1" Text="{Binding CashTenderedText, Mode=TwoWay}" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="2" Text="Change" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                      <TextBox Grid.Column="3" Text="{Binding ChangeText}" IsReadOnly="True" TextAlignment="Right"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- MULTI tender: Gift / Card / Cheque / Cash (Cash auto-fills the residual) -->
                                <Border IsVisible="{Binding IsMultiTender}" Background="White"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="14,10">
                                  <StackPanel Spacing="6">
                                    <TextBlock Text="Payment — Multi Tender" FontWeight="Bold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ItemsControl ItemsSource="{Binding Tenders}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PosTenderRowViewModel">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1" Padding="0,4">
                                            <StackPanel Spacing="4">
                                              <Grid ColumnDefinitions="120,*,130">
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding LedgerChoices}"
                                                          SelectedItem="{Binding SelectedLedger, Mode=TwoWay}"
                                                          PlaceholderText="ledger…">
                                                  <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="ledger:Ledger">
                                                      <TextBlock Text="{Binding Name}"/>
                                                    </DataTemplate>
                                                  </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBox Grid.Column="2" Text="{Binding AmountText, Mode=TwoWay}"
                                                         IsEnabled="{Binding !AmountReadOnly}" TextAlignment="Right"
                                                         Margin="4,0,0,0"/>
                                              </Grid>
                                              <TextBox IsVisible="{Binding ShowCardNo}" Text="{Binding CardNo, Mode=TwoWay}"
                                                       PlaceholderText="Card No." Margin="120,0,0,0"/>
                                              <Grid IsVisible="{Binding ShowChequeRefs}" ColumnDefinitions="*,*" Margin="120,0,0,0">
                                                <TextBox Grid.Column="0" Text="{Binding BankName, Mode=TwoWay}" PlaceholderText="Bank name" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding ChequeNo, Mode=TwoWay}" PlaceholderText="Cheque No."/>
                                              </Grid>
                                              <Grid IsVisible="{Binding ShowCashFields}" ColumnDefinitions="120,140,120,140" Margin="120,0,0,0">
                                                <TextBlock Grid.Column="0" Text="Cash tendered" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding CashTenderedText, Mode=TwoWay}" TextAlignment="Right"/>
                                                <TextBlock Grid.Column="2" Text="Change" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                <TextBox Grid.Column="3" Text="{Binding ChangeText}" IsReadOnly="True" TextAlignment="Right"/>
                                              </Grid>
                                            </StackPanel>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid ColumnDefinitions="*,150">
                                      <TextBlock Grid.Column="0" FontSize="12.5"
                                                 Text="{Binding TenderBalanceText, StringFormat='Σ tenders — {0}'}"/>
                                      <TextBlock Grid.Column="1" Text="{Binding TendersTotalText}" TextAlignment="Right"
                                                 FontWeight="Bold" FontSize="12.5"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Retail-receipt settings (RQ-44 / §4.3): print-after-save + title/messages/declaration on the POS type -->
                                <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="14,10">
                                  <StackPanel Spacing="6" Grid.IsSharedSizeScope="True">
                                    <TextBlock Text="Retail Receipt" FontWeight="Bold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <CheckBox Content="Print receipt after Accept"
                                              IsChecked="{Binding PrintAfterSave, Mode=TwoWay}"/>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PosRcpt"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="Receipt title" VerticalAlignment="Center" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>
                                      <TextBox Grid.Column="1" Text="{Binding ReceiptTitle, Mode=TwoWay}"
                                               PlaceholderText="Retail Invoice"/>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PosRcpt"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="Message line 1" VerticalAlignment="Center" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>
                                      <TextBox Grid.Column="1" Text="{Binding Message1, Mode=TwoWay}"
                                               PlaceholderText="Thank-you message…"/>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PosRcpt"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="Message line 2" VerticalAlignment="Center" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>
                                      <TextBox Grid.Column="1" Text="{Binding Message2, Mode=TwoWay}"
                                               PlaceholderText="(optional)"/>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PosRcpt"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Grid.Column="0" Text="Declaration" VerticalAlignment="Center" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>
                                      <TextBox Grid.Column="1" Text="{Binding Declaration, Mode=TwoWay}"
                                               PlaceholderText="(optional)" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Tax analysis (Alt+A) -->
                                <Border IsVisible="{Binding IsTaxAnalysisVisible}" Background="#FFF7E6"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="12,8">
                                  <StackPanel Spacing="3">
                                    <TextBlock Text="Tax Analysis" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Text="{Binding TaxAnalysisText}" FontSize="12" TextWrapping="Wrap"/>
                                  </StackPanel>
                                </Border>
                              </StackPanel>
                            </ScrollViewer>

                            <!-- Message + Accept / Cancel / Tax Analysis -->
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource AlertRed}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                              <Button Grid.Column="1" Content="Tax Analysis (Alt+A)" Padding="10,6" Margin="0,0,8,0"
                                      Click="OnShowPosTaxAnalysisClick"/>
                              <Button Grid.Column="2" Content="Cancel (Alt+X)" Padding="12,6" Margin="0,0,8,0"
                                      Click="OnCancelPosClick"/>
                              <Button Grid.Column="3" Content="Accept (Ctrl+A)" Padding="14,6"
                                      IsEnabled="{Binding CanAccept}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnAcceptPosClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Price Level master (create + list) — Phase 6 slice 5 (RQ-26/RQ-54) -->
                    <ContentControl IsVisible="{Binding PriceLevels, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding PriceLevels}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PriceLevelsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Price Level Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Wholesale, Retail"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreatePriceLevelClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing price levels header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,140">
                                <TextBlock Grid.Column="0" Text="Price Level" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Price Lists" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PriceLevelListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,140" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Lists}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No price levels created yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Price List master (level+item, dated slabs, append-only history) — Phase 6 slice 5 (RQ-27/RQ-28) -->
                    <ContentControl IsVisible="{Binding PriceLists, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding PriceLists}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PriceListsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="Price List Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Header: level + item + applicable-from -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="14" Margin="0,0,0,8">
                              <!-- Auto + SharedSizeGroup: a fixed 110 sliced "Applicable From" to "Applicable Fror"
                                   at the TextBox border. The shared group keeps this row's input edge aligned with
                                   the Price Level row above it. -->
                              <StackPanel Spacing="8" Grid.IsSharedSizeScope="True">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PlLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PlLabelR"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Price Level" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Levels}"
                                            SelectedItem="{Binding SelectedLevel, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:PriceLevel">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Item" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Items}"
                                            SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:StockItem">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PlLabelL"/>
                                    <ColumnDefinition Width="200"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Applicable From" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding ApplicableFromText, Mode=TwoWay}"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Slab grid header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,*,*,*">
                                <TextBlock Grid.Column="0" Text="From Qty" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="To Qty (blank = onwards)" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Discount %" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Slabs}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PriceListSlabRowViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,*,*,*" Height="30" Margin="2">
                                        <TextBox Grid.Column="0" Text="{Binding FromText, Mode=TwoWay}" Margin="2,0"
                                                 PlaceholderText="0"/>
                                        <TextBox Grid.Column="1" Text="{Binding ToText, Mode=TwoWay}" Margin="2,0"
                                                 PlaceholderText="onwards"/>
                                        <TextBox Grid.Column="2" Text="{Binding RateText, Mode=TwoWay}" Margin="2,0"
                                                 TextAlignment="Right"/>
                                        <TextBox Grid.Column="3" Text="{Binding DiscountText, Mode=TwoWay}" Margin="2,0"
                                                 TextAlignment="Right" PlaceholderText="0"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- History + actions -->
                            <StackPanel Grid.Row="4" Spacing="6" Margin="0,8,0,0">
                              <TextBlock Text="Existing dated versions (a revision appends a new version — history is kept)"
                                         FontSize="11.5" FontStyle="Italic" Foreground="#6A6A6A"/>
                              <ScrollViewer MaxHeight="120" Background="White"
                                            BorderBrush="{StaticResource GridLine}" BorderThickness="1">
                                <ItemsControl ItemsSource="{Binding History}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PriceListVersionRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding ApplicableFrom}" Margin="8,0"
                                                     VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Slabs}" Margin="0,0,8,0"
                                                     VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"
                                                     TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Content="+ Add slab" Padding="12,6" Margin="0,0,8,0"
                                        Click="OnAddPriceListSlabClick"/>
                                <Button Grid.Column="2" Content="Save (Ctrl+A)" Padding="14,6"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnSavePriceListClick"/>
                              </Grid>
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Reorder Levels master (per Item / Group / Category; Simple⇄Advanced) — Phase 6 slice 6 (RQ-32..35/53) -->
                    <ContentControl IsVisible="{Binding ReorderLevels, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ReorderLevels}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ReorderLevelsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Reorder Levels"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,8"/>

                            <!-- Create / upsert form -->
                            <ScrollViewer Grid.Row="1" MaxHeight="330" Margin="0,0,0,10">
                              <Border Background="White"
                                      BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="16">
                                <StackPanel Spacing="10">
                                  <!-- Scope + target -->
                                  <Grid ColumnDefinitions="110,*,90,*">
                                    <TextBlock Grid.Column="0" Text="Scope" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Scopes}"
                                              SelectedItem="{Binding SelectedScope, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ReorderScopeOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Target" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Targets}"
                                              SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                                              PlaceholderText="item / group / category…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ReorderTargetOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>

                                  <!-- Reorder level: Simple (fixed) or Advanced (Alt+S) -->
                                  <Grid ColumnDefinitions="110,*,200">
                                    <TextBlock Grid.Column="0" Text="Reorder level" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding ReorderQuantityText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="qty (optional)"/>
                                    <CheckBox Grid.Column="2" Margin="10,0,0,0"
                                              IsChecked="{Binding ReorderAdvanced, Mode=TwoWay}"
                                              Content="Advanced (Alt+S)"/>
                                  </Grid>

                                  <!-- Min order qty: Simple (fixed) or Advanced (Alt+V) -->
                                  <Grid ColumnDefinitions="110,*,200">
                                    <TextBlock Grid.Column="0" Text="Min order qty" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding MinOrderQtyText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="qty (optional)"/>
                                    <CheckBox Grid.Column="2" Margin="10,0,0,0"
                                              IsChecked="{Binding MinQtyAdvanced, Mode=TwoWay}"
                                              Content="Advanced (Alt+V)"/>
                                  </Grid>

                                  <!-- Advanced consumption period + Higher/Lower criterion (shown only when Advanced) -->
                                  <Border Background="#FBF7EE"
                                          BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                          Padding="12,10" IsVisible="{Binding IsAdvanced}">
                                    <StackPanel Spacing="8">
                                      <TextBlock Text="Advanced — reconcile the fixed figure against consumption over a rolling period"
                                                 FontWeight="SemiBold" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <Grid ColumnDefinitions="110,90,140,90,*">
                                        <TextBlock Grid.Column="0" Text="Period" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                        <TextBox Grid.Column="1" Text="{Binding PeriodCountText, Mode=TwoWay}"
                                                 TextAlignment="Right" PlaceholderText="count"/>
                                        <ComboBox Grid.Column="2" HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                                  ItemsSource="{Binding PeriodUnits}"
                                                  SelectedItem="{Binding SelectedPeriodUnit, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ExpiryPeriodUnitOption">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Grid.Column="3" Text="Criteria" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <ComboBox Grid.Column="4" HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                                  ItemsSource="{Binding Criteria}"
                                                  SelectedItem="{Binding SelectedCriteria, Mode=TwoWay}">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ReorderCriteriaOption">
                                              <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                    </StackPanel>
                                  </Border>

                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Message}"
                                               IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{StaticResource AlertRed}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Save (Ctrl+A)" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnCreateReorderLevelClick"/>
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </ScrollViewer>

                            <!-- Existing definitions header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="90,*,120,120,120,100">
                                <TextBlock Grid.Column="0" Text="Scope" Classes="colHdr" Margin="8,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="Target" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Reorder Level" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Min Order Qty" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Period" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Criteria" Classes="colHdr"
                                           TextAlignment="Right" Margin="0,0,10,0"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ReorderLevelListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="90,*,120,120,120,100" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Scope}" Margin="8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Target}" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Reorder}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding MinQty}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Period}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Criteria}" TextAlignment="Right"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No reorder levels defined yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- ================= PAYROLL MASTERS (Phase 8 slice 1) ================= -->

                    <!-- PAGE: Employee Category master (create + list) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).EmployeeCategoryMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).EmployeeCategoryMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EmployeeCategoryMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Employee Category Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. On-Roll / Contract"/>
                                </Grid>
                                <CheckBox Content="Allocate Revenue Items"
                                          IsChecked="{Binding AllocateRevenueItems, Mode=TwoWay}" FontSize="13"/>
                                <CheckBox Content="Allocate Non-Revenue Items"
                                          IsChecked="{Binding AllocateNonRevenueItems, Mode=TwoWay}" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateEmployeeCategoryClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,170,90,90">
                                <TextBlock Grid.Column="0" Text="Employee Category" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Allocates" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Employees" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Kind" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:EmployeeCategoryListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,170,90,90" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Allocates}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Employees}"
                                                   TextAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Kind}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No employee categories created yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Employee Group master (hierarchical; create + list) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).EmployeeGroupMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).EmployeeGroupMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EmployeeGroupMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Employee Group Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="100,*,80,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Marketing"/>
                                  <TextBlock Grid.Column="2" Text="Alias" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding Alias, Mode=TwoWay}"
                                           PlaceholderText="optional"/>
                                </Grid>
                                <Grid ColumnDefinitions="100,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentEmployeeGroupOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <CheckBox Content="Define salary details?"
                                          IsChecked="{Binding DefineSalaryDetails, Mode=TwoWay}" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateEmployeeGroupClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,200,120">
                                <TextBlock Grid.Column="0" Text="Employee Group" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Salary" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:EmployeeGroupListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,200,120" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Salary}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Employee master (identity + statutory ids + regime; create + list) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).EmployeeMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).EmployeeMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EmployeeMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Employee Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <TextBlock IsVisible="{Binding !CanCreate}"
                                           Text="Create an Employee Group first (Payroll Masters → Employee Group) — an employee must belong to a group."
                                           FontSize="11" Foreground="#B00020" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="120,*,120,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Rajkumar Sharma"/>
                                  <TextBlock Grid.Column="2" Text="Employee No." FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding EmployeeNumber, Mode=TwoWay}"
                                           PlaceholderText="optional"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,*,120,*">
                                  <TextBlock Grid.Column="0" Text="Employee Group" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding GroupOptions}"
                                            SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                            PlaceholderText="group…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:EmployeeGroupOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Category" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding CategoryOptions}"
                                            SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                            PlaceholderText="None…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:EmployeeCategoryOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="120,*,120,*">
                                  <TextBlock Grid.Column="0" Text="Date of Joining" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding DateOfJoiningText, Mode=TwoWay}"
                                           PlaceholderText="yyyy-MM-dd (optional)"/>
                                  <TextBlock Grid.Column="2" Text="Designation" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding Designation, Mode=TwoWay}"
                                           PlaceholderText="e.g. Manager"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,*,120,*">
                                  <TextBlock Grid.Column="0" Text="Gender" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding GenderOptions}"
                                            SelectedItem="{Binding SelectedGender, Mode=TwoWay}"/>
                                  <TextBlock Grid.Column="2" Text="Tax Regime" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Regimes}"
                                            SelectedItem="{Binding SelectedRegime, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:TaxRegimeOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="120,*,120,*">
                                  <TextBlock Grid.Column="0" Text="PAN" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Pan, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="e.g. AAPFU0939F (optional)"/>
                                  <TextBlock Grid.Column="2" Text="UAN" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding Uan, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="12 digits (optional)"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,*,120,*">
                                  <TextBlock Grid.Column="0" Text="ESI No." FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding EsiNumber, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="IP no. — 10 digits (optional)"/>
                                  <TextBlock Grid.Column="2" Text="Date of Birth" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding DateOfBirthText, Mode=TwoWay}"
                                           PlaceholderText="yyyy-MM-dd (optional)"/>
                                </Grid>

                                <!-- Additional statutory / location / bank details (RQ-2): captured here so an
                                     interactively-created employee is complete for the PF/ESI/salary-payment slices. -->
                                <Expander Header="Location, bank &amp; statutory details">
                                  <StackPanel Spacing="10" Margin="0,8,0,0">
                                    <Grid ColumnDefinitions="120,*,120,*">
                                      <TextBlock Grid.Column="0" Text="Location" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding Location, Mode=TwoWay}"
                                               PlaceholderText="e.g. Mumbai (optional)"/>
                                      <TextBlock Grid.Column="2" Text="Function" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding Function, Mode=TwoWay}"
                                               PlaceholderText="e.g. Sales (optional)"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="120,*,120,*">
                                      <TextBlock Grid.Column="0" Text="Aadhaar" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding Aadhaar, Mode=TwoWay}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               PlaceholderText="12 digits (optional)"/>
                                      <TextBlock Grid.Column="2" Text="PF A/c No." FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding PfAccountNumber, Mode=TwoWay}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               PlaceholderText="PF account no. (optional)"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="120,*,120,*">
                                      <TextBlock Grid.Column="0" Text="Bank A/c No." FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding BankAccountNumber, Mode=TwoWay}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               PlaceholderText="account no. (optional)"/>
                                      <TextBlock Grid.Column="2" Text="Bank Name" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding BankName, Mode=TwoWay}"
                                               PlaceholderText="e.g. State Bank (optional)"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="120,*,120,*">
                                      <TextBlock Grid.Column="0" Text="Bank IFSC" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding BankIfsc, Mode=TwoWay}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               PlaceholderText="e.g. SBIN0001234 (optional)"/>
                                      <TextBlock Grid.Column="2" Text="" />
                                      <TextBlock Grid.Column="3" Text="" />
                                    </Grid>

                                    <!-- Provident-Fund details (Phase 8 slice 4; RQ-9) — shown only while Payroll
                                         Statutory is on. Marking PF-applicable requires a valid 12-digit UAN. -->
                                    <StackPanel Spacing="10" IsVisible="{Binding ShowPfDetails}">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                              Margin="0,4,0,0" Padding="0,10,0,0">
                                        <StackPanel Spacing="10">
                                          <TextBlock Text="PROVIDENT FUND" FontSize="10.5" FontWeight="Bold"
                                                     Foreground="#9098A8" LetterSpacing="1.5"/>
                                          <CheckBox Content="Provident Fund applicable (needs a valid 12-digit UAN above)"
                                                    IsChecked="{Binding PfApplicable, Mode=TwoWay}"
                                                    FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                          <Grid ColumnDefinitions="120,*,120,*" IsVisible="{Binding PfApplicable}">
                                            <TextBlock Grid.Column="0" Text="PF Join Date" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                            <TextBox Grid.Column="1" Text="{Binding PfJoinDateText, Mode=TwoWay}"
                                                     PlaceholderText="yyyy-MM-dd (optional)"/>
                                            <CheckBox Grid.Column="2" Grid.ColumnSpan="2"
                                                      Content="Contribute on higher wages (above ₹15,000)"
                                                      IsChecked="{Binding PfContributeOnHigherWages, Mode=TwoWay}"
                                                      Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                                          </Grid>
                                        </StackPanel>
                                      </Border>
                                    </StackPanel>

                                    <!-- Employees'-State-Insurance details (Phase 8 slice 5; RQ-10) — shown only
                                         while Payroll Statutory is on. Marking ESI-applicable requires a valid
                                         10-digit IP number (the ESI No. above), NOT the 17-digit employer code. -->
                                    <StackPanel Spacing="10" IsVisible="{Binding ShowEsiDetails}">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                              Margin="0,4,0,0" Padding="0,10,0,0">
                                        <StackPanel Spacing="10">
                                          <TextBlock Text="EMPLOYEES' STATE INSURANCE" FontSize="10.5" FontWeight="Bold"
                                                     Foreground="#9098A8" LetterSpacing="1.5"/>
                                          <CheckBox Content="ESI applicable (needs a valid 10-digit IP number in ESI No. above)"
                                                    IsChecked="{Binding EsiApplicable, Mode=TwoWay}"
                                                    FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                          <CheckBox Content="Person with disability (higher ₹25,000 coverage ceiling)"
                                                    IsChecked="{Binding EsiPersonWithDisability, Mode=TwoWay}"
                                                    IsEnabled="{Binding EsiApplicable}"
                                                    Foreground="{StaticResource BrandNavy}"/>
                                        </StackPanel>
                                      </Border>
                                    </StackPanel>
                                  </StackPanel>
                                </Expander>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateEmployeeClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,180,160,90">
                                <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Group" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Designation" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Regime" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:EmployeeListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,180,160,90" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Group}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Designation}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Regime}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Payroll Unit master (Simple/Compound toggle; create + list) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).PayrollUnitMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).PayrollUnitMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PayrollUnitMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Payroll Unit Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                  <RadioButton Content="Simple" GroupName="PayrollUnitType"
                                               IsChecked="{Binding !IsCompound, Mode=OneWay}"
                                               Click="OnPayrollUnitSimpleClick" FontSize="13"/>
                                  <RadioButton Content="Compound" GroupName="PayrollUnitType"
                                               IsChecked="{Binding IsCompound, Mode=OneWay}"
                                               Click="OnPayrollUnitCompoundClick" FontSize="13"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="100,*,110,*">
                                  <TextBlock Grid.Column="0" Text="Symbol" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Symbol, Mode=TwoWay}"
                                           PlaceholderText="e.g. Days / Hrs"/>
                                  <TextBlock Grid.Column="2" Text="Formal Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FormalName, Mode=TwoWay}"
                                           PlaceholderText="e.g. Days"/>
                                </Grid>

                                <!-- Simple-only field -->
                                <Grid ColumnDefinitions="100,110,*" IsVisible="{Binding ShowSimpleForm}">
                                  <TextBlock Grid.Column="0" Text="Decimals" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding DecimalPlacesText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="0"/>
                                  <TextBlock Grid.Column="2" Text="(0–4 decimal places)"
                                             VerticalAlignment="Center" Margin="12,0,0,0"
                                             FontSize="11" Foreground="#6A6A6A"/>
                                </Grid>

                                <!-- Compound-only fields -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsCompound}">
                                  <TextBlock IsVisible="{Binding !CanBuildCompound}"
                                             Text="A compound payroll unit needs two existing simple units — create at least two simple units first."
                                             FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                  <Grid ColumnDefinitions="100,*,90,80,80,*" IsVisible="{Binding CanBuildCompound}">
                                    <TextBlock Grid.Column="0" Text="First unit" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding SimpleUnits}"
                                              SelectedItem="{Binding FirstUnit, Mode=TwoWay}"
                                              PlaceholderText="base unit…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:PayrollUnit">
                                          <TextBlock Text="{Binding Symbol}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="× Factor" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding ConversionFactorText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="26"/>
                                    <TextBlock Grid.Column="4" Text="Tail" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="5" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding SimpleUnits}"
                                              SelectedItem="{Binding TailUnit, Mode=TwoWay}"
                                              PlaceholderText="tail unit…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ledger:PayrollUnit">
                                          <TextBlock Text="{Binding Symbol}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreatePayrollUnitClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="120,*,90,*">
                                <TextBlock Grid.Column="0" Text="Symbol" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Formal Name" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Kind" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Detail" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PayrollUnitListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="120,*,90,*" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FormalName}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Detail}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                            <!-- Reusable empty-state (C7): shown across the whole list body when none exist yet. -->
                            <views:EmptyState Grid.Row="3" Message="No payroll units created yet."
                                              IsVisible="{Binding Existing.Count, Converter={StaticResource CollectionEmpty}}"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Attendance / Production Type master (create + list) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).AttendanceTypeMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).AttendanceTypeMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:AttendanceTypeMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Attendance / Production Type Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="110,*,90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Present / Overtime"/>
                                  <TextBlock Grid.Column="2" Text="Type" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Kinds}"
                                            SelectedItem="{Binding SelectedKind, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:AttendanceTypeKindOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="110,*,90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ParentOptions}"
                                            SelectedItem="{Binding SelectedParent, Mode=TwoWay}"
                                            PlaceholderText="Primary…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ParentAttendanceTypeOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="Unit" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding UnitOptions}"
                                            SelectedItem="{Binding SelectedUnit, Mode=TwoWay}"
                                            PlaceholderText="None…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:AttendanceUnitOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateAttendanceTypeClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,140,185,80">
                                <TextBlock Grid.Column="0" Text="Attendance / Production Type" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Type" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Unit" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AttendanceTypeListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,140,185,80" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kind}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Unit}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Pay Head master (Phase 8 slice 2; adaptive per Calculation Type; create + list) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).PayHeadMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).PayHeadMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PayHeadMasterViewModel">
                          <Grid RowDefinitions="Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Pay Head Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <ScrollViewer Grid.Row="1">
                              <StackPanel Spacing="10">
                                <Border Background="White"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="16">
                                  <!-- Auto + SharedSizeGroup: the fixed 130 left only 120px after the 10px margin, so
                                       "Calculation Type" / "Income-Tax Comp." were sliced at the ComboBox border. The
                                       shared groups hold all six stacked rows' input edges on one vertical line. -->
                                  <StackPanel Spacing="10" Grid.IsSharedSizeScope="True">
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelL"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelR"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                               PlaceholderText="e.g. Basic Pay / HRA"/>
                                      <TextBlock Grid.Column="2" Text="Display Name" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,10,0"
                                                 TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding DisplayName, Mode=TwoWay}"
                                               PlaceholderText="on payslip (optional)"/>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelL"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelR"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Pay Head Type" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding Types}"
                                                SelectedItem="{Binding SelectedType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayHeadTypeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBlock Grid.Column="2" Text="Calculation Type" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,10,0"
                                                 TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding CalcTypes}"
                                                SelectedItem="{Binding SelectedCalcType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayHeadCalcTypeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelL"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelR"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Under (Group)" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding GroupOptions}"
                                                SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                                PlaceholderText="None…">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayHeadGroupOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBlock Grid.Column="2" Text="Income-Tax Comp." FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,10,0"
                                                 TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding IncomeTaxComponents}"
                                                SelectedItem="{Binding SelectedIncomeTaxComponent, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:IncomeTaxComponentOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <!-- The checkboxes span cols 0-1 / 2-3 and carry no label of their own, but they
                                         keep the SAME shared groups so the "Use for gratuity" box stays on the col-2
                                         line with the labels above and below it. -->
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelL"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelR"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <CheckBox Grid.Column="0" Grid.ColumnSpan="2" Content="Affects net salary"
                                                IsChecked="{Binding AffectsNetSalary, Mode=TwoWay}"
                                                FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                      <CheckBox Grid.Column="2" Grid.ColumnSpan="2" Content="Use for gratuity"
                                                Margin="10,0,0,0"
                                                IsChecked="{Binding UseForGratuity, Mode=TwoWay}"
                                                FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelL"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelR"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Rounding" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding RoundingMethods}"
                                                SelectedItem="{Binding SelectedRoundingMethod, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayHeadRoundingOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBlock Grid.Column="2" Text="Calc Period" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,10,0"
                                                 TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding Periods}"
                                                SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayHeadPeriodOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="PhLabelL"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Rounding Limit" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding RoundingLimitText, Mode=TwoWay}"
                                               TextAlignment="Right" PlaceholderText="1"/>
                                      <TextBlock Grid.Column="2" Text="(the multiple to round to, e.g. 1)"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"
                                                 FontSize="11" Foreground="#6A6A6A"/>
                                    </Grid>

                                    <!-- On-Attendance / On-Production link -->
                                    <Border IsVisible="{Binding ShowAttendanceLink}"
                                            Background="#F5F7FB" BorderBrush="{StaticResource GridLine}"
                                            BorderThickness="1" Padding="12">
                                      <StackPanel Spacing="10">
                                        <TextBlock Text="Calculated on" FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource BrandNavy}"/>
                                        <Grid ColumnDefinitions="70,*,170,90">
                                          <TextBlock Grid.Column="0" Text="Type" FontWeight="SemiBold"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding AttendanceTypeOptions}"
                                                    SelectedItem="{Binding SelectedAttendanceType, Mode=TwoWay}"
                                                    PlaceholderText="select a type…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="vm:PayHeadAttendanceOption">
                                                <TextBlock Text="{Binding Display}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBlock Grid.Column="2" Text="Per-day basis (days)" FontWeight="SemiBold"
                                                     VerticalAlignment="Center" Margin="10,0,0,0"
                                                     IsVisible="{Binding ShowPerDayBasis}"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                          <TextBox Grid.Column="3" Text="{Binding PerDayBasisText, Mode=TwoWay}"
                                                   TextAlignment="Right" PlaceholderText="26"
                                                   IsVisible="{Binding ShowPerDayBasis}"/>
                                        </Grid>
                                      </StackPanel>
                                    </Border>

                                    <!-- As-Computed-Value: basis + slab editor -->
                                    <Border IsVisible="{Binding ShowComputationEditor}"
                                            Background="#F5F7FB" BorderBrush="{StaticResource GridLine}"
                                            BorderThickness="1" Padding="12">
                                      <StackPanel Spacing="10">
                                        <TextBlock Text="Computation — basis of other pay heads + slab(s)"
                                                   FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource BrandNavy}"/>

                                        <!-- basis picker row -->
                                        <Grid ColumnDefinitions="130,*,110,110">
                                          <TextBlock Grid.Column="0" Text="Computed on" FontWeight="SemiBold"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding BasisPayHeadOptions}"
                                                    SelectedItem="{Binding SelectedBasisPayHead, Mode=TwoWay}"
                                                    PlaceholderText="pay head…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="vm:PayHeadPickerOption">
                                                <TextBlock Text="{Binding Display}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <CheckBox Grid.Column="2" Content="Subtract" Margin="10,0,0,0"
                                                    VerticalAlignment="Center"
                                                    IsChecked="{Binding BasisSubtract, Mode=TwoWay}"/>
                                          <Button Grid.Column="3" Content="+ Add basis" HorizontalAlignment="Right"
                                                  Padding="10,4" Click="OnAddBasisComponentClick"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding BasisComponents}">
                                          <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PayHeadBasisRow">
                                              <Grid ColumnDefinitions="*,80" Height="24">
                                                <TextBlock Grid.Column="0" Text="{Binding Display}"
                                                           Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                                <Button Grid.Column="1" Content="Remove" Padding="6,2"
                                                        FontSize="11" HorizontalAlignment="Right"
                                                        Click="OnRemoveBasisComponentClick"/>
                                              </Grid>
                                            </DataTemplate>
                                          </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- slab picker row -->
                                        <Grid ColumnDefinitions="52,*,64,78,78,80">
                                          <TextBlock Grid.Column="0" Text="Slab" FontWeight="SemiBold"
                                                     VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding SlabTypes}"
                                                    SelectedItem="{Binding SelectedSlabType, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="vm:PayHeadSlabTypeOption">
                                                <TextBlock Text="{Binding Display}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Text="{Binding SlabRateOrValueText, Mode=TwoWay}"
                                                   TextAlignment="Right" Margin="4,0,0,0"
                                                   PlaceholderText="% / ₹"/>
                                          <TextBox Grid.Column="3" Text="{Binding SlabFromText, Mode=TwoWay}"
                                                   TextAlignment="Right" Margin="4,0,0,0"
                                                   PlaceholderText="over"/>
                                          <TextBox Grid.Column="4" Text="{Binding SlabToText, Mode=TwoWay}"
                                                   TextAlignment="Right" Margin="4,0,0,0"
                                                   PlaceholderText="up to"/>
                                          <Button Grid.Column="5" Content="+ Slab" HorizontalAlignment="Right"
                                                  Margin="4,0,0,0" Padding="6,4" Click="OnAddSlabClick"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Slabs}">
                                          <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PayHeadSlabRow">
                                              <Grid ColumnDefinitions="*,80" Height="24">
                                                <TextBlock Grid.Column="0" Text="{Binding Display}"
                                                           Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                                <Button Grid.Column="1" Content="Remove" Padding="6,2"
                                                        FontSize="11" HorizontalAlignment="Right"
                                                        Click="OnRemoveSlabClick"/>
                                              </Grid>
                                            </DataTemplate>
                                          </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                      </StackPanel>
                                    </Border>

                                    <Grid ColumnDefinitions="*,Auto">
                                      <TextBlock Grid.Column="0" Text="{Binding Message}"
                                                 IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 Foreground="{StaticResource AlertRed}" FontSize="12"
                                                 VerticalAlignment="Center" TextWrapping="Wrap"/>
                                      <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                              Background="{StaticResource BrandNavy}" Foreground="White"
                                              Click="OnCreatePayHeadClick"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Existing pay heads -->
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,150,150,*">
                                    <TextBlock Grid.Column="0" Text="Pay Head" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Type" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Calculation" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Detail" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Existing}" Background="White">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PayHeadListRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,150,150,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                     Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Type}"
                                                     VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding CalcType}"
                                                     VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Detail}"
                                                     TextAlignment="Right" Margin="0,0,10,0"
                                                     VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"
                                                     TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Salary Details / structure master (Phase 8 slice 2; dated per-employee; save + history) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).SalaryDetails, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).SalaryDetails}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:SalaryStructureMasterViewModel">
                          <Grid RowDefinitions="Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Salary Details"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <ScrollViewer Grid.Row="1">
                              <StackPanel Spacing="10">
                                <Border Background="White"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="16">
                                  <StackPanel Spacing="10">
                                    <TextBlock IsVisible="{Binding !CanCreate}"
                                               Text="Create an Employee and at least one Pay Head first (Payroll Masters) — a salary structure assigns pay heads to an employee."
                                               FontSize="11" Foreground="#B00020" TextWrapping="Wrap"/>
                                    <!-- Scope (Employee / Employee Group) + effective-from (RQ-5: a structure is
                                         definable at BOTH the employee and the employee-group level). -->
                                    <Grid ColumnDefinitions="130,*,130,*">
                                      <TextBlock Grid.Column="0" Text="For" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding Scopes}"
                                                SelectedItem="{Binding SelectedScope, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:SalaryScopeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBlock Grid.Column="2" Text="Effective From" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding EffectiveFromText, Mode=TwoWay}"
                                               PlaceholderText="yyyy-MM-dd"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="130,*,130,*">
                                      <TextBlock Grid.Column="0" Text="{Binding ScopeTargetLabel}" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <Grid Grid.Column="1">
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  IsVisible="{Binding IsEmployeeScope}"
                                                  ItemsSource="{Binding Employees}"
                                                  SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                                                  PlaceholderText="employee…">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="ledger:Employee">
                                              <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  IsVisible="{Binding IsGroupScope}"
                                                  ItemsSource="{Binding EmployeeGroups}"
                                                  SelectedItem="{Binding SelectedEmployeeGroup, Mode=TwoWay}"
                                                  PlaceholderText="employee group…">
                                          <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="ledger:EmployeeGroup">
                                              <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                        </ComboBox>
                                      </Grid>
                                      <TextBlock Grid.Column="2" Text="Start Type" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding StartTypes}"
                                                SelectedItem="{Binding SelectedStartType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:SalaryStartTypeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <!-- Copy From Employee: pick the source employee whose structure seeds the grid. -->
                                    <Grid ColumnDefinitions="130,*,130,*" IsVisible="{Binding ShowCopyFromEmployeeSource}">
                                      <TextBlock Grid.Column="0" Text="Copy From" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding SourceEmployees}"
                                                SelectedItem="{Binding SelectedSourceEmployee, Mode=TwoWay}"
                                                PlaceholderText="source employee…">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="ledger:Employee">
                                            <TextBlock Text="{Binding Name}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBlock Grid.Column="2" Text="" />
                                      <TextBlock Grid.Column="3" Text="" />
                                    </Grid>

                                    <!-- pay-head lines -->
                                    <Border Background="{StaticResource BrandNavy}">
                                      <Grid ColumnDefinitions="*,200,*">
                                        <TextBlock Grid.Column="0" Text="Pay Head" Classes="colHdr"/>
                                        <TextBlock Grid.Column="1" Text="Value / Rate" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="" Classes="colHdr"/>
                                      </Grid>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Lines}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SalaryStructureLineRowViewModel">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                  Padding="0,2">
                                            <Grid ColumnDefinitions="*,200,*">
                                              <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" Margin="4,0"
                                                        ItemsSource="{Binding PayHeadOptions}"
                                                        SelectedItem="{Binding SelectedPayHead, Mode=TwoWay}"
                                                        PlaceholderText="pay head…">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate x:DataType="vm:PayHeadPickerOption">
                                                    <TextBlock Text="{Binding Display}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="1" Text="{Binding AmountText, Mode=TwoWay}"
                                                       TextAlignment="Right" Margin="4,0"
                                                       IsEnabled="{Binding RequiresAmount}"
                                                       PlaceholderText="amount"/>
                                              <TextBlock Grid.Column="2" Text="{Binding AmountHint}"
                                                         VerticalAlignment="Center" Margin="8,0"
                                                         FontSize="11" FontStyle="Italic" Foreground="#8A8A8A"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="*,Auto">
                                      <TextBlock Grid.Column="0" Text="{Binding Message}"
                                                 IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 Foreground="{StaticResource AlertRed}" FontSize="12"
                                                 VerticalAlignment="Center" TextWrapping="Wrap"/>
                                      <Button Grid.Column="1" Content="Save (Ctrl+A)" Padding="14,6"
                                              Background="{StaticResource BrandNavy}" Foreground="White"
                                              Click="OnSaveSalaryStructureClick"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Dated revisions for this employee (append-only) -->
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="130,110,*">
                                    <TextBlock Grid.Column="0" Text="Effective From" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Start" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Pay Heads" Classes="colHdr"/>
                                  </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding History}" Background="White">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SalaryStructureVersionRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="130,110,*" MinHeight="24">
                                          <TextBlock Grid.Column="0" Text="{Binding EffectiveFrom}"
                                                     Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="1" Text="{Binding StartType}"
                                                     VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Lines}"
                                                     VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11.5"
                                                     Foreground="#555555" TextWrapping="Wrap"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Attendance / Production voucher (Phase 8 slice 3; RQ-6) — records per-employee
                         attendance / leave / production values for a period (non-accounting). -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).AttendanceVoucher, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).AttendanceVoucher}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:AttendanceVoucherEntryViewModel">
                          <Grid RowDefinitions="Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Attendance / Production Voucher"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <ScrollViewer Grid.Row="1">
                              <StackPanel Spacing="10">
                                <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="16">
                                  <StackPanel Spacing="10">
                                    <TextBlock IsVisible="{Binding !CanRecord}"
                                               Text="Create an Employee and an Attendance / Production Type first (Payroll Masters) before recording attendance."
                                               FontSize="11" Foreground="{StaticResource AlertRed}" TextWrapping="Wrap"/>

                                    <!-- The period every line on this voucher is recorded against. -->
                                    <Grid ColumnDefinitions="130,*,130,*">
                                      <TextBlock Grid.Column="0" Text="Period From" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding PeriodFromText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                      <TextBlock Grid.Column="2" Text="Period To" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding PeriodToText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                    </Grid>

                                    <!-- attendance / production lines -->
                                    <Border Background="{StaticResource BrandNavy}">
                                      <Grid ColumnDefinitions="*,*,160">
                                        <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                        <TextBlock Grid.Column="1" Text="Attendance / Production Type" Classes="colHdr"/>
                                        <TextBlock Grid.Column="2" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                                      </Grid>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Rows}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AttendanceVoucherLineRowViewModel">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                  Padding="0,2">
                                            <Grid ColumnDefinitions="*,*,160">
                                              <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" Margin="4,0"
                                                        ItemsSource="{Binding Employees}"
                                                        SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                                                        PlaceholderText="employee…">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate x:DataType="ledger:Employee">
                                                    <TextBlock Text="{Binding Name}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" Margin="4,0"
                                                        ItemsSource="{Binding AttendanceTypes}"
                                                        SelectedItem="{Binding SelectedAttendanceType, Mode=TwoWay}"
                                                        PlaceholderText="attendance / production type…">
                                                <ComboBox.ItemTemplate>
                                                  <DataTemplate x:DataType="ledger:AttendanceType">
                                                    <TextBlock Text="{Binding Name}"/>
                                                  </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                              </ComboBox>
                                              <TextBox Grid.Column="2" Text="{Binding ValueText, Mode=TwoWay}"
                                                       TextAlignment="Right" Margin="4,0"
                                                       PlaceholderText="e.g. 26"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                      <Button Grid.Column="0" Content="+ Add Line" Padding="10,4"
                                              Background="{StaticResource Cream}" Foreground="{StaticResource BrandNavy}"
                                              BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                              Click="OnAddAttendanceLineClick"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Message}"
                                                 IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 Foreground="{StaticResource BrandNavy}" FontSize="12" Margin="12,0"
                                                 VerticalAlignment="Center" TextWrapping="Wrap"/>
                                      <Button Grid.Column="2" Content="Record (Ctrl+A)" Padding="14,6"
                                              Background="{StaticResource BrandNavy}" Foreground="White"
                                              Click="OnRecordAttendanceClick"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Recorded entries in this period (read-back) -->
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,*,200,120">
                                    <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Type" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Period" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Value" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding RecentEntries}" Background="White">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AttendanceEntryRow">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,*,200,120" MinHeight="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Employee}" Margin="8,0"
                                                     VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="1" Text="{Binding AttendanceType}"
                                                     VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Period}"
                                                     VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Value}" Margin="0,0,10,0"
                                                     VerticalAlignment="Center" FontSize="12" TextAlignment="Right"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Payroll voucher (Phase 8 slice 3; RQ-7) — pick a period + employees, Compute the
                         salary breakdown (earnings/deductions/net + Dr/Cr summary + balance indicator), Accept posts
                         the balanced integrated accounting voucher through the engine. -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).PayrollVoucher, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).PayrollVoucher}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PayrollVoucherEntryViewModel">
                          <Grid RowDefinitions="Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Payroll Voucher"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <ScrollViewer Grid.Row="1">
                              <StackPanel Spacing="10">
                                <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="16">
                                  <StackPanel Spacing="10">
                                    <TextBlock IsVisible="{Binding !CanRun}"
                                               Text="Create an Employee with a Salary structure first (Payroll Masters) before running payroll."
                                               FontSize="11" Foreground="{StaticResource AlertRed}" TextWrapping="Wrap"/>

                                    <Grid ColumnDefinitions="120,*,120,*">
                                      <TextBlock Grid.Column="0" Text="Period From" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding PeriodFromText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                      <TextBlock Grid.Column="2" Text="Period To" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding PeriodToText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="120,*,120,*">
                                      <TextBlock Grid.Column="0" Text="Voucher Date" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding VoucherDateText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                      <TextBlock Grid.Column="2" Text="" />
                                      <TextBlock Grid.Column="3" Text="" />
                                    </Grid>

                                    <!-- Employees included in this pay run -->
                                    <TextBlock Text="Include Employees" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}" Margin="0,2,0,0"/>
                                    <ItemsControl ItemsSource="{Binding EmployeeSelections}">
                                      <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                          <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                      </ItemsControl.ItemsPanel>
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PayrollEmployeeSelection">
                                          <CheckBox Content="{Binding Name}" IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                                    Margin="0,0,16,0" FontSize="12"/>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="120,*">
                                      <TextBlock Grid.Column="0" Text="Narration" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding Narration, Mode=TwoWay}"
                                               PlaceholderText="optional"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                      <Button Grid.Column="0" Content="Compute" Padding="14,6"
                                              Background="{StaticResource Cream}" Foreground="{StaticResource BrandNavy}"
                                              BorderBrush="{StaticResource BrandNavy}" BorderThickness="1"
                                              Click="OnComputePayrollClick"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Message}"
                                                 IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 Foreground="{StaticResource BrandNavy}" FontSize="12" Margin="12,0"
                                                 VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Computed breakdown + Dr/Cr summary + balance indicator (only after Compute) -->
                                <StackPanel Spacing="8" IsVisible="{Binding HasComputed}">
                                  <!-- Live "balances (Dr==Cr)" indicator: green banner when Dr==Cr, red when not. -->
                                  <Border Padding="10,6" CornerRadius="3" IsVisible="{Binding IsBalanced}"
                                          Background="{StaticResource PositiveGreen}">
                                    <TextBlock Text="{Binding BalanceText}" FontWeight="Bold" Foreground="White"
                                               FontSize="13" HorizontalAlignment="Center"/>
                                  </Border>
                                  <Border Padding="10,6" CornerRadius="3" IsVisible="{Binding !IsBalanced}"
                                          Background="{StaticResource AlertRed}">
                                    <TextBlock Text="{Binding BalanceText}" FontWeight="Bold" Foreground="White"
                                               FontSize="13" HorizontalAlignment="Center"/>
                                  </Border>

                                  <!-- Summary tiles -->
                                  <Grid ColumnDefinitions="*,*,*,*" >
                                    <StackPanel Grid.Column="0" Margin="2" Classes="statCell">
                                      <TextBlock Text="Gross Earnings" FontSize="11" Foreground="#6A6A6A"/>
                                      <TextBlock Text="{Binding GrossText, StringFormat='₹{0}'}" FontSize="14"
                                                 FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2" Classes="statCell">
                                      <TextBlock Text="Deductions" FontSize="11" Foreground="#6A6A6A"/>
                                      <TextBlock Text="{Binding DeductionsText, StringFormat='₹{0}'}" FontSize="14"
                                                 FontWeight="Bold" Foreground="{StaticResource AlertRed}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="2" Classes="statCell">
                                      <TextBlock Text="Net Payable" FontSize="11" Foreground="#6A6A6A"/>
                                      <TextBlock Text="{Binding NetText, StringFormat='₹{0}'}" FontSize="14"
                                                 FontWeight="Bold" Foreground="{StaticResource PositiveGreen}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="2" Classes="statCell">
                                      <TextBlock Text="Employer Contribution" FontSize="11" Foreground="#6A6A6A"/>
                                      <TextBlock Text="{Binding EmployerText, StringFormat='₹{0}'}" FontSize="14"
                                                 FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                    </StackPanel>
                                  </Grid>

                                  <!-- Wide breakdown grid; horizontal scroll so no column clips. Header + rows share
                                       the SAME explicit widths so they scroll together and line up. -->
                                  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Width="590" HorizontalAlignment="Left">
                                      <Border Background="{StaticResource BrandNavy}">
                                        <Grid ColumnDefinitions="150,150,110,90,90">
                                          <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                          <TextBlock Grid.Column="1" Text="Pay Head" Classes="colHdr"/>
                                          <TextBlock Grid.Column="2" Text="Category" Classes="colHdr"/>
                                          <TextBlock Grid.Column="3" Text="Debit ₹" Classes="colHdr" TextAlignment="Right"/>
                                          <TextBlock Grid.Column="4" Text="Credit ₹" Classes="colHdr" TextAlignment="Right"/>
                                        </Grid>
                                      </Border>
                                      <ItemsControl ItemsSource="{Binding Breakdown}" Background="White">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PayrollBreakdownRow">
                                            <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                              <Grid ColumnDefinitions="150,150,110,90,90" MinHeight="23">
                                                <TextBlock Grid.Column="0" Text="{Binding Employee}" Margin="8,0"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontWeight="{Binding IsEmployeeHeader, Converter={StaticResource BoolWeight}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PayHead}"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Category}"
                                                           VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DebitText}" Margin="0,0,8,0"
                                                           VerticalAlignment="Center" FontSize="12" TextAlignment="Right"/>
                                                <TextBlock Grid.Column="4" Text="{Binding CreditText}" Margin="0,0,8,0"
                                                           VerticalAlignment="Center" FontSize="12" TextAlignment="Right"/>
                                              </Grid>
                                            </Border>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                      <!-- Totals footer -->
                                      <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0">
                                        <Grid ColumnDefinitions="150,150,110,90,90" MinHeight="26">
                                          <TextBlock Grid.Column="2" Text="Total" Margin="0,0,8,0"
                                                     VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Right"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                          <TextBlock Grid.Column="3" Text="{Binding TotalDebitText}" Margin="0,0,8,0"
                                                     VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Right"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                          <TextBlock Grid.Column="4" Text="{Binding TotalCreditText}" Margin="0,0,8,0"
                                                     VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Right"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                        </Grid>
                                      </Border>
                                    </StackPanel>
                                  </ScrollViewer>

                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text=""/>
                                    <Button Grid.Column="1" Content="Post (Ctrl+A)" Padding="14,6"
                                            Background="{StaticResource BrandNavy}" Foreground="White"
                                            Click="OnPostPayrollClick"/>
                                  </Grid>
                                </StackPanel>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GST — Statutory configuration (F11 Features → GST) -->
                    <ContentControl IsVisible="{Binding GstConfig, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding GstConfig}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GstConfigViewModel">
                          <Grid RowDefinitions="Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Statutory Configuration (F11)"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <ScrollViewer Grid.Row="1">
                             <StackPanel Spacing="8">
                            <!-- Enable + config form -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                              <StackPanel Spacing="12">
                                <!-- Inventory features (Phase 6 Cluster 1; RQ-52): the master gate for the whole
                                     batch/expiry feature. When off, the per-item batch switches, the Batch master
                                     and the batch reports are all hidden. Labelled as a company FEATURE (F11), not
                                     a GST/statutory option, so the company-wide inventory switch reads correctly. -->
                                <TextBlock Text="COMPANY FEATURES (F11)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>
                                <CheckBox Content="Maintain Batch-wise details"
                                          IsChecked="{Binding MaintainBatchwiseDetails, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <!-- BOM / Manufacturing F12 config (Phase 6 Cluster 2; RQ-10/RQ-52): the master gate
                                     for the Bill-of-Materials + Manufacturing-Journal feature; the type sub-toggle
                                     surfaces the By-Product/Co-Product/Scrap line-type picker on the BOM master. -->
                                <CheckBox Content="Set Components (BOM) — enable Manufacturing"
                                          IsChecked="{Binding SetComponentsBom, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <CheckBox Content="Define type of component for BOM (By-Product / Co-Product / Scrap)"
                                          IsChecked="{Binding DefineBomComponentType, Mode=TwoWay}"
                                          Margin="20,0,0,0" FontSize="12"
                                          IsVisible="{Binding SetComponentsBom}"/>
                                <!-- Price Levels F11 feature (Phase 6 slice 5; RQ-26/RQ-52): the master gate for the
                                     Price-Level / Price-List masters, the party default-level picker, the Sales
                                     Price-Level header + discount column and the Price List report. -->
                                <CheckBox Content="Enable multiple Price Levels"
                                          IsChecked="{Binding EnableMultiplePriceLevels, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <!-- Job Work F11 feature (Phase 6 slice 8; RQ-45/RQ-52): the master gate for the whole
                                     Job-Work feature. Turning it on activates the four seeded Job-Work voucher types
                                     (Job Work In/Out Order, Material In/Out) under F10 Other Vouchers and surfaces the
                                     four Job Work registers under Reports. When off every non-job-work screen is
                                     byte-identical (ER-13). -->
                                <CheckBox Content="Enable Job Order Processing"
                                          IsChecked="{Binding EnableJobOrderProcessing, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <!-- Payroll F11 feature (Phase 8 slice 1; RQ-1): the master gate for the whole
                                     Payroll module. When on, the Payroll Masters section (Employee Category /
                                     Group / Employee, Payroll Unit, Attendance type) surfaces under Masters →
                                     Create. The statutory sub-toggle surfaces the PF/ESI/PT/Income-Tax codes in
                                     the later statutory slices. When off every non-payroll screen is byte-identical
                                     (ER-13). -->
                                <CheckBox Content="Maintain Payroll"
                                          IsChecked="{Binding PayrollEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <CheckBox Content="Enable Payroll Statutory (PF / ESI / PT / Income-Tax)"
                                          IsChecked="{Binding PayrollStatutoryEnabled, Mode=TwoWay}"
                                          Margin="20,0,0,0" FontSize="12"
                                          IsVisible="{Binding PayrollEnabled}"/>
                                <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"/>
                                <TextBlock Text="STATUTORY" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable GST for this company"
                                          IsChecked="{Binding GstEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding GstEnabled}">
                                  <Grid ColumnDefinitions="130,2*,130,*">
                                    <TextBlock Grid.Column="0" Text="GSTIN / UIN" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Gstin, Mode=TwoWay}"
                                             MinWidth="220" FontFamily="Consolas,Menlo,monospace"
                                             PlaceholderText="15-char GSTIN, e.g. 27ABCDE1234F1Z5"/>
                                    <TextBlock Grid.Column="2" Text="Home State/UT" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding HomeStates}"
                                              SelectedItem="{Binding HomeState, Mode=TwoWay}"
                                              PlaceholderText="state…">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:IndianStateOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="130,*,130,*">
                                    <TextBlock Grid.Column="0" Text="Registration" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding RegistrationTypes}"
                                              SelectedItem="{Binding RegistrationType, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GstRegistrationTypeOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Periodicity" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Periodicities}"
                                              SelectedItem="{Binding Periodicity, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GstPeriodicityOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>

                                  <!-- Composition scheme (Phase 9 slice 3; §10 + Rule 7; RQ-4): the sub-type drives the
                                       tax-on-turnover rate + turnover base; the opt-in date (CMP-02) is advisory. Shown
                                       only when Registration = Composition. A composition dealer issues a Bill of Supply
                                       (no tax collected) and files CMP-08 / GSTR-4. -->
                                  <StackPanel Spacing="10" IsVisible="{Binding IsComposition}">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0" Margin="0,2,0,0"/>
                                    <TextBlock Text="COMPOSITION SCHEME (§10)" FontSize="11" FontWeight="Bold"
                                               Foreground="#9098A8" LetterSpacing="1.5"/>
                                    <Grid ColumnDefinitions="130,2*,130,*">
                                      <TextBlock Grid.Column="0" Text="Sub-type" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding CompositionSubTypes}"
                                                SelectedItem="{Binding SelectedCompositionSubType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:CompositionSubTypeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                      <TextBlock Grid.Column="2" Text="Opt-in date" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding CompositionOptInDateText, Mode=TwoWay}"
                                               PlaceholderText="yyyy-MM-dd (CMP-02)"/>
                                    </Grid>
                                    <Border Background="#F4F6FA" BorderBrush="{StaticResource GridLine}"
                                            BorderThickness="1" Padding="10">
                                      <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding CompositionRateText}" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding CompositionThresholdText}" FontSize="12"
                                                   Foreground="#555555" TextWrapping="Wrap"
                                                   IsVisible="{Binding CompositionThresholdText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Text="Sales issue a Bill of Supply (no tax collected); file CMP-08 (quarterly) + GSTR-4 (annual)."
                                                   FontSize="11" Foreground="#777777" TextWrapping="Wrap"/>
                                      </StackPanel>
                                    </Border>
                                  </StackPanel>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyGstClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Created GST tax-ledgers list -->
                            <StackPanel IsVisible="{Binding GstEnabled}">
                              <Border Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="*,200">
                                  <TextBlock Grid.Column="0" Text="GST Tax Ledger" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                </Grid>
                              </Border>
                              <ItemsControl Background="White" ItemsSource="{Binding TaxLedgers}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstTaxLedgerRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,200" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <!-- ================= TDS / TCS (Phase 7 slice 1) ================= -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                              <StackPanel Spacing="12">
                                <TextBlock Text="INCOME-TAX WITHHOLDING (TDS / TCS)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable TDS (Tax Deducted at Source) for this company"
                                          IsChecked="{Binding TdsEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <CheckBox Content="Enable TCS (Tax Collected at Source) for this company"
                                          IsChecked="{Binding TcsEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <!-- Shared deductor / collector details (a company files 26Q + 27EQ under one TAN) -->
                                <Border Background="#FBF7EE" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                        Padding="12,10" IsVisible="{Binding ShowDeductorDetails}">
                                  <StackPanel Spacing="10">
                                    <TextBlock Text="Deductor / Collector Details" FontWeight="SemiBold" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="130,*,130,*">
                                      <TextBlock Grid.Column="0" Text="TAN" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding Tan, Mode=TwoWay}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               PlaceholderText="10-char TAN, e.g. MUMA12345B"/>
                                      <TextBlock Grid.Column="2" Text="Deductor Type" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding DeductorTypes}"
                                                SelectedItem="{Binding DeductorType, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:DeductorTypeOption">
                                            <TextBlock Text="{Binding Display}"/>
                                          </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                      </ComboBox>
                                    </Grid>
                                    <Grid ColumnDefinitions="130,*,130,*">
                                      <TextBlock Grid.Column="0" Text="Responsible Person" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding ResponsiblePersonName, Mode=TwoWay}"
                                               PlaceholderText="name of the person responsible"/>
                                      <TextBlock Grid.Column="2" Text="Person PAN" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding ResponsiblePersonPan, Mode=TwoWay}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               PlaceholderText="10-char PAN (optional)"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="130,*,130,*">
                                      <TextBlock Grid.Column="0" Text="Designation" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding ResponsiblePersonDesignation, Mode=TwoWay}"
                                               PlaceholderText="e.g. Director"/>
                                      <TextBlock Grid.Column="2" Text="Address" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding ResponsiblePersonAddress, Mode=TwoWay}"
                                               PlaceholderText="address (optional)"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="24">
                                      <CheckBox Content="Surcharge applicable"
                                                IsChecked="{Binding SurchargeApplicable, Mode=TwoWay}" FontSize="12"/>
                                      <CheckBox Content="Health &amp; Education Cess applicable"
                                                IsChecked="{Binding CessApplicable, Mode=TwoWay}" FontSize="12"/>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>

                                <!-- TDS apply -->
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding TdsMessage}"
                                             IsVisible="{Binding TdsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply TDS" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyTdsClick"/>
                                </Grid>
                                <!-- TCS apply -->
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding TcsMessage}"
                                             IsVisible="{Binding TcsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply TCS" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyTcsClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Created TDS/TCS payable-ledgers list -->
                            <StackPanel IsVisible="{Binding ShowDeductorDetails}">
                              <Border Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="*,200">
                                  <TextBlock Grid.Column="0" Text="TDS / TCS Payable Ledger" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                </Grid>
                              </Border>
                              <ItemsControl Background="White" ItemsSource="{Binding TdsTcsLedgers}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstTaxLedgerRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,200" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <!-- ================= Provident Fund (Phase 8 slice 4) ================= -->
                            <!-- Shown only while Payroll Statutory is on (PF lives under it). Enrolling sets the
                                 establishment's EPF rate (12% / 10%), PF code and default cap-at-ceiling. -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8" IsVisible="{Binding ShowPfConfig}">
                              <StackPanel Spacing="12">
                                <TextBlock Text="PROVIDENT FUND (EPF / EPS / EDLI)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable Provident Fund for this establishment"
                                          IsChecked="{Binding PfEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding PfEnabled}">
                                  <Grid ColumnDefinitions="150,*,150,*">
                                    <TextBlock Grid.Column="0" Text="Establishment / PF Code" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding PfEstablishmentCode, Mode=TwoWay}"
                                             FontFamily="Consolas,Menlo,monospace"
                                             PlaceholderText="e.g. MHBAN0012345000 (optional)"/>
                                    <TextBlock Grid.Column="2" Text="EPF Rate" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="3" Text="12% (default) — 10% for a special establishment"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                               TextWrapping="Wrap"/>
                                  </Grid>
                                  <CheckBox Content="Reduced 10% EPF rate (special establishment — &lt;20 employees / sick / jute-beedi-brick-coir-guar-gum)"
                                            IsChecked="{Binding PfReducedRate, Mode=TwoWay}" FontSize="12"/>
                                  <CheckBox Content="Cap PF wages at the ₹15,000 statutory ceiling (per-employee higher-wage opt-in overrides)"
                                            IsChecked="{Binding PfCapWagesAtCeiling, Mode=TwoWay}" FontSize="12"/>
                                  <TextBlock Text="EPS 8.33% (cap ₹1,250) · EDLI 0.50% (cap ₹75) · Admin A/c 2 0.50% (min ₹500) · A/c 22 NIL — these are fixed."
                                             FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding PfMessage}"
                                             IsVisible="{Binding PfMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply PF" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyPfClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- ============ Employees' State Insurance (Phase 8 slice 5) ============ -->
                            <!-- Shown only while Payroll Statutory is on (ESI lives under it). Enrolling captures the
                                 17-digit ESIC employer code; EE 0.75% / ER 3.25% and the ceilings are fixed. -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8" IsVisible="{Binding ShowEsiConfig}">
                              <StackPanel Spacing="12">
                                <TextBlock Text="EMPLOYEES' STATE INSURANCE (ESI)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable Employees' State Insurance for this establishment"
                                          IsChecked="{Binding EsiEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding EsiEnabled}">
                                  <Grid ColumnDefinitions="170,*,150,*">
                                    <TextBlock Grid.Column="0" Text="Establishment / Employer Code" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding EsiEmployerCode, Mode=TwoWay}"
                                             FontFamily="Consolas,Menlo,monospace"
                                             PlaceholderText="17 digits (optional)"/>
                                    <TextBlock Grid.Column="2" Text="Contribution Rates" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="3" Text="Employee 0.75%  ·  Employer 3.25%"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                               TextWrapping="Wrap"/>
                                  </Grid>
                                  <TextBlock Text="Coverage ceiling ₹21,000 gross / month (₹25,000 for a person with disability). Each contribution is rounded UP to the next whole rupee, independently."
                                             FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding EsiMessage}"
                                             IsVisible="{Binding EsiMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply ESI" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyEsiClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- ================= Professional Tax (Phase 8 slice 6) ================= -->
                            <!-- Shown only while Payroll Statutory is on (PT lives under it). A state slab deduction
                                 on the monthly PT-wages: pick the PT state (seeded MH/KA/WB + None) and the enrolment
                                 number; the seeded slab bands for the active state are shown read-only. -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8" IsVisible="{Binding ShowPtConfig}">
                              <StackPanel Spacing="12">
                                <TextBlock Text="PROFESSIONAL TAX (STATE)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable Professional Tax for this establishment"
                                          IsChecked="{Binding PtEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding PtEnabled}">
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="PT State" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding PtStateOptions}"
                                              SelectedItem="{Binding SelectedPtState, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PtStateOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="Enrolment / Reg. No." FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding PtRegistrationNumber, Mode=TwoWay}"
                                             FontFamily="Consolas,Menlo,monospace"
                                             PlaceholderText="PTEC / PTRC number (optional)"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="Wage Basis" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PtWageBasisText}"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                  </Grid>

                                  <!-- Seeded slab bands for the active state (read-only view; right-aligned amounts) -->
                                  <TextBlock Text="Seeded slab (a starting point, not law — annual cap ₹2,500 per person)"
                                             FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>
                                  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <Grid RowDefinitions="Auto,Auto" MinWidth="520"
                                          IsVisible="{Binding HasPtSlabBands}">
                                      <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                        <Grid ColumnDefinitions="130,110,110,90,80">
                                          <TextBlock Grid.Column="0" Text="Applies To" Classes="colHdr"/>
                                          <TextBlock Grid.Column="1" Text="From ₹" Classes="colHdr" TextAlignment="Right"/>
                                          <TextBlock Grid.Column="2" Text="To ₹" Classes="colHdr" TextAlignment="Right"/>
                                          <TextBlock Grid.Column="3" Text="Monthly ₹" Classes="colHdr" TextAlignment="Right"/>
                                          <TextBlock Grid.Column="4" Text="Feb ₹" Classes="colHdr" TextAlignment="Right"/>
                                        </Grid>
                                      </Border>
                                      <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding PtSlabBands}">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="vm:PtSlabRow">
                                            <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                              <Grid ColumnDefinitions="130,110,110,90,80" Height="24">
                                                <TextBlock Grid.Column="0" Text="{Binding AppliesTo}" Margin="6,0"
                                                           VerticalAlignment="Center" FontSize="11.5"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FromText}" TextAlignment="Right"
                                                           VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ToText}" TextAlignment="Right"
                                                           VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding MonthlyText}" TextAlignment="Right"
                                                           VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="4" Text="{Binding FebText}" TextAlignment="Right"
                                                           VerticalAlignment="Center" FontSize="11.5" Margin="0,0,8,0"/>
                                              </Grid>
                                            </Border>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                    </Grid>
                                  </ScrollViewer>
                                  <TextBlock Text="No Professional Tax is levied in the selected state."
                                             FontSize="11.5" Foreground="#777777"
                                             IsVisible="{Binding PtStateHasNoSlab}"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding PtMessage}"
                                             IsVisible="{Binding PtMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply PT" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyPtClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Shown only while Payroll Statutory is on (§192 salary-TDS lives under it). Enabling
                                 flips the average-rate monthly income-tax withholding on; the deductor identity
                                 (TAN / responsible person) reuses the "Enable TDS" block above (no parallel config). -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8" IsVisible="{Binding ShowSalaryTdsConfig}">
                              <StackPanel Spacing="12">
                                <TextBlock Text="SALARY TDS (SECTION 192 INCOME-TAX)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable Salary TDS for this establishment"
                                          IsChecked="{Binding SalaryTdsEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding SalaryTdsEnabled}">
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="Deductor Category" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding SalarySectionCodes}"
                                              SelectedItem="{Binding SelectedSalarySectionCode, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SalarySectionCodeOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="170,*,170,*">
                                    <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SalaryTdsFinancialYearLabel}"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                    <TextBlock Grid.Column="2" Text="Assessment Year" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding SalaryTdsAssessmentYearLabel}"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="Deductor (from TDS)" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SalaryTdsDeductorText}"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                               TextWrapping="Wrap"/>
                                  </Grid>
                                  <TextBlock Text="Average-rate monthly withholding (annual tax spread over the remaining FY months); the per-employee Form 12BB declaration + regime drive the estimate."
                                             FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding SalaryTdsMessage}"
                                             IsVisible="{Binding SalaryTdsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply Salary TDS" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplySalaryTdsClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- ================= Gratuity (Phase 8 slice 9) ================= -->
                            <!-- Shown only while Payroll Statutory is on (gratuity lives under it). Enrolling sets the
                                 ₹20,00,000 cap, the Basic + DA basis and which employees a provision run accrues for. -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8" IsVisible="{Binding ShowGratuityConfig}">
                              <StackPanel Spacing="12">
                                <TextBlock Text="GRATUITY (PAYMENT OF GRATUITY ACT 1972)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable Gratuity provisioning for this establishment"
                                          IsChecked="{Binding GratuityEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding GratuityEnabled}">
                                  <Grid ColumnDefinitions="170,*,150,*">
                                    <TextBlock Grid.Column="0" Text="Gratuity Cap ₹" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding GratuityCapText, Mode=TwoWay}"
                                             TextAlignment="Right"
                                             PlaceholderText="2000000 (₹20,00,000 §4(3) default)"/>
                                    <TextBlock Grid.Column="2" Text="Wage Basis" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding GratuityWageBasisText}"
                                               VerticalAlignment="Center" FontSize="11.5" Foreground="#6A6A6A"
                                               TextWrapping="Wrap"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="Accrue For" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding GratuityPopulations}"
                                              SelectedItem="{Binding SelectedGratuityPopulation, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GratuityPopulationOption">
                                          <TextBlock Text="{Binding Display}"/>
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <TextBlock Text="Provision = (Basic + DA) × 15 × completed years ÷ 26, capped; ≥ 6 months rounds up a year. Vesting is 5 years' continuous service (the register flags it)."
                                             FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding GratuityMessage}"
                                             IsVisible="{Binding GratuityMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply Gratuity" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyGratuityClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- ================= Statutory Bonus (Phase 8 slice 9) ================= -->
                            <!-- Shown only while Payroll Statutory is on (bonus lives under it). Enrolling sets the
                                 8.33%–20% rate, the §12 ₹7,000 calc ceiling, the state minimum wage and the prorate flag. -->
                            <Border Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8" IsVisible="{Binding ShowBonusConfig}">
                              <StackPanel Spacing="12">
                                <TextBlock Text="STATUTORY BONUS (PAYMENT OF BONUS ACT 1965)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9098A8" LetterSpacing="1.5"/>

                                <CheckBox Content="Enable statutory Bonus for this establishment"
                                          IsChecked="{Binding BonusEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>

                                <StackPanel Spacing="10" IsVisible="{Binding BonusEnabled}">
                                  <Grid ColumnDefinitions="170,*,150,*">
                                    <TextBlock Grid.Column="0" Text="Bonus Rate %" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding BonusRatePercentText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="8.33 (min) … 20 (max)"/>
                                    <TextBlock Grid.Column="2" Text="Calc Ceiling ₹" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding BonusCalculationCeilingText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="7000 (§12 default)"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="170,*">
                                    <TextBlock Grid.Column="0" Text="State Minimum Wage ₹" FontWeight="SemiBold"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding BonusMinimumWageText, Mode=TwoWay}"
                                             TextAlignment="Right" PlaceholderText="0 (⇒ ceiling falls back to ₹7,000)"/>
                                  </Grid>
                                  <CheckBox Content="Prorate a mid-year joiner's bonus by the months actually worked"
                                            IsChecked="{Binding BonusProrate, Mode=TwoWay}" FontSize="12"/>
                                  <TextBlock Text="Eligibility: Basic + DA ≤ ₹21,000 / month AND ≥ 30 days worked. Annual bonus = capped monthly base × 12 × rate (₹100 floor); a higher earner is excluded."
                                             FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding BonusMessage}"
                                             IsVisible="{Binding BonusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply Bonus" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyBonusClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                             </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GST Rate Setup — dated GST 2.0 rate history + Compensation-Cess (Phase 9 slice 1) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).GstRateSetup, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).GstRateSetup}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GstRateSetupViewModel">
                          <Grid RowDefinitions="Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="GST Rate Setup — Dated Rates &amp; Compensation Cess"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <ScrollViewer Grid.Row="1">
                             <StackPanel Spacing="10">

                              <!-- Seed the GST 2.0 defaults (idempotent) -->
                              <Border Background="#FBF7EE" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                      Padding="14,10">
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12"
                                             Foreground="#5A5A5A"
                                             Text="Seed the GST 2.0 rate framework (0 / 5 / 18 / 40% + specials + legacy 12/28% inactive-by-date) and the FY2025-26 Compensation-Cess windows. A rate change is a NEW dated window, so historic vouchers always reprint at their original rate."/>
                                  <Button Grid.Column="1" Content="Seed GST 2.0 defaults" Padding="14,6" Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          IsEnabled="{Binding CanSeedDefaults}"
                                          Click="OnSeedAdvancedGstClick"/>
                                </Grid>
                              </Border>

                              <!-- ===================== Dated GST rate-history windows ===================== -->
                              <TextBlock Text="DATED GST RATE WINDOWS" FontSize="11" FontWeight="Bold"
                                         Foreground="#9098A8" LetterSpacing="1.5"/>
                              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel MinWidth="620">
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="85,55,90,95,90,80,*">
                                      <TextBlock Grid.Column="0" Text="HSN/SAC" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="2" Text="Class" Classes="colHdr"/>
                                      <TextBlock Grid.Column="3" Text="From" Classes="colHdr"/>
                                      <TextBlock Grid.Column="4" Text="To" Classes="colHdr"/>
                                      <TextBlock Grid.Column="5" Text="Basis" Classes="colHdr"/>
                                      <TextBlock Grid.Column="6" Text="Label" Classes="colHdr"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl Background="White" ItemsSource="{Binding RateHistoryRows}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:GstRateHistoryDisplayRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="85,55,90,95,90,80,*" Height="24">
                                            <TextBlock Grid.Column="0" Text="{Binding Hsn}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="1" Text="{Binding RateText}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ClassText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="3" Text="{Binding FromText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ToText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="5" Text="{Binding BasisText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="6" Text="{Binding Label}" VerticalAlignment="Center" FontSize="11.5"
                                                       Foreground="#555555" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </ScrollViewer>

                              <!-- Add a dated rate window -->
                              <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="12,10">
                                <StackPanel Spacing="8">
                                  <TextBlock Text="Add a dated rate window (a rate change = a new window)"
                                             FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                  <Grid ColumnDefinitions="70,120,70,120,90,150">
                                    <TextBlock Grid.Column="0" Text="HSN/SAC" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewRateHsn, Mode=TwoWay}" PlaceholderText="blank ⇒ generic"/>
                                    <TextBlock Grid.Column="2" Text="Rate %" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewRatePercentText, Mode=TwoWay}" TextAlignment="Right" PlaceholderText="e.g. 18"/>
                                    <TextBlock Grid.Column="4" Text="Class" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="5" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding RateClasses}" SelectedItem="{Binding NewRateClass, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GstRateClassOption"><TextBlock Text="{Binding Display}"/></DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="70,120,70,120,90,150">
                                    <TextBlock Grid.Column="0" Text="From" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewRateFromText, Mode=TwoWay}" PlaceholderText="22-Sep-2025"/>
                                    <TextBlock Grid.Column="2" Text="To" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewRateToText, Mode=TwoWay}" PlaceholderText="blank ⇒ open"/>
                                    <TextBlock Grid.Column="4" Text="Basis" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="5" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ValuationBases}" SelectedItem="{Binding NewRateBasis, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GstValuationBasisOption"><TextBlock Text="{Binding Display}"/></DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="70,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Label" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewRateLabel, Mode=TwoWay}" PlaceholderText="optional (auto-generated if blank)"/>
                                    <Button Grid.Column="2" Content="Add Rate (Ctrl+A)" Padding="12,6" Margin="10,0,0,0"
                                            Background="{StaticResource BrandNavy}" Foreground="White" Click="OnAddRateHistoryClick"/>
                                  </Grid>
                                </StackPanel>
                              </Border>

                              <!-- ===================== Dated Compensation-Cess windows ===================== -->
                              <TextBlock Text="DATED COMPENSATION-CESS WINDOWS" FontSize="11" FontWeight="Bold"
                                         Foreground="#9098A8" LetterSpacing="1.5" Margin="0,4,0,0"/>
                              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel MinWidth="590">
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="85,95,120,95,90,*">
                                      <TextBlock Grid.Column="0" Text="HSN/SAC" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="Mode" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Cess" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="3" Text="From" Classes="colHdr"/>
                                      <TextBlock Grid.Column="4" Text="To" Classes="colHdr"/>
                                      <TextBlock Grid.Column="5" Text="Label" Classes="colHdr"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl Background="White" ItemsSource="{Binding CessRows}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:GstCessDisplayRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="85,95,120,95,90,*" Height="24">
                                            <TextBlock Grid.Column="0" Text="{Binding Hsn}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ModeText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="3" Text="{Binding FromText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ToText}" VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="5" Text="{Binding Label}" VerticalAlignment="Center" FontSize="11.5"
                                                       Foreground="#555555" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </ScrollViewer>

                              <!-- Add a dated cess window -->
                              <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="12,10">
                                <StackPanel Spacing="8">
                                  <TextBlock Text="Add a dated Compensation-Cess window"
                                             FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                  <Grid ColumnDefinitions="70,120,70,190">
                                    <TextBlock Grid.Column="0" Text="HSN/SAC" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewCessHsn, Mode=TwoWay}" PlaceholderText="blank ⇒ generic"/>
                                    <TextBlock Grid.Column="2" Text="Mode" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding CessModes}" SelectedItem="{Binding NewCessMode, Mode=TwoWay}">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CessModeOption"><TextBlock Text="{Binding Display}"/></DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </Grid>
                                  <Grid ColumnDefinitions="90,110,90,110,90,110">
                                    <TextBlock Grid.Column="0" Text="Rate %" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewCessRatePercentText, Mode=TwoWay}" TextAlignment="Right" PlaceholderText="ad-val %"/>
                                    <TextBlock Grid.Column="2" Text="₹/unit" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewCessPerUnitText, Mode=TwoWay}" TextAlignment="Right" PlaceholderText="specific"/>
                                    <TextBlock Grid.Column="4" Text="RSP ×" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="5" Text="{Binding NewCessRspFactorText, Mode=TwoWay}" TextAlignment="Right" PlaceholderText="factor"/>
                                  </Grid>
                                  <Grid ColumnDefinitions="70,120,70,120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="From" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewCessFromText, Mode=TwoWay}" PlaceholderText="01-Apr-2025"/>
                                    <TextBlock Grid.Column="2" Text="To" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewCessToText, Mode=TwoWay}" PlaceholderText="blank ⇒ open"/>
                                    <TextBox Grid.Column="4" Text="{Binding NewCessLabel, Mode=TwoWay}" Margin="8,0,0,0" PlaceholderText="label (optional)"/>
                                    <Button Grid.Column="5" Content="Add Cess" Padding="12,6" Margin="10,0,0,0"
                                            Background="{StaticResource BrandNavy}" Foreground="White" Click="OnAddCessRateClick"/>
                                  </Grid>
                                </StackPanel>
                              </Border>

                              <TextBlock Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="12" TextWrapping="Wrap"/>
                             </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: CMP-08 composition quarterly statement (Phase 9 slice 3; RQ-16) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Cmp08Report, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Cmp08Report}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Cmp08ReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + quarter selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,Auto,200,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CompositionFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CompositionQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <!-- Sub-type / rate / turnover base -->
                                <Border Background="#F4F6FA" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="12">
                                  <Grid ColumnDefinitions="*,*,*">
                                    <StackPanel Grid.Column="0">
                                      <TextBlock Text="Composition sub-type" FontSize="10.5" Foreground="#777777"/>
                                      <TextBlock Text="{Binding SubTypeText}" FontSize="13" FontWeight="Bold"
                                                 Foreground="{StaticResource BrandNavy}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                      <TextBlock Text="Rate" FontSize="10.5" Foreground="#777777"/>
                                      <TextBlock Text="{Binding RateText}" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                    <!-- Money cell: label+value pinned right together. Columns 0/1 above hold TEXT
                                         ("Trader", "1% on turnover base") and stay left/left — right-aligning them
                                         would be a new defect. -->
                                    <StackPanel Grid.Column="2" Classes="statCell">
                                      <TextBlock Text="Turnover base ₹" FontSize="10.5" Foreground="#777777"/>
                                      <TextBlock Text="{Binding TurnoverBaseText}" FontSize="13" FontWeight="Bold"
                                                 TextAlignment="Right"/>
                                    </StackPanel>
                                  </Grid>
                                </Border>

                                <!-- Table 3(i) — outward tax on turnover -->
                                <TextBlock Text="Table 3(i) — Outward supplies (tax on turnover)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="CGST"/><TextBlock Grid.Column="1" Text="{Binding OutwardCgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="SGST"/><TextBlock Grid.Column="1" Text="{Binding OutwardSgstText}" TextAlignment="Right"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="Tax on turnover" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding OutwardTurnoverTaxText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Table 3(ii) — inward reverse-charge tax paid in cash -->
                                <TextBlock Text="Table 3(ii) — Inward supplies attracting reverse charge (paid in cash)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="CGST"/><TextBlock Grid.Column="1" Text="{Binding InwardRcmCgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="SGST"/><TextBlock Grid.Column="1" Text="{Binding InwardRcmSgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="IGST"/><TextBlock Grid.Column="1" Text="{Binding InwardRcmIgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="Compensation Cess (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding InwardRcmCessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Table 3(iii) — tax payable by head -->
                                <TextBlock Text="Table 3(iii) — Tax payable"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="CGST payable"/><TextBlock Grid.Column="1" Text="{Binding PayableCgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="SGST payable"/><TextBlock Grid.Column="1" Text="{Binding PayableSgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="IGST payable"/><TextBlock Grid.Column="1" Text="{Binding PayableIgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="Compensation Cess (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding PayableCessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="Interest (§50)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding InterestText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,140"><TextBlock Grid.Column="0" Text="Total tax payable" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding TotalTaxPayableText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GSTR-4 composition annual return (Phase 9 slice 3; RQ-16) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr4Report, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr4Report}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Gstr4ReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY selector + sub-type -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,Auto,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CompositionFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Sub-type:" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,6,0" Foreground="{StaticResource BrandNavy}"/>
                              <TextBlock Grid.Column="3" Text="{Binding SubTypeText}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>

                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <!-- Table 5 — quarterly roll-up (from CMP-08) -->
                                <TextBlock Text="Table 5 — Summary of self-assessed liability (quarterly CMP-08)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="130,*,*,*,*">
                                    <TextBlock Grid.Column="0" Text="Quarter" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Turnover base" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="Outward tax" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Inward RCM" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Total payable" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Quarters}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Gstr4QuarterRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="130,*,*,*,*" Height="26">
                                          <TextBlock Grid.Column="0" Text="{Binding Quarter}" Margin="8,0"
                                                     VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding TurnoverBase}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="2" Text="{Binding OutwardTax}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding InwardRcmTax}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding TotalPayable}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Table 4A/4B/4C/4D — inward supplies (value only; no ITC) -->
                                <TextBlock Text="Table 4 — Inward supplies (value only; a composition dealer claims no ITC)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4A — Registered supplier (no RCM)"/><TextBlock Grid.Column="1" Text="{Binding RegisteredValueText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4B — Reverse-charge supplies (value)"/><TextBlock Grid.Column="1" Text="{Binding ReverseChargeValueText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4B — Reverse-charge tax (cash)" Foreground="#555555"/><TextBlock Grid.Column="1" Text="{Binding ReverseChargeTaxText}" TextAlignment="Right" Foreground="#555555"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4C — Unregistered supplier (no RCM)"/><TextBlock Grid.Column="1" Text="{Binding UnregisteredValueText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4D — Import of services" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding ImportServiceValueText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Table 6 — annual liability -->
                                <TextBlock Text="Table 6 — Annual tax liability"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Composition tax on turnover"/><TextBlock Grid.Column="1" Text="{Binding AnnualCompositionTaxText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Inward reverse-charge tax (cash)"/><TextBlock Grid.Column="1" Text="{Binding AnnualRcmTaxText}" TextAlignment="Right"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Total annual tax" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding AnnualTotalText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GSTR-9 annual return (Phase 9 UI-1; RQ-17) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr9Report, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr9Report}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Gstr9ReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*,Auto" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="3" Text="{Binding GstinText}" FontSize="12" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <!-- Part II Table 4 — outward + inward-RCM on which tax is payable -->
                                <TextBlock Text="Part II · Table 4 — Outward + inward-RCM supplies (tax payable)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Taxable value of outward supplies"/><TextBlock Grid.Column="1" Text="{Binding Table4TaxableValueText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Outward CGST"/><TextBlock Grid.Column="1" Text="{Binding Table4CgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Outward SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding Table4SgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Outward IGST"/><TextBlock Grid.Column="1" Text="{Binding Table4IgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Outward Cess (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding Table4CessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4G — Inward RCM CGST"/><TextBlock Grid.Column="1" Text="{Binding Table4RcmCgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4G — Inward RCM SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding Table4RcmSgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4G — Inward RCM IGST"/><TextBlock Grid.Column="1" Text="{Binding Table4RcmIgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="4G — Inward RCM Cess (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding Table4RcmCessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Total tax payable (GST heads)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Table4TotalTaxText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <!-- Part II Table 5 — outward on which tax is NOT payable -->
                                <TextBlock Text="Part II · Table 5 — Outward supplies (no tax) + total turnover"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Exempt / nil-rated / non-GST outward"/><TextBlock Grid.Column="1" Text="{Binding Table5ExemptText}" TextAlignment="Right"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="5N — Total turnover" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Table5NTurnoverText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <!-- Part III Table 6 — ITC availed -->
                                <TextBlock Text="Part III · Table 6 — ITC availed"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="ITC availed — CGST"/><TextBlock Grid.Column="1" Text="{Binding Table6CgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="ITC availed — SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding Table6SgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="ITC availed — IGST"/><TextBlock Grid.Column="1" Text="{Binding Table6IgstText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="ITC availed — Cess (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding Table6CessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="6H — ITC reclaimed" Foreground="#555555"/><TextBlock Grid.Column="1" Text="{Binding Table6ReclaimedText}" TextAlignment="Right" Foreground="#555555"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Total ITC availed (GST heads)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Table6ItcAvailedText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <!-- Part III Table 7 — ITC reversed by rule -->
                                <TextBlock Text="Part III · Table 7 — ITC reversed (by rule)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="7A — Rule 37 / 37A"/><TextBlock Grid.Column="1" Text="{Binding Table7Rule37Text}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="7C — Rule 42"/><TextBlock Grid.Column="1" Text="{Binding Table7Rule42Text}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="7D — Rule 43"/><TextBlock Grid.Column="1" Text="{Binding Table7Rule43Text}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="7E — §17(5) blocked"/><TextBlock Grid.Column="1" Text="{Binding Table7Section17_5Text}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="7H — Other reversals"/><TextBlock Grid.Column="1" Text="{Binding Table7OtherText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Cess reversed (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding Table7CessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,150"><TextBlock Grid.Column="0" Text="Total ITC reversed (GST heads)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Table7ItcReversedText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <!-- Part III Table 8 — ITC reconciliation + Part IV Table 9 — tax paid -->
                                <Grid ColumnDefinitions="*,8,*">
                                  <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Part III · Table 8 — ITC reconciliation" FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                    <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                      <StackPanel Spacing="3">
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="8A — ITC per GSTR-2B"/><TextBlock Grid.Column="1" Text="{Binding Table8AText}" TextAlignment="Right"/></Grid>
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="8A — Cess per 2B" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding Table8ACessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="8B — ITC per Table 6"/><TextBlock Grid.Column="1" Text="{Binding Table8BText}" TextAlignment="Right"/></Grid>
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="8D — Difference (8A − 8B)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding Table8DText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Net ITC (6 − 7)" Foreground="#555555"/><TextBlock Grid.Column="1" Text="{Binding NetItcText}" TextAlignment="Right" Foreground="#555555"/></Grid>
                                      </StackPanel>
                                    </Border>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock Text="Part IV · Table 9 — Tax paid" FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                    <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                      <StackPanel Spacing="3">
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Payable (Table 9)"/><TextBlock Grid.Column="1" Text="{Binding Table9PayableText}" TextAlignment="Right"/></Grid>
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Paid through ITC"/><TextBlock Grid.Column="1" Text="{Binding Table9PaidThroughItcText}" TextAlignment="Right"/></Grid>
                                        <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Paid in cash (PMT-06)"/><TextBlock Grid.Column="1" Text="{Binding Table9PaidInCashText}" TextAlignment="Right"/></Grid>
                                      </StackPanel>
                                    </Border>
                                  </StackPanel>
                                </Grid>
                                <!-- Part VI Table 17 — outward HSN summary -->
                                <TextBlock Text="Part VI · Table 17 — HSN summary of outward supplies"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="120,*,70,80,*,*">
                                    <TextBlock Grid.Column="0" Text="HSN/SAC" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Description" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="UQC" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Qty" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Taxable" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Total tax" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding HsnRows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Gstr9HsnRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,*,70,80,*,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding HsnSac}" Margin="8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Description}" Margin="4,0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Uqc}" Margin="4,0" VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Quantity}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding TaxableValue}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding TotalTax}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0">
                                  <Grid ColumnDefinitions="120,*,70,80,*,*" Height="26">
                                    <TextBlock Grid.Column="0" Text="Total" Margin="8,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Table17TaxableValueText}" TextAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Table17TotalTaxText}" TextAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" Margin="0,0,6,0"/>
                                  </Grid>
                                </Border>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GSTR-9C reconciliation statement (Phase 9 UI-1; RQ-17) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr9cReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr9cReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Gstr9cReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*,Auto" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="3" Text="{Binding GstinText}" FontSize="12" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <TextBlock Text="Part A · Table 5 — Reconciliation of gross turnover"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="5A — Turnover per audited books"/><TextBlock Grid.Column="1" Text="{Binding BooksTurnoverText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="5Q — Turnover per GSTR-9"/><TextBlock Grid.Column="1" Text="{Binding ReturnTurnoverText}" TextAlignment="Right"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="5R — Unreconciled (books − return)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding UnreconciledTurnoverText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <TextBlock Text="Part III · Tables 9–11 — Reconciliation of tax liability"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="Tax per GSTR-9"/><TextBlock Grid.Column="1" Text="{Binding TaxPerReturnText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="Tax per books"/><TextBlock Grid.Column="1" Text="{Binding TaxPerBooksText}" TextAlignment="Right"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="Table 11 — Unreconciled (return − books)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding UnreconciledTaxText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <TextBlock Text="Part B · Table 12 — Reconciliation of net ITC"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="12A — ITC per audited books"/><TextBlock Grid.Column="1" Text="{Binding BooksItcText}" TextAlignment="Right"/></Grid>
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="12E — Net ITC per GSTR-9"/><TextBlock Grid.Column="1" Text="{Binding ReturnItcText}" TextAlignment="Right"/></Grid>
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                    <Grid ColumnDefinitions="*,160"><TextBlock Grid.Column="0" Text="12F — Unreconciled (books − return)" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding UnreconciledItcText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                  </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Electronic Ledgers (Phase 9 UI-1; RQ-20) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).ElectronicLedgersReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).ElectronicLedgersReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ElectronicLedgersReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <TextBlock Text="Electronic Credit Ledger — available ITC + window movements"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="130,*,*,*,*">
                                    <TextBlock Grid.Column="0" Text="Head" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Additions" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="Utilised" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Reversed" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Closing" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding CreditRows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ElectronicCreditRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="130,*,*,*,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Head}" Margin="8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Additions}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Utilised}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Reversed}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Closing}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Electronic Liability Ledger — outstanding output + cash-only RCM"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="130,*,*">
                                    <TextBlock Grid.Column="0" Text="Head" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Output" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="RCM (cash)" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding LiabilityRows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ElectronicLiabilityRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="130,*,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Head}" Margin="8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Output}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Rcm}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Electronic Cash Ledger — per (major · minor) head"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Text="No PMT-06 challan deposited — the cash ledger is empty."
                                           IsVisible="{Binding !HasCashCells}"
                                           FontSize="11.5" Foreground="#777777" Margin="4,0,0,0"/>
                                <ItemsControl Background="White" ItemsSource="{Binding CashRows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ElectronicCashRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="1,0,1,1">
                                        <Grid ColumnDefinitions="*,150" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Cell}" Margin="8,0" VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Balance}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="12">
                                  <Grid ColumnDefinitions="*,*,*,*">
                                    <StackPanel Grid.Column="0" Classes="statCell"><TextBlock Text="Total credit ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding TotalCreditText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                    <StackPanel Grid.Column="1" Classes="statCell"><TextBlock Text="Total liability ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding TotalLiabilityText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                    <StackPanel Grid.Column="2" Classes="statCell"><TextBlock Text="RCM cash ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding TotalRcmLiabilityText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                    <StackPanel Grid.Column="3" Classes="statCell"><TextBlock Text="Cash balance ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding CashBalanceText}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource BrandNavy}" TextAlignment="Right"/></StackPanel>
                                  </Grid>
                                </Border>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: ITC Set-Off (Rule 88A) projection (Phase 9 UI-1; RQ-21) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).ItcSetOffReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).ItcSetOffReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ItcSetOffReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <TextBlock Text="Demand (from GSTR-3B) — liability + available credit"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <!-- ColumnSpacing keeps the left block's right-aligned amounts off the right block's
                                       labels (without it they render flush: "5,58,000.00CGST"). -->
                                  <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                    <StackPanel Grid.Column="0" Spacing="3">
                                      <TextBlock Text="Output liability" FontWeight="SemiBold" Foreground="#555555"/>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="CGST"/><TextBlock Grid.Column="1" Text="{Binding LiabCgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding LiabSgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="IGST"/><TextBlock Grid.Column="1" Text="{Binding LiabIgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="RCM (cash-only)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding LiabRcmCashText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                      <TextBlock Text="Available credit" FontWeight="SemiBold" Foreground="#555555"/>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="CGST"/><TextBlock Grid.Column="1" Text="{Binding CreditCgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding CreditSgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="IGST"/><TextBlock Grid.Column="1" Text="{Binding CreditIgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Cess (ring-fenced)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding CreditCessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                    </StackPanel>
                                  </Grid>
                                </Border>
                                <TextBlock Text="Table 6.1 — credit utilisation (compliant default)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,*,160">
                                    <TextBlock Grid.Column="0" Text="Credit head" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Discharges liability" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Lines}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ItcSetOffLineRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,*,160" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding CreditHead}" Margin="8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding LiabilityHead}" Margin="4,0" VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Amount}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Residual cash payable + credit carried forward"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10">
                                  <!-- ColumnSpacing keeps the left block's right-aligned amounts off the right block's
                                       labels (without it they render flush: "0.00Cess (ring-fenced)"). -->
                                  <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                    <StackPanel Grid.Column="0" Spacing="3">
                                      <TextBlock Text="Residual cash" FontWeight="SemiBold" Foreground="#555555"/>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="CGST"/><TextBlock Grid.Column="1" Text="{Binding CashCgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding CashSgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="IGST"/><TextBlock Grid.Column="1" Text="{Binding CashIgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Cess" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding CashCessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="RCM (cash-only)" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding CashRcmText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Total cash" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding TotalCashText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                      <TextBlock Text="Credit carried forward" FontWeight="SemiBold" Foreground="#555555"/>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="CGST"/><TextBlock Grid.Column="1" Text="{Binding ClosingCgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="SGST/UTGST"/><TextBlock Grid.Column="1" Text="{Binding ClosingSgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="IGST"/><TextBlock Grid.Column="1" Text="{Binding ClosingIgstText}" TextAlignment="Right"/></Grid>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Cess" Foreground="#777777"/><TextBlock Grid.Column="1" Text="{Binding ClosingCessText}" TextAlignment="Right" Foreground="#777777"/></Grid>
                                      <!-- Spacer: the left block carries one extra head row (RCM, cash-only), so
                                           without it "Credit utilised" floats a row above "Total cash". -->
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text=" "/></Grid>
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"/>
                                      <Grid ColumnDefinitions="*,120"><TextBlock Grid.Column="0" Text="Credit utilised" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="{Binding TotalCreditUtilisedText}" TextAlignment="Right" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/></Grid>
                                    </StackPanel>
                                  </Grid>
                                </Border>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: ITC Reversal (view) (Phase 9 UI-1; RQ-27) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).ItcReversalReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).ItcReversalReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ItcReversalReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Border Grid.Row="2" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="*,*,*,*,*">
                                <StackPanel Grid.Column="0" Classes="statCell"><TextBlock Text="ECRS CGST ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding BalanceCgstText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="1" Classes="statCell"><TextBlock Text="SGST ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding BalanceSgstText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="2" Classes="statCell"><TextBlock Text="IGST ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding BalanceIgstText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="3" Classes="statCell"><TextBlock Text="Cess ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding BalanceCessText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="4" Classes="statCell"><TextBlock Text="Total ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding BalanceTotalText}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource BrandNavy}" TextAlignment="Right"/></StackPanel>
                              </Grid>
                            </Border>
                            <TextBlock Grid.Row="3" Text="{Binding CandidatesHeader}" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource BrandNavy}" Margin="0,0,0,4"/>
                            <Grid Grid.Row="4" RowDefinitions="Auto,*">
                              <Border Grid.Row="0" Background="{StaticResource BrandNavy}"
                                      IsVisible="{Binding HasSnapshot}">
                                <Grid ColumnDefinitions="140,*,90,90,90,90">
                                  <TextBlock Grid.Column="0" Text="Reason" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Description" Classes="colHdr"/>
                                  <TextBlock Grid.Column="2" Text="CGST" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="3" Text="SGST" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="4" Text="IGST" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="5" Text="Cess" Classes="colHdr" TextAlignment="Right"/>
                                </Grid>
                              </Border>
                              <ScrollViewer Grid.Row="1">
                                <StackPanel>
                                  <ItemsControl Background="White" ItemsSource="{Binding Candidates}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ItcReversalCandidateRowVm">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="140,*,90,90,90,90" Height="30">
                                            <TextBlock Grid.Column="0" Text="{Binding Reason}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Cgst}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Sgst}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Igst}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                            <!-- C12: the Cess value is a data column alongside CGST/SGST/IGST — drop the
                                                 odd grey tint so all four amount cells read consistently (the sibling
                                                 CGST/SGST/IGST cells carry no Foreground). -->
                                            <TextBlock Grid.Column="5" Text="{Binding Cess}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <TextBlock Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="#7A5B00" FontSize="12" TextWrapping="Wrap" Margin="4,10,0,0"/>
                                  <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="4,8,0,0"/>
                                </StackPanel>
                              </ScrollViewer>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GSTR-2B Reconciliation (Phase 9 UI-1; RQ-13) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr2bReconReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Gstr2bReconReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Gstr2bReconReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,470,*" Margin="0,0,0,8"
                                  IsVisible="{Binding HasSnapshot}">
                              <TextBlock Grid.Column="0" Text="GSTR-2B snapshot" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Snapshots}"
                                        SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Gstr2bSnapshotOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}" IsVisible="{Binding HasSnapshot}">
                              <Grid ColumnDefinitions="110,140,*,95,85">
                                <TextBlock Grid.Column="0" Text="Bucket" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Supplier GSTIN" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Doc no" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Taxable" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Tax" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <!-- Each row is TWO lines: the identity/amount columns, then the bucket note wrapped on its
                                 own full-width line. A single-line grid cannot carry the note — the fixed columns eat the
                                 page column's width and clip it to nothing (caught in render-verify). -->
                            <ListBox Grid.Row="5" Background="White" IsVisible="{Binding HasSnapshot}"
                                     ItemsSource="{Binding Rows}"
                                     SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:Gstr2bReconRowVm">
                                  <Grid RowDefinitions="Auto,Auto" Margin="0,1">
                                    <Grid Grid.Row="0" ColumnDefinitions="110,140,*,95,85" Height="20">
                                      <TextBlock Grid.Column="0" Text="{Binding Bucket}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"
                                                 FontWeight="SemiBold" Foreground="{Binding IsClean, Converter={StaticResource BalancedBrush}}"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Supplier}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="2" Text="{Binding DocNo}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="3" Text="{Binding TaxableValue}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Tax}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                    </Grid>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,6,2" Spacing="6">
                                      <TextBlock Text="{Binding Date}" FontSize="10.5" Foreground="#888888"/>
                                      <TextBlock Text="{Binding Note}" FontSize="10.5" Foreground="#666666" TextWrapping="Wrap"/>
                                    </StackPanel>
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Grid.Row="6" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: IMS — Accept / Reject / Pending (Phase 9 UI-2; RQ-13). INTERACTIVE: opening it posts
                         nothing; only the explicit Accept/Reject/Pending/Clear buttons record an IMS action. An RCM
                         row is rendered disabled (§3.3 bypasses IMS) rather than throwing from the engine. -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImsActions, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImsActions}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ImsActionsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,470,*" Margin="0,0,0,8"
                                  IsVisible="{Binding HasSnapshot}">
                              <TextBlock Grid.Column="0" Text="GSTR-2B snapshot" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Snapshots}"
                                        SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Gstr2bSnapshotOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}" IsVisible="{Binding HasSnapshot}">
                              <Grid ColumnDefinitions="130,*,85,80">
                                <TextBlock Grid.Column="0" Text="Status" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Supplier / doc no" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Taxable" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Tax" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <!-- Two lines per row: the fixed status/amount columns cannot also carry the GSTIN + note
                                 inside the ~640px page column without clipping the note to nothing. -->
                            <ListBox Grid.Row="5" Background="White" IsVisible="{Binding HasSnapshot}"
                                     ItemsSource="{Binding Rows}"
                                     SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ImsLineRowVm">
                                  <Grid RowDefinitions="Auto,Auto" Margin="0,1">
                                    <Grid Grid.Row="0" ColumnDefinitions="130,*,85,80" Height="20">
                                      <TextBlock Grid.Column="0" Text="{Binding Status}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"
                                                 FontWeight="SemiBold" Foreground="{Binding IsClean, Converter={StaticResource BalancedBrush}}"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding DocNo}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"
                                                 FontWeight="{Binding IsExplicit, Converter={StaticResource BoolWeight}}"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="2" Text="{Binding TaxableValue}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Tax}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                    </Grid>
                                    <!-- A Grid, NOT a horizontal StackPanel: a horizontal StackPanel measures its
                                         children with infinite width, so TextWrapping never engages and a long note
                                         is silently clipped mid-word at the page column's edge (caught in
                                         render-verify on the RCM row). The star column bounds it so it wraps. -->
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" Margin="8,0,6,2">
                                      <TextBlock Grid.Column="0" Text="{Binding Supplier}" FontSize="10.5" Foreground="#888888"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Date}" FontSize="10.5" Foreground="#888888" Margin="6,0"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Note}" FontSize="10.5" Foreground="#666666" TextWrapping="Wrap"/>
                                    </Grid>
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                            <!-- The explicit action bar: nothing here fires unless the user clicks it. The declared
                                 partial reversal + remarks ride along with Accept (the Oct-2025 credit-note rule). -->
                            <Border Grid.Row="6" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="8" Margin="0,6,0,0" IsVisible="{Binding HasSnapshot}">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,90,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Declared reversal ₹" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding DeclaredReversalText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="2" Text="Remarks" FontSize="11" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding Remarks, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <CheckBox Content="No ITC reversal declared" FontSize="11"
                                          IsChecked="{Binding NoReversalDeclared, Mode=TwoWay}"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <Button Content="Accept" Command="{Binding AcceptLineCommand}" FontSize="11" Padding="12,4"/>
                                  <Button Content="Reject" Command="{Binding RejectLineCommand}" FontSize="11" Padding="12,4"/>
                                  <Button Content="Pending" Command="{Binding HoldLineCommand}" FontSize="11" Padding="12,4"/>
                                  <Button Content="Clear decision" Command="{Binding ClearLineCommand}" FontSize="11" Padding="12,4"/>
                                </StackPanel>
                              </StackPanel>
                            </Border>
                            <Border Grid.Row="7" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Run Set-Off (Rule 88A) & Pay (Phase 9 UI-2; RQ-21). INTERACTIVE: opening it only
                         PREVIEWS the allocation; the Run / Deposit / Pay buttons are the only mutators. -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).RunSetOff, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).RunSetOff}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:RunSetOffViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,110,Auto,130,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="FY" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Period" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="10,0,6,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Periods}"
                                        SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstPeriodOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <!-- Demand: liability (incl. the cash-only RCM) vs the available credit pool. -->
                            <Border Grid.Row="3" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10" Margin="0,0,0,6">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*,*">
                                  <StackPanel Grid.Column="0" Classes="statCell"><TextBlock Text="Liab CGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding LiabCgstText}" FontSize="12" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell"><TextBlock Text="SGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding LiabSgstText}" FontSize="12" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell"><TextBlock Text="IGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding LiabIgstText}" FontSize="12" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell"><TextBlock Text="RCM (cash-only) ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding LiabRcmCashText}" FontSize="12" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*">
                                  <StackPanel Grid.Column="0" Classes="statCell"><TextBlock Text="Credit CGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding CreditCgstText}" FontSize="12" TextAlignment="Right"/></StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell"><TextBlock Text="SGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding CreditSgstText}" FontSize="12" TextAlignment="Right"/></StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell"><TextBlock Text="IGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding CreditIgstText}" FontSize="12" TextAlignment="Right"/></StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell"><TextBlock Text="Cess ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding CreditCessText}" FontSize="12" TextAlignment="Right"/></StackPanel>
                                </Grid>
                              </StackPanel>
                            </Border>
                            <TextBlock Grid.Row="4" Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <!-- The Table-6.1 utilisation preview + the cash cells that must fund the residual. -->
                            <ScrollViewer Grid.Row="5">
                              <StackPanel Spacing="6">
                                <TextBlock Text="Credit utilisation (Table 6.1)" FontWeight="Bold" FontSize="11.5" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}" IsVisible="{Binding HasCreditLines}">
                                  <Grid ColumnDefinitions="*,*,110">
                                    <TextBlock Grid.Column="0" Text="Credit head" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Discharges" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Lines}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ItcSetOffLineRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,*,110" Height="26">
                                          <TextBlock Grid.Column="0" Text="{Binding CreditHead}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding LiabilityHead}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Amount}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Electronic cash ledger (Tax) — available vs this period's residual"
                                           FontWeight="Bold" FontSize="11.5" Foreground="{StaticResource BrandNavy}" Margin="0,6,0,0"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,110,110">
                                    <TextBlock Grid.Column="0" Text="Head" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Available" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="Required" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding CashCells}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GstCashCellRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,110,110" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Head}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Available}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"
                                                     Foreground="{Binding IsFunded, Converter={StaticResource BalancedBrush}}"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Required}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                            <!-- The explicit action bar. A PMT-06 challan funds the cash ledger; the discharge draws on it. -->
                            <Border Grid.Row="6" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="8" Margin="0,6,0,0">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,110,Auto,100,Auto,110,Auto,110">
                                  <TextBlock Grid.Column="0" Text="Challan head" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding ChallanHeads}" SelectedItem="{Binding ChallanHead, Mode=TwoWay}" FontSize="11"/>
                                  <TextBlock Grid.Column="2" Text="₹" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding ChallanAmountText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="4" Text="CPIN" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="5" Text="{Binding Cpin, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="6" Text="CIN" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="7" Text="{Binding Cin, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="Paid from" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" FontSize="11"
                                            ItemsSource="{Binding BankOptions}" SelectedItem="{Binding SelectedBank, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <Button Content="Run set-off" Command="{Binding RunSetOffActionCommand}" FontSize="11" Padding="12,4"/>
                                  <Button Content="Deposit PMT-06 challan" Command="{Binding DepositChallanActionCommand}" FontSize="11" Padding="12,4"/>
                                  <Button Content="Pay residual cash" Command="{Binding PayResidualCashActionCommand}" FontSize="11" Padding="12,4"/>
                                </StackPanel>
                              </StackPanel>
                            </Border>
                            <Border Grid.Row="7" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Post ITC Reversal (Phase 9 UI-2; RQ-27). INTERACTIVE: opening it only projects the ECRS
                         balance / candidates / history; the Post / Post-candidate / Reclaim buttons are the only
                         mutators. A reclaim over the ECRS cap is refused by the engine and shown in the message strip. -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).PostItcReversal, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).PostItcReversal}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PostItcReversalViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <!-- The ECRS balance — the cap a reclaim may never exceed. -->
                            <Border Grid.Row="2" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="10" Margin="0,0,0,6">
                              <Grid ColumnDefinitions="*,*,*,*,*">
                                <StackPanel Grid.Column="0" Classes="statCell"><TextBlock Text="ECRS CGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding BalanceCgstText}" FontSize="12.5" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="1" Classes="statCell"><TextBlock Text="SGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding BalanceSgstText}" FontSize="12.5" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="2" Classes="statCell"><TextBlock Text="IGST ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding BalanceIgstText}" FontSize="12.5" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="3" Classes="statCell"><TextBlock Text="Cess ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding BalanceCessText}" FontSize="12.5" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                <StackPanel Grid.Column="4" Classes="statCell"><TextBlock Text="Total ₹" FontSize="10" Foreground="#777777"/><TextBlock Text="{Binding BalanceTotalText}" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource BrandNavy}" TextAlignment="Right"/></StackPanel>
                              </Grid>
                            </Border>
                            <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <ScrollViewer Grid.Row="4">
                              <StackPanel Spacing="6">
                                <!-- The 2B candidates (one-click postable). -->
                                <TextBlock Text="Reversal candidates from the latest GSTR-2B" FontWeight="Bold" FontSize="11.5"
                                           Foreground="{StaticResource BrandNavy}" IsVisible="{Binding HasCandidates}"/>
                                <ListBox Background="White" MaxHeight="120" IsVisible="{Binding HasCandidates}"
                                         ItemsSource="{Binding Candidates}"
                                         SelectedIndex="{Binding CandidateIndex, Mode=TwoWay}">
                                  <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ItcReversalCandidateRowVm">
                                      <Grid RowDefinitions="Auto,Auto" Margin="0,1">
                                        <Grid Grid.Row="0" ColumnDefinitions="130,*,90" Height="18">
                                          <TextBlock Grid.Column="0" Text="{Binding Reason}" Margin="4,0" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Description}" Margin="4,0" VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Suggested}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Grid>
                                    </DataTemplate>
                                  </ListBox.ItemTemplate>
                                </ListBox>
                                <!-- The posted history — the reclaim acts on the highlighted row. -->
                                <TextBlock Text="Posted reversals" FontWeight="Bold" FontSize="11.5" Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="90,90,*,90">
                                    <TextBlock Grid.Column="0" Text="Rule" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Period" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Bucket" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Total" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ListBox Background="White" MaxHeight="180"
                                         ItemsSource="{Binding Posted}"
                                         SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                  <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PostedReversalRowVm">
                                      <Grid RowDefinitions="Auto,Auto" Margin="0,1">
                                        <Grid Grid.Row="0" ColumnDefinitions="90,90,*,90" Height="18">
                                          <TextBlock Grid.Column="0" Text="{Binding Rule}" Margin="4,0" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                                     Foreground="{Binding IsReclaimable, Converter={StaticResource BalancedBrush}}"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Period}" Margin="4,0" VerticalAlignment="Center" FontSize="11"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Bucket}" Margin="4,0" VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Total}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0"/>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding Note}" Margin="8,0,6,2" FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ListBox.ItemTemplate>
                                </ListBox>
                              </StackPanel>
                            </ScrollViewer>
                            <!-- The explicit action bar. -->
                            <Border Grid.Row="5" Classes="gstActionBar" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="8" Margin="0,6,0,0">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,150,Auto,100">
                                  <TextBlock Grid.Column="0" Text="Rule" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding Kinds}" SelectedItem="{Binding Kind, Mode=TwoWay}" FontSize="11"/>
                                  <TextBlock Grid.Column="2" Text="Period" FontSize="11" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding Period, Mode=TwoWay}" FontSize="11" Padding="4,2" PlaceholderText="yyyy-MM"/>
                                </Grid>
                                <!-- The SOURCE anchor. Rule 43 apportions ONE capital good over 60 months and Rule
                                     37/37A reverses ONE supplier purchase; the engine keys both on (rule, period,
                                     sourceVoucherId), so this pick is the audit trail AND the idempotency key. It is
                                     never guessed: without it the Post refuses. Only shown for the anchored rules —
                                     Rule 42 derives its own amount from the C2 pool. -->
                                <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding NeedsSourceVoucher}">
                                  <TextBlock Grid.Column="0" Text="{Binding SourceVoucherLabel}" FontSize="11"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding SourceVouchers}" FontSize="11"
                                            HorizontalAlignment="Stretch"
                                            SelectedIndex="{Binding SelectedSourceIndex, Mode=TwoWay}"
                                            PlaceholderText="select the purchase this reversal is keyed to">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ItcReversalSourceRowVm">
                                        <TextBlock Text="{Binding Label}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,70,Auto,70,Auto,70,Auto,70">
                                  <TextBlock Grid.Column="0" Text="CGST ₹" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding CgstText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="2" Text="SGST ₹" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding SgstText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="4" Text="IGST ₹" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="5" Text="{Binding IgstText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="6" Text="Cess ₹" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="7" Text="{Binding CessText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,110,Auto,110,*">
                                  <TextBlock Grid.Column="0" Text="Exempt T/O ₹" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding ExemptTurnoverText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="2" Text="Total T/O ₹" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding TotalTurnoverText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="4" Text="(Rule 42 / 43 only)" FontSize="10" Foreground="#888888" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <Button Content="Post reversal" Command="{Binding PostActionCommand}" FontSize="11" Padding="12,4"/>
                                  <Button Content="Post highlighted candidate" Command="{Binding PostCandidateActionCommand}" FontSize="11" Padding="12,4"
                                          IsEnabled="{Binding HasCandidates}"/>
                                  <Button Content="Reclaim" Command="{Binding ReclaimActionCommand}" FontSize="11" Padding="12,4"/>
                                </StackPanel>
                              </StackPanel>
                            </Border>
                            <Border Grid.Row="6" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Import GSTR-2B (Phase 9 UI-2; RQ-13). INTERACTIVE: opening it imports nothing; the
                         Import button is the only mutator. A malformed / wrong-GSTIN file fails all-or-nothing with
                         the parser's error code shown in the message strip. -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImportGstr2b, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).ImportGstr2b}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ImportGstr2bViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Border Grid.Row="2" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="8" Margin="0,0,0,6">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,120,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Statement" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding StatementTypes}" SelectedItem="{Binding StatementType, Mode=TwoWay}" FontSize="11">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:GstStatementType">
                                        <TextBlock Text="{Binding Converter={StaticResource GstStatementTypeLabel}}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock Grid.Column="2" Text="File" FontSize="11" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding FilePath, Mode=TwoWay}" FontSize="11" Padding="4,2"
                                           PlaceholderText="Full path of the portal's GSTR-2B .json"/>
                                </Grid>
                                <Button Content="Import" Command="{Binding ImportActionCommand}" FontSize="11" Padding="16,4" HorizontalAlignment="Left"/>
                              </StackPanel>
                            </Border>
                            <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="90,90,*,60,95">
                                <TextBlock Grid.Column="0" Text="Statement" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Period" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Imported" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Lines" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Tax" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>
                            <ItemsControl Grid.Row="5" Background="White" ItemsSource="{Binding Imported}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ImportedSnapshotRowVm">
                                  <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="90,90,*,60,95" Height="26">
                                      <TextBlock Grid.Column="0" Text="{Binding Statement}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Period}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="2" Text="{Binding ImportedAt}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Lines}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Tax}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Grid.Row="6" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Generate e-Invoice (Phase 9 UI-2; RQ-24). INTERACTIVE, offline INV-01 mode: opening it
                         prepares nothing; Prepare writes the JSON to upload, and the IRN / Ack / QR are typed back
                         from the portal (copied, never derived). -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).GenerateEInvoice, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).GenerateEInvoice}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GenerateEInvoiceViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}" IsVisible="{Binding HasCandidates}">
                              <Grid ColumnDefinitions="*,90,100,110">
                                <TextBlock Grid.Column="0" Text="Doc no" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Coverage" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Status" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="IRN" Classes="colHdr"/>
                              </Grid>
                            </Border>
                            <ListBox Grid.Row="4" Background="White" IsVisible="{Binding HasCandidates}"
                                     ItemsSource="{Binding Rows}"
                                     SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:EInvoiceCandidateRowVm">
                                  <Grid RowDefinitions="Auto,Auto" Margin="0,1">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,90,100,110" Height="20">
                                      <TextBlock Grid.Column="0" Text="{Binding DocNo}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"
                                                 FontWeight="{Binding IsCovered, Converter={StaticResource BoolWeight}}" TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Coverage}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"
                                                 Foreground="{Binding IsCovered, Converter={StaticResource BalancedBrush}}"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Status}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Irn}" Margin="4,0" VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    <!-- Grid, not a horizontal StackPanel — see the IMS row: an unbounded StackPanel
                                         clips a long note instead of wrapping it. -->
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" Margin="8,0,6,2">
                                      <TextBlock Grid.Column="0" Text="{Binding Date}" FontSize="10.5" Foreground="#888888"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="10.5" Foreground="#888888" Margin="6,0"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Note}" FontSize="10.5" Foreground="#666666" TextWrapping="Wrap"/>
                                    </Grid>
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Grid.Row="5" Classes="gstActionBar" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="8" Margin="0,6,0,0">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="INV-01 folder" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding Folder, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*,Auto,100,Auto,100">
                                  <TextBlock Grid.Column="0" Text="IRN" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding Irn, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="2" Text="Ack no" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding AckNo, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="4" Text="Ack date" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="5" Text="{Binding AckDateText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                  <TextBlock Grid.Column="0" Text="Signed QR" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding SignedQr, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <!-- The IRP's REJECTION, mirroring how the IRN / Ack are surfaced. Record-failure
                                     guards on ErrorCode, so without these boxes the button could never succeed — it
                                     failed every click with advice the user had no way to follow. -->
                                <Grid ColumnDefinitions="Auto,90,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Error code" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding ErrorCode, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="2" Text="Error message" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding ErrorMessage, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <!-- The cancellation reason ACTUALLY filed — it was hard-coded to "1", so the recorded
                                     statutory reason never reflected reality. -->
                                <Grid ColumnDefinitions="Auto,70,*">
                                  <TextBlock Grid.Column="0" Text="Cancel reason" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding CancelReasonCodes}"
                                            SelectedItem="{Binding CancelReasonCode, Mode=TwoWay}" FontSize="11"/>
                                  <TextBlock Grid.Column="2" Text="1 Duplicate · 2 Data entry mistake · 3 Order cancelled · 4 Other"
                                             FontSize="10" Foreground="#888888" VerticalAlignment="Center" Margin="8,0,0,0"
                                             TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <Button Content="Prepare + write INV-01" Command="{Binding PrepareActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Record IRN" Command="{Binding RecordIrnActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Record failure" Command="{Binding RecordFailureActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Cancel" Command="{Binding CancelActionCommand}" FontSize="11" Padding="10,4"/>
                                </StackPanel>
                              </StackPanel>
                            </Border>
                            <Border Grid.Row="6" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Generate e-Way Bill (Phase 9 UI-2; RQ-25). INTERACTIVE, offline EWB-01 mode. -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).GenerateEWayBill, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).GenerateEWayBill}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GenerateEWayBillViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}" IsVisible="{Binding HasCandidates}">
                              <Grid ColumnDefinitions="*,110,95,100">
                                <TextBlock Grid.Column="0" Text="Doc no" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Consignment" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Coverage" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Status" Classes="colHdr"/>
                              </Grid>
                            </Border>
                            <ListBox Grid.Row="4" Background="White" IsVisible="{Binding HasCandidates}"
                                     ItemsSource="{Binding Rows}"
                                     SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:EWayCandidateRowVm">
                                  <Grid RowDefinitions="Auto,Auto" Margin="0,1">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,110,95,100" Height="20">
                                      <TextBlock Grid.Column="0" Text="{Binding DocNo}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"
                                                 FontWeight="{Binding IsRequired, Converter={StaticResource BoolWeight}}" TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding ConsignmentValue}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Coverage}" Margin="4,0" VerticalAlignment="Center" FontSize="11"
                                                 Foreground="{Binding IsRequired, Converter={StaticResource BalancedBrush}}" TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Status}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Grid>
                                    <!-- Grid, not a horizontal StackPanel — see the IMS row: an unbounded StackPanel
                                         clips a long note instead of wrapping it. -->
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,*" Margin="8,0,6,2">
                                      <TextBlock Grid.Column="0" Text="{Binding Date}" FontSize="10.5" Foreground="#888888"/>
                                      <TextBlock Grid.Column="1" Text="{Binding EwbNumber}" FontSize="10.5" Foreground="#888888" Margin="6,0"/>
                                      <TextBlock Grid.Column="2" Text="{Binding ValidUpto}" FontSize="10.5" Foreground="#888888" Margin="0,0,6,0"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Note}" FontSize="10.5" Foreground="#666666" TextWrapping="Wrap"/>
                                    </Grid>
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Grid.Row="5" Classes="gstActionBar" Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="8" Margin="0,6,0,0">
                              <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,100,Auto,110,Auto,70,Auto,*">
                                  <TextBlock Grid.Column="0" Text="Mode" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding Modes}" SelectedItem="{Binding Mode, Mode=TwoWay}" FontSize="11"/>
                                  <TextBlock Grid.Column="2" Text="Vehicle" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding VehicleNumber, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="4" Text="km" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="5" Text="{Binding DistanceKmText, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="6" Text="Transporter" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="7" Text="{Binding TransporterId, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,140,Auto,140,Auto,*">
                                  <TextBlock Grid.Column="0" Text="EWB number" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <TextBox Grid.Column="1" Text="{Binding EwbNumber, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <TextBlock Grid.Column="2" Text="Ship-To GSTIN" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                  <TextBox Grid.Column="3" Text="{Binding ShipToGstin, Mode=TwoWay}" FontSize="11" Padding="4,2"/>
                                  <CheckBox Grid.Column="4" Content="ODC" FontSize="11" Margin="8,0,0,0"
                                            IsChecked="{Binding IsOverDimensionalCargo, Mode=TwoWay}"/>
                                </Grid>
                                <!-- The cancellation reason ACTUALLY filed on the portal — it was hard-coded to "1". -->
                                <Grid ColumnDefinitions="Auto,70,*">
                                  <TextBlock Grid.Column="0" Text="Cancel reason" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <ComboBox Grid.Column="1" ItemsSource="{Binding CancelReasonCodes}"
                                            SelectedItem="{Binding CancelReasonCode, Mode=TwoWay}" FontSize="11"/>
                                  <TextBlock Grid.Column="2" Text="1 Duplicate · 2 Order cancelled · 3 Data entry mistake · 4 Other"
                                             FontSize="10" Foreground="#888888" VerticalAlignment="Center" Margin="8,0,0,0"
                                             TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <!-- Close sits between Extend and Cancel: the statutory closure mechanism (01-Aug-2026
                                     onwards). It was implemented and command-generated but bound to NO button, so the
                                     shipped UI could not reach it at all. -->
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <Button Content="Prepare + write EWB-01" Command="{Binding PrepareActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Update Part-B" Command="{Binding SetPartBActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Record EWB no" Command="{Binding RecordPortalActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Extend" Command="{Binding ExtendActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Close" Command="{Binding CloseActionCommand}" FontSize="11" Padding="10,4"/>
                                  <Button Content="Cancel" Command="{Binding CancelActionCommand}" FontSize="11" Padding="10,4"/>
                                </StackPanel>
                              </StackPanel>
                            </Border>
                            <Border Grid.Row="6" Background="#FFF7E6" BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0"
                                    IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11.5" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: ITC Gate (§16(2)(aa) / §17(5)) (Phase 9 UI-1; RQ-15/RQ-26) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).ItcGateReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).ItcGateReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ItcGateReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,470,*" Margin="0,0,0,8"
                                  IsVisible="{Binding HasSnapshot}">
                              <TextBlock Grid.Column="0" Text="GSTR-2B snapshot" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Snapshots}"
                                        SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Gstr2bSnapshotOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <Border Background="{StaticResource BrandNavy}" IsVisible="{Binding HasSnapshot}">
                                  <!-- The numeric columns are kept narrow so the "*" label column has room: the row
                                       labels carry the statutory citation (§16(2)(aa), §17(5), Table 4(D)) that
                                       identifies the row, and must never ellipsis-truncate. -->
                                  <Grid ColumnDefinitions="*,95,95,95,105">
                                    <TextBlock Grid.Column="0" Text="ITC pool" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="CGST" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="SGST" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="IGST" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Total" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Rows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ItcGateTripleRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,95,95,95,105" Height="26">
                                          <TextBlock Grid.Column="0" Text="{Binding Label}" Margin="8,0" VerticalAlignment="Center" FontSize="12"
                                                     FontWeight="{Binding Emphasise, Converter={StaticResource BoolWeight}}"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Cgst}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Sgst}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Igst}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Total}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Reversal candidates"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"
                                           IsVisible="{Binding HasSnapshot}"/>
                                <ItemsControl Background="White" ItemsSource="{Binding Candidates}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ItcReversalCandidateRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="1,0,1,1" Padding="0">
                                        <Grid ColumnDefinitions="140,*,110" Height="28">
                                          <TextBlock Grid.Column="0" Text="{Binding Reason}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Description}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Suggested}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="#7A5B00" FontSize="12" TextWrapping="Wrap"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: QRMP / IFF cadence (Phase 9 UI-1; RQ-17) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).QrmpReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).QrmpReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:QrmpReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <TextBlock Text="IFF (Invoice Furnishing Facility) — M1 / M2 B2B windows"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"
                                           IsVisible="{Binding Applicable}"/>
                                <Border Background="{StaticResource BrandNavy}" IsVisible="{Binding Applicable}">
                                  <Grid ColumnDefinitions="150,120,90,*,120">
                                    <TextBlock Grid.Column="0" Text="Quarter" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Month" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Invoices" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Taxable value" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="₹50 L cap" Classes="colHdr"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding IffRows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:QrmpIffRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="150,120,90,*,120" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Quarter}" Margin="8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Month}" Margin="4,0" VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Invoices}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding TaxableValue}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Cap}" Margin="6,0" VerticalAlignment="Center" FontSize="11.5"
                                                     Foreground="{Binding WithinCap, Converter={StaticResource BalancedBrush}}"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="PMT-06 — M1 / M2 monthly-tax suggestions"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"
                                           IsVisible="{Binding Applicable}"/>
                                <Border Background="{StaticResource BrandNavy}" IsVisible="{Binding Applicable}">
                                  <Grid ColumnDefinitions="150,120,*,*,*,*">
                                    <TextBlock Grid.Column="0" Text="Quarter" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Month" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Fixed 35%" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Fixed 100%" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Self-assess" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Deposited" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Pmt06Rows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:QrmpPmt06RowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="150,120,*,*,*,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Quarter}" Margin="8,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Month}" Margin="4,0" VerticalAlignment="Center" FontSize="12"/>
                                          <TextBlock Grid.Column="2" Text="{Binding FixedSum35}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding FixedSum100}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding SelfAssessment}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding AlreadyDeposited}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#555555" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: GSTR-1 / 3B Amendments (Phase 9 UI-1; RQ-29) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).GstAmendmentsReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).GstAmendmentsReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GstAmendmentsReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GstAdvFyOption"><TextBlock Text="{Binding Label}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>
                            <ScrollViewer Grid.Row="3">
                              <StackPanel Spacing="8">
                                <TextBlock Text="Table 9A — Amended B2B invoices (advisory: original → revised → differential)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <!-- The identifier columns are held tight (a GSTIN is 15 chars, a doc-no short) so the
                                       four "*" amount columns are wide enough for both their headers and real
                                       amendment amounts — at 150/80/110 the headers clipped mid-word ("Orig taxat"). -->
                                  <Grid ColumnDefinitions="120,60,90,*,*,*,*">
                                    <TextBlock Grid.Column="0" Text="Party GSTIN" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Doc no" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Orig date" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Orig taxable" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Rev taxable" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Diff taxable" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="Diff tax" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Table9A}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Gstr1Amend9ARowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,60,90,*,*,*,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Party}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding DocNo}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="2" Text="{Binding OriginalDate}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding OriginalTaxable}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding RevisedTaxable}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding DifferentialTaxable}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="6" Text="{Binding DifferentialTax}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Table 9C — Amended credit / debit notes (signed revised tax)"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="100,140,110,110,*,*">
                                    <TextBlock Grid.Column="0" Text="Note type" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Orig invoice" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Orig date" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Note date" Classes="colHdr"/>
                                    <TextBlock Grid.Column="4" Text="Rev taxable" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Rev tax" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding Table9C}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Gstr1Amend9CRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="100,140,110,110,*,*" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding NoteType}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding OriginalInvoice}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding OriginalDate}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding NoteDate}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="4" Text="{Binding RevisedTaxable}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding RevisedTax}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="GSTR-3B correction advisory"
                                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="#F4F6FA" BorderBrush="{StaticResource GridLine}" BorderThickness="1" Padding="12">
                                  <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,*,*">
                                      <StackPanel Grid.Column="0"><TextBlock Text="Corrections" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding CorrectionCountText}" FontSize="13" FontWeight="Bold"/></StackPanel>
                                      <StackPanel Grid.Column="1" Classes="statCell"><TextBlock Text="Net tax ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding CorrectionTaxText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                      <StackPanel Grid.Column="2" Classes="statCell"><TextBlock Text="Net taxable ₹" FontSize="10.5" Foreground="#777777"/><TextBlock Text="{Binding CorrectionTaxableText}" FontSize="13" FontWeight="Bold" TextAlignment="Right"/></StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding MechanismText}" FontSize="11" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                  </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold" Foreground="#555555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: e-Invoice / e-Way status (Phase 9 UI-1; RQ-5/RQ-6) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).EInvoiceEWayStatusReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).EInvoiceEWayStatusReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EInvoiceEWayStatusReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <ScrollViewer Grid.Row="2">
                              <StackPanel Spacing="8">
                                <TextBlock Text="{Binding EInvoiceStatusText}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                <Border Background="{StaticResource BrandNavy}" IsVisible="{Binding HasEInvoices}">
                                  <Grid ColumnDefinitions="140,110,*,70,140,110">
                                    <TextBlock Grid.Column="0" Text="Document" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Status" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="IRN" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="QR" Classes="colHdr"/>
                                    <TextBlock Grid.Column="4" Text="Ack no" Classes="colHdr"/>
                                    <TextBlock Grid.Column="5" Text="Ack date" Classes="colHdr"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding EInvoices}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EInvoiceStatusRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="140,110,*,70,140,110" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding DocNo}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Status}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Irn}" Margin="4,0" VerticalAlignment="Center" FontSize="11" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="3" Text="{Binding Qr}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="4" Text="{Binding AckNo}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="5" Text="{Binding AckDate}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding EWayStatusText}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,6,0,0"/>
                                <Border Background="{StaticResource BrandNavy}" IsVisible="{Binding HasEWayBills}">
                                  <Grid ColumnDefinitions="140,110,140,170,120,90">
                                    <TextBlock Grid.Column="0" Text="Document" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Status" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="EWB no" Classes="colHdr"/>
                                    <TextBlock Grid.Column="3" Text="Valid upto" Classes="colHdr"/>
                                    <TextBlock Grid.Column="4" Text="Vehicle" Classes="colHdr"/>
                                    <TextBlock Grid.Column="5" Text="Distance" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Background="White" ItemsSource="{Binding EWayBills}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EWayStatusRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="140,110,140,170,120,90" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding DocNo}" Margin="8,0" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Status}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="2" Text="{Binding EwbNumber}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="3" Text="{Binding ValidUpto}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Vehicle}" Margin="4,0" VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="5" Text="{Binding Distance}" TextAlignment="Right" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Nature of Payment (TDS section) master (Phase 7 slice 1) -->
                    <ContentControl IsVisible="{Binding NatureOfPaymentMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding NatureOfPaymentMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:NatureOfPaymentMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Nature of Payment (TDS)"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <!-- Label columns are Auto + SharedSizeGroup: Auto guarantees a label can never clip
                                   its own text (a fixed 150 sliced "…§206AA)" down to "…§206A" — a real but DIFFERENT
                                   section), and the shared group keeps every row's input edge on one vertical line. -->
                              <StackPanel Spacing="10" Grid.IsSharedSizeScope="True">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelR"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Section Code" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding SectionCode, Mode=TwoWay}"
                                           PlaceholderText="e.g. 194J(b)"/>
                                  <TextBlock Grid.Column="2" Text="Form-26Q / FVU Code" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding FvuSectionCode, Mode=TwoWay}"
                                           PlaceholderText="e.g. 94J-B"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Fees for professional services"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelR"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Rate % (with PAN)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding RateWithPanText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="e.g. 10"/>
                                  <TextBlock Grid.Column="2" Text="Rate % (no PAN, §206AA)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0" FontSize="12"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding RateWithoutPanText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="e.g. 20"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NopLabelR"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Single-txn Threshold ₹" FontWeight="SemiBold"
                                             VerticalAlignment="Center" FontSize="12"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding SingleThresholdText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="blank ⇒ none"/>
                                  <TextBlock Grid.Column="2" Text="Cumulative-FY Threshold ₹" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0" FontSize="12"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding CumulativeThresholdText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="blank ⇒ none"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateNatureOfPaymentClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="90,*,80,80,140,70,90">
                                <TextBlock Grid.Column="0" Text="Section" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Name" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="PAN" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="no-PAN" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Threshold" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="FVU" Classes="colHdr"/>
                                <TextBlock Grid.Column="6" Text="Kind" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Natures}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:NatureOfPaymentListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="90,*,80,80,140,70,90" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding SectionCode}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding RateWithPan}"
                                                   TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding RateWithoutPan}"
                                                   TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Threshold}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" Text="{Binding FvuCode}"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Kind}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#777777"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Nature of Goods (§206C TCS) master (Phase 7 slice 1) -->
                    <ContentControl IsVisible="{Binding NatureOfGoodsMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding NatureOfGoodsMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:NatureOfGoodsMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Nature of Goods (§206C TCS)"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <!-- Same Auto + SharedSizeGroup treatment as the Nature-of-Payment form: a fixed 150
                                   sliced "…§206CC)" down to "…§206C" — §206C (the TCS charging section) and §206CC
                                   (the no-PAN higher rate) are DIFFERENT statutes carrying different rates. -->
                              <StackPanel Spacing="10" Grid.IsSharedSizeScope="True">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NogLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NogLabelR"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Collection Code" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding CollectionCode, Mode=TwoWay}"
                                           PlaceholderText="e.g. 6CE"/>
                                  <TextBlock Grid.Column="2" Text="Threshold ₹" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding ThresholdText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="blank ⇒ full value"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NogLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. Scrap"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NogLabelL"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="NogLabelR"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Margin="0,0,10,0" Grid.Column="0" Text="Rate % (with PAN)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding RateWithPanText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="e.g. 1"/>
                                  <TextBlock Grid.Column="2" Text="Rate % (no PAN, §206CC)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,10,0" FontSize="12"
                                             TextTrimming="CharacterEllipsis"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="3" Text="{Binding RateWithoutPanText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="e.g. 5"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateNatureOfGoodsClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="80,*,80,80,120,140">
                                <TextBlock Grid.Column="0" Text="Code" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Name" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="PAN" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="no-PAN" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Threshold" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Kind" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Natures}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:NatureOfGoodsListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="80,*,80,80,120,140" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding CollectionCode}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding RateWithPan}"
                                                   TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding RateWithoutPan}"
                                                   TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Threshold}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Kind}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11.5"
                                                   Foreground="#777777" TextTrimming="CharacterEllipsis"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: TDS Stat Payment deposit (Payment Ctrl+F; Phase 7 slice 3) -->
                    <ContentControl IsVisible="{Binding TdsStatPayment, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding TdsStatPayment}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:TdsStatPaymentViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="TDS Stat Payment (Deposit)"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,4"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding OutstandingText, StringFormat='Outstanding TDS Payable: ₹{0}'}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="10" MaxWidth="640">
                                <Grid ColumnDefinitions="160,*">
                                  <TextBlock Grid.Column="0" Text="Section (remaining)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding SectionOptions}"
                                            SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                            PlaceholderText="Nothing outstanding">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:StatPaymentSectionOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="160,*,160,*">
                                  <TextBlock Grid.Column="0" Text="Deposit Amount ₹" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding AmountText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="e.g. 5000"/>
                                  <TextBlock Grid.Column="2" Text="Pay From (Bank/Cash)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding BankOptions}"
                                            SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                            PlaceholderText="Select ledger…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Ledger">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="12" Margin="0,4,0,0">
                                  <StackPanel Spacing="10">
                                    <TextBlock Text="Challan (ITNS-281)" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="160,*,160,*">
                                      <TextBlock Grid.Column="0" Text="Challan (CIN) No." FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding ChallanNo, Mode=TwoWay}"
                                               PlaceholderText="e.g. 00021"/>
                                      <TextBlock Grid.Column="2" Text="BSR Code" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding BsrCode, Mode=TwoWay}"
                                               PlaceholderText="7-digit, e.g. 0510308"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="160,*,160,*">
                                      <TextBlock Grid.Column="0" Text="Deposit Date" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding DepositDateText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                      <TextBlock Grid.Column="2" Text="Section" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding SectionCode, Mode=TwoWay}"
                                               PlaceholderText="e.g. 194J(b)"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="160,*">
                                      <TextBlock Grid.Column="0" Text="Minor Head" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding MinorHead, Mode=TwoWay}"
                                               PlaceholderText="200 (TDS payable) / 400 (regular assessment)"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Deposit (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnDepositTdsStatPaymentClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Challan Reconciliation report (Alt+R; Phase 7 slice 3) -->
                    <ContentControl IsVisible="{Binding ChallanReconciliation, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ChallanReconciliation}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ChallanReconciliationViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                                       FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"
                                       Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="140,*,140,140,140,110">
                                <TextBlock Grid.Column="0" Text="Section" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Deducted" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Deposited" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Remaining" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Status" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ListBox Grid.Row="4" Background="White"
                                     ItemsSource="{Binding Rows}"
                                     SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChallanReconRow">
                                  <Grid ColumnDefinitions="140,*,140,140,140,110" Height="24">
                                    <TextBlock Grid.Column="0" Text="{Binding Section}"
                                               Margin="4,0" VerticalAlignment="Center" FontSize="12"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Deducted}"
                                               TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Deposited}"
                                               TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Remaining}"
                                               TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Status}"
                                               Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding IsMatched, Converter={StaticResource BalancedBrush}}"/>
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="5" Background="#F4F4EC"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0">
                              <Grid ColumnDefinitions="140,*,140,140,140,110" Height="28">
                                <TextBlock Grid.Column="0" Text="Total" Margin="4,0"
                                           VerticalAlignment="Center" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Grid.Column="2" Text="{Binding TotalDeducted}"
                                           TextAlignment="Right" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="{Binding TotalDeposited}"
                                           TextAlignment="Right" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="{Binding TotalRemaining}"
                                           TextAlignment="Right" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="12"/>
                              </Grid>
                            </Border>

                            <!-- Cash-basis clarifying note: this recon windows deposits by challan deposit date, so a
                                 legally-compliant cross-FY deposit can read as outstanding here. Point the reader at the
                                 period-attributed views (Form 26Q + TDS Outstandings). Amber band mirrors the S8 footnote. -->
                            <Border Grid.Row="6" Background="#FFF7E6"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0">
                              <TextBlock Text="{Binding BasisNote}" TextWrapping="Wrap"
                                         FontSize="11" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 26Q quarterly TDS return (Ctrl+A export FVU · Alt+B save-return; Phase 7 slice 4) -->
                    <ContentControl IsVisible="{Binding Form26Q, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Form26Q}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form26QViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + quarter selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,180,Auto,180,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form26QFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form26QQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Deductor block -->
                            <Border Grid.Row="3" Background="#F4F4EC"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Deductor (TAN)" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeductorTan}"
                                           FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,12,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Type" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DeductorType}"
                                           FontSize="12" Margin="0,0,0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Responsible" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                           Text="{Binding ResponsiblePerson}" FontSize="12" TextWrapping="Wrap"/>
                              </Grid>
                            </Border>

                            <!-- Control totals (Form-27A style) -->
                            <Border Grid.Row="4" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*,*,*">
                                  <StackPanel Grid.Column="0">
                                    <TextBlock Text="Deductee rows" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding DeducteeRecordCount}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1">
                                    <TextBlock Text="Challans" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding ChallanRecordCount}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell">
                                    <TextBlock Text="Amount paid ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalAmountPaid}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell">
                                    <TextBlock Text="TDS deducted ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalTdsDeducted}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="4" Classes="statCell">
                                    <TextBlock Text="Deposited ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalDeposited}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding ControlTotalsTally, Converter={StaticResource BalancedBrush}}"/>
                              </StackPanel>
                            </Border>

                            <!-- Challan blocks -->
                            <StackPanel Grid.Row="5" Margin="0,0,0,6"
                                        IsVisible="{Binding !IsEmpty}">
                              <TextBlock Text="Challans (ITNS-281)" FontWeight="Bold" FontSize="12"
                                         Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                              <Border Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="120,120,120,140,90">
                                  <TextBlock Grid.Column="0" Text="Challan No." Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="BSR Code" Classes="colHdr"/>
                                  <TextBlock Grid.Column="2" Text="Deposit Date" Classes="colHdr"/>
                                  <TextBlock Grid.Column="3" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="4" Text="Section" Classes="colHdr"/>
                                </Grid>
                              </Border>
                              <ItemsControl ItemsSource="{Binding Challans}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form26QChallanRowVm">
                                    <Grid ColumnDefinitions="120,120,120,140,90" Height="22">
                                      <TextBlock Grid.Column="0" Text="{Binding ChallanNo}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding BsrCode}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 FontFamily="Consolas,Menlo,monospace"/>
                                      <TextBlock Grid.Column="2" Text="{Binding DepositDate}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Amount}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Section}" Margin="6,0,0,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <!-- Deductee detail grid (selectable) -->
                            <Grid Grid.Row="6" RowDefinitions="Auto,Auto,*">
                              <TextBlock Grid.Row="0" Text="Deductee details" FontWeight="Bold" FontSize="12"
                                         Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                              <Border Grid.Row="1" Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="110,*,80,70,100,110,100,55">
                                  <TextBlock Grid.Column="0" Text="PAN" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Deductee" Classes="colHdr"/>
                                  <TextBlock Grid.Column="2" Text="Section" Classes="colHdr"/>
                                  <TextBlock Grid.Column="3" Text="FVU" Classes="colHdr"/>
                                  <TextBlock Grid.Column="4" Text="Date" Classes="colHdr"/>
                                  <TextBlock Grid.Column="5" Text="Amount Paid" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="6" Text="TDS" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="7" Text="Rate %" Classes="colHdr" TextAlignment="Right"/>
                                </Grid>
                              </Border>
                              <ListBox Grid.Row="2" Background="White"
                                       ItemsSource="{Binding Deductees}"
                                       SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form26QDeducteeRowVm">
                                    <Grid ColumnDefinitions="110,*,80,70,100,110,100,55" Height="24">
                                      <TextBlock Grid.Column="0" Text="{Binding Pan}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 FontFamily="Consolas,Menlo,monospace"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Section}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="3" Text="{Binding FvuCode}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Date}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="5" Text="{Binding AmountPaid}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="6" Text="{Binding Tds}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="7" Text="{Binding Rate}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                    </Grid>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>
                            </Grid>

                            <!-- Status + actions -->
                            <Grid Grid.Row="7" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export FVU (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportFvuForm26QClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm26QClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: PF ECR / Challan report (Phase 8 slice 4; RQ-9) -->
                    <ContentControl IsVisible="{Binding PfEcrReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding PfEcrReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PfEcrReportViewModel">
                          <Grid x:Name="PfEcrReportPane" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + wage-month selectors (establishment code is shown in the subtitle) -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,160,Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PfEcrFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Wage Month" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Months}"
                                        SelectedItem="{Binding SelectedMonth, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PfEcrMonthOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Challan account-head totals (A/c 1/2/10/21/22 + grand total) -->
                            <Border Grid.Row="3" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*,*,*,*">
                                  <StackPanel Grid.Column="0" Classes="statCell">
                                    <TextBlock Text="A/c 1 — EPF ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding Account1Text}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell">
                                    <TextBlock Text="A/c 2 — Admin ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding Account2Text}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell">
                                    <TextBlock Text="A/c 10 — EPS ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding Account10Text}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell">
                                    <TextBlock Text="A/c 21 — EDLI ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding Account21Text}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="4" Classes="statCell">
                                    <TextBlock Text="A/c 22 — EDLI Adm ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding Account22Text}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="5" Classes="statCell">
                                    <TextBlock Text="Total ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding GrandTotalText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>

                            <!-- Member (ECR 2.0) detail grid — wide, so it scrolls horizontally -->
                            <TextBlock Grid.Row="4" Text="ECR 2.0 member lines" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                            <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                              <Grid RowDefinitions="Auto,*" Width="{Binding #PfEcrReportPane.Bounds.Width}" MinWidth="1120">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="120,*,90,90,90,90,90,90,90,60,80" MinWidth="1120">
                                    <TextBlock Grid.Column="0" Text="UAN" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Member" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Gross" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="EPF Wg" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="EPS Wg" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="EDLI Wg" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="EE EPF" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="7" Text="EPS" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="8" Text="ER EPF" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="9" Text="NCP" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="10" Text="Refund" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding Members}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PfEcrMemberRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="120,*,90,90,90,90,90,90,90,60,80" MinWidth="1120" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding Uan}" Margin="6,0"
                                                     VerticalAlignment="Center" FontSize="11.5"
                                                     FontFamily="Consolas,Menlo,monospace"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding GrossWages}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding EpfWages}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding EpsWages}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding EdliWages}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="6" Text="{Binding EmployeeShareEpf}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="7" Text="{Binding EpsContribution}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="8" Text="{Binding EmployerShareEpf}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="9" Text="{Binding NcpDays}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="10" Text="{Binding RefundOfAdvances}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Grid>
                            </ScrollViewer>

                            <!-- Status + actions -->
                            <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export ECR (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportEcrClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnPfEcrClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: ESI Monthly Contribution report (Phase 8 slice 5; RQ-10) -->
                    <ContentControl IsVisible="{Binding EsiContributionReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding EsiContributionReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EsiContributionReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + wage-month selectors (employer code is shown in the subtitle) -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,160,Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:EsiContributionFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Wage Month" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Months}"
                                        SelectedItem="{Binding SelectedMonth, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:EsiContributionMonthOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Contribution footings (total wages + EE 0.75% + ER 3.25% + grand total) -->
                            <Border Grid.Row="3" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*,*">
                                  <StackPanel Grid.Column="0" Classes="statCell">
                                    <TextBlock Text="ESI Wages ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalWagesText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell">
                                    <TextBlock Text="Employee 0.75% ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalEmployeeText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell">
                                    <TextBlock Text="Employer 3.25% ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalEmployerText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell">
                                    <TextBlock Text="Total ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding GrandTotalText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>

                            <!-- Per-IP contribution grid — wide, so it scrolls horizontally -->
                            <TextBlock Grid.Row="4" Text="Insured-Person contribution lines" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                            <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                              <Grid RowDefinitions="Auto,*" Width="560">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="100,*,46,88,88,92">
                                    <TextBlock Grid.Column="0" Text="IP Number" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Insured Person" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="Days" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="ESI Wages" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="EE 0.75%" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="ER 3.25%" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding Members}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EsiContributionRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="100,*,46,88,88,92" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding IpNumber}" Margin="6,0"
                                                     VerticalAlignment="Center" FontSize="11.5"
                                                     FontFamily="Consolas,Menlo,monospace"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Days}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding EsiWages}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding EmployeeContribution}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding EmployerContribution}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,8,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Grid>
                            </ScrollViewer>

                            <!-- Status + actions -->
                            <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export Contribution File (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportEsiContributionClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnEsiContributionClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: PT Deduction Register (Phase 8 slice 6; RQ-11) -->
                    <ContentControl IsVisible="{Binding ProfessionalTaxRegister, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ProfessionalTaxRegister}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ProfessionalTaxRegisterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + wage-month selectors (state + enrolment are shown in the subtitle) -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,160,Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PtRegisterFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Wage Month" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Months}"
                                        SelectedItem="{Binding SelectedMonth, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PtRegisterMonthOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Footings: total PT wages + total PT to remit -->
                            <Border Grid.Row="3" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*">
                                  <StackPanel Grid.Column="0" Classes="statCell">
                                    <TextBlock Text="PT Wages ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalWagesText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell">
                                    <TextBlock Text="Professional Tax ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalPtText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>

                            <!-- Per-employee PT grid — wide, so it scrolls horizontally -->
                            <TextBlock Grid.Row="4" Text="Employee-wise Professional Tax" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                            <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                              <Grid RowDefinitions="Auto,*" Width="560">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,110,110,110,120">
                                    <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Emp. No." Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="PT Wages" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Monthly PT" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="FY Cumulative" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding Rows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PtRegisterRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,110,110,110,120" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding EmployeeName}" Margin="6,0"
                                                     VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding EmployeeNumber}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                          <TextBlock Grid.Column="2" Text="{Binding PtWages}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding MonthlyPt}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding FyCumulative}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,8,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Grid>
                            </ScrollViewer>

                            <!-- Status + actions -->
                            <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export Register (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportProfessionalTaxClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnProfessionalTaxClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Gratuity Provision register (Phase 8 slice 9; RQ-14) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).GratuityProvisionRegister, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).GratuityProvisionRegister}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GratuityProvisionRegisterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + provision-as-on selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,160,Auto,170,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GratuityFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Provision as-on" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Months}"
                                        SelectedItem="{Binding SelectedMonth, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:GratuityAsOnMonthOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Footings: total liability + prior provision + delta to post -->
                            <Border Grid.Row="3" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*">
                                  <StackPanel Grid.Column="0" Classes="statCell">
                                    <TextBlock Text="Total Liability ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalLiabilityText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell">
                                    <TextBlock Text="Prior Provision ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding PriorProvisionText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell">
                                    <TextBlock Text="Delta to Post ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding DeltaText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>

                            <!-- Per-employee accrual grid — wide, so it scrolls horizontally -->
                            <TextBlock Grid.Row="4" Text="Employee-wise Gratuity Accrual" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                            <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                              <Grid RowDefinitions="Auto,*" Width="560">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,64,82,44,50,80,96">
                                    <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Emp. No." Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="Joined" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Years" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Vested" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Basic+DA" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="Accrued" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding Rows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GratuityRegisterRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,64,82,44,50,80,96" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding EmployeeName}" Margin="6,0"
                                                     VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding EmployeeNumber}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                          <TextBlock Grid.Column="2" Text="{Binding DateOfJoining}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding CompletedYears}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Vested}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding BasicPlusDa}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="6" Text="{Binding AccruedGratuity}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,8,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Grid>
                            </ScrollViewer>

                            <!-- Status + actions -->
                            <Grid Grid.Row="6" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding PostStatus}"
                                         IsVisible="{Binding PostStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Post Provision (Ctrl+A)" Padding="12,6"
                                      IsEnabled="{Binding CanPost}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnPostGratuityProvisionClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Statutory Bonus register (Phase 8 slice 9; RQ-15) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).BonusRegister, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).BonusRegister}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BonusRegisterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- Accounting-year selector -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,180,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Accounting Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BonusFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Footing: total bonus -->
                            <Border Grid.Row="3" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*">
                                  <StackPanel Grid.Column="0">
                                    <TextBlock Text="Accounting Year" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding AccountingYearText}" FontSize="12.5" FontWeight="SemiBold"/>
                                  </StackPanel>
                                  <!-- Money cell. Column 0 above holds the accounting-year TEXT and stays left/left. -->
                                  <StackPanel Grid.Column="1" Classes="statCell">
                                    <TextBlock Text="Total Bonus ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalBonusText}" TextAlignment="Right"
                                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="#555555" TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>

                            <!-- Per-employee bonus grid — wide, so it scrolls horizontally -->
                            <TextBlock Grid.Row="4" Text="Employee-wise Statutory Bonus" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                            <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                              <Grid RowDefinitions="Auto,*" Width="560">
                                <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="*,58,68,80,86,54,96">
                                    <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Emp. No." Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="Eligible" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Basic+DA" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Capped Base" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="Annual Bonus" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding Rows}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BonusRegisterRowVm">
                                      <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,58,68,80,86,54,96" Height="24">
                                          <TextBlock Grid.Column="0" Text="{Binding EmployeeName}" Margin="6,0"
                                                     VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding EmployeeNumber}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Eligible}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="3" Text="{Binding ActualBasicDa}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="4" Text="{Binding CappedBase}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="5" Text="{Binding RatePercent}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                          <TextBlock Grid.Column="6" Text="{Binding AnnualBonus}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,8,0"/>
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Grid>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Income Tax Declaration (Form 12BB) master (Phase 8 slice 7; RQ-12) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).TaxDeclarationMaster, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).TaxDeclarationMaster}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:TaxDeclarationViewModel">
                          <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <Grid Grid.Row="2" ColumnDefinitions="260,*">
                              <!-- Employee picker (left) -->
                              <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="0,0,10,0">
                                <TextBlock Grid.Row="0" Text="Employee" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                                <ListBox Grid.Row="1" Background="White"
                                         ItemsSource="{Binding Employees}"
                                         SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                  <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TaxDeclarationEmployeeVm">
                                      <Grid ColumnDefinitions="*,44" Height="30">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Text="{Binding Pan}" FontSize="10.5" Foreground="#888888"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#EEF1F6" CornerRadius="3"
                                                VerticalAlignment="Center" Padding="4,1">
                                          <TextBlock Text="{Binding Regime}" FontSize="10.5"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                        </Border>
                                      </Grid>
                                    </DataTemplate>
                                  </ListBox.ItemTemplate>
                                </ListBox>
                              </Grid>

                              <!-- Declaration editor (right) -->
                              <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                            IsVisible="{Binding HasEmployee}">
                                <StackPanel Spacing="10">
                                  <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto">
                                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Regime" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RegimeText}"
                                                 FontSize="12" Margin="0,0,12,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="2" Text="Age band" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding AgeBandText}"
                                                 FontSize="12" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="1" Grid.Column="0" Text="PAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding PanText}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                                    </Grid>
                                  </Border>
                                  <TextBlock Text="{Binding RegimeNote}" FontSize="11" Foreground="#8A8A8A"
                                             TextWrapping="Wrap"/>

                                  <TextBlock Text="DECLARED DEDUCTIONS &amp; EXEMPTIONS (₹)" FontSize="11" FontWeight="Bold"
                                             Foreground="#9098A8" LetterSpacing="1.2"/>
                                  <Grid ColumnDefinitions="230,160" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                        IsEnabled="{Binding IsOldRegime}">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="80C (LIC/PPF/ELSS, ≤₹1.5L)"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Section80CText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="80D (medical insurance)"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Section80DText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="80CCD(1B) NPS (≤₹50k)"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Section80CCD1BText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="HRA exemption 10(13A)"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HouseRentAllowanceExemptText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="24(b) home-loan interest (≤₹2L)"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding HomeLoanInterest24bText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Previous-employer salary"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding PreviousEmployerSalaryText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                  </Grid>

                                  <TextBlock Text="ALLOWED IN BOTH REGIMES / OTHER (₹)" FontSize="11" FontWeight="Bold"
                                             Foreground="#9098A8" LetterSpacing="1.2"/>
                                  <Grid ColumnDefinitions="230,160" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="80CCD(2) employer NPS"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Section80CCD2EmployerText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Other income declared"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OtherIncomeText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Previous-employer TDS"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PreviousEmployerTdsText, Mode=TwoWay}"
                                             Margin="0,3" PlaceholderText="0"/>
                                  </Grid>
                                </StackPanel>
                              </ScrollViewer>
                            </Grid>

                            <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="11.5" Margin="0,8,0,0"
                                       Foreground="#555555" TextWrapping="Wrap"/>
                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Message}"
                                         IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="#B00020" FontSize="11.5" VerticalAlignment="Center"
                                         TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Save (Ctrl+A)" Padding="14,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnSaveTaxDeclarationClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 24Q quarterly salary-TDS return (Phase 8 slice 7; RQ-13) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Form24Q, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Form24Q}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form24QViewModel">
                          <Grid x:Name="Form24QReportPane" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + quarter + section selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,Auto,150,Auto,220" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form24QFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form24QQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="4" Text="Section" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="5" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding SectionCodes}"
                                        SelectedItem="{Binding SelectedSectionCode, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:SalarySectionCodeOption">
                                    <TextBlock Text="{Binding Display}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Deductor block -->
                            <Border Grid.Row="3" Background="#F4F4EC"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Deductor (TAN)" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeductorTan}"
                                           FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,12,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Type" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DeductorType}"
                                           FontSize="12" Margin="0,0,0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Responsible" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                           Text="{Binding ResponsiblePerson}" FontSize="12" TextWrapping="Wrap"/>
                              </Grid>
                            </Border>

                            <!-- Control totals -->
                            <Border Grid.Row="4" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*,*">
                                  <StackPanel Grid.Column="0">
                                    <TextBlock Text="Deductee rows (Annexure I)" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding DeducteeRecordCount}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1" Classes="statCell">
                                    <TextBlock Text="TDS deducted ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalTdsDeducted}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2">
                                    <TextBlock Text="Annexure II employees" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding AnnexureIiCount}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell">
                                    <TextBlock Text="Annexure II TDS ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding AnnexureIiTaxDeducted}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Foreground="{StaticResource BrandNavy}"/>
                              </StackPanel>
                            </Border>

                            <!-- Annexure I deductee grid (selectable) + Annexure II (Q4 only) -->
                            <Grid Grid.Row="5" RowDefinitions="Auto,Auto,*,Auto">
                              <TextBlock Grid.Row="0" Text="Annexure I — deductee-wise §192 TDS" FontWeight="Bold"
                                         FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                              <Border Grid.Row="1" Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="120,*,70,110,110">
                                  <TextBlock Grid.Column="0" Text="PAN" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Employee" Classes="colHdr"/>
                                  <TextBlock Grid.Column="2" Text="Section" Classes="colHdr"/>
                                  <TextBlock Grid.Column="3" Text="Date" Classes="colHdr"/>
                                  <TextBlock Grid.Column="4" Text="TDS" Classes="colHdr" TextAlignment="Right"/>
                                </Grid>
                              </Border>
                              <ListBox Grid.Row="2" Background="White"
                                       ItemsSource="{Binding Deductees}"
                                       SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form24QDeducteeRowVm">
                                    <Grid ColumnDefinitions="120,*,70,110,110" Height="24">
                                      <TextBlock Grid.Column="0" Text="{Binding Pan}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 FontFamily="Consolas,Menlo,monospace"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="2" Text="{Binding Section}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Date}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Tds}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                    </Grid>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>
                              <!-- Reusable empty-state (C7): shown across the Annexure I body when this
                                   quarter has no deductee rows yet. -->
                              <views:EmptyState Grid.Row="2" Message="No deductee rows for this quarter yet."
                                                IsVisible="{Binding Deductees.Count, Converter={StaticResource CollectionEmpty}}"/>

                              <StackPanel Grid.Row="3" Margin="0,8,0,0" IsVisible="{Binding IsQ4}">
                                <TextBlock Text="Annexure II — per-employee annual salary &amp; tax (Q4)" FontWeight="Bold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                              MaxHeight="200">
                                  <Grid RowDefinitions="Auto,*" Width="{Binding #Form24QReportPane.Bounds.Width}" MinWidth="1160">
                                    <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
                                      <Grid ColumnDefinitions="*,110,60,100,90,90,100,100,90,80,100,100" MinWidth="1160">
                                        <TextBlock Grid.Column="0" Text="Employee" Classes="colHdr"/>
                                        <TextBlock Grid.Column="1" Text="PAN" Classes="colHdr"/>
                                        <TextBlock Grid.Column="2" Text="Regime" Classes="colHdr"/>
                                        <TextBlock Grid.Column="3" Text="Gross" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="Std Ded" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="5" Text="Ch VI-A" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="6" Text="Taxable" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="7" Text="Income Tax" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="8" Text="Surcharge" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="9" Text="Cess" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="10" Text="Total Tax" Classes="colHdr" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="11" Text="TDS" Classes="colHdr" TextAlignment="Right"/>
                                      </Grid>
                                    </Border>
                                    <ItemsControl Grid.Row="1" Background="White" ItemsSource="{Binding AnnexureII}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:Form24QAnnexureIIRowVm">
                                          <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,110,60,100,90,90,100,100,90,80,100,100" MinWidth="1160" Height="24">
                                              <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="4,0"
                                                         VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                                         TextTrimming="CharacterEllipsis"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Pan}" Margin="2,0"
                                                         VerticalAlignment="Center" FontSize="11"
                                                         FontFamily="Consolas,Menlo,monospace"/>
                                              <TextBlock Grid.Column="2" Text="{Binding Regime}" Margin="2,0"
                                                         VerticalAlignment="Center" FontSize="11"/>
                                              <TextBlock Grid.Column="3" Text="{Binding GrossSalary}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="4" Text="{Binding StandardDeduction}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="5" Text="{Binding ChapterVia}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="6" Text="{Binding TaxableIncome}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="7" Text="{Binding IncomeTax}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="8" Text="{Binding Surcharge}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="9" Text="{Binding Cess}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="10" Text="{Binding TotalTax}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Margin="0,0,4,0"/>
                                              <TextBlock Grid.Column="11" Text="{Binding TaxDeducted}" TextAlignment="Right"
                                                         VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                            </Grid>
                                          </Border>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </Grid>
                                </ScrollViewer>
                              </StackPanel>
                            </Grid>

                            <!-- Status + actions -->
                            <Grid Grid.Row="7" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportForm24QClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm24QClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 16 salary-TDS certificate (Phase 8 slice 7; RQ-13) -->
                    <ContentControl IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).Form16, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding #Root.((vm:MainWindowViewModel)DataContext).Form16}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form16ViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + section selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,Auto,220,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form16FyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Section" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding SectionCodes}"
                                        SelectedItem="{Binding SelectedSectionCode, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:SalarySectionCodeOption">
                                    <TextBlock Text="{Binding Display}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="220,*">
                              <!-- Employee picker (left) -->
                              <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="0,0,10,0">
                                <TextBlock Grid.Row="0" Text="Employee" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                                <ListBox Grid.Row="1" Background="White"
                                         ItemsSource="{Binding Employees}"
                                         SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                  <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Form16EmployeeOptionVm">
                                      <Grid ColumnDefinitions="*,Auto" Height="30">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Text="{Binding Pan}" FontSize="10.5" Foreground="#888888"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TdsTotal}" FontSize="11.5"
                                                   VerticalAlignment="Center" Margin="4,0,4,0"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ListBox.ItemTemplate>
                                </ListBox>
                              </Grid>

                              <!-- Certificate detail (right) -->
                              <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8">
                                  <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto">
                                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Employee" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EmployeeName}"
                                                 FontSize="12" FontWeight="SemiBold" Margin="0,0,12,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="2" Text="AY" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding AssessmentYear}"
                                                 FontSize="12" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="1" Grid.Column="0" Text="PAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EmployeePan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,12,0"/>
                                      <TextBlock Grid.Row="1" Grid.Column="2" Text="TAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding DeductorTan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                                    </Grid>
                                  </Border>

                                  <!-- Part A -->
                                  <TextBlock Text="Part A — Quarter-wise TDS" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="*,160">
                                      <TextBlock Grid.Column="0" Text="Quarter" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="TDS Deducted ₹" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding PartA}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:Form16QuarterRowVm">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                          <Grid ColumnDefinitions="*,160" Height="24">
                                            <TextBlock Grid.Column="0" Text="{Binding Quarter}" Margin="6,0"
                                                       VerticalAlignment="Center" FontSize="11.5"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TdsDeducted}" TextAlignment="Right"
                                                       VerticalAlignment="Center" FontSize="11.5" Margin="0,0,6,0"/>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Grid ColumnDefinitions="*,160" Background="#EEF1F6">
                                    <TextBlock Grid.Column="0" Text="Total TDS deducted" Margin="6,3"
                                               FontWeight="Bold" FontSize="11.5" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalTdsDeducted}" TextAlignment="Right"
                                               Margin="0,3,6,3" FontWeight="Bold" FontSize="11.5"/>
                                  </Grid>

                                  <!-- Part B -->
                                  <TextBlock Text="Part B — Salary &amp; tax computation" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}" Margin="0,6,0,0"/>
                                  <Grid ColumnDefinitions="*,160" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                        IsVisible="{Binding HasPartB}">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Regime" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Regime}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Gross salary" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GrossSalary}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Standard deduction" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StandardDeduction}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Chapter VI-A / exemptions" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ChapterVia}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Total taxable income" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TaxableIncome}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Income tax (after §87A)" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding IncomeTax}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Surcharge" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Surcharge}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Health &amp; edu. cess (4%)" Margin="6,2" FontSize="11.5"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Cess}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontSize="11.5"/>
                                    <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Background="#EEF1F6" Height="1" Margin="0,2"/>
                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Total tax liability" Margin="6,2"
                                               FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrandNavy}"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding TotalTax}" TextAlignment="Right"
                                               Margin="0,2,6,2" FontWeight="Bold" FontSize="12"/>
                                  </Grid>
                                  <TextBlock Text="No annual computation for this employee (Part B is built from the Q4 return)."
                                             FontSize="11.5" Foreground="#777777" IsVisible="{Binding !HasPartB}"/>
                                </StackPanel>
                              </ScrollViewer>
                            </Grid>

                            <!-- Status + actions -->
                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export PDF (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportForm16Click"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm16Click"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: TCS Stat Payment (deposit; Ctrl+A; Phase 7 slice 6) -->
                    <ContentControl IsVisible="{Binding TcsStatPayment, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding TcsStatPayment}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:TcsStatPaymentViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="TCS Stat Payment (Deposit)"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,4"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding OutstandingText, StringFormat='Outstanding TCS Payable: ₹{0}'}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="10" MaxWidth="640">
                                <Grid ColumnDefinitions="160,*">
                                  <TextBlock Grid.Column="0" Text="Code (remaining)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding CodeOptions}"
                                            SelectedItem="{Binding SelectedCode, Mode=TwoWay}"
                                            PlaceholderText="Nothing outstanding">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:TcsStatPaymentCodeOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="160,*,160,*">
                                  <TextBlock Grid.Column="0" Text="Deposit Amount ₹" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding AmountText, Mode=TwoWay}"
                                           TextAlignment="Right" PlaceholderText="e.g. 1180"/>
                                  <TextBlock Grid.Column="2" Text="Pay From (Bank/Cash)" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding BankOptions}"
                                            SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                            PlaceholderText="Select ledger…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Ledger">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="12" Margin="0,4,0,0">
                                  <StackPanel Spacing="10">
                                    <TextBlock Text="Challan (ITNS-281)" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <Grid ColumnDefinitions="160,*,160,*">
                                      <TextBlock Grid.Column="0" Text="Challan (CIN) No." FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding ChallanNo, Mode=TwoWay}"
                                               PlaceholderText="e.g. 00021"/>
                                      <TextBlock Grid.Column="2" Text="BSR Code" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding BsrCode, Mode=TwoWay}"
                                               PlaceholderText="7-digit, e.g. 0510308"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="160,*,160,*">
                                      <TextBlock Grid.Column="0" Text="Deposit Date" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding DepositDateText, Mode=TwoWay}"
                                               PlaceholderText="dd-MM-yyyy"/>
                                      <TextBlock Grid.Column="2" Text="Collection Code" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="3" Text="{Binding CollectionCode, Mode=TwoWay}"
                                               PlaceholderText="§206C, e.g. 6CE"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="160,*">
                                      <TextBlock Grid.Column="0" Text="Minor Head" FontWeight="SemiBold"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 Foreground="{StaticResource BrandNavy}"/>
                                      <TextBox Grid.Column="1" Text="{Binding MinorHead, Mode=TwoWay}"
                                               PlaceholderText="200 (TCS payable) / 400 (regular assessment)"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Deposit (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnDepositTcsStatPaymentClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: TCS Challan Reconciliation report (Phase 7 slice 6) -->
                    <ContentControl IsVisible="{Binding TcsChallanReconciliation, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding TcsChallanReconciliation}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:TcsChallanReconciliationViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                                       FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"
                                       Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="140,*,140,140,140,110">
                                <TextBlock Grid.Column="0" Text="Code" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Collected" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Deposited" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Remaining" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Status" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ListBox Grid.Row="4" Background="White"
                                     ItemsSource="{Binding Rows}"
                                     SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:TcsChallanReconRow">
                                  <Grid ColumnDefinitions="140,*,140,140,140,110" Height="24">
                                    <TextBlock Grid.Column="0" Text="{Binding CollectionCode}"
                                               Margin="4,0" VerticalAlignment="Center" FontSize="12"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Collected}"
                                               TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Deposited}"
                                               TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Remaining}"
                                               TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Status}"
                                               Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding IsMatched, Converter={StaticResource BalancedBrush}}"/>
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="5" Background="#F4F4EC"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0">
                              <Grid ColumnDefinitions="140,*,140,140,140,110" Height="28">
                                <TextBlock Grid.Column="0" Text="Total" Margin="4,0"
                                           VerticalAlignment="Center" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Grid.Column="2" Text="{Binding TotalCollected}"
                                           TextAlignment="Right" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="{Binding TotalDeposited}"
                                           TextAlignment="Right" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="{Binding TotalRemaining}"
                                           TextAlignment="Right" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="12"/>
                              </Grid>
                            </Border>

                            <!-- Cash-basis clarifying note: this recon windows deposits by challan deposit date, so a
                                 legally-compliant cross-FY deposit can read as outstanding here. Point the reader at the
                                 period-attributed views (Form 27EQ + TCS Outstandings). Amber band mirrors the S8 footnote. -->
                            <Border Grid.Row="6" Background="#FFF7E6"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="0,1,0,0"
                                    Padding="10,6" Margin="0,6,0,0">
                              <TextBlock Text="{Binding BasisNote}" TextWrapping="Wrap"
                                         FontSize="11" Foreground="#7A5B00"/>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 27EQ quarterly TCS return (Ctrl+A export FVU · Alt+B save-return; Phase 7 slice 6) -->
                    <ContentControl IsVisible="{Binding Form27EQ, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Form27EQ}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form27EQViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + quarter selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,180,Auto,180,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form27EQFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form27EQQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Collector block -->
                            <Border Grid.Row="3" Background="#F4F4EC"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Collector (TAN)" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CollectorTan}"
                                           FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,12,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Type" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding CollectorType}"
                                           FontSize="12" Margin="0,0,0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Responsible" FontWeight="SemiBold"
                                           FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                           Text="{Binding ResponsiblePerson}" FontSize="12" TextWrapping="Wrap"/>
                              </Grid>
                            </Border>

                            <!-- Control totals (Form-27A style) -->
                            <Border Grid.Row="4" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,*,*,*,*">
                                  <StackPanel Grid.Column="0">
                                    <TextBlock Text="Collectee rows" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding CollecteeRecordCount}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="1">
                                    <TextBlock Text="Challans" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding ChallanRecordCount}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrandNavy}"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Classes="statCell">
                                    <TextBlock Text="Amount received ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalAmountReceived}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="3" Classes="statCell">
                                    <TextBlock Text="TCS collected ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalTcsCollected}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                  <StackPanel Grid.Column="4" Classes="statCell">
                                    <TextBlock Text="Deposited ₹" FontSize="10.5" Foreground="#777777"/>
                                    <TextBlock Text="{Binding TotalDeposited}" FontSize="14" FontWeight="Bold"/>
                                  </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding ControlTotalsTally, Converter={StaticResource BalancedBrush}}"/>
                              </StackPanel>
                            </Border>

                            <!-- Challan blocks -->
                            <StackPanel Grid.Row="5" Margin="0,0,0,6"
                                        IsVisible="{Binding !IsEmpty}">
                              <TextBlock Text="Challans (ITNS-281)" FontWeight="Bold" FontSize="12"
                                         Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                              <Border Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="120,120,120,140,90">
                                  <TextBlock Grid.Column="0" Text="Challan No." Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="BSR Code" Classes="colHdr"/>
                                  <TextBlock Grid.Column="2" Text="Deposit Date" Classes="colHdr"/>
                                  <TextBlock Grid.Column="3" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="4" Text="Code" Classes="colHdr"/>
                                </Grid>
                              </Border>
                              <ItemsControl ItemsSource="{Binding Challans}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form27EQChallanRowVm">
                                    <Grid ColumnDefinitions="120,120,120,140,90" Height="22">
                                      <TextBlock Grid.Column="0" Text="{Binding ChallanNo}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding BsrCode}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 FontFamily="Consolas,Menlo,monospace"/>
                                      <TextBlock Grid.Column="2" Text="{Binding DepositDate}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="3" Text="{Binding Amount}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="4" Text="{Binding CollectionCode}" Margin="6,0,0,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <!-- Collectee detail grid (selectable) -->
                            <Grid Grid.Row="6" RowDefinitions="Auto,Auto,*">
                              <TextBlock Grid.Row="0" Text="Collectee details" FontWeight="Bold" FontSize="12"
                                         Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                              <Border Grid.Row="1" Background="{StaticResource BrandNavy}">
                                <Grid ColumnDefinitions="110,*,80,70,100,110,100,55">
                                  <TextBlock Grid.Column="0" Text="PAN" Classes="colHdr"/>
                                  <TextBlock Grid.Column="1" Text="Collectee" Classes="colHdr"/>
                                  <TextBlock Grid.Column="2" Text="Code" Classes="colHdr"/>
                                  <TextBlock Grid.Column="3" Text="FVU" Classes="colHdr"/>
                                  <TextBlock Grid.Column="4" Text="Date" Classes="colHdr"/>
                                  <TextBlock Grid.Column="5" Text="Amount Recd" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="6" Text="TCS" Classes="colHdr" TextAlignment="Right"/>
                                  <TextBlock Grid.Column="7" Text="Rate %" Classes="colHdr" TextAlignment="Right"/>
                                </Grid>
                              </Border>
                              <ListBox Grid.Row="2" Background="White"
                                       ItemsSource="{Binding Collectees}"
                                       SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form27EQCollecteeRowVm">
                                    <Grid ColumnDefinitions="110,*,80,70,100,110,100,55" Height="24">
                                      <TextBlock Grid.Column="0" Text="{Binding Pan}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 FontFamily="Consolas,Menlo,monospace"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                 VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="2" Text="{Binding CollectionCode}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="3" Text="{Binding FvuCode}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="4" Text="{Binding Date}" Margin="2,0"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="5" Text="{Binding AmountReceived}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="6" Text="{Binding Tcs}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5"/>
                                      <TextBlock Grid.Column="7" Text="{Binding Rate}" TextAlignment="Right"
                                                 VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                    </Grid>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>
                            </Grid>

                            <!-- Status + actions -->
                            <Grid Grid.Row="7" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export FVU (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportFvuForm27EQClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm27EQClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 16A TDS certificate (pick deductee · Ctrl+A export PDF · Alt+B save-return; Phase 7 slice 7) -->
                    <ContentControl IsVisible="{Binding Form16A, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Form16A}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form16AViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- FY + quarter selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,180,Auto,180,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CertificateFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CertificateQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Left: deductee picker · Right: certificate detail -->
                            <Grid Grid.Row="3" ColumnDefinitions="280,*">
                              <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="0,0,8,0">
                                <TextBlock Grid.Row="0" Text="Deductees" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                                <Border Grid.Row="1" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="80,*,68">
                                    <TextBlock Grid.Column="0" Text="PAN" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Deductee" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="TDS" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ListBox Grid.Row="2" Background="White"
                                         ItemsSource="{Binding Deductees}"
                                         SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                  <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Form16ADeducteeOptionVm">
                                      <Grid ColumnDefinitions="80,*,68" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Pan}" Margin="4,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontFamily="Consolas,Menlo,monospace"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                   VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TdsTotal}" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ListBox.ItemTemplate>
                                </ListBox>
                              </Grid>

                              <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                            HorizontalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8" MinWidth="384">
                                  <!-- Deductor block -->
                                  <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Deductor" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeductorName}"
                                                 FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="1" Grid.Column="0" Text="TAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeductorTan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="2" Grid.Column="0" Text="PAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeductorPan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="3" Grid.Column="0" Text="Responsible" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ResponsiblePerson}"
                                                 FontSize="12" TextWrapping="Wrap"/>
                                    </Grid>
                                  </Border>

                                  <!-- Deductee block -->
                                  <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                      <TextBlock Grid.Column="0" Text="Certificate to" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Column="1" Text="{Binding DeducteeName}"
                                                 FontSize="12" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                      <TextBlock Grid.Column="2" Text="PAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Column="3" Text="{Binding DeducteePan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                                    </Grid>
                                  </Border>

                                  <!-- TDS deduction rows -->
                                  <TextBlock Text="Summary of TDS deducted" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="56,42,82,86,70,46">
                                      <TextBlock Grid.Column="0" Text="Section" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="FVU" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Date" Classes="colHdr"/>
                                      <TextBlock Grid.Column="3" Text="Amount Paid" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="4" Text="TDS" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="5" Text="Rate %" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding Deductions}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:Form16ADeductionRowVm">
                                        <Grid ColumnDefinitions="56,42,82,86,70,46" Height="22">
                                          <TextBlock Grid.Column="0" Text="{Binding Section}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding FvuCode}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Date}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding AmountPaid}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Tds}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="5" Text="{Binding Rate}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                        </Grid>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>

                                  <!-- Challan rows -->
                                  <TextBlock Text="Tax deposited (challans)" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="86,64,90,92">
                                      <TextBlock Grid.Column="0" Text="Challan No." Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="BSR Code" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Deposit Date" Classes="colHdr"/>
                                      <TextBlock Grid.Column="3" Text="TDS Deposited" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding Challans}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:Form16AChallanRowVm">
                                        <Grid ColumnDefinitions="86,64,90,92" Height="22">
                                          <TextBlock Grid.Column="0" Text="{Binding ChallanNo}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding BsrCode}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                          <TextBlock Grid.Column="2" Text="{Binding DepositDate}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding TdsDeposited}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                        </Grid>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>

                                  <!-- Totals -->
                                  <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <StackPanel Spacing="4">
                                      <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel Grid.Column="0" Classes="statCell">
                                          <TextBlock Text="Amount paid ₹" FontSize="10.5" Foreground="#777777"/>
                                          <TextBlock Text="{Binding TotalAmountPaid}" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Classes="statCell">
                                          <TextBlock Text="TDS deducted ₹" FontSize="10.5" Foreground="#777777"/>
                                          <TextBlock Text="{Binding TotalTdsDeducted}" FontSize="14" FontWeight="Bold"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Classes="statCell">
                                          <TextBlock Text="TDS deposited ₹" FontSize="10.5" Foreground="#777777"/>
                                          <TextBlock Text="{Binding TotalTdsDeposited}" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                      </Grid>
                                      <TextBlock Text="{Binding AmountInWords}" FontSize="11.5" FontStyle="Italic"
                                                 TextWrapping="Wrap"
                                                 IsVisible="{Binding AmountInWords, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </ScrollViewer>
                            </Grid>

                            <!-- Status + actions -->
                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export PDF (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportPdfForm16AClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm16AClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 27D TCS certificate (pick collectee · Ctrl+A export PDF · Alt+B save-return; Phase 7 slice 7) -->
                    <ContentControl IsVisible="{Binding Form27D, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Form27D}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form27DViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <Grid Grid.Row="2" ColumnDefinitions="Auto,180,Auto,180,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Financial Year" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CertificateFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CertificateQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="280,*">
                              <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="0,0,8,0">
                                <TextBlock Grid.Row="0" Text="Collectees" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,0,0,2"/>
                                <Border Grid.Row="1" Background="{StaticResource BrandNavy}">
                                  <Grid ColumnDefinitions="80,*,68">
                                    <TextBlock Grid.Column="0" Text="PAN" Classes="colHdr"/>
                                    <TextBlock Grid.Column="1" Text="Collectee" Classes="colHdr"/>
                                    <TextBlock Grid.Column="2" Text="TCS" Classes="colHdr" TextAlignment="Right"/>
                                  </Grid>
                                </Border>
                                <ListBox Grid.Row="2" Background="White"
                                         ItemsSource="{Binding Collectees}"
                                         SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                                  <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Form27DCollecteeOptionVm">
                                      <Grid ColumnDefinitions="80,*,68" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Pan}" Margin="4,0"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   FontFamily="Consolas,Menlo,monospace"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="4,0"
                                                   VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TcsTotal}" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ListBox.ItemTemplate>
                                </ListBox>
                                <!-- Reusable empty-state (C7): shown across the collectee picker body when this
                                     quarter has no collectees yet. -->
                                <views:EmptyState Grid.Row="2" Message="No collectees for this quarter yet."
                                                  IsVisible="{Binding Collectees.Count, Converter={StaticResource CollectionEmpty}}"/>
                              </Grid>

                              <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                            HorizontalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8" MinWidth="384">
                                  <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Collector" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CollectorName}"
                                                 FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="1" Grid.Column="0" Text="TAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CollectorTan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="2" Grid.Column="0" Text="PAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,2"/>
                                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CollectorPan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace" Margin="0,0,0,2"/>
                                      <TextBlock Grid.Row="3" Grid.Column="0" Text="Responsible" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ResponsiblePerson}"
                                                 FontSize="12" TextWrapping="Wrap"/>
                                    </Grid>
                                  </Border>

                                  <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                      <TextBlock Grid.Column="0" Text="Certificate to" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Column="1" Text="{Binding CollecteeName}"
                                                 FontSize="12" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                      <TextBlock Grid.Column="2" Text="PAN" FontWeight="SemiBold"
                                                 FontSize="12" Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                      <TextBlock Grid.Column="3" Text="{Binding CollecteePan}"
                                                 FontSize="12" FontFamily="Consolas,Menlo,monospace"/>
                                    </Grid>
                                  </Border>

                                  <TextBlock Text="Summary of TCS collected" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="56,42,82,86,70,46">
                                      <TextBlock Grid.Column="0" Text="Code" Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="FVU" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Date" Classes="colHdr"/>
                                      <TextBlock Grid.Column="3" Text="Amount Recd" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="4" Text="TCS" Classes="colHdr" TextAlignment="Right"/>
                                      <TextBlock Grid.Column="5" Text="Rate %" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding Collections}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:Form27DCollectionRowVm">
                                        <Grid ColumnDefinitions="56,42,82,86,70,46" Height="22">
                                          <TextBlock Grid.Column="0" Text="{Binding CollectionCode}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding FvuCode}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="2" Text="{Binding Date}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding AmountReceived}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="4" Text="{Binding Tcs}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="5" Text="{Binding Rate}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                        </Grid>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>

                                  <TextBlock Text="Tax deposited (challans)" FontWeight="Bold" FontSize="12"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <Border Background="{StaticResource BrandNavy}">
                                    <Grid ColumnDefinitions="86,64,90,92">
                                      <TextBlock Grid.Column="0" Text="Challan No." Classes="colHdr"/>
                                      <TextBlock Grid.Column="1" Text="BSR Code" Classes="colHdr"/>
                                      <TextBlock Grid.Column="2" Text="Deposit Date" Classes="colHdr"/>
                                      <TextBlock Grid.Column="3" Text="TCS Deposited" Classes="colHdr" TextAlignment="Right"/>
                                    </Grid>
                                  </Border>
                                  <ItemsControl ItemsSource="{Binding Challans}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:Form27DChallanRowVm">
                                        <Grid ColumnDefinitions="86,64,90,92" Height="22">
                                          <TextBlock Grid.Column="0" Text="{Binding ChallanNo}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="1" Text="{Binding BsrCode}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"
                                                     FontFamily="Consolas,Menlo,monospace"/>
                                          <TextBlock Grid.Column="2" Text="{Binding DepositDate}" Margin="4,0"
                                                     VerticalAlignment="Center" FontSize="11.5"/>
                                          <TextBlock Grid.Column="3" Text="{Binding TcsDeposited}" TextAlignment="Right"
                                                     VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                        </Grid>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>

                                  <Border Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                          BorderThickness="1" Padding="10">
                                    <StackPanel Spacing="4">
                                      <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel Grid.Column="0" Classes="statCell">
                                          <TextBlock Text="Amount received ₹" FontSize="10.5" Foreground="#777777"/>
                                          <TextBlock Text="{Binding TotalAmountReceived}" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Classes="statCell">
                                          <TextBlock Text="TCS collected ₹" FontSize="10.5" Foreground="#777777"/>
                                          <TextBlock Text="{Binding TotalTcsCollected}" FontSize="14" FontWeight="Bold"
                                                     Foreground="{StaticResource BrandNavy}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Classes="statCell">
                                          <TextBlock Text="TCS deposited ₹" FontSize="10.5" Foreground="#777777"/>
                                          <TextBlock Text="{Binding TotalTcsDeposited}" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                      </Grid>
                                      <TextBlock Text="{Binding AmountInWords}" FontSize="11.5" FontStyle="Italic"
                                                 TextWrapping="Wrap"
                                                 IsVisible="{Binding AmountInWords, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </ScrollViewer>
                            </Grid>

                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export PDF (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportPdfForm27DClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm27DClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Form 27A return control chart (pick return · Ctrl+A export PDF · Alt+B save-return; Phase 7 slice 7) -->
                    <ContentControl IsVisible="{Binding Form27A, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Form27A}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:Form27AViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- Return + FY + quarter selectors -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,200,Auto,150,Auto,150,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="Return" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Returns}"
                                        SelectedItem="{Binding SelectedReturn, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:Form27AReturnOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="2" Text="FY" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding FinancialYears}"
                                        SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CertificateFyOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <TextBlock Grid.Column="4" Text="Quarter" FontWeight="SemiBold" FontSize="12"
                                         VerticalAlignment="Center" Margin="16,0,8,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="5" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Quarters}"
                                        SelectedItem="{Binding SelectedQuarter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:CertificateQuarterOption">
                                    <TextBlock Text="{Binding Label}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Header block: form + TAN -->
                            <Border Grid.Row="3" Background="#F4F4EC" BorderBrush="{StaticResource GridLine}"
                                    BorderThickness="1" Padding="10" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,*,Auto,*">
                                <TextBlock Grid.Column="0" Text="Return" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding ReturnFormName}" FontSize="12"
                                           FontWeight="SemiBold" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="TAN" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding Tan}" FontSize="12"
                                           FontFamily="Consolas,Menlo,monospace"/>
                              </Grid>
                            </Border>

                            <!-- Control totals + validation -->
                            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                              <StackPanel Spacing="8">
                                <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                        BorderThickness="1" Padding="10">
                                  <StackPanel Spacing="2">
                                    <TextBlock Text="Control totals" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource BrandNavy}" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding ControlTotals}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:Form27AControlRowVm">
                                          <Grid ColumnDefinitions="*,180" Height="24">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" TextAlignment="Right"
                                                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                          </Grid>
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding AmountInWords}" FontSize="11.5" FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding AmountInWords, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding Tallies, Converter={StaticResource BalancedBrush}}"/>

                                <ItemsControl ItemsSource="{Binding ValidationMessages}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <TextBlock Text="{Binding}" FontSize="11.5" Foreground="#B00020"
                                                 TextWrapping="Wrap" Margin="0,1"/>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="5" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding ExportStatus}"
                                         IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="11.5"
                                         VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                              <Button Grid.Column="1" Content="Export PDF (Ctrl+A)" Padding="12,6" Margin="0,0,8,0"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnExportPdfForm27AClick"/>
                              <Button Grid.Column="2" Content="Save &amp; Return (Alt+B)" Padding="12,6"
                                      Click="OnSaveReturnForm27AClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: F12 report Configuration panel (RQ-1 period/as-of, RQ-2 detail, RQ-6 display) -->
                    <ContentControl IsVisible="{Binding ReportConfig, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ReportConfig}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ReportConfigViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding ReportTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="300">

                                <!-- RQ-1: period / as-of -->
                                <TextBlock Text="Period (F2 as-of · Alt+F2 range)" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="As at" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding AsOfText, Mode=TwoWay}"
                                           IsEnabled="{Binding !UsePeriod}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>
                                <CheckBox Content="Use an explicit period [From, To]"
                                          IsChecked="{Binding UsePeriod, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <Grid ColumnDefinitions="90,*" IsVisible="{Binding UsePeriod}">
                                  <TextBlock Grid.Column="0" Text="From" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding PeriodFromText, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*" IsVisible="{Binding UsePeriod}">
                                  <TextBlock Grid.Column="0" Text="To" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding PeriodToText, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>

                                <!-- RQ-2: detailed / summary -->
                                <CheckBox Content="Detailed (ledger/item-level; unchecked = group summary)"
                                          IsChecked="{Binding Detailed, Mode=TwoWay}"
                                          IsVisible="{Binding SupportsDetailToggle}"
                                          Foreground="{StaticResource BrandNavy}"/>

                                <!-- RQ-6: display config -->
                                <TextBlock Text="Display" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <CheckBox Content="Hide zero balances"
                                          IsChecked="{Binding HideZeroBalances, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <CheckBox Content="Show percentages (of section/column total)"
                                          IsChecked="{Binding ShowPercentages, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <Grid ColumnDefinitions="130,*">
                                  <TextBlock Grid.Column="0" Text="Closing stock" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding ClosingStockOptions}"
                                            SelectedItem="{Binding SelectedClosingStock, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ClosingStockOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Apply (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyReportConfigClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: F12 print Configuration panel (RQ-12 title override, narration, copy marking) -->
                    <ContentControl IsVisible="{Binding PrintConfigPanel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding PrintConfigPanel}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PrintConfigViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding DocumentTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="300">

                                <!-- RQ-12: title override -->
                                <TextBlock Text="Document title override" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBox Text="{Binding TitleOverride, Mode=TwoWay}"
                                         PlaceholderText="(blank = template default, e.g. TAX INVOICE)"/>

                                <!-- RQ-12: narration -->
                                <CheckBox Content="Print narration"
                                          IsChecked="{Binding ShowNarration, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>

                                <!-- RQ-12: copy marking -->
                                <TextBlock Text="Copy marking" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <RadioButton GroupName="CopyMark" Content="None"
                                             IsChecked="{Binding IsCopyNone, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="CopyMark" Content="Original for Recipient"
                                             IsChecked="{Binding IsCopyOriginal, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="CopyMark" Content="Duplicate for Supplier"
                                             IsChecked="{Binding IsCopyDuplicate, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="CopyMark" Content="Triplicate for Transporter"
                                             IsChecked="{Binding IsCopyTriplicate, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>

                                <TextBlock Text="Logo embedding is deferred (later polish)."
                                           FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>

                                <Button Content="Apply (Ctrl+A)" Padding="14,6" HorizontalAlignment="Left"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnApplyPrintConfigClick"/>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: E / Alt+E "Export" panel (RQ-14/16 — CSV / XLSX / PDF export of the open report) -->
                    <ContentControl IsVisible="{Binding ExportPanel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ExportPanel}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ExportViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding DocumentTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="320">

                                <!-- RQ-16: format -->
                                <TextBlock Text="Format" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ExportFormat" Content="CSV (comma-separated)"
                                             IsChecked="{Binding IsCsv, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ExportFormat" Content="XLSX (Excel workbook)"
                                             IsChecked="{Binding IsXlsx, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ExportFormat" Content="PDF (printable)"
                                             IsChecked="{Binding IsPdf, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>

                                <!-- RQ-16: destination -->
                                <TextBlock Text="Destination" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Folder" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Folder, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="(target folder)"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="File name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding FileName, Mode=TwoWay}"
                                           PlaceholderText="(base name, no extension)"/>
                                </Grid>
                                <CheckBox Content="Append timestamp to the file name"
                                          IsChecked="{Binding AppendTimestamp, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Text="{Binding ResolvedFileName, StringFormat='Will write: {0}'}"
                                           FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Export (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyExportClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Y "Export Data" panel (RQ-19/DP-4 — canonical JSON/XML backup of the whole company) -->
                    <ContentControl IsVisible="{Binding ExportDataPanel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ExportDataPanel}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ExportDataViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding DocumentTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="320">

                                <TextBlock Text="Canonical backup of the whole company (masters + vouchers)."
                                           FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>

                                <!-- Format -->
                                <TextBlock Text="Format" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ExportDataFormat" Content="JSON (canonical)"
                                             IsChecked="{Binding IsJson, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ExportDataFormat" Content="XML (canonical)"
                                             IsChecked="{Binding IsXml, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>

                                <!-- Destination -->
                                <TextBlock Text="Destination" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Folder" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Folder, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="(target folder)"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="File name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding FileName, Mode=TwoWay}"
                                           PlaceholderText="(base name, no extension)"/>
                                </Grid>
                                <CheckBox Content="Append timestamp to the file name"
                                          IsChecked="{Binding AppendTimestamp, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Text="{Binding ResolvedFileName, StringFormat='Will write: {0}'}"
                                           FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Export (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyExportDataClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: O / Alt+O "Import" panel (RQ-20..24 — canonical JSON/XML or flat CSV company import) -->
                    <ContentControl IsVisible="{Binding ImportDataPanel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ImportDataPanel}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ImportDataViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding DocumentTitle, StringFormat='Into: {0}'}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="340">

                                <!-- Source file -->
                                <TextBlock Text="Source file" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBox Text="{Binding FilePath, Mode=TwoWay}"
                                         FontFamily="Consolas,Menlo,monospace"
                                         PlaceholderText="(full path to the backup / CSV file)"/>

                                <!-- Format -->
                                <TextBlock Text="Format" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <RadioButton GroupName="ImportFormat" Content="JSON (canonical, lossless)"
                                             IsChecked="{Binding IsJson, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ImportFormat" Content="XML (canonical, lossless)"
                                             IsChecked="{Binding IsXml, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ImportFormat" Content="CSV (flat masters/vouchers)"
                                             IsChecked="{Binding IsCsv, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>

                                <!-- Duplicate policy -->
                                <TextBlock Text="If a master already exists" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <RadioButton GroupName="ImportDupPolicy" Content="Skip (keep existing)"
                                             IsChecked="{Binding IsSkip, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ImportDupPolicy" Content="Merge opening balance"
                                             IsChecked="{Binding IsMerge, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="ImportDupPolicy" Content="Reject the whole batch"
                                             IsChecked="{Binding IsReject, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Import (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyImportDataClick"/>
                                </Grid>

                                <!-- Per-record errors (nothing was applied) -->
                                <ItemsControl ItemsSource="{Binding Errors}"
                                              IsVisible="{Binding Errors.Count}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                      <TextBlock Text="{Binding}" Foreground="#B00020"
                                                 FontSize="11" TextWrapping="Wrap" Margin="0,1"/>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: M / Ctrl+M "E-Mail" compose panel (RQ-25/26 — offline .eml / mailto hand-off) -->
                    <ContentControl IsVisible="{Binding EmailCompose, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding EmailCompose}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EmailComposeViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding DocumentTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="12" MinWidth="360">

                                <!-- Offline-only notice (RQ-26) -->
                                <TextBlock Text="{Binding Notice}" FontSize="11" Foreground="#8A8A8A"
                                           TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="70,*">
                                  <TextBlock Grid.Column="0" Text="To" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding To, Mode=TwoWay}"
                                           PlaceholderText="recipient@example.com (comma/semicolon separated)"/>
                                </Grid>
                                <Grid ColumnDefinitions="70,*">
                                  <TextBlock Grid.Column="0" Text="Cc" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Cc, Mode=TwoWay}"
                                           PlaceholderText="(optional)"/>
                                </Grid>
                                <Grid ColumnDefinitions="70,*">
                                  <TextBlock Grid.Column="0" Text="Subject" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Subject, Mode=TwoWay}"/>
                                </Grid>
                                <Grid ColumnDefinitions="70,*">
                                  <TextBlock Grid.Column="0" Text="Body" FontWeight="SemiBold"
                                             VerticalAlignment="Top" Margin="0,6,0,0"
                                             Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Body, Mode=TwoWay}"
                                           AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90"/>
                                </Grid>

                                <!-- Attachment (the exported PDF that travels with the .eml) -->
                                <Grid ColumnDefinitions="70,*" IsVisible="{Binding HasAttachment}">
                                  <TextBlock Grid.Column="0" Text="Attach" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBlock Grid.Column="1" Text="{Binding AttachmentName}"
                                             VerticalAlignment="Center" FontSize="12"
                                             FontFamily="Consolas,Menlo,monospace" TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Save .eml (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnSaveEmailClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: "SMTP Settings" capture panel (RQ-27 — capture-only outgoing-mail profile, no password) -->
                    <ContentControl IsVisible="{Binding SmtpSettings, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding SmtpSettings}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:SmtpSettingsViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding CompanyName}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="12" MinWidth="340">

                                <!-- Capture-only / no-password notice (RQ-26/27, R13) -->
                                <TextBlock Text="{Binding Notice}" FontSize="11" Foreground="#8A8A8A"
                                           TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="110,*">
                                  <TextBlock Grid.Column="0" Text="Host" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Host, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="smtp.example.com"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*">
                                  <TextBlock Grid.Column="0" Text="Port" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Port, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="587"/>
                                </Grid>
                                <CheckBox Content="Use TLS/SSL" IsChecked="{Binding UseTls, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <Grid ColumnDefinitions="110,*">
                                  <TextBlock Grid.Column="0" Text="From address" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding FromAddress, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="accounts@example.com"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*">
                                  <TextBlock Grid.Column="0" Text="From name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding FromName, Mode=TwoWay}"
                                           PlaceholderText="(optional display name)"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Save (Ctrl+A)" Padding="14,6"
                                          IsEnabled="{Binding CanSave}"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnSaveSmtpClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Alt+F12 report Sort/Filter panel (RQ-3 sort & value/range/name filter) -->
                    <ContentControl IsVisible="{Binding ReportSortFilter, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ReportSortFilter}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ReportSortFilterViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding ReportTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="300" Grid.IsSharedSizeScope="True">

                                <!-- Sort -->
                                <TextBlock Text="Sort" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RsfL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="By" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding SortKeys}"
                                            SelectedItem="{Binding SelectedSortKey, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:SortKeyOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <CheckBox Content="Ascending (unchecked = descending)"
                                          IsChecked="{Binding Ascending, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>

                                <!-- Filter: amount range + name -->
                                <TextBlock Text="Filter" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}" Margin="0,4,0,0"/>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RsfL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Min" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding MinText, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="rupees (blank = no lower bound)"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RsfL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Max" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding MaxText, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="rupees (blank = no upper bound)"/>
                                </Grid>
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RsfL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Name has" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding NameContains, Mode=TwoWay}"
                                           PlaceholderText="substring (blank = all)"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Clear" Padding="14,6" Margin="0,0,8,0"
                                          Click="OnClearReportSortFilterClick"/>
                                  <Button Grid.Column="2" Content="Apply (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyReportSortFilterClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Alt+C "Add Comparison Column" panel (RQ-4 comparative/columnar reports) -->
                    <ContentControl IsVisible="{Binding AddComparisonColumn, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding AddComparisonColumn}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:AddComparisonColumnViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding ReportTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="300" Grid.IsSharedSizeScope="True">

                                <TextBlock Text="Add one comparison column" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>

                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="AccL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Label" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Label, Mode=TwoWay}"
                                           PlaceholderText="(blank = from period / scenario)"/>
                                </Grid>

                                <!-- Period window -->
                                <CheckBox Content="Use an explicit period [From, To] (unchecked = as-at / whole books)"
                                          IsChecked="{Binding UsePeriod, Mode=TwoWay}"
                                          Foreground="{StaticResource BrandNavy}"/>
                                <Grid IsVisible="{Binding UsePeriod}">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="AccL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="From" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding PeriodFromText, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>
                                <Grid IsVisible="{Binding UsePeriod}">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="AccL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="To" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding PeriodToText, Mode=TwoWay}"
                                           FontFamily="Consolas,Menlo,monospace"
                                           PlaceholderText="dd-MMM-yyyy"/>
                                </Grid>

                                <!-- Scenario -->
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="AccL"/>
                                    <ColumnDefinition Width="*"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" Text="Scenario" FontWeight="SemiBold" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Scenarios}"
                                            SelectedItem="{Binding SelectedScenario, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ScenarioOption">
                                        <TextBlock Text="{Binding Display}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Single Column" Padding="14,6" Margin="0,0,8,0"
                                          Click="OnClearComparativeClick"/>
                                  <Button Grid.Column="2" Content="Add (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyAddComparisonColumnClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Alt+N "Auto Columns" chooser (RQ-4 comparative axis: by month / by scenario) -->
                    <ContentControl IsVisible="{Binding AutoColumns, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding AutoColumns}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:AutoColumnsViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding ReportTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="300">

                                <TextBlock Text="Generate columns across an axis" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>

                                <RadioButton GroupName="AutoColumnAxis"
                                             Content="By month (one column per calendar month of the period)"
                                             IsChecked="{Binding ByMonth, Mode=TwoWay}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <RadioButton GroupName="AutoColumnAxis"
                                             Content="By scenario (one column per defined scenario)"
                                             IsChecked="{Binding ByScenario, Mode=TwoWay}"
                                             IsEnabled="{Binding HasScenarios}"
                                             Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Text="No scenarios are defined for this company."
                                           IsVisible="{Binding !HasScenarios}"
                                           FontSize="11" Foreground="#8A8A8A" Margin="24,0,0,0"/>

                                <Grid ColumnDefinitions="*,Auto,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Single Column" Padding="14,6" Margin="0,0,8,0"
                                          Click="OnClearComparativeClick"/>
                                  <Button Grid.Column="2" Content="Generate (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplyAutoColumnsClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Ctrl+S "Save View" panel (RQ-8 — name + store the report's current configuration) -->
                    <ContentControl IsVisible="{Binding SaveView, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding SaveView}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:SaveViewViewModel">
                          <Grid RowDefinitions="Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding ReportTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" VerticalAlignment="Top">
                              <StackPanel Spacing="14" MinWidth="300">

                                <TextBlock Text="Save this report's view under a name" FontWeight="Bold"
                                           Foreground="{StaticResource BrandNavy}"/>
                                <TextBlock Text="Only the configuration is saved (period, detail, sort/filter, columns, F12 options) — the report is recomputed when the view is opened."
                                           FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap"/>

                                <StackPanel Spacing="4">
                                  <TextBlock Text="Name" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Text="{Binding Name, Mode=TwoWay}" PlaceholderText="e.g. Monthly TB"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Status}"
                                             IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource BrandNavy}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Save (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnApplySaveViewClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Alt+K "Saved Views" list (RQ-8 — open/apply or delete this company's saved views) -->
                    <ContentControl IsVisible="{Binding SavedViews, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding SavedViews}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:SavedViewsViewModel">
                          <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1" Margin="0,0,0,8">
                              <ListBox ItemsSource="{Binding Views}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                                       Background="White" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:SavedViewItem">
                                    <Grid ColumnDefinitions="*,Auto" Height="30">
                                      <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                 VerticalAlignment="Center" Margin="8,0" FontSize="13"
                                                 Foreground="{StaticResource BrandNavy}"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <TextBlock Grid.Column="1" Text="{Binding KindLabel}"
                                                 VerticalAlignment="Center" Margin="8,0" FontSize="11"
                                                 Foreground="#8A8A8A"/>
                                    </Grid>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>
                            </Border>

                            <TextBlock Grid.Row="2" Text="{Binding Status}"
                                       IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,0,0,8" TextWrapping="Wrap"/>

                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto">
                              <Button Grid.Column="1" Content="Delete" Padding="14,6" Margin="0,0,8,0"
                                      Click="OnDeleteSavedViewClick"/>
                              <Button Grid.Column="2" Content="Open (Ctrl+A)" Padding="14,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnOpenSavedViewClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Print Preview (RQ-9 / DP-8 — render the report to a de-branded PDF and preview it) -->
                    <ContentControl IsVisible="{Binding PrintPreview, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding PrintPreview}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PrintPreviewViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding ReportTitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Page options -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="2,0,0,8">
                              <CheckBox Content="Letter (else A4)" IsChecked="{Binding UseLetter, Mode=TwoWay}"/>
                              <CheckBox Content="Landscape" IsChecked="{Binding Landscape, Mode=TwoWay}"/>
                              <TextBlock Text="{Binding PageCount, StringFormat='Pages: {0}'}"
                                         VerticalAlignment="Center" Foreground="#8A8A8A" FontSize="12"/>
                              <TextBlock Text="F12: Print Config" IsVisible="{Binding SupportsPrintConfig}"
                                         VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}" FontSize="12"/>
                            </StackPanel>

                            <!-- Paginated preview: one framed 'sheet' per page -->
                            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto" Background="#EDEDED">
                              <ItemsControl ItemsSource="{Binding Pages}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PreviewPage">
                                    <Border Background="White" BorderBrush="{StaticResource GridLine}"
                                            BorderThickness="1" Margin="0,0,0,12" Padding="18">
                                      <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                   HorizontalAlignment="Center" Foreground="#555555" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding Headers}">
                                          <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                          </ItemsControl.ItemsPanel>
                                          <ItemsControl.ItemTemplate>
                                            <DataTemplate><TextBlock Text="{Binding}" FontWeight="Bold" FontSize="11"
                                                                     Width="120" Foreground="{StaticResource BrandNavy}"/></DataTemplate>
                                          </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border Height="1" Background="{StaticResource GridLine}" Margin="0,2"/>
                                        <ItemsControl ItemsSource="{Binding Lines}">
                                          <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PreviewLine">
                                              <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                  <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                  <DataTemplate><TextBlock Text="{Binding}" FontSize="11" Width="120"
                                                                           TextTrimming="CharacterEllipsis"/></DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                              </ItemsControl>
                                            </DataTemplate>
                                          </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding Footer}" FontSize="10" Foreground="#8A8A8A"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding Status}"
                                         IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{StaticResource BrandNavy}" FontSize="12"
                                         VerticalAlignment="Center" TextWrapping="Wrap"/>
                              <Button Grid.Column="1" Content="Save PDF (Ctrl+A)" Padding="14,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnSavePrintPreviewClick"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Forex Gain/Loss (unrealized revaluation) report -->
                    <ContentControl IsVisible="{Binding ForexReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding ForexReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ForexReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- As-of date + recompute + book adjustment -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,150,Auto,Auto,*" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Revalue as at" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <TextBox Grid.Column="1" Text="{Binding AsOfText, Mode=TwoWay}"
                                       PlaceholderText="dd-MMM-yyyy"/>
                              <Button Grid.Column="2" Content="Recompute" Margin="8,0,0,0" Padding="12,5"
                                      Background="{StaticResource Panel}"
                                      Click="OnRecomputeForexClick"/>
                              <Button Grid.Column="3" Content="Book Adjustment (Journal)" Margin="8,0,0,0" Padding="12,5"
                                      IsEnabled="{Binding CanBook}"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnBookForexAdjustmentClick"/>
                            </Grid>

                            <!-- Net summary headline -->
                            <Border Grid.Row="3" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="8,0,8,8">
                              <TextBlock Text="{Binding NetSummary}" FontWeight="SemiBold"
                                         Foreground="{Binding IsNetGain, Converter={StaticResource BalancedBrush}}"/>
                            </Border>

                            <!-- Column header -->
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}" Margin="8,0">
                              <Grid ColumnDefinitions="*,90,130,110,80,130,60">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Currency" Classes="colHdr" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Forex Bal." Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Booked ₹" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Revalued ₹" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="G/L" Classes="colHdr" TextAlignment="Center"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="5" Background="White" Margin="8,0">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ForexReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Background="{Binding IsTotal, Converter={StaticResource SelBrush}}">
                                      <Grid ColumnDefinitions="*,90,130,110,80,130,60" Height="26">
                                        <TextBlock Grid.Column="0" Text="{Binding Ledger}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Currency}"
                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ForexBalance}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding BookedBase}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Rate}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="5" Text="{Binding RevaluedBase}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Direction}"
                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="6" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="8,6" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Budget Variance report (Budget / Actual / Variance) -->
                    <ContentControl IsVisible="{Binding BudgetVariance, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BudgetVariance}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BudgetVarianceViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Budget picker -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,10">
                              <TextBlock Grid.Column="0" Text="Budget" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Budgets}"
                                        SelectedItem="{Binding SelectedBudget, Mode=TwoWay}"
                                        PlaceholderText="No budgets defined…">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="ledger:Budget">
                                    <TextBlock Text="{Binding Name}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="3" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,130,130,140,90">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Budget" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Actual" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Variance" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="%" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="4" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BudgetVarianceRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,130,130,140,90" Height="24">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center" Margin="8,0">
                                          <TextBlock Text="{Binding Target}"
                                                     FontSize="12.5"
                                                     FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                          <TextBlock Text="{Binding Type}"
                                                     FontSize="10.5" Foreground="#8A8A8A"
                                                     VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Budget}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Actual}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Variance}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}">
                                          <TextBlock.Foreground>
                                            <MultiBinding Converter="{x:Static conv:VarianceToBrushConverter.Instance}">
                                              <Binding Path="IsOver"/>
                                              <Binding Path="IsUnder"/>
                                            </MultiBinding>
                                          </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Grid.Column="4" Text="{Binding VariancePercent}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11">
                                          <TextBlock.Foreground>
                                            <MultiBinding Converter="{x:Static conv:VarianceToBrushConverter.Instance}">
                                              <Binding Path="IsOver"/>
                                              <Binding Path="IsUnder"/>
                                            </MultiBinding>
                                          </TextBlock.Foreground>
                                        </TextBlock>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Bank Reconciliation (pick bank → editable Bank Date → book-vs-bank) -->
                    <ContentControl IsVisible="{Binding BankReconciliation, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BankReconciliation}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BankReconciliationViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Bank ledger picker -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Bank Ledger" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding BankLedgers}"
                                        SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                        PlaceholderText="No bank ledgers defined…">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="ledger:Ledger">
                                    <TextBlock Text="{Binding Name}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- Book-vs-Bank balance summary -->
                            <Border Grid.Row="3" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="8,0,8,8">
                              <Grid ColumnDefinitions="*,*,Auto">
                                <StackPanel Grid.Column="0">
                                  <TextBlock Text="Balance as per Company Books" FontSize="11" Foreground="#6A6A6A"/>
                                  <TextBlock Text="{Binding BalanceAsPerBooksText}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                  <TextBlock Text="Balance as per Bank" FontSize="11" Foreground="#6A6A6A"/>
                                  <TextBlock Text="{Binding BalanceAsPerBankText}" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                  <TextBlock Text="Not reflected in bank" FontSize="11" Foreground="#6A6A6A"
                                             TextAlignment="Right"/>
                                  <TextBlock Text="{Binding AmountNotReflectedText}" FontSize="13" FontWeight="SemiBold"
                                             TextAlignment="Right"/>
                                </StackPanel>
                              </Grid>
                            </Border>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="4" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="90,60,*,90,110,130">
                                <TextBlock Grid.Column="0" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="V.No" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Instrument / Type" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Dr/Cr" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Bank Date" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="5" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:BankReconRowViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="90,60,*,90,110,130" Height="28">
                                        <TextBlock Grid.Column="0" Text="{Binding Date}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="11.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding VoucherNo}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center">
                                          <TextBlock Text="{Binding Instrument}" FontSize="12"/>
                                          <TextBlock Text="{Binding Kind}" FontSize="10.5" Foreground="#8A8A8A"
                                                     VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{Binding Direction}"
                                                   VerticalAlignment="Center" FontSize="11.5" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox Grid.Column="5" Text="{Binding BankDateText, Mode=TwoWay}"
                                                 Margin="4,2,6,2" FontSize="11" Height="22"
                                                 VerticalContentAlignment="Center"
                                                 PlaceholderText="dd-MMM-yyyy"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Reconcile bar -->
                            <Border Grid.Row="6" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,4">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Type a Bank Date on each cleared transaction, then Reconcile (Ctrl+A)."
                                           FontSize="11" Foreground="#6A6A6A" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Reconcile (Ctrl+A)" Padding="12,5"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnReconcileBankClick"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="7" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,2,0,2" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Import Bank Statement (CSV → auto-match → matched/unmatched) -->
                    <ContentControl IsVisible="{Binding BankStatementImport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding BankStatementImport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:BankStatementImportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <!-- Bank ledger picker -->
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Bank Ledger" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding BankLedgers}"
                                        SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                        PlaceholderText="No bank ledgers defined…">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="ledger:Ledger">
                                    <TextBlock Text="{Binding Name}"/>
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </Grid>

                            <!-- CSV path + Import -->
                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="8,0,8,8">
                              <TextBlock Grid.Column="0" Text="Statement CSV" FontWeight="SemiBold"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{StaticResource BrandNavy}"/>
                              <TextBox Grid.Column="1" Text="{Binding StatementPath, Mode=TwoWay}"
                                       PlaceholderText="path to bank-statement.csv (date, description, amount, instrument)"/>
                              <Button Grid.Column="2" Content="Import (Ctrl+A)" Margin="8,0,0,0" Padding="12,6"
                                      Background="{StaticResource BrandNavy}" Foreground="White"
                                      Click="OnImportBankStatementClick"/>
                            </Grid>

                            <!-- Summary -->
                            <TextBlock Grid.Row="4" Text="{Binding SummaryText}"
                                       IsVisible="{Binding SummaryText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"
                                       Margin="8,0,8,6"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="5" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="150,90,*,120,110,100">
                                <TextBlock Grid.Column="0" Text="Status" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Description" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Instrument" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Amount" Classes="colHdr"/>
                                <TextBlock Grid.Column="5" Text="Bank Date" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="6" Background="White">
                              <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:StatementResultRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Background="{Binding Kind, Converter={x:Static conv:StatementRowBrushConverter.Instance}}">
                                      <Grid ColumnDefinitions="150,90,*,120,110,100" Height="26">
                                        <TextBlock Grid.Column="0" Text="{Binding StatusLabel}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Date}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Description}"
                                                   VerticalAlignment="Center" FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Instrument}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#333333"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}"
                                                   VerticalAlignment="Center" FontSize="11"/>
                                        <TextBlock Grid.Column="5" Text="{Binding BankDate}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="7" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,4,0,2" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Interest Calculation report (per interest-enabled ledger: principal / rate / days / interest) -->
                    <ContentControl IsVisible="{Binding InterestReport, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding InterestReport}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:InterestReportViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,110,150,80,80,150">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Ref" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Principal" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Rate" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Days" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Interest" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:InterestReportRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,110,150,80,80,150" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Ledger}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Reference}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Principal}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Rate}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Days}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Interest}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"
                                                   FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                                </Panel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                </Panel>
            </Border>

            <!-- RIGHT BUTTON BAR -->
            <Border Grid.Column="1" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ButtonBar}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ButtonBarItem">
                                <Button Classes="barBtn" Command="{Binding Invoke}" IsEnabled="{Binding Enabled}">
                                    <Grid ColumnDefinitions="52,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                   Foreground="{StaticResource AlertRed}" FontWeight="Bold"
                                                   FontSize="11" Margin="0,0,6,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Caption}"
                                                   Foreground="{StaticResource Ink}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ============ STATUS BAR (navy) ============ -->
        <Border Grid.Row="3" Background="{StaticResource BrandNavy}" Height="26">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="12,0" FontSize="11" Foreground="#CFE0FF"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="Company: "/><Run Text="{Binding StatusCompany}"/>
                </TextBlock>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0" FontSize="11" Foreground="#CFE0FF">
                    <Run Text="Current Date: "/><Run Text="{Binding StatusDate}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
