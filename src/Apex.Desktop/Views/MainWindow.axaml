<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Apex.Desktop.ViewModels"
        xmlns:conv="using:Apex.Desktop.Converters"
        xmlns:ledger="using:Apex.Ledger.Domain"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="Apex.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="1100" Height="700"
        MinWidth="820" MinHeight="560"
        Background="{StaticResource Cream}"
        FontFamily="Consolas, Cascadia Mono, Menlo, monospace"
        Title="Apex Solutions">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:ScreenEqualsConverter x:Key="ScreenEquals"/>
        <conv:SelectedToBrushConverter x:Key="SelBrush"/>
        <conv:SelectedActiveToBrushConverter x:Key="SelActiveBrush"/>
        <conv:SelectedToForegroundConverter x:Key="SelFore"/>
        <conv:BoolToWeightConverter x:Key="BoolWeight"/>
        <conv:DrCrLabelConverter x:Key="DrCrLabel"/>
        <conv:BalancedToBrushConverter x:Key="BalancedBrush"/>
        <conv:UpperConverter x:Key="Upper"/>
        <conv:SubIndentConverter x:Key="SubIndent"/>
        <conv:IndentToThicknessConverter x:Key="Indent"/>
        <conv:ColumnWidthConverter x:Key="ColWidth"/>
        <conv:ColumnHeaderBrushConverter x:Key="ColHeaderBrush"/>
        <conv:BillRefTypeLabelConverter x:Key="BillRefLabel"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Menu item row -->
        <Style Selector="Border.menuRow">
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
        <!-- Button-bar button -->
        <Style Selector="Button.barBtn">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.barBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Amber}"/>
        </Style>
        <!-- Report grid header cell -->
        <Style Selector="TextBlock.colHdr">
            <Setter Property="Foreground" Value="{StaticResource AppWhite}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ============ TOP BAR (navy) ============ -->
        <Border Grid.Row="0" Background="{StaticResource BrandNavy}">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="34">
                <TextBlock Grid.Column="0" Text="Apex Solutions"
                           Foreground="White" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ScreenTitle}"
                           Foreground="#CFE0FF" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="P: Print   E: Export   M: E-Mail   O: Import"
                           Foreground="#9FB8E0" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ============ MENU ROW (navy dark) ============ -->
        <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Height="24">
            <TextBlock Text="Gateway of Apex Solutions   —   K: Company   Y: Data   Z: Exchange   G: Go To   O: Import   E: Export   M: Share"
                       Foreground="#8FA9D6" FontSize="11" VerticalAlignment="Center" Margin="12,0"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ============ BODY: work area + right button bar ============ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,168">

            <!-- CENTRAL CREAM WORK AREA -->
            <Border Grid.Column="0" Background="{StaticResource Cream}" Margin="6">
                <Panel>

                    <!-- SCREEN: Company Select / Gateway / (menu-based screens) -->
                    <Grid IsVisible="{Binding IsMenuScreen}" RowDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Row="0" Text="{Binding ScreenTitle}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BrandNavy}"
                                   HorizontalAlignment="Center" Margin="0,18,0,10"/>

                        <!-- The keyboard-navigable menu (centred vertical list) -->
                        <Border Grid.Row="1"
                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                Background="White"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,10" MinWidth="420" Padding="0,8">
                            <ItemsControl ItemsSource="{Binding Menu}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MenuItemViewModel">
                                        <Panel>
                                            <!-- Section header: dim, uppercase, non-selectable -->
                                            <Border Classes="menuRow" IsVisible="{Binding IsHeader}"
                                                    Margin="0,7,0,1">
                                                <TextBlock Text="{Binding Label, Converter={StaticResource Upper}}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#9098A8"
                                                           LetterSpacing="1.5"/>
                                            </Border>
                                            <!-- Selectable item -->
                                            <Border Classes="menuRow" IsVisible="{Binding IsSelectable}"
                                                    Background="{Binding IsSelected, Converter={StaticResource SelBrush}}">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      Margin="{Binding IsSubItem, Converter={StaticResource SubIndent}}">
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                               FontSize="14"
                                                               Foreground="{Binding IsSelected, Converter={StaticResource SelFore}}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Hint}"
                                                               FontSize="11" Foreground="#6A6A6A"
                                                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Create-company inline form -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding CurrentScreen, Converter={StaticResource ScreenEquals}, ConverterParameter=CreateCompany}"
                                Background="White" BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,10" Width="460" Padding="18">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Name" FontWeight="SemiBold" Foreground="{StaticResource BrandNavy}"/>
                                <TextBox x:Name="CompanyNameBox" Text="{Binding NewCompanyName, Mode=TwoWay}"
                                         PlaceholderText="e.g. Acme Traders" FontSize="14"/>
                                <TextBlock Text="Financial year begins 1-Apr; base currency ₹ INR (Phase 1 defaults)."
                                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap"/>
                                <Button Content="Create (Ctrl+A)" HorizontalAlignment="Right"
                                        Click="OnCreateCompanyClick"
                                        Background="{StaticResource BrandNavy}" Foreground="White" Padding="14,6"/>
                            </StackPanel>
                        </Border>

                        <!-- Message / hint line -->
                        <TextBlock Grid.Row="2" Text="{Binding Message}"
                                   IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="{StaticResource AlertRed}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,6,0,14" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- ============ CASCADING (MILLER-COLUMNS) GATEWAY ============ -->
                    <!-- A horizontal row of columns: each drill-in adds a column to the right; earlier
                         columns stay visible. Menu columns are narrow; a page column is wide. The whole
                         row scrolls sideways if it overflows; each column has its own up/down scroll so
                         text is never clipped or overwritten across columns. -->
                    <ScrollViewer x:Name="CascadeScroller"
                                  IsVisible="{Binding IsGatewayCascade}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                      <ItemsControl x:Name="CascadeColumns" ItemsSource="{Binding Columns}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:GatewayColumn">
                            <!-- One column: header band + body. Menu columns = 300 wide; page columns = 560. -->
                            <Border Margin="0,0,6,0"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Background="White"
                                    Width="{Binding IsMenu, Converter={StaticResource ColWidth}}">
                              <Grid RowDefinitions="Auto,*">

                                <!-- Column header -->
                                <Border Grid.Row="0"
                                        Background="{Binding IsActive, Converter={StaticResource ColHeaderBrush}}"
                                        Padding="10,6">
                                  <TextBlock Text="{Binding Title}"
                                             Foreground="White" FontWeight="SemiBold" FontSize="13"
                                             TextTrimming="CharacterEllipsis"/>
                                </Border>

                                <!-- BODY (a) menu column: keyboard-navigable list -->
                                <ScrollViewer Grid.Row="1" IsVisible="{Binding IsMenu}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0,6">
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:MenuItemViewModel">
                                        <Panel>
                                          <!-- Section header: dim, uppercase, non-selectable -->
                                          <Border Classes="menuRow" IsVisible="{Binding IsHeader}" Margin="0,7,0,1">
                                            <TextBlock Text="{Binding Label, Converter={StaticResource Upper}}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#9098A8" LetterSpacing="1.5"/>
                                          </Border>
                                          <!-- Selectable item: bright amber in the active column, dim slate when
                                               selected in an earlier column, transparent otherwise. -->
                                          <Border Classes="menuRow" IsVisible="{Binding IsSelectable}">
                                            <Border.Background>
                                              <MultiBinding Converter="{x:Static conv:SelectedActiveToBrushConverter.Instance}">
                                                <Binding Path="IsSelected"/>
                                                <Binding Path="IsActiveColumn"/>
                                              </MultiBinding>
                                            </Border.Background>
                                            <Grid ColumnDefinitions="*,Auto"
                                                  Margin="{Binding IsSubItem, Converter={StaticResource SubIndent}}">
                                              <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                         FontSize="14" TextTrimming="CharacterEllipsis"
                                                         Foreground="{Binding IsSelected, Converter={StaticResource SelFore}}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding Hint}"
                                                         FontSize="11" Foreground="#6A6A6A"
                                                         VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            </Grid>
                                          </Border>
                                        </Panel>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>

                                <!-- BODY (b) page column: exactly one of the four page kinds -->
                                <Panel Grid.Row="1" IsVisible="{Binding IsPage}">

                    <!-- PAGE: Report viewer -->
                    <ContentControl IsVisible="{Binding Report, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Report}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ReportsViewModel">
                        <Grid RowDefinitions="Auto,Auto,Auto,*">
                        <TextBlock Grid.Row="0" Text="{Binding Title}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                   HorizontalAlignment="Center" Margin="0,12,0,2"/>
                        <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                   FontSize="12" Foreground="#555555"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- Column header band (navy) -->
                        <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                            <Grid ColumnDefinitions="*,150,150">
                                <TextBlock Grid.Column="0" Text="Particulars" Classes="colHdr"/>
                                <!-- Two-column (Dr/Cr) mode -->
                                <TextBlock Grid.Column="1" Text="Debit" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding IsTwoColumn}"/>
                                <TextBlock Grid.Column="2" Text="Credit" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding IsTwoColumn}"/>
                                <!-- Single-amount mode -->
                                <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr"
                                           TextAlignment="Right" IsVisible="{Binding !IsTwoColumn}"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="3" Background="White">
                            <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ReportRow">
                                        <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                Background="Transparent">
                                            <Grid ColumnDefinitions="*,150,150" Height="24">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center" Margin="8,0">
                                                    <TextBlock Text="{Binding Particulars}"
                                                               FontWeight="{Binding IsHeader, Converter={StaticResource BoolWeight}}"
                                                               FontSize="12.5"/>
                                                    <TextBlock Text="{Binding Secondary}"
                                                               FontSize="10.5" Foreground="#8A8A8A"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- Two-column (Dr/Cr) mode: Debit + Credit both visible -->
                                                <TextBlock Grid.Column="1" Text="{Binding Debit}"
                                                           TextAlignment="Right" Margin="0,0,10,0"
                                                           IsVisible="{Binding IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Credit}"
                                                           TextAlignment="Right" Margin="0,0,10,0"
                                                           IsVisible="{Binding IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                                <!-- Single-amount mode: Amount occupies column 2 alone -->
                                                <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                           TextAlignment="Right" Margin="0,0,10,0"
                                                           IsVisible="{Binding !IsTwoColumn}"
                                                           FontWeight="{Binding IsTotal, Converter={StaticResource BoolWeight}}"
                                                           VerticalAlignment="Center" FontSize="12.5"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Voucher entry (Contra/Payment/Receipt/Journal/Sales/Purchase) -->
                    <ContentControl IsVisible="{Binding Voucher, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Voucher}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:VoucherEntryViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="4">

                            <!-- Header: type + auto number + date -->
                            <Border Grid.Row="0" Background="{StaticResource BrandNavy}" Padding="10,6">
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding TypeName}"
                                           Foreground="White" FontWeight="Bold" FontSize="15"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Foreground="#CFE0FF" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,18,0">
                                  <Run Text="No. "/><Run Text="{Binding VoucherNumber}"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Width="140"
                                         Text="{Binding DateText, Mode=TwoWay}"
                                         FontSize="12" VerticalAlignment="Center"/>
                              </Grid>
                            </Border>

                            <!-- Column header band -->
                            <Border Grid.Row="1" Background="{StaticResource BrandNavyDark}" Margin="0,6,0,0">
                              <Grid ColumnDefinitions="*,90,160,40">
                                <TextBlock Grid.Column="0" Text="Particulars (Ledger)" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Dr/Cr" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Amount" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="" Classes="colHdr"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="2" Text="" />

                            <!-- Particulars grid: Dr/Cr lines -->
                            <ScrollViewer Grid.Row="3" Background="White" VerticalScrollBarVisibility="Auto">
                              <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:VoucherLineViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                            Padding="6,4">
                                      <StackPanel Spacing="0">
                                        <Grid ColumnDefinitions="*,90,160,40">
                                          <ComboBox Grid.Column="0" MinWidth="200"
                                                    HorizontalAlignment="Stretch"
                                                    ItemsSource="{Binding Ledgers}"
                                                    SelectedItem="{Binding SelectedLedger, Mode=TwoWay}"
                                                    PlaceholderText="Select ledger…">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="ledger:Ledger">
                                                <TextBlock Text="{Binding Name}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <ComboBox Grid.Column="1" Margin="6,0" Width="80"
                                                    ItemsSource="{Binding Sides}"
                                                    SelectedItem="{Binding Side, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                              <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource DrCrLabel}}"/>
                                              </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                          </ComboBox>
                                          <TextBox Grid.Column="2" Width="150"
                                                   Text="{Binding AmountText, Mode=TwoWay}"
                                                   TextAlignment="Right"
                                                   PlaceholderText="0.00"/>
                                        </Grid>

                                        <!-- Bill-wise Details sub-panel (only for a bill-by-bill ledger) -->
                                        <Border IsVisible="{Binding IsBillWise}"
                                                Background="#F4F7FB"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                                Margin="18,4,4,2" Padding="8,6">
                                          <StackPanel Spacing="4">
                                            <TextBlock Text="Bill-wise Details"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource BrandNavy}"/>
                                            <!-- Allocation column header -->
                                            <Grid ColumnDefinitions="130,*,120,120">
                                              <TextBlock Grid.Column="0" Text="Type of Ref" FontSize="10.5"
                                                         Foreground="#6A6A6A"/>
                                              <TextBlock Grid.Column="1" Text="Name" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="2" Text="Due Date" FontSize="10.5"
                                                         Foreground="#6A6A6A" Margin="4,0,0,0"/>
                                              <TextBlock Grid.Column="3" Text="Amount" FontSize="10.5"
                                                         Foreground="#6A6A6A" TextAlignment="Right"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding BillAllocations}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:BillAllocationRowViewModel">
                                                  <Grid ColumnDefinitions="130,*,120,120" Margin="0,1">
                                                    <ComboBox Grid.Column="0" Width="124"
                                                              ItemsSource="{Binding RefTypes}"
                                                              SelectedItem="{Binding RefType, Mode=TwoWay}"
                                                              FontSize="11">
                                                      <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                          <TextBlock Text="{Binding Converter={StaticResource BillRefLabel}}"/>
                                                        </DataTemplate>
                                                      </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="1" Margin="4,0,0,0"
                                                             Text="{Binding Name, Mode=TwoWay}"
                                                             FontSize="11" PlaceholderText="Bill ref…"/>
                                                    <TextBox Grid.Column="2" Width="114" Margin="4,0,0,0"
                                                             Text="{Binding DueDateText, Mode=TwoWay}"
                                                             FontSize="11" PlaceholderText="dd-MMM-yyyy"/>
                                                    <TextBox Grid.Column="3" Width="114"
                                                             Text="{Binding AmountText, Mode=TwoWay}"
                                                             FontSize="11" TextAlignment="Right"
                                                             PlaceholderText="0.00"/>
                                                  </Grid>
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="Auto,*">
                                              <Button Grid.Column="0" Content="+ Add bill"
                                                      FontSize="10.5" Padding="8,2"
                                                      Background="{StaticResource Panel}"
                                                      Click="OnAddBillAllocationClick"
                                                      CommandParameter="{Binding}"/>
                                              <TextBlock Grid.Column="1" Text="{Binding BillSummary}"
                                                         FontSize="10.5" Foreground="#555555"
                                                         VerticalAlignment="Center" TextAlignment="Right"
                                                         Margin="8,0,0,0"/>
                                            </Grid>
                                          </StackPanel>
                                        </Border>
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Add-line -->
                            <Button Grid.Row="4" Content="+ Add line" HorizontalAlignment="Left"
                                    Margin="0,6" Padding="10,4"
                                    Background="{StaticResource Panel}"
                                    Click="OnAddVoucherLineClick"/>

                            <!-- Live balance indicator -->
                            <Border Grid.Row="5" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <TextBlock Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center">
                                  <Run Text="Difference: "/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding DifferenceText}"
                                           VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="{Binding !IsBalanced, Converter={StaticResource BoolWeight}}"
                                           Foreground="{Binding IsBalanced, Converter={StaticResource BalancedBrush}}"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0" FontSize="12">
                                  <Run Text="Dr "/><Run Text="{Binding TotalDebitText}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="12,0" FontSize="12">
                                  <Run Text="Cr "/><Run Text="{Binding TotalCreditText}"/>
                                </TextBlock>
                              </Grid>
                            </Border>

                            <!-- Narration + accept row + message -->
                            <StackPanel Grid.Row="6" Spacing="6" Margin="0,4,0,0">
                              <TextBox Text="{Binding Narration, Mode=TwoWay}"
                                       PlaceholderText="Narration…" AcceptsReturn="False"/>
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Message}"
                                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{StaticResource AlertRed}" FontSize="12"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Content="Cancel (Esc)" Margin="0,0,8,0" Padding="12,6"
                                        Click="OnCancelVoucherClick"/>
                                <Button Grid.Column="2" Content="Accept (Ctrl+A)" Padding="14,6"
                                        IsEnabled="{Binding CanAccept}"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnAcceptVoucherClick"/>
                              </Grid>
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Ledger master (create + list) -->
                    <ContentControl IsVisible="{Binding Ledger, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Ledger}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:LedgerMasterViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="Ledger Creation"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,8,0,10"/>

                            <!-- Create form -->
                            <Border Grid.Row="1" Background="White"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,10">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                           PlaceholderText="e.g. State Bank of India"/>
                                </Grid>
                                <Grid ColumnDefinitions="90,*">
                                  <TextBlock Grid.Column="0" Text="Under" FontWeight="SemiBold"
                                             VerticalAlignment="Center" Foreground="{StaticResource BrandNavy}"/>
                                  <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding Groups}"
                                            SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                            PlaceholderText="Select group…">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="ledger:Group">
                                        <TextBlock Text="{Binding Name}"/>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>

                                <!-- Bill-wise options (shown for party groups: Sundry Debtors/Creditors) -->
                                <StackPanel Spacing="8" IsVisible="{Binding IsPartyGroup}">
                                  <CheckBox Content="Maintain balances bill-by-bill"
                                            IsChecked="{Binding MaintainBillByBill, Mode=TwoWay}"
                                            FontSize="13"/>
                                  <Grid ColumnDefinitions="180,120"
                                        IsVisible="{Binding MaintainBillByBill}">
                                    <TextBlock Grid.Column="0" Text="Default credit period (days)"
                                               VerticalAlignment="Center" FontSize="12.5"
                                               Foreground="{StaticResource BrandNavy}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DefaultCreditPeriodText, Mode=TwoWay}"
                                             PlaceholderText="e.g. 30" TextAlignment="Right"/>
                                  </Grid>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding Message}"
                                             IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Foreground="{StaticResource AlertRed}" FontSize="12"
                                             VerticalAlignment="Center" TextWrapping="Wrap"/>
                                  <Button Grid.Column="1" Content="Create (Ctrl+A)" Padding="14,6"
                                          Background="{StaticResource BrandNavy}" Foreground="White"
                                          Click="OnCreateLedgerClick"/>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <!-- Existing ledgers header -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,200,140">
                                <TextBlock Grid.Column="0" Text="Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Under" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Opening" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Existing}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:LedgerListRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,200,140" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="8,0" VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Under}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#555555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Opening}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Chart of Accounts (read-only group/ledger tree) -->
                    <ContentControl IsVisible="{Binding Chart, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Chart}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ChartOfAccountsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,160">
                                <TextBlock Grid.Column="0" Text="Group / Ledger" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Nature / Opening" Classes="colHdr"
                                           TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ChartRow">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Grid ColumnDefinitions="*,160" Height="24">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Margin="{Binding Indent, Converter={StaticResource Indent}}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12.5"
                                                   FontWeight="{Binding IsGroup, Converter={StaticResource BoolWeight}}"
                                                   Foreground="{Binding IsGroup, Converter={StaticResource SelFore}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- PAGE: Outstandings (Receivables / Payables) with Ctrl+B bill settlement -->
                    <ContentControl IsVisible="{Binding Outstanding, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Content="{Binding Outstanding}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:OutstandingsViewModel">
                          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="6">
                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrandNavy}"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12" Foreground="#555555"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Column header band (navy) -->
                            <Border Grid.Row="2" Background="{StaticResource BrandNavy}">
                              <Grid ColumnDefinitions="*,110,90,90,120,90">
                                <TextBlock Grid.Column="0" Text="Party" Classes="colHdr"/>
                                <TextBlock Grid.Column="1" Text="Ref" Classes="colHdr"/>
                                <TextBlock Grid.Column="2" Text="Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="3" Text="Due Date" Classes="colHdr"/>
                                <TextBlock Grid.Column="4" Text="Pending" Classes="colHdr" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="Ageing" Classes="colHdr" TextAlignment="Right"/>
                              </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" Background="White">
                              <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:OutstandingRowViewModel">
                                    <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1">
                                      <Border.Background>
                                        <MultiBinding Converter="{x:Static conv:OutstandingRowBrushConverter.Instance}">
                                          <Binding Path="IsSelected"/>
                                          <Binding Path="IsHighlighted"/>
                                        </MultiBinding>
                                      </Border.Background>
                                      <Grid ColumnDefinitions="*,110,90,90,120,90" Height="24">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center" Margin="8,0">
                                          <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                     Foreground="#2E7D32"
                                                     IsVisible="{Binding IsSelected}"/>
                                          <TextBlock Text="{Binding Party}" FontSize="12.5"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Reference}"
                                                   VerticalAlignment="Center" FontSize="12" Foreground="#333333"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Date}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DueDate}"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#555555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Pending}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="12.5"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Ageing}"
                                                   TextAlignment="Right" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" FontSize="11" Foreground="#6A6A6A"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>

                            <!-- Total + settle bar -->
                            <Border Grid.Row="4" Background="{StaticResource Cream}"
                                    BorderBrush="{StaticResource GridLine}" BorderThickness="1"
                                    Padding="10,6" Margin="0,2">
                              <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Space: select bill    Ctrl+B: settle selected"
                                           FontSize="11" Foreground="#6A6A6A" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                                           FontWeight="SemiBold">
                                  <Run Text="Total Pending: "/><Run Text="{Binding TotalText}"/>
                                </TextBlock>
                                <Button Grid.Column="2" Content="Settle (Ctrl+B)" Padding="12,5"
                                        Background="{StaticResource BrandNavy}" Foreground="White"
                                        Click="OnSettleBillsClick"/>
                              </Grid>
                            </Border>

                            <TextBlock Grid.Row="5" Text="{Binding Message}"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource BrandNavy}" FontSize="12"
                                       Margin="2,4,0,0" TextWrapping="Wrap"/>
                          </Grid>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>

                                </Panel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                </Panel>
            </Border>

            <!-- RIGHT BUTTON BAR -->
            <Border Grid.Column="1" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ButtonBar}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ButtonBarItem">
                                <Button Classes="barBtn" Command="{Binding Invoke}" IsEnabled="{Binding Enabled}">
                                    <Grid ColumnDefinitions="34,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                   Foreground="{StaticResource AlertRed}" FontWeight="Bold"
                                                   FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Caption}"
                                                   Foreground="{StaticResource Ink}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ============ STATUS BAR (navy) ============ -->
        <Border Grid.Row="3" Background="{StaticResource BrandNavy}" Height="26">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="12,0" FontSize="11" Foreground="#CFE0FF"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="Company: "/><Run Text="{Binding StatusCompany}"/>
                </TextBlock>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0" FontSize="11" Foreground="#CFE0FF">
                    <Run Text="Current Date: "/><Run Text="{Binding StatusDate}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
