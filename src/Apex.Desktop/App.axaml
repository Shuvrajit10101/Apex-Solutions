<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Apex.Desktop.App"
             xmlns:local="using:Apex.Desktop"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <!-- Apex Solutions palette -->
        <Color x:Key="BrandNavyColor">#1B3A6B</Color>
        <Color x:Key="BrandNavyDarkColor">#142C52</Color>
        <Color x:Key="PanelColor">#E8E8E8</Color>
        <Color x:Key="PanelBorderColor">#B8B8B8</Color>
        <Color x:Key="CreamColor">#FDFDF5</Color>
        <Color x:Key="AmberColor">#FFD54F</Color>
        <Color x:Key="AmberBorderColor">#E0A400</Color>
        <Color x:Key="InkColor">#1A1A1A</Color>
        <Color x:Key="GridLineColor">#D2D2C4</Color>
        <Color x:Key="AlertRedColor">#B00020</Color>
        <Color x:Key="PositiveGreenColor">#2E7D32</Color>

        <SolidColorBrush x:Key="BrandNavy" Color="{StaticResource BrandNavyColor}"/>
        <SolidColorBrush x:Key="BrandNavyDark" Color="{StaticResource BrandNavyDarkColor}"/>
        <SolidColorBrush x:Key="Panel" Color="{StaticResource PanelColor}"/>
        <SolidColorBrush x:Key="PanelBorder" Color="{StaticResource PanelBorderColor}"/>
        <SolidColorBrush x:Key="Cream" Color="{StaticResource CreamColor}"/>
        <SolidColorBrush x:Key="Amber" Color="{StaticResource AmberColor}"/>
        <SolidColorBrush x:Key="AmberBorder" Color="{StaticResource AmberBorderColor}"/>
        <SolidColorBrush x:Key="Ink" Color="{StaticResource InkColor}"/>
        <SolidColorBrush x:Key="GridLine" Color="{StaticResource GridLineColor}"/>
        <SolidColorBrush x:Key="AlertRed" Color="{StaticResource AlertRedColor}"/>
        <SolidColorBrush x:Key="PositiveGreen" Color="{StaticResource PositiveGreenColor}"/>
        <SolidColorBrush x:Key="AppWhite" Color="#FFFFFF"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!--
          RC-5 — a ComboBox that outgrows its slot must SIGNAL the cut, not swallow it.

          The defect: a selected value longer than the box (a 55-character party ledger, a bank name, a
          nature-of-payment description) was simply cut off mid-glyph. The user read "Bank of Maharas" and
          had no way to tell whether that was the whole value or the visible third of it — there was no
          ellipsis, no tooltip, and the box does not scroll. Silent truncation of a value the operator is
          about to POST is the dangerous kind: it misreads as complete.

          Why a global style rather than per-site edits: the shell carries ~199 ComboBoxes, 192 of which
          supply their own ItemTemplate, and only 4 mentioned TextTrimming anywhere. Setting it once here
          covers the whole family — including every ComboBox added later, which is the half that per-site
          edits always miss. The slot genuinely constrains these TextBlocks (verified by measurement), so
          trimming engages and paints the ellipsis; this is not the infinite-width StackPanel shape where
          TextTrimming can never fire.
        -->
        <Style Selector="ComboBox TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Application.Styles>
</Application>
